\begin_layout Section
P-Function
\end_layout

\begin_layout Standard
Recall
\begin_inset Formula 
\[
r_{2}\triangleq\dot{r}_{1}+k_{2}r_{1}
\]

\end_inset

Introduce
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\zeta\left(t\right) & \triangleq K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-r_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\\
\phi\left(t\right) & \triangleq r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)+\left(k_{2}-\lambda_{P}\right)\zeta\left(t\right)
\end{align*}

\end_inset

Let
\begin_inset Formula 
\[
\dot{\eta}\left(t\right)=-\lambda_{P}\eta\left(t\right)+\phi\left(t\right)\quad\eta\left(t_{0}\right)=0
\]

\end_inset

Define
\begin_inset Formula 
\[
P\left(t\right)\triangleq\zeta\left(t\right)+\eta\left(t\right)
\]

\end_inset

So,
\begin_inset Formula 
\begin{align*}
\dot{P}\left(t\right) & \in\dot{\zeta}\left(t\right)+\dot{\eta}\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\eta\left(t\right)+\phi\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\cancel{r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)}-\lambda_{P}\eta\left(t\right)+\cancel{r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)}+\left(k_{2}-\lambda_{P}\right)\zeta\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\eta\left(t\right)+\left(k_{2}-\lambda_{P}\right)\zeta\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\eta\left(t\right)+k_{2}\zeta\left(t\right)-\lambda_{P}\zeta\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\left(\eta\left(t\right)+\zeta\left(t\right)\right)+k_{2}\left(K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-r_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-k_{2}r_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\left(\dot{r}_{1}^{\top}\left(t\right)+k_{2}r_{1}^{\top}\left(t\right)\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}\left\Vert r_{1}\left(t\right)\right\Vert _{1}\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-r_{2}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}\left\Vert r_{1}\left(t\right)\right\Vert _{1}\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-r_{2}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}r_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)\\
 & \in K_{\text{RISE}}\left(\dot{r}_{1}^{\top}\left(t\right)+k_{2}r_{1}^{\top}\left(t\right)\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-r_{2}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)\\
 & \in K_{\text{RISE}}r_{2}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-r_{2}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)\\
 & \in-\lambda_{P}P\left(t\right)+r_{2}^{\top}\left(t\right)\left(K_{\text{RISE}}K[\text{sgn}]\left(r_{1}\left(t\right)\right)-D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\right)
\end{align*}

\end_inset

NOTE: 
\begin_inset Formula $P\left(t_{0}\right)$
\end_inset

 must satisfy:
\begin_inset Formula 
\begin{align*}
P\left(t_{0}\right) & =\zeta\left(t_{0}\right)\\
 & =K_{\text{RISE}}\left\Vert r_{1}\left(t_{0}\right)\right\Vert _{1}-r_{1}^{\top}\left(t_{0}\right)D\left(\kappa_{d}\left(t_{0}\right),\theta^{\ast},\hat{\theta}\left(t_{0}\right),t_{0}\right)
\end{align*}

\end_inset

NOTE:
\begin_inset Formula 
\begin{align*}
\left|P\left(t_{0}\right)\right| & \le K_{\text{RISE}}\left\Vert r_{1}\left(t_{0}\right)\right\Vert _{1}+\left\Vert r_{1}\left(t_{0}\right)\right\Vert \overline{D}\\
 & \le\sqrt{n}K_{\text{RISE}}\left\Vert r_{1}\left(t_{0}\right)\right\Vert +\left\Vert r_{1}\left(t_{0}\right)\right\Vert \overline{D}\\
 & \le\left(\sqrt{n}K_{\text{RISE}}+\overline{D}\right)\left\Vert r_{1}\left(t_{0}\right)\right\Vert 
\end{align*}

\end_inset

How do we know 
\begin_inset Formula $P\ge0$
\end_inset

 for all time? Use sufficient conditions.
 An obvious first step is to ensure 
\begin_inset Formula $\left\Vert \zeta\left(t\right)\right\Vert \ge0$
\end_inset

 for all time.
 Since 
\begin_inset Formula $\left\Vert r\right\Vert _{1}\ge\left\Vert r\right\Vert $
\end_inset

,
\begin_inset Formula 
\begin{align*}
K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-r_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right) & \ge K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-\left\Vert r_{1}\left(t\right)\right\Vert \overline{D}\\
 & \ge K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert -\overline{D}\left\Vert r_{1}\left(t\right)\right\Vert \\
 & \ge\left(\underbrace{K_{\text{RISE}}-\overline{D}}_{b_{1}}\right)\left\Vert r_{1}\left(t\right)\right\Vert 
\end{align*}

\end_inset

To get 
\begin_inset Formula $b_{1}>0$
\end_inset

, select (choice of strict inequality will be apparent later)
\begin_inset Formula 
\[
K_{\text{RISE}}>\overline{D}
\]

\end_inset

and thus
\begin_inset Formula 
\[
\left\Vert \zeta\left(t\right)\right\Vert \ge b_{1}\left\Vert r_{1}\left(t\right)\right\Vert >0
\]

\end_inset

Let 
\begin_inset Formula $\lambda_{P}\in\left(0,k_{2}\right)$
\end_inset

 and 
\begin_inset Formula $b_{2}\triangleq k_{2}-\lambda_{P}$
\end_inset

.
 Thus 
\begin_inset Formula $b_{2}>0$
\end_inset

.
 Next, we want 
\begin_inset Formula $\phi\left(t\right)\ge0$
\end_inset

.
 
\begin_inset Formula 
\begin{align*}
r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)+\left(k_{2}-\lambda_{P}\right)\zeta\left(t\right) & =r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)+b_{2}\zeta\left(t\right)\\
 & >-\left\Vert r_{1}\left(t\right)\right\Vert \overline{\dot{D}}+b_{1}b_{2}\left\Vert r_{1}\left(t\right)\right\Vert \\
 & >\left(b_{1}b_{2}-\overline{\dot{D}}\right)\left\Vert r_{1}\left(t\right)\right\Vert 
\end{align*}

\end_inset

We need 
\begin_inset Formula 
\begin{align*}
b_{1}b_{2}-\overline{\dot{D}} & \ge0\\
b_{1}b_{2} & \ge\overline{\dot{D}}\\
b_{1} & \ge\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}\\
K_{\text{RISE}}-\overline{D} & \ge\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}\\
K_{\text{RISE}} & \ge\overline{D}+\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}
\end{align*}

\end_inset

So the only gain suggestion you need (well, it's sufficient)
\color green

\begin_inset Formula 
\[
K_{\text{RISE}}\ge\overline{D}+\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}
\]

\end_inset


\color inherit
NOTE: The above requires
\begin_inset Formula 
\[
\lambda_{P}\in\left(0,k_{2}\right)
\]

\end_inset

which can always be satisfied since 
\begin_inset Formula $k_{2}>0$
\end_inset

.
 However, we will need to mention this in the gain conditions.
 Note that the solution to the 
\begin_inset Formula $\eta\left(t\right)$
\end_inset

 ODE is
\begin_inset Formula 
\begin{align*}
\eta\left(t\right) & =\cancelto{0}{\eta\left(t_{0}\right){\rm e}^{-\lambda_{P}\left(t-t_{0}\right)}}+\intop_{t_{0}}^{t}{\rm e}^{-\lambda_{P}\left(t-\tau\right)}\phi\left(\tau\right)d\tau\\
 & =\intop_{t_{0}}^{t}{\rm e}^{-\lambda_{P}\left(t-\tau\right)}\phi\left(\tau\right)d\tau
\end{align*}

\end_inset

Clearly a sufficient condition for 
\begin_inset Formula $\eta\left(t\right)\ge0$
\end_inset

 for all 
\begin_inset Formula $t$
\end_inset

 is that 
\begin_inset Formula $\phi\left(t\right)\ge0$
\end_inset

 for all 
\begin_inset Formula $t$
\end_inset

, which was shown.
 Thus, 
\begin_inset Formula $\eta\left(t\right)\ge0$
\end_inset

 for all 
\begin_inset Formula $t$
\end_inset

.
\end_layout

