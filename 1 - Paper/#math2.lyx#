V=\frac{1}{2}e^{\top}e+\frac{1}{2}r_{1}^{\top}r_{1}+\frac{1}{2}r_{2}^{\top}r_{2}+\frac{1}{2}\widetilde{\theta}^{\top}\Gamma^{-1}\widetilde{\theta}+P
\]

\end_inset

Let
\begin_inset Formula 
\[
\dot{P}\in-\lambda_{P}P\left(t\right)+r_{2}^{\top}\left(t\right)\left(K_{\text{RISE}}K[\text{sgn}\left(r_{1}\right)]-D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\right)
\]

\end_inset

Let
\begin_inset Formula 
\[
\dot{\widehat{\theta}}=\text{proj}\left(\Gamma\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r_{2}\right)
\]

\end_inset

Let
\begin_inset Formula 
\[
\widetilde{\theta}\triangleq\theta^{\ast}-\widehat{\theta}
\]

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\dot{\widetilde{\theta}} & =-\dot{\widehat{\theta}}\\
 & =-\text{proj}\left(\Gamma\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r_{2}\right)
\end{align*}

\end_inset

From Krstic's Appendix E.4,
\begin_inset Formula 
\[
-\widetilde{\theta}^{\top}\Gamma^{-1}\text{proj}\left(\tau\right)\le-\widetilde{\theta}^{\top}\Gamma^{-1}\tau
\]

\end_inset

so
\begin_inset Formula 
\begin{align*}
\widetilde{\theta}^{\top}\Gamma^{-1}\dot{\widetilde{\theta}} & =\widetilde{\theta}^{\top}\Gamma^{-1}\left(-\text{proj}\left(\Gamma\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r_{2}\right)\right)\\
 & =-\widetilde{\theta}^{\top}\Gamma^{-1}\text{proj}\left(\Gamma\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r_{2}\right)\\
 & \le-\widetilde{\theta}^{\top}\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r_{2}
\end{align*}

\end_inset

The trajectory derivative
\begin_inset Formula 
\begin{align*}
\dot{V}\left(z,t\right) & =e^{\top}\dot{e}+r_{1}^{\top}\dot{r}_{1}+r_{2}^{\top}\dot{r}_{2}+\widetilde{\theta}^{\top}\Gamma^{-1}\dot{\widetilde{\theta}}+\dot{P}\\
 & =e^{\top}r_{1}-k_{1}e^{\top}e+\cancel{r_{1}^{\top}r_{2}}-k_{2}r_{1}^{\top}r_{1}+\cancel{r_{2}^{\top}\frac{\partial\widehat{\Phi}}{\partial\widehat{\theta}}\widetilde{\theta}}+r_{2}^{\top}\mathcal{R}\left(\kappa,\widetilde{\theta}\right)+r_{2}^{\top}\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\\
