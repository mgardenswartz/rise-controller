Stability
\end_layout

\begin_layout Standard
Let 
\begin_inset Formula 
\[
z_{P}\triangleq\left[\begin{array}{cc}
z^{\top} & P\end{array}\right]^{\top}\in\mathbb{R}^{3n+1}
\]

\end_inset

Consider the differential inclusion
\begin_inset Formula 
\begin{align*}
z_{P} & \in H\left(z_{p},t\right)\\
H\left(z_{p},t\right) & \triangleq\left\{ \left[\begin{array}{c}
r_{1}-k_{1}e\\
r_{2}-k_{2}r_{1}\\
\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}-r_{1}-K_{\text{RISE}}\nu_{1}+D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\\
-\lambda_{P}P\left(t\right)+r_{2}^{\top}\left(t\right)\left(K_{\text{RISE}}\nu_{2}-D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\right)
\end{array}\right]:\nu_{1},\nu_{2}\in K[\text{sgn}\left(r_{1}\left(t\right)\right)]\right\} 
\end{align*}

\end_inset

Stability.
 Consider the Lyapunov candidate
\begin_inset Formula 
\begin{align*}
V\left(z_{P}\right) & =\frac{1}{2}z^{\top}z+P
\end{align*}

\end_inset

Trajectory derivative
\begin_inset Formula 
\begin{align*}
\dot{V}\left(z_{p},t\right) & =e^{\top}\left(r_{1}-k_{1}e\right)+r_{1}^{\top}\left(r_{2}-k_{2}r_{1}\right)+r_{2}^{\top}\left(\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}-r_{1}-K_{\text{RISE}}\nu_{1}+D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\right)\\
 & -\lambda_{P}P+r_{2}^{\top}\left(t\right)\left(K_{\text{RISE}}\nu_{2}-D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\right)\\
\\
 & ={\color{blue}e^{\top}r_{1}}-k_{1}e^{\top}e+\cancel{r_{1}^{\top}r_{2}}-k_{2}r_{1}^{\top}r_{1}+r_{2}^{\top}\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}^{\top}r_{2}-\cancel{r_{2}^{\top}r_{1}}-K_{\text{RISE}}r_{2}^{\top}\nu_{1}+\cancel{r_{2}^{\top}D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)}\\
 & -\lambda_{P}P+K_{\text{RISE}}r_{2}^{\top}\left(t\right)\nu_{2}-\cancel{r_{2}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)}\\
\\
 & =-k_{1}\left\Vert e\right\Vert ^{2}-k_{2}\left\Vert r_{1}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}+r_{2}^{\top}\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)+K_{\text{RISE}}r_{2}^{\top}\left(\nu_{2}-\nu_{1}\right)-\lambda_{P}P+{\color{blue}\left\Vert e\right\Vert \left\Vert r_{1}\right\Vert }\\
 & \underset{\text{a.e.}}{=}-k_{1}\left\Vert e\right\Vert ^{2}-k_{2}\left\Vert r_{1}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}+r_{2}^{\top}\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P+{\color{blue}\frac{1}{2}\left\Vert e\right\Vert ^{2}+\frac{1}{2}\left\Vert r_{1}\right\Vert ^{2}}\\
 & \underset{\text{a.e.}}{=}-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}+r_{2}^{\top}\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P
\end{align*}

\end_inset

Using Bounding Lemma 3.4 and triangle inequality,
\begin_inset Formula 
\begin{align*}
\dot{V}\left(z\right) & \underset{\text{a.e.}}{\le}-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}+\left\Vert r_{2}\right\Vert \rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert -k_{3}\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}+\left\Vert r_{2}\right\Vert \rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left(\left\Vert e\right\Vert +\left\Vert r_{1}\right\Vert +\left\Vert r_{2}\right\Vert \right)-k_{3}\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}\\
 & +\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert e\right\Vert \left\Vert r_{2}\right\Vert +\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{1}\right\Vert \left\Vert r_{2}\right\Vert +\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}+\frac{1}{2}\left\Vert e\right\Vert ^{2}+\frac{1}{2}\rho_{0}^{2}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}+\frac{1}{2}\left\Vert r_{1}\right\Vert ^{2}\\
 & +\frac{1}{2}\rho_{0}^{2}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}+\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-1\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-1\right)\left\Vert r_{1}\right\Vert ^{2}\\
 & +\frac{1}{2}\rho_{0}^{2}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}+\frac{1}{2}\rho_{0}^{2}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}+\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-1\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-1\right)\left\Vert r_{1}\right\Vert ^{2}-\left(k_{3}-\left(\underbrace{\rho_{0}^{2}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)+\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}_{\rho\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\right)\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-1\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-1\right)\left\Vert r_{1}\right\Vert ^{2}-\left(k_{3}-\rho\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\right)\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P
\end{align*}

\end_inset

Pick 
\begin_inset Formula $\Delta,\lambda_{V}\in\mathbb{R}_{>0}$
\end_inset

.
 Let the desired region of attraction (for 
\begin_inset Formula $z$
\end_inset

 not 
\begin_inset Formula $z_{P}$
\end_inset

!) be 
\begin_inset Formula $\mathcal{S}\triangleq\left\{ \zeta\in\mathbb{R}^{5n}:\left\Vert \zeta\right\Vert \le\Delta\right\} $
\end_inset

.
 The gain conditions should be selected to ensure that for all 
\begin_inset Formula $z\in\mathcal{S}$
\end_inset

,
\begin_inset Formula 
\[
\dot{V}\left(z\right)\underset{\text{a.e.}}{\le}-\frac{\lambda_{V}}{2}\left\Vert z\right\Vert ^{2}-\lambda_{P}P
\]

\end_inset

So,
\begin_inset Formula 
\begin{align*}
-\left(k_{1}-1\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-1\right)\left\Vert r_{1}\right\Vert ^{2}-\left(k_{3}-\rho\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\right)\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P & \underset{\text{a.e.}}{\le}-\min\left\{ k_{1}-1,k_{2}-1,k_{3}-\rho\left(k_{1},k_{2},\Delta\right)\right\} \left\Vert z\right\Vert ^{2}-\lambda_{P}P
\end{align*}

\end_inset

Compare
\begin_inset Formula 
\begin{align*}
-\min\left\{ k_{1}-1,k_{2}-1,k_{3}-\rho\left(k_{1},k_{2},\Delta\right)\right\} \left\Vert z\right\Vert ^{2} & \underset{\text{a.e.}}{\le}-\frac{\lambda_{V}}{2}\left\Vert z\right\Vert ^{2}\\
\min\left\{ k_{1}-1,k_{2}-1,k_{3}-\rho\left(k_{1},k_{2},\Delta\right)\right\}  & \underset{\text{a.e.}}{\le}\frac{\lambda_{V}}{2}
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\dot{V}\left(z\right) & \underset{\text{a.e.}}{\le}-\frac{\lambda_{V}}{2}\left\Vert z\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{\text{a.e.}}{\le}-\min\left\{ \lambda_{V},\lambda_{P}\right\} \left(\frac{1}{2}\left\Vert z\right\Vert ^{2}+P\right)
\end{align*}

