\\
 & -\cancel{\widetilde{\theta}^{\top}\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r_{2}}-\lambda_{P}P\left(t\right)+\cancel{K_{\text{RISE}}r_{2}^{\top}K[\text{sgn}\left(r_{1}\right)]}-\cancel{r_{2}^{\top}D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)}
\end{align*}

\end_inset

I don't need to finish.
