\]

\end_inset

By the stated assumptions and EVT, there exists a known constant
\begin_inset Formula 
\[
\overline{\dot{u}}_{d}\triangleq\overline{\dddot{q}}_{d}+\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left(\left\Vert \left.\frac{\partial f}{\partial q}\right|_{\left(q_{d},\dot{q}_{d}\right)}\right\Vert \right)\overline{\dot{q}}_{d}+\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left(\left\Vert \left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\right\Vert \right)\overline{\ddot{q}}_{d}+\overline{\dot{d}}
\]

\end_inset

such that
\begin_inset Formula 
\[
\left\Vert \dot{u}_{d}\right\Vert \le\overline{\dot{u}}_{d}
\]

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 2.3
\end_layout

\begin_layout Standard
Recall
\begin_inset Formula 
\[
\kappa_{d}\triangleq\left[\begin{array}{ccccc}
q_{d}^{\top} & \dot{q}_{d}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u_{d}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{5n}
\]

\end_inset

Thus, by Bounding Lemma 2.1,
\begin_inset Formula 
\begin{align*}
\left\Vert \kappa_{d}\right\Vert  & \le\overline{\kappa}_{d}\\
\overline{\kappa}_{d} & \triangleq2\overline{q}_{d}+2\overline{\dot{q}}_{d}+\overline{u}_{d}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 2.4
\end_layout

\begin_layout Standard
Define
\begin_inset Formula 
\[
\widetilde{u}\triangleq u_{d}-u
\]

\end_inset

Recall 
\begin_inset Formula $u_{d}$
\end_inset

 satisfies
\begin_inset Formula 
\[
\ddot{q}_{d}=d\left(t\right)+f\left(q_{d},\dot{q}_{d}\right)+u_{d}
\]

\end_inset

Recall 
\begin_inset Formula $u$
\end_inset

 satisfies
\begin_inset Formula 
\[
\ddot{q}=d\left(t\right)+f\left(q,\dot{q}\right)+u
\]

\end_inset

Subtract them
\begin_inset Formula 
\begin{align*}
\ddot{q}_{d}-\ddot{q} & =f\left(q_{d},\dot{q}_{d}\right)+u_{d}-f\left(q,\dot{q}\right)-u\\
\ddot{e} & =f\left(q_{d},\dot{q}_{d}\right)+\widetilde{u}-f\left(q,\dot{q}\right)\\
\ddot{e}-f\left(q_{d},\dot{q}_{d}\right)+f\left(q,\dot{q}\right) & =\widetilde{u}\\
\widetilde{u} & =\ddot{e}-f\left(q_{d},\dot{q}_{d}\right)+f\left(q,\dot{q}\right)
\end{align*}

\end_inset

Recall
\begin_inset Formula 
\begin{align*}
r_{1} & \triangleq\dot{e}+k_{1}e\\
\dot{r}_{1} & =\ddot{e}+k_{1}\dot{e}\\
r_{2} & \triangleq\dot{r}_{1}+k_{2}r_{1}
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
r_{2} & =\ddot{e}+k_{1}\dot{e}+k_{2}r_{1}\\
r_{2}-k_{1}\dot{e}-k_{2}r_{1} & =\ddot{e}\\
\ddot{e} & =r_{2}-k_{1}\dot{e}-k_{2}r_{1}
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\[
\widetilde{u}=r_{2}-k_{1}\dot{e}-k_{2}r_{1}-f\left(q_{d},\dot{q}_{d}\right)+f\left(q,\dot{q}\right)
\]

\end_inset

By Bounding Lemma 1.2,
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{u}\right\Vert  & \le\left\Vert r_{2}\right\Vert +k_{1}\left\Vert \dot{e}\right\Vert +k_{2}\left\Vert r_{1}\right\Vert +\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert \\
 & \le\left\Vert r_{2}\right\Vert +k_{1}\left\Vert r_{1}-k_{1}e\right\Vert +k_{2}\left\Vert r_{1}\right\Vert +\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left\Vert r_{2}\right\Vert +k_{1}\left\Vert r_{1}\right\Vert +k_{1}^{2}\left\Vert e\right\Vert +k_{2}\left\Vert r_{1}\right\Vert +\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left\Vert z\right\Vert +k_{1}\left\Vert z\right\Vert +k_{1}^{2}\left\Vert z\right\Vert +k_{2}\left\Vert z\right\Vert +\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(\underbrace{1+k_{1}+k_{1}^{2}+k_{2}+\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)}_{\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\left\Vert z\right\Vert \\
\left\Vert \widetilde{u}\right\Vert  & \le\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 2.5
\end_layout

\begin_layout Standard
Recall
\begin_inset Formula 
\begin{align*}
\kappa & \triangleq\left[\begin{array}{ccccc}
q^{\top} & \dot{q}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{5n}\\
\kappa_{d} & \triangleq\left[\begin{array}{ccccc}
q_{d}^{\top} & \dot{q}_{d}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u_{d}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{5n}\\
\widetilde{u} & \triangleq u_{d}-u
\end{align*}

\end_inset

Let
\begin_inset Formula 
\begin{align*}
\widetilde{\kappa} & \triangleq\kappa_{d}-\kappa\\
 & =\left[\begin{array}{ccccc}
q_{d}^{\top} & \dot{q}_{d}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u_{d}^{\top}\end{array}\right]^{\top}-\left[\begin{array}{ccccc}
q^{\top} & \dot{q}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u^{\top}\end{array}\right]^{\top}\\
 & =\left[\begin{array}{ccccc}
e^{\top} & \dot{e}^{\top} & 0_{1\times n} & 0_{1\times n} & \widetilde{u}^{\top}\end{array}\right]^{\top}
\end{align*}

\end_inset

By Bounding Lemma 2.4,
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{\kappa}\right\Vert  & \le\left\Vert e\right\Vert +\left\Vert \dot{e}\right\Vert +\left\Vert \widetilde{u}\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert r_{1}-k_{1}e\right\Vert +\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert r_{1}\right\Vert +k_{1}\left\Vert e\right\Vert +\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(k_{1}+2\right)\left\Vert z\right\Vert +\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(\underbrace{k_{1}+2+\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}_{\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\left\Vert z\right\Vert \\
 & \le\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 2.6
\end_layout

\begin_layout Standard
Notice
\begin_inset Formula 
\[
\dot{\kappa}_{d}=\left[\begin{array}{ccccc}
\dot{q}_{d}^{\top} & \ddot{q}_{d}^{\top} & \dot{q}_{d}^{\top} & \ddot{q}_{d}^{\top} & \dot{u}_{d}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{5n}
\]

\end_inset

By Bounding Lemma 2.2,
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{\kappa}_{d}\right\Vert  & \le\overline{\dot{\kappa}}_{d}\\
\overline{\dot{\kappa}}_{d} & \triangleq2\overline{\dot{q}}_{d}+2\overline{\ddot{q}}_{d}+\overline{\dot{u}}_{d}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.1
\end_layout

\begin_layout Standard
Recall
\begin_inset Formula 
\[
\widetilde{N}_{\varepsilon}\left(\kappa,\kappa_{d}\right)\triangleq\varepsilon\left(\kappa\right)-\varepsilon\left(\kappa_{d}\right)
\]

\end_inset

Since 
\begin_inset Formula $\kappa_{d}$
\end_inset

 is bounded (by Bounding Lemma 2.3) and 
\begin_inset Formula $\varepsilon\in\mathcal{C}^{1}$
\end_inset

, by Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:non-decreasing-continuous-bound"
plural "false"
caps "false"
noprefix "false"

\end_inset

, there exists an 
\color red
unknown
\color inherit
 nondecreasing 
\begin_inset Formula $\mathcal{C}^{0}$
\end_inset

 function 
\begin_inset Formula $\sigma_{\varepsilon}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{N}_{\varepsilon}\left(\kappa,\kappa_{d}\right)\right\Vert  & \le\sigma_{\varepsilon1}\left(\left\Vert \widetilde{\kappa}\right\Vert \right)\left\Vert \widetilde{\kappa}\right\Vert \\
\sigma_{\varepsilon1}\left(s\right) & \triangleq\sup_{\kappa\in\overline{B}_{\overline{\kappa}_{d}+s}\left(\boldsymbol{0}_{n}\right)}\left(\left\Vert \left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa}\right\Vert \right)
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{N}_{\varepsilon}\left(\kappa,\kappa_{d}\right)\right\Vert  & \le\underbrace{\sigma_{\varepsilon1}\left(\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \right)\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}_{\sigma_{\varepsilon}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\left\Vert z\right\Vert \\
 & \le\sigma_{\varepsilon}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.2
\end_layout

\begin_layout Standard
Recall
\begin_inset Formula 
\[
\left\Vert \theta\right\Vert \le\overline{\theta}
\]

\end_inset

Consider
\begin_inset Formula 
\[
\Phi\left(\kappa_{d},\theta\right)-\Phi\left(\kappa,\theta\right)
\]

\end_inset

Since 
\begin_inset Formula $\Phi$
\end_inset

 is 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

 in fact) and 
\begin_inset Formula $\kappa_{d}$
\end_inset

 is bounded, by Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:non-decreasing-continuous-bound"
plural "false"
caps "false"
noprefix "false"

\end_inset

, there exists a 
\begin_inset Formula $\mathcal{C}^{0}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 in fact) nondecreasing function 
\begin_inset Formula $\sigma_{\Phi\kappa}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that 
\begin_inset Formula 
\begin{align*}
\left\Vert \Phi\left(\kappa_{d},\theta\right)-\Phi\left(\kappa,\theta\right)\right\Vert  & \le\sigma_{\Phi\kappa}\left(\left\Vert \widetilde{\kappa}\right\Vert \right)\left\Vert \widetilde{\kappa}\right\Vert \\
\sigma_{\Phi\kappa}\left(s\right) & \triangleq\sup_{\left\Vert \theta\right\Vert \le\overline{\theta},\left\Vert \zeta\right\Vert \le\overline{\kappa}_{d}+s}\left(\left\Vert \left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\zeta,\theta\right)}\right\Vert \right)
\end{align*}

\end_inset

By Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:strictly-increasing"
plural "false"
caps "false"
noprefix "false"

\end_inset

, there exists a class 
\begin_inset Formula $\mathcal{P}_{\infty}$
\end_inset

 function 
\begin_inset Formula $\rho_{\Phi\kappa}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that (for some 
\begin_inset Formula $c>0$
\end_inset

)
\begin_inset Formula 
\begin{align*}
\left\Vert \Phi\left(\kappa_{d},\theta\right)-\Phi\left(\kappa,\theta\right)\right\Vert  & \le\rho_{\Phi\kappa}\left(\left\Vert \widetilde{\kappa}\right\Vert \right)\left\Vert \widetilde{\kappa}\right\Vert \\
\rho_{\Phi\kappa}\left(s\right) & \triangleq\sigma_{\Phi\kappa}\left(s\right)+cs
\end{align*}

\end_inset

By Bounding Lemma 2.5,
\begin_inset Formula 
\begin{align*}
\left\Vert \Phi\left(\kappa_{d},\theta\right)-\Phi\left(\kappa,\theta\right)\right\Vert  & \le\underbrace{\rho_{\Phi\kappa}\left(\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \right)\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}_{\rho_{\Phi\kappa}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\left\Vert z\right\Vert \\
 & \le\rho_{\Phi\kappa}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.3
\end_layout

\begin_layout Standard
Recall
\begin_inset Formula 
\begin{align*}
\widetilde{N}_{1}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta}\right) & \triangleq N_{0}\left(\kappa,\theta^{\ast},\hat{\theta}\right)-N_{0}\left(\kappa_{d},\theta^{\ast},\hat{\theta}\right)\\
N_{0}\left(\kappa,\theta^{\ast},\hat{\theta}\right) & \triangleq\Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa,\hat{\theta}\right)
\end{align*}

\end_inset

So,
\begin_inset Formula 
\begin{align*}
\widetilde{N}_{1}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta}\right) & =\Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa,\hat{\theta}\right)-\Phi\left(\kappa_{d},\theta^{\ast}\right)+\Phi\left(\kappa_{d},\hat{\theta}\right)\\
 & =\Phi\left(\kappa_{d},\hat{\theta}\right)-\Phi\left(\kappa,\hat{\theta}\right)+\Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa_{d},\theta^{\ast}\right)
\end{align*}

\end_inset

By triangle inequality and Bounding Lemma 3.2 (and since 
\begin_inset Formula $\left\Vert \theta^{\ast}\right\Vert \le\overline{\theta}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \widehat{\theta}\right\Vert \le\overline{\theta}$
\end_inset

), there exists class 
\begin_inset Formula $\mathcal{P}_{\infty}$
\end_inset

 functions 
\begin_inset Formula $\rho_{\widehat{\Phi}\kappa},\rho_{\Phi^{\ast}\kappa}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{N}_{1}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta}\right)\right\Vert  & \le\left\Vert \Phi\left(\kappa_{d},\hat{\theta}\right)-\Phi\left(\kappa,\hat{\theta}\right)\right\Vert +\left\Vert \Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa_{d},\theta^{\ast}\right)\right\Vert \\
 & \le\rho_{\widehat{\Phi}\kappa}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\Phi^{\ast}\kappa}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(\underbrace{\rho_{\widehat{\Phi}\kappa}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)+\rho_{\Phi^{\ast}\kappa}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}_{\rho_{\Phi}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\left\Vert z\right\Vert \\
 & \le\rho_{\Phi}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.4
\end_layout

\begin_layout Standard
Recall
\begin_inset Formula 
\[
\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\triangleq\widetilde{N}_{1}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta}\right)+\widetilde{N}_{\varepsilon}\left(\kappa,\kappa_{d}\right)+\widetilde{N}_{2}\left(q,\dot{q},q_{d},\dot{q}_{d}\right)d\left(t\right)
\]

\end_inset

By Bounding Lemma 1.3, 3.1, and 3.3,
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\right\Vert  & \le\left\Vert \widetilde{N}_{1}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta}\right)\right\Vert +\left\Vert \widetilde{N}_{\varepsilon}\left(\kappa,\kappa_{d}\right)\right\Vert +\left\Vert \widetilde{N}_{2}\left(q,\dot{q},q_{d},\dot{q}_{d}\right)\right\Vert \left\Vert d\left(t\right)\right\Vert \\
 & \le\rho_{\Phi}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\sigma_{\varepsilon}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\overline{d}\rho_{f^{\prime}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(\underbrace{\rho_{\Phi}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)+\sigma_{\varepsilon}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)+\overline{d}\rho_{f^{\prime}}\left(k_{1},\left\Vert z\right\Vert \right)}_{\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\left\Vert z\right\Vert \\
 & \le\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 4.1
\end_layout

\begin_layout Standard
Recall
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right) & \triangleq-\dot{d}\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}d\left(t\right)+\varepsilon\left(\kappa_{d}\right)+N_{0}\left(\kappa_{d},\theta^{\ast},\hat{\theta}\right)\\
 & =-\dot{d}\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}d\left(t\right)+\varepsilon\left(\kappa_{d}\right)+\Phi\left(\kappa_{d},\theta^{\ast}\right)-\Phi\left(\kappa_{d},\hat{\theta}\right)
\end{align*}

\end_inset

By Bounding Lemma 2.3 and 
\begin_inset Formula $f\in\mathcal{C}^{1}$
\end_inset

 and EVT, there exists a known constant
\begin_inset Formula 
\begin{align*}
\overline{D} & \triangleq\overline{\dot{d}}+\overline{d}\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left\Vert \left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\right\Vert \\
 & +\sup_{\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\in\overline{B}_{\overline{\kappa}_{d}}\left(0_{5n}\right)\times\overline{B}_{\overline{\theta}}\left(0_{p}\right)\times\overline{B}_{\overline{\theta}}\left(0_{p}\right)}\left\Vert \Phi\left(\kappa_{d},\theta^{\ast}\right)-\Phi\left(\kappa_{d},\hat{\theta}\right)\right\Vert +\sup_{\kappa_{d}\in\overline{B}_{\overline{\kappa}_{d}}\left(0_{5n}\right)}\left\Vert \varepsilon\left(\kappa_{d}\right)\right\Vert \\
\\
\left\Vert D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\right\Vert  & \le\overline{D}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 4.2
\end_layout

\begin_layout Standard
Differentiate
\begin_inset Formula 
\begin{align*}
\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right) & =-\ddot{d}\left(t\right)-\left(\left.\frac{\partial f}{\partial\dot{q}\partial q}\right|_{\left(q_{d},\dot{q}_{d}\right)}\dot{q}_{d}+\left.\frac{\partial^{2}f}{\partial\dot{q}^{2}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\ddot{q}_{d}\right)d\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\dot{d}\left(t\right)+\left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa_{d}}\dot{\kappa}_{d}\\
 & +\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\theta^{\ast}\right)}\dot{\kappa}_{d}+\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{d},\theta^{\ast}\right)}\cancelto{0_{p}}{\dot{\theta}^{\ast}}-\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}\dot{\kappa}_{d}-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}\dot{\widehat{\theta}}\\
\\
 & =-\ddot{d}\left(t\right)-\left(\left.\frac{\partial f}{\partial\dot{q}\partial q}\right|_{\left(q_{d},\dot{q}_{d}\right)}\dot{q}_{d}+\left.\frac{\partial^{2}f}{\partial\dot{q}^{2}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\ddot{q}_{d}\right)d\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\dot{d}\left(t\right)+\left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa_{d}}\dot{\kappa}_{d}\\
 & +\left(\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\theta^{\ast}\right)}-\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}\right)\dot{\kappa}_{d}-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}\dot{\widehat{\theta}}
\end{align*}

\end_inset

By 
\begin_inset Formula $\frac{d\varepsilon}{d\kappa}\in\mathcal{C}^{0}$
\end_inset

, 
\begin_inset Formula $\frac{\partial\Phi}{\partial\theta}\in\mathcal{C}^{0}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 in fact), 
\begin_inset Formula $\frac{\partial\Phi}{\partial\kappa}\in\mathcal{C}^{0}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 in fact), EVT and Bounding Lemma 2.6, there exists an 
\color red
unknown
\color inherit
 constant
\begin_inset Formula 
\begin{align*}
\overline{\dot{D}} & \triangleq\overline{\ddot{d}}+\overline{d}\overline{\dot{q}}_{d}\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left\Vert \left.\frac{\partial f}{\partial\dot{q}\partial q}\right|_{\left(q_{d},\dot{q}_{d}\right)}\right\Vert +\overline{d}\overline{\ddot{q}}_{d}\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left\Vert \left.\frac{\partial^{2}f}{\partial\dot{q}^{2}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\right\Vert \\
 & +\overline{\dot{d}}\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left\Vert \left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\right\Vert +\overline{\dot{\kappa}}_{d}\sup_{\kappa_{d}\le\overline{\kappa}_{d}}\left\Vert \left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa_{d}}\right\Vert \\
 & +\overline{\dot{\kappa}}_{d}\sup_{\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\in\overline{B}_{\overline{\kappa}_{d}}\left(0_{5n}\right)\times\overline{B}_{\overline{\theta}}\left(0_{p}\right)\times\overline{B}_{\overline{\theta}}\left(0_{p}\right)}\left\Vert \left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\theta^{\ast}\right)}-\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}\right\Vert \\
 & +\eta_{1}\sup_{\left(\kappa_{d},\widehat{\theta}\right)\in\overline{B}_{\overline{\kappa}_{d}}\left(0_{5n}\right)\times\overline{B}_{\overline{\theta}}\left(0_{p}\right)}\left\Vert \left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}\right\Vert 
\end{align*}

\end_inset


\color blue
NOTE: We will return to 
\begin_inset Formula $\left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa_{d}}$
\end_inset

 later to make it known! For now, we assume without proof that
\color inherit

\begin_inset Formula 
\[
\sup_{\kappa_{d}\le\overline{\kappa}_{d}}\left\Vert \left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa_{d}}\right\Vert \le\overline{\varepsilon}_{d}
\]

\end_inset

where 
\begin_inset Formula $\overline{\varepsilon}_{d}$
\end_inset

 is a 
\color green
known
\color inherit
 constant.
 Thus, 
\begin_inset Formula $\overline{\dot{D}}$
\end_inset

 is now a 
\color green
known
\color inherit
 constant.
