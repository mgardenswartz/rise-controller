\begin_layout Section
Second-Order Target Tracking
\end_layout

\begin_layout Plain Layout
Let the target's dynamics be
\begin_inset Formula 
\[
\ddot{q}_{d}=h\left(q_{d},\dot{q}_{d}\right)
\]

\end_inset

Let the controlled agent's dynamics be
\begin_inset Formula 
\[
\ddot{q}=f\left(q,\dot{q}\right)+u+d\left(t\right)
\]

\end_inset

Assume 
\begin_inset Formula $q$
\end_inset

, 
\begin_inset Formula $\dot{q}$
\end_inset

, 
\begin_inset Formula $q_{d}$
\end_inset


\family roman
\series medium
\shape up
\size normal
\emph off
\bar no
\strikeout off
\xout off
\uuline off
\uwave off
\noun off
\color none
, 
\begin_inset Formula $\dot{q}_{d}$
\end_inset

 are measurable, 
\begin_inset Formula $d\in\mathcal{C}^{2}$
\end_inset

, 
\begin_inset Formula $q_{d}\in\mathcal{C}^{3}$
\end_inset

, with
\begin_inset Formula 
\begin{align*}
\left\Vert d\right\Vert  & \le\overline{d}\\
\left\Vert \dot{d}\right\Vert  & \le\overline{\dot{d}}\\
\left\Vert \ddot{d}\right\Vert  & \le\overline{\ddot{d}}
\end{align*}

\end_inset

and
\begin_inset Formula 
\begin{align*}
\left\Vert q_{d}\right\Vert  & \le\overline{q_{d}}\\
\left\Vert \dot{q}_{d}\right\Vert  & \le\overline{\dot{q}_{d}}\\
\left\Vert \ddot{q}_{d}\right\Vert  & \le\overline{\ddot{q}_{d}}\\
\left\Vert \dddot{q}_{d}\right\Vert  & \le\overline{\dddot{q}_{d}}
\end{align*}

\end_inset

 Let
\begin_inset Formula 
\begin{align*}
e & \triangleq q_{d}-q\\
r_{1} & \triangleq\dot{e}+k_{1}e\\
r_{2} & \triangleq\dot{r}_{1}+k_{2}r_{1}+e
\end{align*}

\end_inset

Error derivative
\begin_inset Formula 
\[
\dot{e}=r_{1}-k_{1}e
\]

\end_inset

Error second derivative
\begin_inset Formula 
\begin{align*}
\ddot{e} & =\ddot{q}_{d}-\ddot{q}\\
 & =h\left(q_{d},\dot{q}_{d}\right)-f\left(q,\dot{q}\right)-u-d\\
 & =h\left(q_{d},\dot{q}_{d}\right)-f\left(q,\dot{q}\right)-u-d
\end{align*}

\end_inset

Error third derivative
\begin_inset Formula 
\begin{align*}
\dddot{e} & =\dddot{q}_{d}-\dddot{q}\\
 & =\frac{d}{dt}\left(h\left(q_{d},\dot{q}_{d}\right)\right)-\frac{d}{dt}\left(f\left(q,\dot{q}\right)+u+d\left(t\right)\right)\\
 & =\frac{\partial h}{\partial q_{d}}\dot{q}_{d}+\frac{\partial h}{\partial\dot{q}_{d}}\ddot{q}_{d}-\frac{\partial f}{\partial q}\dot{q}-\frac{\partial f}{\partial\dot{q}}\ddot{q}-\dot{u}-\dot{d}\\
 & =\frac{\partial h}{\partial q_{d}}\dot{q}_{d}+\frac{\partial h}{\partial\dot{q}_{d}}h\left(q_{d},\dot{q}_{d}\right)-\frac{\partial f}{\partial q}\dot{q}-\frac{\partial f}{\partial\dot{q}}\left(f\left(q,\dot{q}\right)+u+d\left(t\right)\right)-\dot{u}-\dot{d}\\
 & =\underbrace{\frac{\partial h}{\partial q_{d}}\left(q_{d},\dot{q}_{d}\right)\dot{q}_{d}+\frac{\partial h}{\partial\dot{q}_{d}}\left(q_{d},\dot{q}_{d}\right)h\left(q_{d},\dot{q}_{d}\right)-\frac{\partial f}{\partial q}\left(q,\dot{q}\right)\dot{q}-\frac{\partial f}{\partial\dot{q}}\left(q,\dot{q}\right)f\left(q,\dot{q}\right)-\frac{\partial f}{\partial\dot{q}}\left(q,\dot{q}\right)u}_{F\left(q,\dot{q},q_{d},\dot{q}_{d},u\right)}-\dot{u}-\dot{d}-\frac{\partial f}{\partial\dot{q}}d\left(t\right)\\
 & =F\left(q,\dot{q},q_{d},\dot{q}_{d},u\right)-\dot{u}-\dot{d}-\frac{\partial f}{\partial\dot{q}}d\left(t\right)
\end{align*}

\end_inset

R1 derivative
\begin_inset Formula 
\begin{align*}
\dot{r}_{1} & =\ddot{e}+k_{1}\dot{e}\\
 & =h\left(q_{d},\dot{q}_{d}\right)-f\left(q,\dot{q}\right)-u-d+k_{1}\left(r_{1}-k_{1}e\right)\\
 & =h\left(q_{d},\dot{q}_{d}\right)-f\left(q,\dot{q}\right)-u-d+k_{1}r_{1}-k_{1}^{2}e
\end{align*}

\end_inset

R2 derivative
\begin_inset Formula 
\begin{align*}
\dot{r}_{2} & =\ddot{r}_{1}+k_{2}\dot{r}_{1}+\dot{e}\\
 & =\frac{d}{dt}\left(h\left(q_{d},\dot{q}_{d}\right)-f\left(q,\dot{q}\right)-u-d+k_{1}r_{1}-k_{1}^{2}e\right)+k_{2}\left(r_{2}-k_{2}r_{1}-e\right)+\left(r_{1}-k_{1}e\right)\\
 & =\frac{\partial h}{\partial q_{d}}\left(q_{d},\dot{q}_{d}\right)\dot{q}_{d}+\frac{\partial h}{\partial\dot{q}_{d}}\left(q_{d},\dot{q}_{d}\right)\ddot{q}_{d}-\frac{\partial f}{\partial q}\left(q,\dot{q}\right)\dot{q}-\frac{\partial f}{\partial\dot{q}}\left(q,\dot{q}\right)\ddot{q}-\dot{u}-\dot{d}+k_{1}\dot{r}_{1}-k_{1}^{2}\dot{e}+k_{2}r_{2}-k_{2}^{2}r_{1}-k_{2}e+r_{1}-k_{1}e\\
\\
 & =\frac{\partial h}{\partial q_{d}}\left(q_{d},\dot{q}_{d}\right)\dot{q}_{d}+\frac{\partial h}{\partial\dot{q}_{d}}\left(q_{d},\dot{q}_{d}\right)h\left(q_{d},\dot{q}_{d}\right)-\frac{\partial f}{\partial q}\left(q,\dot{q}\right)\dot{q}-\frac{\partial f}{\partial\dot{q}}\left(q,\dot{q}\right)\left(f\left(q,\dot{q}\right)+u+d\right)\\
