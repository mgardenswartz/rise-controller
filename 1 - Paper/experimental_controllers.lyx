\begin_layout Part
Regular Controllers
\end_layout

\begin_layout Section
Intro
\end_layout

\begin_layout Standard
Dynamics
\begin_inset Formula 
\[
\dot{x}=f\left(x\right)+d\left(t\right)+u\left(t\right)
\]

\end_inset

where 
\begin_inset Formula $f\in\mathcal{C}^{2}$
\end_inset

 and globally Lipschitz and 
\begin_inset Formula $d\in\mathcal{C}^{2}$
\end_inset

, where
\begin_inset Formula 
\begin{align*}
\left\Vert d\right\Vert  & \le\overline{d}\\
\left\Vert \dot{d}\right\Vert  & \le\overline{\dot{d}}\\
\left\Vert \ddot{d}\right\Vert  & \le\overline{\ddot{d}}\\
\left\Vert \frac{df}{dx}\right\Vert  & \le L
\end{align*}

\end_inset

are known constants.
 Errors
\begin_inset Formula 
\begin{align*}
e & \triangleq x_{d}-x\\
r & \triangleq\dot{e}+k_{1}e
\end{align*}

\end_inset

where 
\begin_inset Formula $x_{d}\in\mathcal{C}^{2}$
\end_inset

 and
\begin_inset Formula 
\begin{align*}
\left\Vert x_{d}\right\Vert  & \le\overline{x_{d}}\\
\left\Vert \dot{x}_{d}\right\Vert  & \le\overline{\dot{x}_{d}}\\
\left\Vert \ddot{x_{d}}\right\Vert  & \le\overline{\ddot{x_{d}}}
\end{align*}

\end_inset

are known constants.
 Assume 
\begin_inset Formula 
\begin{align*}
\left\Vert \widehat{\theta}\right\Vert  & \le\overline{\theta}\\
\left\Vert \theta^{\ast}\right\Vert  & \le\overline{\theta}\\
\left\Vert \dot{\widehat{\theta}}\right\Vert  & \le\eta_{1}
\end{align*}

\end_inset

are known constants.
 
\end_layout

\begin_layout Section
RISE: Inside the Integral
\end_layout

\begin_layout Standard
Write
\begin_inset Formula 
\[
\dot{e}=r-k_{1}e
\]

\end_inset

Write
\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{e}+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\ddot{x}+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\frac{d}{dt}\left(f\left(x\right)+d\left(t\right)+u\left(t\right)\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\frac{d}{dt}f\left(x\right)-\dot{d}\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\left.\frac{df}{dx}\right|_{x}\dot{x}-\dot{d}\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\left.\frac{df}{dx}\right|_{x}\left(f\left(x\right)+d\left(t\right)+u\left(t\right)\right)-\dot{d}\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\left.\frac{df}{dx}\right|_{x}f\left(x\right)-\left.\frac{df}{dx}\right|_{x}u\left(t\right)-\dot{d}\left(t\right)-\left.\frac{df}{dx}\right|_{x}d\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\left(\underbrace{\left.\frac{df}{dx}\right|_{x}f\left(x\right)+\left.\frac{df}{dx}\right|_{x}u\left(t\right)}_{h\left(x,u\right)}\right)-\left(\underbrace{\dot{d}\left(t\right)+\left.\frac{df}{dx}\right|_{x}d\left(t\right)}_{D\left(x,t\right)}\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-h\left(\kappa\right)-D\left(x,t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\Phi\left(\kappa,\theta^{\ast}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}
\end{align*}

\end_inset

Let 
\begin_inset Formula $\kappa\triangleq\left[\begin{array}{cc}
x^{\top} & u^{\top}\end{array}\right]^{\top}$
\end_inset

.
 Let
\begin_inset Formula 
\[
{\color{green}\dot{u}=k_{2}r+\ddot{x}_{d}-\Phi\left(\kappa,\widehat{\theta}\right)+k_{1}\dot{e}+\beta\text{sgn}\left(e\right)+e}
\]

\end_inset

So,
\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{x}_{d}-\Phi\left(\kappa,\theta^{\ast}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\left(k_{2}r+\ddot{x}_{d}-\Phi\left(\kappa,\widehat{\theta}\right)+k_{1}\dot{e}+\beta\text{sgn}\left(e\right)+e\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\Phi\left(\kappa,\theta^{\ast}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-k_{2}r-\ddot{x}_{d}+\Phi\left(\kappa,\widehat{\theta}\right)-k_{1}\dot{e}-\beta\text{sgn}\left(e\right)-e+k_{1}\dot{e}\\
 & =\underbrace{-\Phi\left(\kappa,\theta^{\ast}\right)+\Phi\left(\kappa,\widehat{\theta}\right)}_{M\left(x,u,\theta^{\ast},\widehat{\theta}\right)}-\varepsilon\left(\kappa\right)-D\left(x,t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =M\left(x,u,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =\underbrace{M\left(x,u,\theta^{\ast},\widehat{\theta}\right)-M\left(x_{d},u,\theta^{\ast},\widehat{\theta}\right)}_{\widetilde{N}\left(x,x_{d},u,\theta^{\ast},\widehat{\theta}\right)}+\underbrace{M\left(x_{d},u,\theta^{\ast},\widehat{\theta}\right)}_{N_{B}\left(x_{d},u,\theta^{\ast},\widehat{\theta}\right)}-\varepsilon\left(\kappa\right)-D\left(x,t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =\widetilde{N}\left(x,x_{d},u,\theta^{\ast},\widehat{\theta}\right)+\underbrace{N_{B}\left(x_{d},u,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)}_{g\left(t\right)}-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =\widetilde{N}\left(x,x_{d},u,\theta^{\ast},\widehat{\theta}\right)+g\left(t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e
\end{align*}

\end_inset

Lemmas done elsewhere show:
\begin_inset Formula 
\[
\left\Vert u\right\Vert \le\rho_{u}\left(\left\Vert z\right\Vert \right)
\]

\end_inset


\begin_inset Formula 
\[
\left\Vert N_{B}\left(x_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert \le\overline{N}_{B}
\]

\end_inset


\begin_inset Formula 
\[
\left\Vert \widetilde{N}\left(x,x_{d},u,\theta^{\ast},\widehat{\theta}\right)\right\Vert \le\rho_{\widetilde{N}}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\]

\end_inset

Closed-loop dynamics
\begin_inset Formula 
\[
\left[\begin{array}{c}
\dot{e}\\
\dot{r}\\
\dot{P}
\end{array}\right]=\left[\begin{array}{c}
r-k_{1}e\\
\widetilde{N}+g\left(t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
-\lambda_{P}P-r^{\top}g\left(t\right)+\beta r^{\top}\text{sgn}\left(e\right)
\end{array}\right]
\]

\end_inset

Lyapunov
\begin_inset Formula 
\[
V=\frac{1}{2}e^{\top}e+\frac{1}{2}r^{\top}r+P
\]

\end_inset

Assume it has been shown elsewhere that 
\begin_inset Formula $\left\Vert g\left(t\right)\right\Vert \le\overline{g}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{g}\left(t\right)\right\Vert \le\overline{\dot{g}}$
\end_inset

 and 
\begin_inset Formula $\beta$
\end_inset

 is chosen such that 
\begin_inset Formula $P\ge0$
\end_inset

 always.
 Ignore nuances with the signum thing.
 Derivative.
\begin_inset Formula 
\begin{align*}
\dot{V} & =e^{\top}\dot{e}+r^{\top}\dot{r}+\dot{P}\\
 & =e^{\top}\left(r-k_{1}e\right)+r^{\top}\left(\widetilde{N}+g\left(t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\right)\\
 & -\lambda_{P}P-r^{\top}g\left(t\right)+\beta r^{\top}\text{sgn}\left(e\right)\\
\\
 & =\cancel{e^{\top}r}-k_{1}e^{\top}e+r^{\top}\widetilde{N}\left(x,x_{d},u,\theta^{\ast},\widehat{\theta}\right)+\cancel{r^{\top}g\left(t\right)}-k_{2}r^{\top}r-\cancel{\beta r^{\top}\text{sgn}\left(e\right)}-\cancel{r^{\top}e}\\
 & -\lambda_{P}P-\cancel{r^{\top}g\left(t\right)}+\cancel{\beta r^{\top}\text{sgn}\left(e\right)}\\
\\
 & =-k_{1}e^{\top}e-k_{2}r^{\top}r-\lambda_{P}P+r^{\top}\widetilde{N}\left(x,x_{d},u,\theta^{\ast},\widehat{\theta}\right)\\
 & =-k_{1}\left\Vert e\right\Vert ^{2}-k_{2}\left\Vert r\right\Vert ^{2}-\lambda_{P}P+\left\Vert r\right\Vert \rho_{\widetilde{N}}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & =-\min\left(k_{1},k_{2}\right)\left\Vert z\right\Vert ^{2}-\lambda_{P}P+\rho_{\widetilde{N}}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert ^{2}\\
 & =-\left(\min\left(k_{1},k_{2}\right)-\rho_{\widetilde{N}}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}-\lambda_{P}P
\end{align*}

\end_inset

We can stop here.
 That's enough to design the controller.
\end_layout

\begin_layout Section
Non-RISE: Inside the Integral
\end_layout

\begin_layout Standard
We start from the 
\begin_inset Formula $\dot{r}$
\end_inset

 dynamics again but do a Taylor series:
\begin_inset Formula 
\[
\Phi\left(\kappa,\theta^{\ast}\right)=\Phi\left(\kappa,\widehat{\theta}\right)+\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}\widetilde{\theta}+\mathcal{R}\left(\kappa,\widetilde{\theta}\right)
\]

\end_inset


\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{x}_{d}-\Phi\left(\kappa,\theta^{\ast}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\left(k_{2}r+\ddot{x}_{d}-\Phi\left(\kappa,\widehat{\theta}\right)+k_{1}\dot{e}+\beta\text{sgn}\left(e\right)+e\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\Phi\left(\kappa,\theta^{\ast}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-k_{2}r-\ddot{x}_{d}+\Phi\left(\kappa,\widehat{\theta}\right)-k_{1}\dot{e}-\beta\text{sgn}\left(e\right)-e+k_{1}\dot{e}\\
 & =-\Phi\left(\kappa,\theta^{\ast}\right)+\Phi\left(\kappa,\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}\widetilde{\theta}\underbrace{-\mathcal{R}\left(\kappa,\widetilde{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)}_{g_{\text{new}}\left(t\right)}-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}\widetilde{\theta}+g_{\text{new}}\left(t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e
\end{align*}

\end_inset

Design
\begin_inset Formula 
\[
\dot{\widehat{\theta}}=\text{proj}\left(-\Gamma\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r\right)
\]

\end_inset

Let
\begin_inset Formula 
\[
\widetilde{\theta}\triangleq\theta^{\ast}-\widehat{\theta}
\]

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\dot{\widetilde{\theta}} & =-\dot{\widehat{\theta}}\\
 & =-\text{proj}\left(-\Gamma\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r\right)
\end{align*}

\end_inset

From Krstic's Appendix E.4,
\begin_inset Formula 
\[
-\widetilde{\theta}^{\top}\Gamma^{-1}\text{proj}\left(\tau\right)\le-\widetilde{\theta}^{\top}\Gamma^{-1}\tau
\]

\end_inset

so
\begin_inset Formula 
\begin{align*}
\widetilde{\theta}^{\top}\Gamma^{-1}\dot{\widetilde{\theta}} & =\widetilde{\theta}^{\top}\Gamma^{-1}\left(-\text{proj}\left(-\Gamma\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r\right)\right)\\
 & =-\widetilde{\theta}^{\top}\Gamma^{-1}\text{proj}\left(-\Gamma\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r\right)\\
 & \le\widetilde{\theta}^{\top}\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r
\end{align*}

\end_inset

Lyapunov
\begin_inset Formula 
\[
V=\frac{1}{2}e^{\top}e+\frac{1}{2}r^{\top}r+\frac{1}{2}\widetilde{\theta}^{\top}\Gamma^{-1}\widetilde{\theta}+P
\]

\end_inset

Derivative.
\begin_inset Formula 
\begin{align*}
\dot{V} & =e^{\top}\dot{e}+r^{\top}\dot{r}+\widetilde{\theta}^{\top}\Gamma^{-1}\dot{\widetilde{\theta}}+\dot{P}\\
 & =e^{\top}\left(r-k_{1}e\right)+r^{\top}\left(-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}\widetilde{\theta}+g_{\text{new}}\left(t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\right)\\
 & -\lambda_{P}P-r^{\top}\left(g_{\text{new}}\left(t\right)-\beta\text{sgn}\left(e\right)\right)+\widetilde{\theta}^{\top}\Gamma^{-1}\dot{\widetilde{\theta}}\\
\\
 & \le\cancel{e^{\top}r}-k_{1}e^{\top}e-\cancel{r^{\top}\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}\widetilde{\theta}}+\cancel{r^{\top}g_{\text{new}}\left(t\right)}-k_{2}r^{\top}r-\cancel{r^{\top}\beta\text{sgn}\left(e\right)}-\cancel{r^{\top}e}\\
 & -\lambda_{P}P-\cancel{r^{\top}\left(g_{\text{new}}\left(t\right)-\beta\text{sgn}\left(e\right)\right)}+\cancel{\widetilde{\theta}^{\top}\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa,\widehat{\theta}\right)}^{\top}r}\\
\\
 & \le-k_{1}e^{\top}e-k_{2}r^{\top}r-\lambda_{P}P
\end{align*}

\end_inset

Thus we have asymptotic stability.
 We can stop here.
 That's enough to design the controller.
\end_layout

\begin_layout Section
RISE: Outside the Integral
\end_layout

\begin_layout Standard
As before,
\begin_inset Formula 
\[
\dot{e}=r-k_{1}e
\]

\end_inset

Write
\begin_inset Formula 
\begin{align*}
\dot{x} & =f\left(x\right)+d\left(t\right)+u\left(t\right)\\
 & =\Phi\left(x,\theta^{\ast}\right)+\varepsilon\left(x\right)+d\left(t\right)+u\left(t\right)
\end{align*}

\end_inset

Assume
\begin_inset Formula 
\[
\left\Vert \varepsilon\left(x\right)\right\Vert \le\overline{\varepsilon}
\]

\end_inset

Let
\begin_inset Formula 
\[
u\left(t\right)=-\Phi\left(x,\widehat{\theta}\right)+u_{RISE}
\]

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\dot{x} & =\underbrace{\Phi\left(x,\theta^{\ast}\right)-\Phi\left(x,\widehat{\theta}\right)+\varepsilon\left(x\right)}_{f_{\text{new}}\left(x,\theta^{\ast},\widehat{\theta}\right)}+d\left(t\right)+u_{RISE}\left(t\right)\\
 & =f_{\text{new}}\left(x,\theta^{\ast},\widehat{\theta}\right)+d\left(t\right)+u_{RISE}\left(t\right)
\end{align*}

\end_inset

Differentiate
\begin_inset Formula 
\begin{align*}
\ddot{x} & =\frac{d}{dt}\left(f_{\text{new}}\left(x,\theta^{\ast},\widehat{\theta}\right)\right)+\dot{d}+\dot{u}_{RISE}\\
 & =\underbrace{\frac{d}{dt}\left(f_{\text{new}}\left(x,\theta^{\ast},\widehat{\theta}\right)\right)-\frac{d}{dt}\left(f_{\text{new}}\left(x_{d},\theta^{\ast},\widehat{\theta}\right)\right)}_{-\widetilde{N}\left(x,x_{d},\theta^{\ast},\widehat{\theta}\right)}+\dot{d}+\dot{u}_{RISE}+\underbrace{\frac{d}{dt}\left(f_{\text{new}}\left(x_{d},\theta^{\ast},\widehat{\theta}\right)\right)}_{-N_{B}\left(x_{d},\theta^{\ast},\widehat{\theta}\right)}\\
 & =-N_{B}\left(x_{d},\theta^{\ast},\widehat{\theta}\right)-\widetilde{N}\left(x,x_{d},\theta^{\ast},\widehat{\theta}\right)+\dot{d}+\dot{u}_{RISE}
\end{align*}

\end_inset


\begin_inset Note Note
status open

\begin_layout Plain Layout
Note (for personal reference)
\begin_inset Formula 
\[
\frac{d}{dt}\left(f_{\text{new}}\left(x,\theta^{\ast},\widehat{\theta}\right)\right)=\left.\frac{\partial\Phi}{\partial x}\right|_{\left(x,\theta^{\ast}\right)}\dot{x}-\left.\frac{\partial\Phi}{\partial x}\right|_{\left(x,\widehat{\theta}\right)}\dot{x}+\left.\frac{d\varepsilon}{dx}\right|_{x}\dot{x}-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}
\]

\end_inset


\end_layout

\end_inset

Assume (shown elsewhere but not here)
\begin_inset Formula 
\begin{align*}
\left\Vert N_{B}\left(x_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert  & \le\gamma_{1}\\
\left\Vert \widetilde{N}\left(x,x_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert  & \le\rho_{\widetilde{N}}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset

Dynamics
\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{e}+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\ddot{x}+k_{1}\left(r-k_{1}e\right)\\
 & =\ddot{x}_{d}-\left(-N_{B}-\widetilde{N}+\dot{d}+\dot{u}_{RISE}\right)+k_{1}r-k_{1}^{2}e\\
 & =\ddot{x}_{d}+N_{B}+\widetilde{N}-\dot{d}-\dot{u}_{RISE}+k_{1}r-k_{1}^{2}e
\end{align*}

\end_inset

Let
\begin_inset Formula 
\[
\dot{u}_{RISE}=k_{1}r+k_{2}r-k_{1}^{2}e+\ddot{x}_{d}+\beta\text{sgn}\left(e\right)+e
\]

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{x}_{d}+N_{B}+\widetilde{N}-\dot{d}+k_{1}r-k_{1}^{2}e-\left(k_{1}r+k_{2}r-k_{1}^{2}e+\ddot{x}_{d}+\beta\text{sgn}\left(e\right)+e\right)\\
 & =\cancel{\ddot{x}_{d}}+N_{B}+\widetilde{N}-\dot{d}+\cancel{k_{1}r}-\cancel{k_{1}^{2}e}-\cancel{k_{1}r}-k_{2}r+\cancel{k_{1}^{2}e}-\cancel{\ddot{x}_{d}}-\beta\text{sgn}\left(e\right)-e\\
 & =\widetilde{N}+\underbrace{N_{B}-\dot{d}}_{g\left(t\right)}-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =\widetilde{N}+g\left(t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e
\end{align*}

\end_inset

Closed-loop dynamics
\begin_inset Formula 
\[
\left[\begin{array}{c}
\dot{e}\\
\dot{r}\\
\dot{P}
\end{array}\right]=\left[\begin{array}{c}
r-k_{1}e\\
\widetilde{N}+g\left(t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
-\lambda_{P}P-r^{\top}g\left(t\right)+\beta r^{\top}\text{sgn}\left(e\right)
\end{array}\right]
\]

\end_inset

Lyapunov
\begin_inset Formula 
\[
V=\frac{1}{2}e^{\top}e+\frac{1}{2}r^{\top}r+P
\]

\end_inset

Assume it has been shown elsewhere that 
\begin_inset Formula $\left\Vert g\left(t\right)\right\Vert \le\overline{g}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{g}\left(t\right)\right\Vert \le\overline{\dot{g}}$
\end_inset

 and 
\begin_inset Formula $\beta$
\end_inset

 is chosen such that 
\begin_inset Formula $P\ge0$
\end_inset

 always.
 Ignore nuances with the signum thing.
 Derivative.
\begin_inset Formula 
\begin{align*}
\dot{V} & =e^{\top}\dot{e}+r^{\top}\dot{r}+\dot{P}\\
 & =e^{\top}\left(r-k_{1}e\right)+r^{\top}\left(\widetilde{N}+g\left(t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\right)-\lambda_{P}P-r^{\top}g\left(t\right)+\beta r^{\top}\text{sgn}\left(e\right)\\
 & =\cancel{e^{\top}r}-k_{1}e^{\top}e+r^{\top}\widetilde{N}+\cancel{r^{\top}g\left(t\right)}-k_{2}r^{\top}r-\cancel{\beta r^{\top}\text{sgn}\left(e\right)}-\cancel{r^{\top}e}-\lambda_{P}P-\cancel{r^{\top}g\left(t\right)}+\cancel{\beta r^{\top}\text{sgn}\left(e\right)}\\
 & =-k_{1}e^{\top}e+r^{\top}\widetilde{N}-k_{2}r^{\top}r-\lambda_{P}P\\
 & \le-k_{1}\left\Vert e\right\Vert ^{2}+\left\Vert r\right\Vert \left\Vert \widetilde{N}\right\Vert -k_{2}\left\Vert r\right\Vert ^{2}-\lambda_{P}P\\
 & \le-k_{1}\left\Vert e\right\Vert ^{2}+\left\Vert r\right\Vert \rho_{\widetilde{N}}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert -k_{2}\left\Vert r\right\Vert ^{2}-\lambda_{P}P\\
 & =-\min\left(k_{1},k_{2}\right)\left\Vert z\right\Vert ^{2}-\lambda_{P}P+\rho_{\widetilde{N}}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert ^{2}\\
 & =-\left(\min\left(k_{1},k_{2}\right)-\rho_{\widetilde{N}}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}-\lambda_{P}P
\end{align*}

\end_inset

We can stop here.
 That's enough to design the controller.
\end_layout

\begin_layout Section
Non-RISE: Outside the Integral
\end_layout

\begin_layout Standard
We start from the 
\begin_inset Formula $\dot{r}$
\end_inset

 dynamics again
\begin_inset Formula 
\begin{align*}
\dot{x} & =\Phi\left(x,\theta^{\ast}\right)-\Phi\left(x,\widehat{\theta}\right)+\varepsilon\left(x\right)+d\left(t\right)+u_{RISE}\left(t\right)
\end{align*}

\end_inset

Differentiate.
\begin_inset Formula 
\begin{align*}
\ddot{x} & =\underbrace{\left.\frac{\partial\Phi}{\partial x}\right|_{\left(x,\theta^{\ast}\right)}\dot{x}}_{\Psi\left(x,\dot{x},\theta^{\ast}\right)}-\underbrace{\left.\frac{\partial\Phi}{\partial x}\right|_{\left(x,\widehat{\theta}\right)}\dot{x}}_{\Psi\left(x,\dot{x},\widehat{\theta}\right)}-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}+\frac{d\varepsilon}{dx}\dot{x}+\dot{d}+\dot{u}_{RISE}\\
 & =\Psi\left(x,\dot{x},\theta^{\ast}\right)-\Psi\left(x,\dot{x},\widehat{\theta}\right)-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}+\frac{d\varepsilon}{dx}\dot{x}+\dot{d}+\dot{u}_{RISE}
\end{align*}

\end_inset

Do a Taylor series.
\begin_inset Formula 
\[
\Psi\left(x,\dot{x},\theta^{\ast}\right)=\Psi\left(x,\dot{x},\widehat{\theta}\right)+\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}+\mathcal{R}\left(x,\dot{x},\widetilde{\theta}\right)
\]

\end_inset

Thus,
\begin_inset Formula 
\[
\ddot{x}=\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}+\mathcal{R}\left(x,\dot{x},\widetilde{\theta}\right)-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}+\frac{d\varepsilon}{dx}\dot{x}+\dot{d}+\dot{u}_{RISE}
\]

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{e}+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\ddot{x}+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\left(\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}+\mathcal{R}\left(x,\dot{x},\widetilde{\theta}\right)-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}+\frac{d\varepsilon}{dx}\dot{x}+\dot{d}+\dot{u}_{RISE}\right)+k_{1}\dot{e}\\
 & =-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}\underbrace{-\mathcal{R}\left(x,\dot{x},\widetilde{\theta}\right)-\frac{d\varepsilon}{dx}\dot{x}-\dot{d}}_{g_{\text{new}}\left(t\right)}+\ddot{x}_{d}+\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}-\dot{u}_{RISE}+k_{1}\dot{e}\\
 & =-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}+g_{\text{new}}\left(t\right)+\ddot{x}_{d}+\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}-\dot{u}_{RISE}+k_{1}\dot{e}
\end{align*}

\end_inset

Thus,
\color green

\begin_inset Formula 
\[
\dot{u}_{RISE}\left(t\right)=k_{1}\dot{e}+\left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}+\ddot{x}_{d}+\beta\text{sgn}\left(e\right)+e+k_{2}r
\]

\end_inset


\color inherit
Thus,
\begin_inset Formula 
\begin{align*}
\dot{r} & =-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}+g_{\text{new}}\left(t\right)+\ddot{x}_{d}+\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}-\left(k_{1}\dot{e}+\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}+\ddot{x}_{d}+\beta\text{sgn}\left(e\right)+e+k_{2}r\right)+k_{1}\dot{e}\\
 & =-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}+g_{\text{new}}\left(t\right)+\cancel{\ddot{x}_{d}}+\cancel{\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}}-\cancel{k_{1}\dot{e}}-\cancel{\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\widehat{\theta}\right)}\dot{\widehat{\theta}}}-\cancel{\ddot{x}_{d}}-\beta\text{sgn}\left(e\right)-e-k_{2}r+\cancel{k_{1}\dot{e}}\\
 & =-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}+g_{\text{new}}\left(t\right)-\beta\text{sgn}\left(e\right)-e-k_{2}r
\end{align*}

\end_inset

Design
\begin_inset Formula 
\[
\dot{\widehat{\theta}}=\text{proj}\left(-\Gamma\left(\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\right)^{\top}r\right)
\]

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\dot{\widetilde{\theta}} & =-\dot{\widehat{\theta}}\\
 & =-\text{proj}\left(-\Gamma\left(\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\right)^{\top}r\right)
\end{align*}

\end_inset

From Krstic's Appendix E.4,
\begin_inset Formula 
\[
-\widetilde{\theta}^{\top}\Gamma^{-1}\text{proj}\left(\tau\right)\le-\widetilde{\theta}^{\top}\Gamma^{-1}\tau
\]

\end_inset

so
\begin_inset Formula 
\begin{align*}
\widetilde{\theta}^{\top}\Gamma^{-1}\dot{\widetilde{\theta}} & =\widetilde{\theta}^{\top}\Gamma^{-1}\left(-\text{proj}\left(-\Gamma\left(\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\right)^{\top}r\right)\right)\\
 & =-\widetilde{\theta}^{\top}\Gamma^{-1}\text{proj}\left(-\Gamma\left(\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\right)^{\top}r\right)\\
 & \le\widetilde{\theta}^{\top}\left(\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\right)^{\top}r
\end{align*}

\end_inset

Closed-loop dynamics
\begin_inset Formula 
\[
\left[\begin{array}{c}
\dot{e}\\
\dot{r}\\
\dot{\widetilde{\theta}}\\
\dot{P}
\end{array}\right]=\left[\begin{array}{c}
r-k_{1}e\\
-\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}+g_{\text{new}}\left(t\right)-\beta\text{sgn}\left(e\right)-e-k_{2}r\\
-\text{proj}\left(-\Gamma\left(\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\right)^{\top}r\right)\\
-\lambda_{P}P-r^{\top}g_{\text{new}}\left(t\right)+\beta r^{\top}\text{sgn}\left(e\right)
\end{array}\right]
\]

\end_inset

Lyapunov
\begin_inset Formula 
\[
V=\frac{1}{2}e^{\top}e+\frac{1}{2}r^{\top}r+\frac{1}{2}\widetilde{\theta}^{\top}\Gamma^{-1}\widetilde{\theta}+P
\]

\end_inset

Derivative.
\begin_inset Formula 
\begin{align*}
\dot{V} & =e^{\top}\dot{e}+r^{\top}\dot{r}+\widetilde{\theta}^{\top}\Gamma^{-1}\dot{\widetilde{\theta}}+\dot{P}\\
 & =e^{\top}\left(r-k_{1}e\right)+r^{\top}\left(-\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}+g_{\text{new}}\left(t\right)-\beta\text{sgn}\left(e\right)-e-k_{2}r\right)\\
 & -\lambda_{P}P-r^{\top}g_{\text{new}}\left(t\right)+\beta r^{\top}\text{sgn}\left(e\right)+\widetilde{\theta}^{\top}\Gamma^{-1}\dot{\widetilde{\theta}}\\
\\
 & \le\cancel{e^{\top}r}-k_{1}e^{\top}e-\cancel{r^{\top}\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\widetilde{\theta}}+\cancel{r^{\top}g_{\text{new}}\left(t\right)}-\cancel{\beta r^{\top}\text{sgn}\left(e\right)}-\cancel{r^{\top}e}-k_{2}r^{\top}r\\
 & -\lambda_{P}P-\cancel{r^{\top}g_{\text{new}}\left(t\right)}+\cancel{\beta r^{\top}\text{sgn}\left(e\right)}+\cancel{\widetilde{\theta}^{\top}\left(\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,\dot{x},\widehat{\theta}\right)}\right)^{\top}r}\\
\\
 & \le-k_{1}e^{\top}e-k_{2}r^{\top}r-\lambda_{P}P
\end{align*}

\end_inset

Thus we have asymptotic stability.
 We can stop here.
 That's enough to design the controller.
\end_layout

