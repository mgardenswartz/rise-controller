\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)-\rho_{\varepsilon}\left(0\right)-\rho_{\Phi}\left(0\right)-\rho_{\widehat{\Phi}}\left(0\right) & =\widetilde{N}_{0}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta}\right)+\widetilde{N}_{\varepsilon}\left(\kappa_{d},\kappa\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)-\rho_{\varepsilon}\left(0\right)-\rho_{\Phi}\left(0\right)-\rho_{\widehat{\Phi}}\left(0\right)\\
\left\Vert \widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)-\rho_{\varepsilon}\left(0\right)-\rho_{\Phi}\left(0\right)-\rho_{\widehat{\Phi}}\left(0\right)\right\Vert  & \le\rho_{\widetilde{N_{0}}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\Phi}\left(k_{1},0\right)+\rho_{\widehat{\Phi}}\left(k_{1},0\right)+\rho_{\varepsilon}\left(k_{1},\left\Vert z\right\Vert \right)+\overline{d}\sigma_{\nabla f}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert -\rho_{\varepsilon}\left(k_{1},0\right)-\rho_{\Phi}\left(k_{1},0\right)-\rho_{\widehat{\Phi}}\left(k_{1},0\right)\\
 & \le\rho_{\widetilde{N_{0}}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\cancel{\rho_{\Phi}\left(k_{1},0\right)+\rho_{\widehat{\Phi}}\left(k_{1},0\right)}+\overline{\rho}_{\varepsilon}\left(k_{1},\left\Vert z\right\Vert \right)+\cancel{\rho_{\varepsilon}\left(k_{1},0\right)}+\overline{d}\sigma_{\nabla f}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert -\cancel{\rho_{\varepsilon}\left(k_{1},0\right)-\rho_{\Phi}\left(k_{1},0\right)-\rho_{\widehat{\Phi}}\left(k_{1},0\right)}\\
