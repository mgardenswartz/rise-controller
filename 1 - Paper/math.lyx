.
 Note that
\begin_inset Formula 
\begin{align*}
r & =\dot{e}+k_{1}e\\
\dot{e} & =r-k_{1}e\\
\dot{x}_{d}-\dot{x} & =r-k_{1}e\\
\dot{x}_{d}-\left(f\left(x\right)+u+d\left(t\right)\right) & =r-k_{1}e\\
\dot{x}_{d}-f\left(x\right)-d\left(t\right)+k_{1}e-r & =u\\
u & =\dot{x}_{d}-f\left(x\right)-d\left(t\right)+k_{1}e-r\\
u & =\dot{x}_{d}\underbrace{-f\left(x\right)+f\left(x_{d}\right)}_{N_{f}\left(x_{d},x\right)}-f\left(x_{d}\right)-d\left(t\right)+k_{1}e-r\\
u & =\dot{x}_{d}+N_{f}\left(x_{d},x\right)-f\left(x_{d}\right)-d\left(t\right)+k_{1}e-r
\end{align*}

