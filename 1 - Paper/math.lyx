\end_inset


\begin_inset Formula 
\begin{align*}
\beta\left\Vert e\left(t\right)\right\Vert _{1}-e^{\top}g\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right) & \ge\beta\left\Vert e\left(t\right)\right\Vert _{1}-\left\Vert e\right\Vert \overline{g}\left(k_{1}\right)\\
