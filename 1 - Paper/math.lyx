\begin_layout Subsection
Dynamics
\end_layout

\begin_layout Standard
Consider
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\dot{x}=f\left(x\right)+d\left(t\right)+u\left(t\right)
\]

\end_inset

where 
\begin_inset Formula $f\in\mathcal{C}^{2}$
\end_inset

 and 
\begin_inset Formula $d\in\mathcal{C}^{2}$
\end_inset

, where
\begin_inset Formula 
\begin{align*}
\left\Vert d\right\Vert  & \le\overline{d}\\
\left\Vert \dot{d}\right\Vert  & \le\overline{\dot{d}}\\
\left\Vert \ddot{d}\right\Vert  & \le\overline{\ddot{d}}
\end{align*}

\end_inset

are known constants.
 Errors
\begin_inset Formula 
\begin{align*}
e & \triangleq x_{d}-x\\
r & \triangleq\dot{e}+k_{1}e
\end{align*}

\end_inset

where 
\begin_inset Formula $x_{d}\in\mathcal{C}^{2}$
\end_inset

 and
\begin_inset Formula 
\begin{align*}
\left\Vert x_{d}\right\Vert  & \le\overline{x_{d}}\\
\left\Vert \dot{x}_{d}\right\Vert  & \le\overline{\dot{x}_{d}}\\
\left\Vert \ddot{x_{d}}\right\Vert  & \le\overline{\ddot{x_{d}}}
\end{align*}

\end_inset

are known constants.
 Assume
\begin_inset Formula 
\begin{align*}
\left\Vert \widehat{\theta}\right\Vert  & \le\overline{\theta}\\
\left\Vert \theta^{\ast}\right\Vert  & \le\overline{\theta}\\
\left\Vert \dot{\widehat{\theta}}\right\Vert  & \le\eta_{1}
\end{align*}

\end_inset

are known constants.
 Goal:
\begin_inset Formula 
\begin{align*}
e & \to0\\
r & \to0
\end{align*}

\end_inset

 Write
\begin_inset Formula 
\[
\dot{e}=r-k_{1}e
\]

\end_inset

Let 
\begin_inset Formula 
\begin{align*}
\kappa & \triangleq\left[\begin{array}{cc}
x^{\top} & u^{\top}\end{array}\right]^{\top}\\
\kappa_{d} & \triangleq\left[\begin{array}{cc}
x_{d}^{\top} & u_{d}^{\top}\end{array}\right]^{\top}
\end{align*}

\end_inset

Write
\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{e}+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\ddot{x}+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\frac{d}{dt}\left(f\left(x\right)+d\left(t\right)+u\left(t\right)\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\frac{d}{dt}f\left(x\right)-\dot{d}\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\left.\frac{df}{dx}\right|_{x}\dot{x}-\dot{d}\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\left.\frac{df}{dx}\right|_{x}\left(f\left(x\right)+d\left(t\right)+u\left(t\right)\right)-\dot{d}\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\left.\frac{df}{dx}\right|_{x}f\left(x\right)-\left.\frac{df}{dx}\right|_{x}u\left(t\right)-\dot{d}\left(t\right)-\left.\frac{df}{dx}\right|_{x}d\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\left(\underbrace{\left.\frac{df}{dx}\right|_{x}f\left(x\right)+\left.\frac{df}{dx}\right|_{x}u\left(t\right)}_{h\left(\kappa\right)}\right)-\dot{d}\left(t\right)-\left.\frac{df}{dx}\right|_{x}d\left(t\right)+\left.\frac{df}{dx}\right|_{x_{d}}d\left(t\right)-\left.\frac{df}{dx}\right|_{x_{d}}d\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-h\left(\kappa\right)-\dot{d}\left(t\right)+\left(\underbrace{\left.\frac{df}{dx}\right|_{x_{d}}-\left.\frac{df}{dx}\right|_{x}}_{\widetilde{N}_{\nabla f}\left(x_{d},x\right)}\right)d\left(t\right)-\left.\frac{df}{dx}\right|_{x_{d}}d\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-h\left(\kappa\right)-\dot{d}\left(t\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)-\left.\frac{df}{dx}\right|_{x_{d}}d\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}
\end{align*}

\end_inset

NN
\begin_inset Formula 
\begin{align*}
\varepsilon\left(\kappa\right) & \triangleq h\left(\kappa\right)-\Phi\left(\kappa,\theta^{\ast}\right)
\end{align*}

\end_inset

where 
\begin_inset Formula $\Phi$
\end_inset

 is of class 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

 (jointly so).
 Thus, 
\begin_inset Formula $\varepsilon$
\end_inset

 is of class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 since 
\begin_inset Formula $\frac{df}{dx}$
\end_inset

 is of class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

.
 Introduce
\begin_inset Formula 
\[
u_{d}=\dot{x}_{d}-f\left(x_{d}\right)-d\left(t\right)
\]

\end_inset

which is the ideal controller to keep the controller on the desired trajectory.
 Thus,
\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{x}_{d}-\Phi\left(\kappa,\theta^{\ast}\right)-\varepsilon\left(\kappa\right)-\dot{d}\left(t\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)-\left.\frac{df}{dx}\right|_{x_{d}}d\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\Phi\left(\kappa,\theta^{\ast}\right)\underbrace{+\varepsilon\left(\kappa_{d}\right)-\varepsilon\left(\kappa\right)}_{\widetilde{N}_{\varepsilon}\left(\kappa_{d},\kappa\right)}-\varepsilon\left(\kappa_{d}\right)-\dot{d}\left(t\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)-\left.\frac{df}{dx}\right|_{x_{d}}d\left(t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\Phi\left(\kappa,\theta^{\ast}\right)+\widetilde{N}_{\varepsilon}\left(\kappa_{d},\kappa\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)\underbrace{-\varepsilon\left(\kappa_{d}\right)-\dot{d}\left(t\right)-\left.\frac{df}{dx}\right|_{x_{d}}d\left(t\right)}_{D_{0}\left(\kappa_{d},t\right)}-\dot{u}\left(t\right)+k_{1}\dot{e}\\
 & =\ddot{x}_{d}-\Phi\left(\kappa,\theta^{\ast}\right)+\widetilde{N}_{\varepsilon}\left(\kappa_{d},\kappa\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)+D_{0}\left(\kappa_{d},t\right)-\dot{u}\left(t\right)+k_{1}\dot{e}
\end{align*}

\end_inset

Let
\begin_inset Formula 
\[
{\color{green}\dot{u}=k_{2}r+\ddot{x}_{d}-\Phi\left(\kappa,\widehat{\theta}\right)+k_{1}\dot{e}+\beta\text{sgn}\left(e\right)+e}
\]

\end_inset

So,
\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{x}_{d}-\Phi\left(\kappa,\theta^{\ast}\right)+\widetilde{N}_{\varepsilon}\left(\kappa_{d},\kappa\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)+D_{0}\left(\kappa_{d},t\right)-\left(k_{2}r+\ddot{x}_{d}-\Phi\left(\kappa,\widehat{\theta}\right)+k_{1}\dot{e}+\beta\text{sgn}\left(e\right)+e\right)+k_{1}\dot{e}\\
 & =\cancel{\ddot{x}_{d}}-\Phi\left(\kappa,\theta^{\ast}\right)+\widetilde{N}_{\varepsilon}\left(\kappa_{d},\kappa\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)+D_{0}\left(\kappa_{d},t\right)-k_{2}r-\cancel{\ddot{x}_{d}}+\Phi\left(\kappa,\widehat{\theta}\right)-\cancel{k_{1}\dot{e}}-\beta\text{sgn}\left(e\right)-e+\cancel{k_{1}\dot{e}}\\
 & =\underbrace{\Phi\left(\kappa,\widehat{\theta}\right)-\Phi\left(\kappa,\theta^{\ast}\right)}_{N_{B}\left(\kappa,\theta^{\ast},\widehat{\theta}\right)}+\widetilde{N}_{\varepsilon}\left(\kappa_{d},\kappa\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)+D_{0}\left(\kappa_{d},t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =\underbrace{N_{B}\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-N_{B}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)}_{\widetilde{N}_{0}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta}\right)}+N_{B}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)+\widetilde{N}_{\varepsilon}\left(\kappa_{d},\kappa\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)+D_{0}\left(\kappa_{d},t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =N_{B}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)+\underbrace{\widetilde{N}_{0}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta}\right)+\widetilde{N}_{\varepsilon}\left(\kappa_{d},\kappa\right)+\widetilde{N}_{\nabla f}\left(x_{d},x\right)d\left(t\right)}_{\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)}+D_{0}\left(\kappa_{d},t\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =N_{B}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)+\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)+\underbrace{D_{0}\left(\kappa_{d},t\right)+\rho_{\varepsilon}\left(k_{1},0\right)+\rho_{\Phi}\left(k_{1},0\right)+\rho_{\widehat{\Phi}}\left(k_{1},0\right)}_{D\left(k_{1},\kappa_{d},t\right)}-\rho_{\varepsilon}\left(k_{1},0\right)-\rho_{\Phi}\left(k_{1},0\right)-\rho_{\widehat{\Phi}}\left(k_{1},0\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)+\underbrace{N_{B}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)+D\left(k_{1},\kappa_{d},t\right)}_{g\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)}-\rho_{\varepsilon}\left(k_{1},0\right)-\rho_{\Phi}\left(k_{1},0\right)-\rho_{\widehat{\Phi}}\left(k_{1},0\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e\\
 & =\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)+g\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)-\rho_{\varepsilon}\left(k_{1},0\right)-\rho_{\Phi}\left(k_{1},0\right)-\rho_{\widehat{\Phi}}\left(k_{1},0\right)-k_{2}r-\beta\text{sgn}\left(e\right)-e
\end{align*}

\end_inset

Let 
\begin_inset Formula $K[]$
\end_inset

 denote the Krasovskii regularization (or Filippov, doesn't matter here).
 Regularizing the above so we can study Filippov solutions to the resulting
 ensemble differential inclusion:
\begin_inset Formula 
\[
\dot{r}\overset{\text{a.a.t}}{\in}\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)+g\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)-\rho_{\varepsilon}\left(k_{1},0\right)-\rho_{\Phi}\left(k_{1},0\right)-\rho_{\widehat{\Phi}}\left(k_{1},0\right)-k_{2}r-\beta K[\text{sgn}]\left(e\right)-e
\]

\end_inset


\end_layout

