Thus, we can also write
\begin_inset Formula 
\begin{align*}
\rho_{\varepsilon_{0}}\left(k_{1},s\right) & =\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)\\
 & =\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)s+\left(\overline{u}_{d}+\overline{\rho}_{u}\left(k_{1},s\right)+\rho_{u}\left(0\right)\right)\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)\\
 & =\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)s+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)+\overline{\rho}_{u}\left(k_{1},s\right)\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)\\
 & =\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)s+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)+\overline{\rho}_{u}\left(k_{1},s\right)\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)\\
\\
 & =\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)s+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)+\overline{\rho}_{u}\left(k_{1},s\right)\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)\\
 & -\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\sigma_{\varepsilon}\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\sigma_{\varepsilon}\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\\
\\
 & =\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)s+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\left(\underbrace{\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)-\sigma_{\varepsilon}\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)}_{\alpha_{a}\left(k_{1},s\right)}\right)+\overline{\rho}_{u}\left(k_{1},s\right)\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)\\
 & +\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\sigma_{\varepsilon}\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\\
\\
 & \le\underbrace{\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)s+\alpha_{f}\left(k_{1},s\right)\sigma_{\varepsilon}\left(s+\overline{u}_{d}+\rho_{u}\left(k_{1},s\right)\right)s+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\alpha_{a}\left(k_{1},s\right)+\underbrace{\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\sigma_{\varepsilon}\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)}_{\text{y-intercept}}}_{\rho_{\varepsilon}\left(s\right)}
\end{align*}

