\begin_layout Lemma
\begin_inset CommandInset label
LatexCommand label
name "lem:strictly-increasing"

\end_inset

 Let 
\begin_inset Formula $a_{8}\in\overline{\mathbb{R}}_{>0}$
\end_inset

 and let 
\begin_inset Formula $\sigma_{2}:\left[0,a_{8}\right)\to\mathbb{R}_{\geq0}$
\end_inset

 be a continuous, non-decreasing function.
 Let 
\begin_inset Formula $\rho_{2}\left(s\right)\triangleq\sigma_{2}\left(s\right)+cs$
\end_inset

 for all 
\begin_inset Formula $s\in\left[0,a_{8}\right)$
\end_inset

 where 
\begin_inset Formula $c\in\mathbb{R}_{>0}$
\end_inset

 is a user-defined constant.
 Consequently, 
\begin_inset Formula $\sigma_{2}\left(s\right)\leq\rho_{2}\left(s\right)$
\end_inset

 for all 
\begin_inset Formula $s\in\left[0,a_{8}\right)$
\end_inset

 and 
\begin_inset Formula $\rho_{2}\in\mathcal{P}$
\end_inset

.
 If 
\begin_inset Formula $a_{8}=\infty$
\end_inset

, 
\begin_inset Formula $\rho_{2}\in\mathcal{P}_{\infty}.$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Lemma
\begin_inset CommandInset label
LatexCommand label
name "lem:power-reduction"

\end_inset

 Let 
\begin_inset Formula $a_{13}\in\overline{\mathbb{R}}_{>0}$
\end_inset

.
 For all class 
\begin_inset Formula $\mathcal{K}$
\end_inset

 functions 
\begin_inset Formula $\rho_{13}:\left[0,a_{13}\right)\to\mathbb{R}_{\ge0}$
\end_inset

 such that the right-hand derivative at the origin, 
\begin_inset Formula $\rho_{13}^{\prime}\left(0^{+}\right)\in\mathbb{R}_{\geq0}$
\end_inset

, exists and is finite, there exists a 
\begin_inset Formula $\rho_{14}\in\mathcal{P}$
\end_inset

 such that 
\begin_inset Formula $\rho_{13}\left(s\right)\leq\rho_{14}\left(s\right)s$
\end_inset

 for all 
\shape up

\begin_inset Formula $s\in\left[0,a_{13}\right)$
\end_inset


\shape default
.
 If 
\begin_inset Formula $\rho_{13}^{\prime}\left(0^{+}\right)=0$
\end_inset

, 
\begin_inset Formula $\rho_{14}\in\mathcal{K}$
\end_inset

.
 If 
\begin_inset Formula $a_{13}=\infty$
\end_inset

, 
\begin_inset Formula $\rho_{14}\in\mathcal{P}_{\infty}$
\end_inset

.
 If both are true, 
\begin_inset Formula $\rho_{14}\in\mathcal{K}_{\infty}$
\end_inset

.
 Let 
\begin_inset Formula $g_{1}:\left[0,a_{13}\right)\to\mathbb{R}_{\ge0}$
\end_inset

 be defined as
\begin_inset Formula 
\[
g_{1}\left(s\right)\triangleq\begin{cases}
\frac{\rho_{13}\left(s\right)}{s} & s\in\left(0,a_{13}\right),\\
\rho_{13}^{\prime}\left(0^{+}\right) & s=0.
\end{cases}
\]

\end_inset

Suppose 
\begin_inset Formula $a_{13}=\infty$
\end_inset

.
 In this case, define 
\begin_inset Formula $\rho_{14}:\left[0,a_{13}\right)\to\mathbb{R}_{\ge0}$
\end_inset

 as 
\begin_inset Formula $\rho_{14}\left(s\right)\triangleq\underset{\zeta\in\left[0,s\right]}{\sup}g_{1}\left(\zeta\right)+c_{8}s+c_{9}$
\end_inset

 for all 
\begin_inset Formula $s\in\left[0,a_{13}\right)$
\end_inset

 and for user-defined constants, 
\begin_inset Formula $c_{8}\in\mathbb{R}_{>0}$
\end_inset

 and 
\begin_inset Formula $c_{9}\in\mathbb{R}_{\geq0}$
\end_inset

.
 Suppose 
\begin_inset Formula $a_{13}\in\mathbb{R}_{>0}$
\end_inset

 (i.e., 
\begin_inset Formula $a_{13}$
\end_inset

 is finite).
 In this case, define 
\begin_inset Formula $\rho_{14}:\left[0,a_{13}\right)\to\mathbb{R}_{\ge0}$
\end_inset

 as 
\begin_inset Formula $\rho_{14}\left(s\right)\triangleq\underset{\zeta\in\left[0,s\right]}{\sup}\left(g_{1}\left(\zeta\right)\right)+\frac{c_{6}s}{a_{13}-s}+c_{7}$
\end_inset

 for all 
\begin_inset Formula $s\in\left[0,a_{13}\right)$
\end_inset

 and for some user-defined constants, 
\begin_inset Formula $c_{6}\in\mathbb{R}_{>0}$
\end_inset

 and 
\begin_inset Formula $c_{7}\in\mathbb{R}_{\geq0}$
\end_inset

.
\end_layout

