 in fact), by Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:non-decreasing-continuous-bound"
plural "false"
caps "false"
noprefix "false"

\end_inset

, there exists a 
\begin_inset Formula $\mathcal{C}^{0}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 in fact) nondecreasing function 
\begin_inset Formula $\sigma_{f}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that
\begin_inset Formula 
\begin{align*}
\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert  & \le\sigma_{f}\left(\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \\
\sigma_{f}\left(s\right) & \triangleq\sup_{\left[\begin{array}{cc}
q^{\top} & \dot{q}^{\top}\end{array}\right]^{\top}\in\overline{B}_{\overline{q}_{d}+\overline{\dot{q}}_{d}+s}\left(0_{2n}\right)}\left(\left\Vert \left.\frac{df}{d\left[\begin{array}{cc}
q^{\top} & \dot{q}^{\top}\end{array}\right]^{\top}}\right|_{\left(q,\dot{q}\right)}\right\Vert \right)
\end{align*}

\end_inset

By Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:strictly-increasing"
plural "false"
caps "false"
noprefix "false"

\end_inset

, there exists a class 
\begin_inset Formula $\mathcal{P}_{\infty}$
\end_inset

 function 
\begin_inset Formula $\rho_{f}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that (for some 
\begin_inset Formula $c>0$
\end_inset

)
\begin_inset Formula 
\begin{align*}
\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert  & \le\rho_{f}\left(\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \\
\rho_{f}\left(s\right) & \triangleq\sigma_{f}\left(s\right)+cs
\end{align*}

\end_inset

By Bounding Lemma 1.1,
\begin_inset Formula 
\begin{align*}
\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert  & \le\rho_{f}\left(\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \\
 & \le\underbrace{\rho_{f}\left(\left(k_{1}+1\right)\left\Vert z\right\Vert \right)\left(k_{1}+1\right)}_{\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)}\left\Vert z\right\Vert \\
 & \le\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


