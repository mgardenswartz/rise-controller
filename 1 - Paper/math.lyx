\begin_layout Plain Layout
Dynamics
\begin_inset Formula 
\[
\dot{x}=Y\left(x\right)\theta^{\ast}+u
\]

\end_inset

Errors
\begin_inset Formula 
\begin{align*}
e & \triangleq x-x_{d}\\
\widetilde{\theta} & \triangleq\theta^{\ast}-\widehat{\theta}
\end{align*}

\end_inset

Controller
\begin_inset Formula 
\[
u=\dot{x}_{d}-k_{1}e-Y\left(x\right)\widehat{\theta}
\]

\end_inset

Design the filter.
\end_layout

\begin_layout Itemize
\begin_inset Formula $W\left(s\right)=\frac{\lambda}{\lambda+s}$
\end_inset

 where 
\begin_inset Formula $\lambda\in\mathbb{R}_{>0}$
\end_inset

 
\begin_inset Formula ${\rm rad/s}$
\end_inset

 is the cutoff frequency.
 Thus, 
\begin_inset Formula $\dot{z}_{f}=-\lambda z_{f}+\lambda z$
\end_inset

.
 Write:
\begin_inset Formula 
\begin{align*}
W\left(s\right)[Y\left(x\right)\theta^{\ast}] & =W\left(s\right)[\dot{x}-u]\\
Y_{f}\theta^{\ast} & =\dot{x}_{f}-W\left(s\right)u
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
From the filter definition:
\begin_inset Formula 
\begin{align*}
sX_{f}\left(s\right) & =\frac{\lambda s}{\lambda+s}X\left(s\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
Use
\begin_inset Formula 
\begin{align*}
\frac{s}{s+\lambda} & =\frac{s+\lambda}{s+\lambda}-\frac{\lambda}{s+\lambda}\\
 & =1-\frac{\lambda}{s+\lambda}
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
Then,
\begin_inset Formula 
\begin{align*}
sX_{f}\left(s\right) & =\lambda\left(1-\frac{\lambda}{s+\lambda}\right)X\left(s\right)\\
\dot{x}_{f} & =\lambda\left(x-x_{f}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Itemize
Back to the dynamics
\begin_inset Formula 
\[
Y_{f}\theta^{\ast}=\underbrace{\lambda\left(x-x_{f}\right)-\underbrace{W\left(s\right)u}_{u_{1}}}_{u_{f}}
\]

\end_inset


\end_layout

\begin_layout Itemize
The filters is implemented as (effectively a dirty derivative)
\begin_inset Formula 
\begin{align*}
\dot{x}_{f} & =\lambda\left(x-x_{f}\right)\\
u_{f} & =\lambda\left(x-x_{f}\right)-u_{1}
\end{align*}

\end_inset

where
\begin_inset Formula 
\[
\dot{u}_{1}=\lambda\left(u-u_{1}\right)\;u_{1}\left(t_{0}\right)=\boldsymbol{0}_{n}
\]

\end_inset


\end_layout

\begin_layout Itemize
The most important fact is:
\begin_inset Formula 
\[
u_{f}=Y_{f}\theta^{\ast}
\]

\end_inset


\end_layout

\begin_layout Plain Layout
Dynamics
\begin_inset Formula 
\begin{align*}
\dot{e} & =\dot{x}-\dot{x}_{d}\\
 & =Y\left(x\right)\theta^{\ast}-\dot{x}_{d}+u\\
 & =Y\left(x\right)\widetilde{\theta}-k_{1}e
\end{align*}

\end_inset

Lyapunov
\begin_inset Formula 
\[
V=\frac{1}{2}e^{\top}e+\frac{1}{2}\widetilde{\theta}^{\top}\Gamma^{-1}\widetilde{\theta}
\]

\end_inset

Let
\begin_inset Formula 
\begin{align*}
\dot{\widehat{\theta}} & =\Gamma Y^{\top}e+k_{c}\frac{\Gamma Y_{f}^{\top}\left(u_{f}-Y_{f}\widehat{\theta}\right)}{1+\nu\left\Vert Y_{f}\right\Vert ^{2}}
\end{align*}

\end_inset

Parameter error dynamics
\begin_inset Formula 
\begin{align*}
\dot{\widetilde{\theta}} & =\cancelto{0}{\dot{\theta}^{\ast}}-\dot{\widehat{\theta}}\\
 & =-\Gamma Y^{\top}e-k_{c}\frac{\Gamma Y_{f}^{\top}\left(u_{f}-Y_{f}\widehat{\theta}\right)}{1+\nu\left\Vert Y_{f}\right\Vert ^{2}}
\end{align*}

\end_inset

Derivative
\begin_inset Formula 
\begin{align*}
\dot{V} & =e^{\top}\left(Y\left(x\right)\widetilde{\theta}-k_{1}e\right)+\widetilde{\theta}^{\top}\Gamma^{-1}\dot{\widetilde{\theta}}\\
 & =e^{\top}Y\widetilde{\theta}-k_{1}e^{\top}e+\widetilde{\theta}^{\top}\Gamma^{-1}\left(-\Gamma Y^{\top}e-k_{c}\frac{\Gamma Y_{f}^{\top}\left(u_{f}-Y_{f}\widehat{\theta}\right)}{1+\nu\left\Vert Y_{f}\right\Vert ^{2}}\right)\\
 & =-k_{1}\left\Vert e\right\Vert ^{2}-\frac{k_{c}}{1+\nu\left\Vert Y_{f}\right\Vert ^{2}}\widetilde{\theta}^{\top}Y_{f}^{\top}\left(u_{f}-Y_{f}\widehat{\theta}\right)
\end{align*}

\end_inset

Using the fact that 
\begin_inset Formula $u_{f}=Y_{f}\theta^{\ast}$
\end_inset

 gives
\begin_inset Formula 
\begin{align*}
\dot{V} & \le-k_{1}\left\Vert e\right\Vert ^{2}-\frac{k_{c}}{1+\nu\left\Vert Y_{f}\right\Vert ^{2}}\widetilde{\theta}^{\top}Y_{f}^{\top}\left(Y_{f}\theta^{\ast}-Y_{f}\widehat{\theta}\right)\\
 & \le-k_{1}\left\Vert e\right\Vert ^{2}-\frac{k_{c}}{1+\nu\left\Vert Y_{f}\right\Vert ^{2}}\widetilde{\theta}^{\top}Y_{f}^{\top}Y_{f}\widetilde{\theta}
\end{align*}

\end_inset

Assume that 
\begin_inset Formula $Y_{f}$
\end_inset

 is 
\bar under
u-PE
\bar default
:
\begin_inset Formula 
\[
-\widetilde{\theta}^{\top}Y_{f}^{\top}Y_{f}\widetilde{\theta}\le-\alpha\widetilde{\theta}^{\top}\widetilde{\theta}
\]

\end_inset

Continuing we have
\begin_inset Formula 
\begin{align*}
\dot{V} & \le-k_{1}\left\Vert e\right\Vert ^{2}-\frac{k_{c}\alpha}{1+\nu\left\Vert Y_{f}\right\Vert ^{2}}\left\Vert \mathcal{\widetilde{\theta}}\right\Vert ^{2}
\end{align*}

\end_inset

Uniformity is guaranteed only it the excitation is uniform.
 
\series bold
\bar under
Only then do we have UGES
\series default
\bar default
.
\end_layout

\end_inset


\end_layout

