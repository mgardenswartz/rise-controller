, 
\begin_inset Formula $\left(q,\dot{q}\right)\mapsto f\left(q,\dot{q},u\right)$
\end_inset

 is one-on-one/injective and (iv) for any fixed 
\begin_inset Formula $\left(q,\dot{q}\right)$
\end_inset

, 
\begin_inset Formula $\lim_{\left\Vert u\right\Vert \to\infty}\left\Vert f\left(q,\dot{q},u\right)\right\Vert =\infty$
\end_inset

 (
\begin_inset Formula $u\mapsto f\left(q,\dot{q},u\right)$
\end_inset

 is coercive), it follows that 
\begin_inset Formula $u\mapsto f\left(q,\dot{q},u\right)$
\end_inset

 is a global homeomorphism by Brouwer's Invariance of Domain.
 Thus, a continuous inverse mapping exists.
 Thus, 
\begin_inset Formula $u_{d}$
\end_inset

 is continuous.
 However, we need 
\begin_inset Formula $u_{d}$
\end_inset

 to be 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

.
 We need a global diffeomorphism.
\end_layout

\end_inset

 Since (i) 
\begin_inset Formula $f$
\end_inset

 is jointly 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

, (ii) 
\begin_inset Formula $\ddot{q}_{d}-d$
\end_inset

 is 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

(since 
\begin_inset Formula $q_{d}\in\mathcal{C}^{3}$
\end_inset

, 
\begin_inset Formula $h\in\mathcal{C}^{1}$
\end_inset

, 
\begin_inset Formula $d\in\mathcal{C}^{1}$
\end_inset

), (iii) 
\begin_inset Formula $\frac{\partial f}{\partial u}$
\end_inset

 is full row rank everywhere, (iv) for any fixed 
\begin_inset Formula $\left(q,\dot{q}\right)$
\end_inset

, 
\begin_inset Formula $\lim_{\left\Vert u\right\Vert \to\infty}\left\Vert f\left(q,\dot{q},u\right)\right\Vert =\infty$
\end_inset

 (
\begin_inset Formula $u\mapsto f\left(q,\dot{q},u\right)$
\end_inset

 is coercive), it follows that 
\begin_inset Formula $u\mapsto f\left(q,\dot{q},u\right)$
\end_inset

 is a global diffeomorphism by the Hadamard Global Inverse Theorem.
 Recall 
\begin_inset Formula $u_{d}$
\end_inset

 satisfies
\begin_inset Formula 
\[
\ddot{q}_{d}=d\left(t\right)+f\left(q_{d},\dot{q}_{d},u_{d}\right)
\]

\end_inset

Write
\begin_inset Formula 
\[
u_{d}=\phi\left(q_{d},\dot{q}_{d},\ddot{q}_{d}-d\left(t\right)\right)
\]

\end_inset

Since 
\begin_inset Formula $\phi$
\end_inset

 is 
\begin_inset Formula $\mathcal{C}^{0}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 in fact) and 
\begin_inset Formula $\mathcal{X}$
\end_inset

 is compact, by EVT, it follows that there exists an 
\color red
unknown
\color inherit
 constant 
\begin_inset Formula $\overline{u}_{d}$
\end_inset

 such that
\begin_inset Formula 
\[
\left\Vert u_{d}\right\Vert \le\overline{u}_{d}
\]

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 1.2
\end_layout

\begin_layout Plain Layout
Recall 
\begin_inset Formula $u_{d}$
\end_inset

 satisfies
\begin_inset Formula 
\[
\ddot{q}_{d}=d\left(t\right)+f\left(q_{d},\dot{q}_{d},u_{d}\right)
\]

\end_inset

Thus, differentiating gives
\begin_inset Formula 
\[
\dddot{q}_{d}=\dot{d}\left(t\right)+\left.\frac{\partial f}{\partial q}\right|_{\left(q_{d},\dot{q}_{d},u_{d}\right)}\dot{q}_{d}+\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d},u_{d}\right)}\ddot{q}_{d}+\underbrace{\left.\frac{\partial f}{\partial u}\right|_{\left(q_{d},\dot{q}_{d},u_{d}\right)}}_{G\left(q_{d},\dot{q}_{d},u_{d}\right)}\dot{u}_{d}
\]

\end_inset

Since 
\begin_inset Formula $f$
\end_inset

 is jointly 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 and 
\begin_inset Formula $\frac{\partial f}{\partial u}$
\end_inset

 is full row rank everywhere, 
\begin_inset Formula $\left(\frac{\partial f}{\partial u}\right)^{+}$
\end_inset

 acts as a right inverse and is continuous everywhere.
 Thus,
\begin_inset Formula 
\[
\dot{u}_{d}=\left(G\left(q_{d},\dot{q}_{d},u_{d}\right)\right)^{+}\left(\dddot{q}_{d}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d},u_{d}\right)}\ddot{q}_{d}-\left.\frac{\partial f}{\partial q}\right|_{\left(q_{d},\dot{q}_{d},u_{d}\right)}\dot{q}_{d}-\dot{d}\left(t\right)\right)
\]

\end_inset

Since 
\begin_inset Formula $u_{d}$
\end_inset

 is bounded and 
\begin_inset Formula $f$
\end_inset

 is 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

 in fact) by EVT, it follows that there exists an 
\color red
unknown
\color inherit
 constant 
\begin_inset Formula $\overline{\dot{u}}_{d}$
\end_inset

 such that
\begin_inset Formula 
\[
\left\Vert \dot{u}_{d}\right\Vert \le\overline{\dot{u}}_{d}
\]

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 1.3
\end_layout

\begin_layout Plain Layout
Recall 
\begin_inset Formula $u_{d}$
\end_inset

 satisfies
\begin_inset Formula 
\[
\ddot{q}_{d}=d\left(t\right)+f\left(q_{d},\dot{q}_{d},u_{d}\right)
\]

\end_inset

Recall 
\begin_inset Formula $u$
\end_inset

 satisfies
\begin_inset Formula 
\[
\ddot{q}=d\left(t\right)+f\left(q,\dot{q},u\right)
\]

\end_inset

Subtract them
\begin_inset Formula 
\begin{align*}
\ddot{q}_{d}-\ddot{q} & =\cancel{d\left(t\right)-d\left(t\right)}+f\left(q_{d},\dot{q}_{d},u_{d}\right)-f\left(q,\dot{q},u\right)\\
\ddot{e} & =f\left(q_{d},\dot{q}_{d},u_{d}\right)-f\left(q,\dot{q},u\right)
\end{align*}

\end_inset

Let 
\begin_inset Formula $v_{d}\triangleq\left[\begin{array}{ccc}
q_{d}^{\top} & \dot{q}_{d}^{\top} & u_{d}^{\top}\end{array}\right]^{\top}$
\end_inset

 and 
\begin_inset Formula $v\triangleq\left[\begin{array}{ccc}
q^{\top} & \dot{q}^{\top} & u^{\top}\end{array}\right]^{\top}$
\end_inset

.
 For each element of 
\begin_inset Formula $\ddot{e}$
\end_inset

, there exists a scalar 
\begin_inset Formula $c_{i}\in\left[0,1\right]$
\end_inset

 on the line 
\begin_inset Formula $\gamma\left(\lambda\right)\triangleq v_{d}\left(1-\lambda\right)+\lambda v$
\end_inset

 where 
\begin_inset Formula $\lambda\in\left[0,1\right]$
\end_inset

.
 Use mean value theorem.
\begin_inset Formula 
\begin{align*}
f\left(q_{d},\dot{q}_{d},u_{d}\right)-f\left(q,\dot{q},u\right) & =\left.\frac{\partial f}{\partial q}\right|_{\gamma\left(c_{i}\right)}\left(\dot{q}_{d}-\dot{q}\right)+\left.\frac{\partial f}{\partial\dot{q}}\right|_{\gamma\left(c_{i}\right)}\left(\ddot{q}_{d}-\ddot{q}\right)+\left.\frac{\partial f}{\partial u}\right|_{\gamma\left(c_{i}\right)}\left(u_{d}-u\right)\\
 & =\left.\frac{\partial f}{\partial q}\right|_{\gamma\left(c_{i}\right)}\dot{e}+\left.\frac{\partial f}{\partial\dot{q}}\right|_{\gamma\left(c_{i}\right)}\ddot{e}+\underbrace{\left.\frac{\partial f}{\partial u}\right|_{\gamma\left(c_{i}\right)}}_{G\left(\gamma\left(c_{i}\right)\right)}\widetilde{u}
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\[
\ddot{e}=\left.\frac{\partial f}{\partial q}\right|_{\gamma\left(c_{i}\right)}\dot{e}+\left.\frac{\partial f}{\partial\dot{q}}\right|_{\gamma\left(c_{i}\right)}\ddot{e}+G\left(\gamma\left(c_{i}\right)\right)\widetilde{u}
\]

\end_inset

Isolate 
\begin_inset Formula $\widetilde{u}$
\end_inset

.
\begin_inset Formula 
\begin{align*}
G\left(\gamma\left(c_{i}\right)\right)\widetilde{u} & =\ddot{e}-\left.\frac{\partial f}{\partial q}\right|_{\gamma\left(c_{i}\right)}\dot{e}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\gamma\left(c_{i}\right)}\ddot{e}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 1.4
\end_layout

\begin_layout Plain Layout
Recall
\begin_inset Formula 
\begin{align*}
\kappa & \triangleq\left[\begin{array}{ccccc}
q^{\top} & \dot{q}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{4n+m}\\
\widetilde{u} & \triangleq u_{d}-u\\
\kappa_{d} & \triangleq\left[\begin{array}{ccccc}
q_{d}^{\top} & \dot{q}_{d}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u_{d}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{4n+m}
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\[
\kappa_{d}-\kappa=\left[\begin{array}{ccccc}
e^{\top} & \dot{e}^{\top} & 0_{1\times n} & 0_{1\times n} & \widetilde{u}^{\top}\end{array}\right]^{\top}
\]

\end_inset

and
\begin_inset Formula 
\begin{align*}
\left\Vert \kappa_{d}-\kappa\right\Vert  & \le\left\Vert \left[\begin{array}{ccccc}
e^{\top} & \dot{e}^{\top} & 0_{1\times n} & 0_{1\times n} & \widetilde{u}^{\top}\end{array}\right]^{\top}\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert \dot{e}\right\Vert +\left\Vert \widetilde{u}\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert r_{1}-k_{1}e\right\Vert +\left\Vert \widetilde{u}\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert r_{1}\right\Vert +k_{1}\left\Vert e\right\Vert +\left\Vert \widetilde{u}\right\Vert \\
 & \le\left\Vert z\right\Vert +\left\Vert z\right\Vert +k_{1}\left\Vert z\right\Vert +\left\Vert \widetilde{u}\right\Vert \\
 & \le\left(k_{1}+2\right)\left\Vert z\right\Vert +\left\Vert \widetilde{u}\right\Vert 
\end{align*}

\end_inset


\end_layout

