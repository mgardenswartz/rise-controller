.
\begin_inset Formula 
\begin{align*}
e^{\top}\left(t\right)\dot{g}\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)+\left(k_{1}-\lambda_{P}\right)\zeta\left(k_{1},t\right) & =e^{\top}\left(t\right)\dot{g}\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)+c_{2}\zeta\left(k_{1},t\right)\\
