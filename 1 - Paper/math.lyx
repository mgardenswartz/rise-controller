\dot{g}\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right) & =\frac{d}{dt}\left(N_{B}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)+D\left(k_{1},\kappa_{d},t\right)\right)\\
