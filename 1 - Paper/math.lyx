 & =\frac{d}{dt}\left(\Phi\left(\kappa_{d},\widehat{\theta}\right)-\Phi\left(\kappa_{d},\theta^{\ast}\right)-\varepsilon\left(\kappa_{d}\right)-\dot{d}\left(t\right)-\left.\frac{df}{dx}\right|_{x_{d}}d\left(t\right)\right)\\
 & =\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}\dot{\kappa}_{d}+\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}\dot{\widehat{\theta}}-\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\theta^{\ast}\right)}\dot{\kappa}_{d}-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{d},\theta^{\ast}\right)}\cancelto{0_{p}}{\dot{\theta}^{\ast}}-\left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa_{d}}\dot{\kappa}_{d}-\ddot{d}\left(t\right)-\left.\frac{d^{2}f}{dx^{2}}\right|_{x_{d}}\dot{x}_{d}\left(t\right)d\left(t\right)-\left.\frac{df}{dx}\right|_{x_{d}}\dot{d}\left(t\right)\\
 & =\left\Vert \left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}-\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\theta^{\ast}\right)}\right\Vert \left\Vert \dot{\widehat{\theta}}\right\Vert +\left\Vert \left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}\right\Vert \left\Vert \dot{\kappa}_{d}\right\Vert +\left\Vert \left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa_{d}}\right\Vert \left\Vert \dot{\kappa}_{d}\right\Vert +\left\Vert \ddot{d}\left(t\right)\right\Vert +\left\Vert \left.\frac{d^{2}f}{dx^{2}}\right|_{x_{d}}\right\Vert \left\Vert \dot{x}_{d}\left(t\right)\right\Vert \left\Vert d\left(t\right)\right\Vert +\left\Vert \left.\frac{df}{dx}\right|_{x_{d}}\right\Vert \left\Vert \dot{d}\left(t\right)\right\Vert \\
 & =\left\Vert \left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}-\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{d},\theta^{\ast}\right)}\right\Vert \eta_{1}+\left\Vert \left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{d},\widehat{\theta}\right)}\right\Vert \overline{\dot{\kappa}_{d}}+\left\Vert \left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa_{d}}\right\Vert \overline{\dot{\kappa}_{d}}+\overline{\ddot{d}}+\left\Vert \left.\frac{d^{2}f}{dx^{2}}\right|_{x_{d}}\right\Vert \overline{\dot{x}}_{d}\overline{d}+\left\Vert \left.\frac{df}{dx}\right|_{x_{d}}\right\Vert \overline{\dot{d}}
