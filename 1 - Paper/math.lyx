\begin_layout Subsection
Stability Analysis
\end_layout

\begin_layout Standard
Let
\begin_inset Formula 
\[
V=\frac{1}{2}e^{\top}e+\frac{1}{2}r^{\top}r+P
\]

\end_inset

which we assure is PD with a gain condition to ensure to 
\begin_inset Formula $P\ge0$
\end_inset

 for almost all 
\begin_inset Formula $t\ge0$
\end_inset

.
 Let
\begin_inset Formula 
\[
\dot{P}\overset{\text{a.a.t}}{\in}-\lambda_{P}P-r^{\top}\left(g\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)-\beta K[\text{sgn}]\left(e\right)\right)
\]

\end_inset

where 
\begin_inset Formula $\text{sgn}\left(0\right)=0$
\end_inset

.
 The trajectory derivative is:
\begin_inset Formula 
\begin{align*}
\dot{V} & =e^{\top}\dot{e}+r^{\top}\dot{r}+\dot{P}\\
 & =e^{\top}\left(r-k_{1}e\right)+r^{\top}\left(\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)-\rho_{\varepsilon}\left(k_{1},0\right)-\rho_{\Phi}\left(k_{1},0\right)-\rho_{\widehat{\Phi}}\left(k_{1},0\right)+g\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)-k_{2}r-\beta K[\text{sgn}]\left(e\right)-e\right)\\
 & -\lambda_{P}P-r^{\top}\left(g\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)-\beta K[\text{sgn}]\left(e\right)\right)\\
\\
 & =\cancel{e^{\top}r}-k_{1}e^{\top}e+r^{\top}\left(\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)-\rho_{\varepsilon}\left(k_{1},0\right)-\rho_{\Phi}\left(k_{1},0\right)-\rho_{\widehat{\Phi}}\left(k_{1},0\right)\right)+\cancel{r^{\top}g\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)}-k_{2}r^{\top}r-\cancel{\beta r^{\top}K[\text{sgn}]\left(e\right)}-\cancel{r^{\top}e}\\
 & -\lambda_{P}P-\cancel{r^{\top}g\left(k_{1},\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)}+\cancel{\beta r^{\top}K[\text{sgn}]\left(e\right)}\\
\\
 & \underset{a.e.}{\le}-k_{1}\left\Vert e\right\Vert ^{2}-k_{2}\left\Vert r\right\Vert ^{2}-\lambda_{P}P+\left\Vert r\right\Vert \left\Vert \widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta},t\right)-\rho_{\varepsilon}\left(k_{1},0\right)-\rho_{\Phi}\left(k_{1},0\right)-\rho_{\widehat{\Phi}}\left(k_{1},0\right)\right\Vert \\
 & \underset{a.e.}{\le}-k_{1}\left\Vert e\right\Vert ^{2}-k_{2}\left\Vert r\right\Vert ^{2}-\lambda_{P}P+\left\Vert r\right\Vert \rho_{\widetilde{N}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \underset{a.e.}{\le}-k_{1}\left\Vert e\right\Vert ^{2}-k_{2}\left\Vert r\right\Vert ^{2}-\lambda_{P}P+\left\Vert r\right\Vert \rho_{\widetilde{N}}\left(k_{1},\left\Vert z\right\Vert \right)\left(\left\Vert e\right\Vert +\left\Vert r\right\Vert \right)\\
 & \underset{a.e.}{\le}-k_{1}\left\Vert e\right\Vert ^{2}-k_{2}\left\Vert r\right\Vert ^{2}-\lambda_{P}P+\rho_{\widetilde{N}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert e\right\Vert \left\Vert r\right\Vert +\rho_{\widetilde{N}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert r\right\Vert ^{2}\\
 & \underset{a.e.}{\le}-k_{1}\left\Vert e\right\Vert ^{2}-k_{2}\left\Vert r\right\Vert ^{2}-\lambda_{P}P+\frac{1}{2}\rho_{\widetilde{N}}^{2}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert r\right\Vert ^{2}+\frac{1}{2}\left\Vert e\right\Vert ^{2}+\rho_{\widetilde{N}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert r\right\Vert ^{2}\\
 & \underset{a.e.}{\le}-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\rho_{\widetilde{N}}^{2}\left(k_{1},\left\Vert z\right\Vert \right)-\rho_{\widetilde{N}}\left(k_{1},\left\Vert z\right\Vert \right)\right)\left\Vert r\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{a.e.}{\le}-\min\left(k_{1}-\frac{1}{2},k_{2}-\frac{1}{2}\rho_{\widetilde{N}}^{2}\left(k_{1},\left\Vert z\right\Vert \right)-\rho_{\widetilde{N}}\left(k_{1},\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}-\lambda_{P}P
\end{align*}

\end_inset

Our goal is to now find the set of 
\begin_inset Formula $z$
\end_inset

 such that
\begin_inset Formula 
\begin{align*}
-\min\left(k_{1}-\frac{1}{2},k_{2}-\frac{1}{2}\rho_{\widetilde{N}}^{2}\left(k_{1},\left\Vert z\right\Vert \right)-\rho_{\widetilde{N}}\left(k_{1},\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2} & \underset{a.e.}{\le}-\frac{\lambda_{V}}{2}\left\Vert z\right\Vert ^{2}\\
-\min\left(k_{1}-\frac{1}{2},k_{2}-\frac{1}{2}\rho_{\widetilde{N}}^{2}\left(k_{1},\left\Vert z\right\Vert \right)-\rho_{\widetilde{N}}\left(k_{1},\left\Vert z\right\Vert \right)\right) & \underset{a.e.}{\le}-\frac{\lambda_{V}}{2}\\
\min\left(k_{1}-\frac{1}{2},k_{2}-\frac{1}{2}\rho_{\widetilde{N}}^{2}\left(k_{1},\left\Vert z\right\Vert \right)-\rho_{\widetilde{N}}\left(k_{1},\left\Vert z\right\Vert \right)\right) & \underset{a.e.}{\ge}\frac{\lambda_{V}}{2}
\end{align*}

\end_inset

Let the desired region of attraction be 
\begin_inset Formula $\mathcal{S}\triangleq\left\{ \zeta\in\mathbb{R}^{2n}:\left\Vert \zeta\right\Vert \le\Delta\right\} $
\end_inset

 for 
\begin_inset Formula $\Delta\in\mathbb{R}_{>0}$
\end_inset

.
 First,
\begin_inset Formula 
\[
k_{1}>\frac{\lambda_{V}}{2}+\frac{1}{2}
\]

\end_inset

Second,
\begin_inset Formula 
\[
k_{2}>\frac{1}{2}\rho_{\widetilde{N}}^{2}\left(k_{1},\Delta\right)+\rho_{\widetilde{N}}\left(k_{1},\Delta\right)+\frac{\lambda_{V}}{2}
\]

\end_inset

Note that the convergence speed can be made arbitrarily large, but doing
 requires 
\begin_inset Formula $k_{1}\to\infty$
\end_inset

 and thus 
\begin_inset Formula $k_{2}\to\infty$
\end_inset

.
 For any fixed convergence speed, 
\begin_inset Formula $\mathcal{S}$
\end_inset

 can be made arbitrarily by making 
\begin_inset Formula $k_{2}\to\infty$
\end_inset

.
 Thus, we have USAS with exponential convergence.
 Thus, for all 
\begin_inset Formula $z\in\mathcal{S}$
\end_inset

,
\begin_inset Formula 
\begin{align*}
\dot{V} & \le-\frac{\lambda_{V}}{2}\left\Vert z\right\Vert ^{2}-\lambda_{P}P\\
 & \le-\min\left(\lambda_{V},\lambda_{P}\right)\left(\frac{1}{2}\left\Vert z\right\Vert ^{2}+P\right)\\
 & \le-\min\left(\lambda_{V},\lambda_{P}\right)\left(V\left(z_{P}\right)\right)
\end{align*}

\end_inset

where 
\begin_inset Formula $z_{P}\triangleq\left[\begin{array}{cc}
x^{\top} & P\end{array}\right]^{\top}\in\mathbb{R}^{2n+1}$
\end_inset

.
 Applying Gronwall inequality gives that (
\color red
guessing at the steps here
\color inherit
)
\begin_inset Formula 
\[
V\left(z_{P}\left(t\right)\right)\le V\left(z_{P}\left(t_{0}\right)\right){\rm e}^{-2\min\left(\lambda_{V},\lambda_{P}\right)\left(t-t_{0}\right)}
\]

\end_inset


