\begin_layout Plain Layout
First
\begin_inset Formula 
\begin{align*}
\widetilde{N}_{0}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta}\right) & =N_{B}\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-N_{B}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\\
 & =\Phi\left(\kappa,\widehat{\theta}\right)-\Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa_{d},\widehat{\theta}\right)+\Phi\left(\kappa_{d},\theta^{\ast}\right)\\
 & =\Phi\left(\kappa_{d},\theta^{\ast}\right)-\Phi\left(\kappa,\theta^{\ast}\right)+\Phi\left(\kappa,\widehat{\theta}\right)-\Phi\left(\kappa_{d},\widehat{\theta}\right)
\end{align*}

\end_inset

First, look at 
\begin_inset Formula $\Phi\left(\kappa_{d},\theta^{\ast}\right)-\Phi\left(\kappa,\theta^{\ast}\right)$
\end_inset

.
 By Fundamental Theorem of Calculus,
\begin_inset Formula 
\[
\left\Vert \Phi\left(\kappa_{d},\theta^{\ast}\right)-\Phi\left(\kappa,\theta^{\ast}\right)\right\Vert \le\left\Vert \kappa_{d}-\kappa\right\Vert \intop_{0}^{1}\left\Vert \left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\gamma\left(\lambda_{L}\right),\theta^{\ast}\right)}\right\Vert d\lambda_{L}
\]

\end_inset

where 
\begin_inset Formula $\gamma:\left[0,1\right]\to\mathbb{R}^{2n}$
\end_inset

 is a line connecting 
\begin_inset Formula $\gamma\left(0\right)=\kappa$
\end_inset

 and 
\begin_inset Formula $\gamma\left(1\right)=\kappa_{d}$
\end_inset

, 
\begin_inset Formula $\gamma\left(\lambda_{L}\right)\triangleq\left(1-\lambda_{L}\right)\kappa+\lambda_{L}\kappa_{d}$
\end_inset

.
 Note: 
\begin_inset Formula $\left\Vert \kappa_{d}\right\Vert \le\overline{\kappa}_{d}\triangleq\overline{u}_{d}+\overline{x}_{d}$
\end_inset

.
 Using 
\begin_inset Formula $\left\Vert \theta^{\ast}\right\Vert \le\overline{\theta}$
\end_inset

 and
\begin_inset Formula 
\begin{align*}
\gamma\left(\lambda_{L}\right) & =\left(1-\lambda_{L}\right)\kappa+\lambda_{L}\kappa_{d}\\
 & =\lambda_{L}e_{d}+\kappa\\
\left\Vert \gamma\left(\lambda_{L}\right)\right\Vert  & \le\lambda_{L}\left\Vert e_{d}\right\Vert +\left\Vert \kappa\right\Vert \\
 & \le\lambda_{L}\left(\left\Vert \kappa\right\Vert +\left\Vert \kappa_{d}\right\Vert \right)+\left\Vert \kappa\right\Vert \\
 & \le\lambda_{L}\left(\left\Vert x\right\Vert +\left\Vert u\right\Vert +\overline{\kappa}_{d}\right)+\left\Vert x\right\Vert +\left\Vert u\right\Vert \\
 & \le\lambda_{L}\left(\left\Vert x_{d}-e\right\Vert +\rho_{u}\left(k_{1},\left\Vert z\right\Vert \right)+\overline{\kappa}_{d}\right)+\left\Vert x_{d}-e\right\Vert +\rho_{u}\left(k_{1},\left\Vert z\right\Vert \right)\\
 & \le\lambda_{L}\left(\overline{x}_{d}+\left\Vert e\right\Vert +\rho_{u}\left(k_{1},\left\Vert z\right\Vert \right)+\overline{\kappa}_{d}\right)+\overline{x}_{d}+\left\Vert e\right\Vert +\rho_{u}\left(k_{1},\left\Vert z\right\Vert \right)\\
 & \le\overline{x}_{d}+\left\Vert e\right\Vert +\rho_{u}\left(k_{1},\left\Vert z\right\Vert \right)+\overline{\kappa}_{d}+\overline{x}_{d}+\left\Vert e\right\Vert +\rho_{u}\left(k_{1},\left\Vert z\right\Vert \right)\\
 & \le2\overline{x}_{d}+2\left\Vert e\right\Vert +2\rho_{u}\left(k_{1},\left\Vert z\right\Vert \right)+\overline{\kappa}_{d}\\
 & \le2\overline{x}_{d}+2\left\Vert z\right\Vert +2\rho_{u}\left(k_{1},\left\Vert z\right\Vert \right)+\overline{\kappa}_{d}
\end{align*}

\end_inset

 So,
\begin_inset Formula 
\[
\left\Vert \left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\gamma\left(\lambda_{L}\right),\theta^{\ast}\right)}\right\Vert \le\sigma_{\Phi}\left(s\right)\triangleq\sup_{\left\Vert \theta^{\ast}\right\Vert \le\overline{\theta},\left\Vert \zeta\right\Vert \le2\overline{x}_{d}+2s+2\rho_{u}\left(k_{1},s\right)+\overline{\kappa}_{d}}\left(\left\Vert \left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\zeta,\theta^{\ast}\right)}\right\Vert \right)
\]

\end_inset

where 
\begin_inset Formula $\sigma_{\Phi}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 is a nondecreasing function (not 
\begin_inset Formula $\mathcal{P}_{\infty}$
\end_inset

).
 Technically, this is a constant for a DNN.
 Unsure for a ResNet.
 Let (by Lemma 3)
\begin_inset Formula 
\begin{align*}
\rho_{\Phi_{0}}\left(k_{1},s\right) & \triangleq\sigma_{\Phi}\left(k_{1},s\right)+cs\\
\sigma_{\Phi}\left(k_{1},s\right) & \le\rho_{\Phi_{0}}\left(k_{1},s\right)
\end{align*}

\end_inset

Thus, 
\begin_inset Formula $\rho_{\Phi}$
\end_inset

 is strictly increasing (and 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 because 
\begin_inset Formula $\Phi$
\end_inset

 is 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

).
 Let
\begin_inset Formula 
\[
\overline{\rho}_{\Phi_{0}}\left(k_{1},s\right)\triangleq\rho_{\Phi_{0}}\left(k_{1},s\right)-\rho_{\Phi_{0}}\left(k_{1},0\right)
\]

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\left\Vert \Phi\left(\kappa_{d},\theta^{\ast}\right)-\Phi\left(\kappa,\theta^{\ast}\right)\right\Vert  & \le\left\Vert \kappa_{d}-\kappa\right\Vert \intop_{0}^{1}\sigma_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)d\lambda_{L}\\
 & \le\sigma_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert e_{d}\right\Vert \\
 & \le\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\left(\left\Vert e\right\Vert +\left\Vert u_{d}\right\Vert +\left\Vert u\right\Vert \right)\\
 & \le\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\left(\left\Vert z\right\Vert +\overline{u}_{d}+\rho_{u}\left(k_{1},\left\Vert z\right\Vert \right)\right)\\
 & \le\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\left(\left\Vert z\right\Vert +\overline{u}_{d}+\overline{\rho}_{u}\left(k_{1},\left\Vert z\right\Vert \right)+\rho_{u}\left(k_{1},0\right)\right)\\
 & \le\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\left(\left\Vert z\right\Vert +\overline{u}_{d}+\alpha_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{u}\left(k_{1},0\right)\right)\\
 & \le\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\alpha_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\\
 & \le\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\alpha_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\left(\overline{\rho}_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)+\rho_{\Phi_{0}}\left(k_{1},0\right)\right)\\
 & \le\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\alpha_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\overline{\rho}_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\rho_{\Phi_{0}}\left(k_{1},0\right)\\
 & \le\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\Phi_{0}}\left(k_{1},\left\Vert z\right\Vert \right)\alpha_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\alpha_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\rho_{\Phi_{0}}\left(k_{1},0\right)
\end{align*}

\end_inset

Let
\begin_inset Formula 
\begin{align*}
\overline{\rho}_{\Phi}\left(k_{1},s\right) & \triangleq\rho_{\Phi}\left(k_{1},s\right)-\rho_{\Phi}\left(k_{1},0\right)\\
\rho_{\Phi}\left(k_{1},s\right) & \triangleq\rho_{\Phi_{0}}\left(k_{1},s\right)s+\rho_{\Phi_{0}}\left(k_{1},s\right)\alpha_{f}\left(k_{1},s\right)s+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\alpha_{\Phi}\left(k_{1},s\right)s+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\rho_{\Phi_{0}}\left(k_{1},0\right)\\
\\
\rho_{\Phi}\left(k_{1},s\right) & \triangleq\rho_{\Phi_{0}}\left(k_{1},s\right)s+\rho_{\Phi_{0}}\left(k_{1},s\right)\alpha_{f}\left(k_{1},s\right)s+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\alpha_{\Phi}\left(k_{1},s\right)s+\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\rho_{\Phi_{0}}\left(k_{1},0\right)\\
\rho_{\Phi}\left(k_{1},0\right) & =\left(\overline{u}_{d}+\rho_{u}\left(k_{1},0\right)\right)\rho_{\Phi_{0}}\left(k_{1},0\right)\\
\overline{\rho}_{\Phi}\left(k_{1},s\right) & =\rho_{\Phi_{0}}\left(k_{1},s\right)s+\rho_{\Phi_{0}}\left(k_{1},s\right)\alpha_{f}\left(k_{1},s\right)s+\left(\overline{u}_{d}+\rho_{u}\left(0\right)\right)\alpha_{\Phi}\left(k_{1},s\right)s\\
\alpha_{\Phi}\left(k_{1},s\right) & \triangleq\rho_{\Phi_{0}}\left(k_{1},s\right)+\rho_{\Phi_{0}}\left(k_{1},s\right)\alpha_{f}\left(k_{1},s\right)+\left(\overline{u}_{d}+\rho_{u}\left(0\right)\right)\alpha_{\Phi}\left(k_{1},s\right)
\end{align*}

\end_inset

Write
\begin_inset Formula 
\begin{align*}
\left\Vert \Phi\left(\kappa_{d},\theta^{\ast}\right)-\Phi\left(\kappa,\theta^{\ast}\right)\right\Vert  & \le\rho_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)\\
 & \le\alpha_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\Phi}\left(k_{1},0\right)
\end{align*}

\end_inset

Likewise, since 
\begin_inset Formula $\left\Vert \widehat{\theta}\right\Vert \le\overline{\theta}$
\end_inset

, there exists a strictly increasing function 
\begin_inset Formula $\rho_{\widehat{\Phi}}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that
\begin_inset Formula 
\begin{align*}
\left\Vert \Phi\left(\kappa,\widehat{\theta}\right)-\Phi\left(\kappa_{d},\widehat{\theta}\right)\right\Vert  & \le\alpha_{\widehat{\Phi}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\widehat{\Phi}}\left(k_{1},0\right)
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{N}_{0}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert  & \le\left\Vert \Phi\left(\kappa_{d},\theta^{\ast}\right)-\Phi\left(\kappa,\theta^{\ast}\right)\right\Vert +\left\Vert \Phi\left(\kappa,\widehat{\theta}\right)-\Phi\left(\kappa_{d},\widehat{\theta}\right)\right\Vert \\
 & \le\alpha_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\Phi}\left(k_{1},0\right)+\alpha_{\widehat{\Phi}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\widehat{\Phi}}\left(k_{1},0\right)
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{N}_{0}\left(\kappa,\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert  & \le\rho_{\widetilde{N_{0}}}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\Phi}\left(k_{1},0\right)+\rho_{\widehat{\Phi}}\left(k_{1},0\right)\\
\rho_{\widetilde{N_{0}}}\left(k_{1},\left\Vert z\right\Vert \right) & \triangleq\alpha_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)+\alpha_{\widehat{\Phi}}\left(k_{1},\left\Vert z\right\Vert \right)
\end{align*}

\end_inset


\end_layout

