\widetilde{V}\left(t\right)-\widetilde{V}\left(t_{0}\right) & \le\intop_{t_{0}}^{t}\left(-k_{1}\left\Vert e\left(\tau\right)\right\Vert ^{2}-k_{2}\left\Vert r\left(\tau\right)\right\Vert ^{2}\right)d\tau\\
\intop_{t_{0}}^{t}\left(k_{1}\left\Vert e\left(\tau\right)\right\Vert ^{2}+k_{2}\left\Vert r\left(\tau\right)\right\Vert ^{2}\right)d\tau & \le\widetilde{V}\left(t_{0}\right)-\widetilde{V}\left(t\right)
\end{align*}

\end_inset

Thus, 
\begin_inset Formula $e,r\in\mathcal{L}_{2}\left(\mathbb{R}_{\ge t_{0}};\mathbb{R}^{n}\right)$
\end_inset

 and the integrals are finite.
 Thus, 
\begin_inset Formula $e\to0$
\end_inset

 and 
\begin_inset Formula $r\to0$
\end_inset

 as 
\begin_inset Formula $t\to\infty$
\end_inset

.
