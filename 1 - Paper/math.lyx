 & =\Phi\left(\kappa,\theta^{\ast}\right)+\varepsilon\left(\kappa\right)-\left(k_{3}r_{2}+r_{1}+\beta\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q},u\right)}d\left(t\right)-\dot{d}\left(t\right)\\
 & =\Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa,\hat{\theta}\right)+\varepsilon\left(\kappa\right)-k_{3}r_{2}-r_{1}-\beta\text{sgn}\left(r_{1}\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q},u\right)}d\left(t\right)-\dot{d}\left(t\right)\\
 & =\underbrace{\Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa,\hat{\theta}\right)}_{N_{0}\left(\kappa,\theta^{\ast},\hat{\theta}\right)}+\varepsilon\left(\kappa\right)-k_{3}r_{2}-r_{1}-\beta\text{sgn}\left(r_{1}\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q},u\right)}d\left(t\right)-\dot{d}\left(t\right)+\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d},u_{d}\right)}d\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d},u_{d}\right)}d\left(t\right)-\varepsilon\left(\kappa_{d}\right)+\varepsilon\left(\kappa_{d}\right)+N_{0}\left(\kappa_{d},\theta^{\ast},\hat{\theta}\right)-N_{0}\left(\kappa_{d},\theta^{\ast},\hat{\theta}\right)\\
 & =\underbrace{N_{0}\left(\kappa,\theta^{\ast},\hat{\theta}\right)-N_{0}\left(\kappa_{d},\theta^{\ast},\hat{\theta}\right)}_{\widetilde{N}_{1}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta}\right)}+\underbrace{\varepsilon\left(\kappa\right)-\varepsilon\left(\kappa_{d}\right)}_{\widetilde{N}_{\varepsilon}\left(\kappa,\kappa_{d}\right)}-k_{3}r_{2}-r_{1}-\beta\text{sgn}\left(r_{1}\right)+\left(\underbrace{\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d},u_{d}\right)}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q},u\right)}}_{\widetilde{N}_{2}\left(q,\dot{q},q_{d},\dot{q}_{d},u,u_{d}\right)}\right)d\left(t\right)-\dot{d}\left(t\right)\underbrace{-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d},u_{d}\right)}d\left(t\right)+\varepsilon\left(\kappa_{d}\right)}_{D_{0}\left(\kappa_{d},t\right)}+N_{0}\left(\kappa_{d},\theta^{\ast},\hat{\theta}\right)\\
 & =\underbrace{\widetilde{N}_{1}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta}\right)+\widetilde{N}_{\varepsilon}\left(\kappa,\kappa_{d}\right)+d\left(t\right)\widetilde{N}_{2}\left(q,\dot{q},q_{d},\dot{q}_{d},u,u_{d}\right)}_{\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)}-k_{3}r_{2}-r_{1}-\beta\text{sgn}\left(r_{1}\right)\underbrace{-\dot{d}\left(t\right)+D_{0}\left(\kappa_{d},t\right)+N_{0}\left(\kappa_{d},\theta^{\ast},\hat{\theta}\right)}_{D_{1}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)}\\
 & =\widetilde{N}\left(\kappa,\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}-r_{1}-\beta\text{sgn}\left(r_{1}\right)+D_{1}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)
\end{align*}

\end_inset


