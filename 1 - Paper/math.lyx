\begin_layout Lemma
\begin_inset CommandInset label
LatexCommand label
name "lem:non-decreasing-bound"

\end_inset

Let 
\begin_inset Formula $D\subseteq\mathbb{R}^{n}$
\end_inset

 be a convex, open set with 
\begin_inset Formula $\boldsymbol{0}_{n}\in D$
\end_inset

.
 Define 
\begin_inset Formula $a_{6}\triangleq\inf\left\{ \left\Vert x\right\Vert \vert x\in\mathbb{R}^{n}\backslash D\right\} $
\end_inset

 and let 
\begin_inset Formula ${\tt r}\in\left[0,a_{6}\right)$
\end_inset

 be such that 
\begin_inset Formula $\overline{B}_{{\tt r}}\left(\boldsymbol{0}_{n}\right)\subsetneq D$
\end_inset

.
\begin_inset Foot
status open

\begin_layout Plain Layout
If 
\begin_inset Formula $D$
\end_inset

 is selected as an open ball, 
\begin_inset Formula $a_{6}$
\end_inset

 is its radius, i.e., 
\begin_inset Formula $D=B_{a_{6}}\left(\boldsymbol{0}_{n}\right)$
\end_inset

.
 If 
\begin_inset Formula $D=\mathbb{R}^{n}$
\end_inset

, let 
\begin_inset Formula $a_{6}=\infty$
\end_inset

.
\end_layout

\end_inset

 Let 
\begin_inset Formula $f_{6}:D\times\mathbb{R}_{\geq0}\to\mathbb{R}^{m}$
\end_inset

 be locally Lipschitz continuous on 
\begin_inset Formula $D$
\end_inset

, uniformly in the second argument.
 Then, there exists a non-decreasing function 
\begin_inset Formula $\sigma_{1}:\left[0,a_{6}-{\tt r}\right)\to\mathbb{R}_{\geq0}$
\end_inset

 such that for all 
\begin_inset Formula $\left(x,x_{d},t\right)\in D\times\overline{B}_{{\tt r}}\left(\boldsymbol{0}_{n}\right)\times\mathbb{R}_{\geq0}$
\end_inset

 that satisfy 
\begin_inset Formula $\left\Vert x-x_{d}\right\Vert <a_{6}-{\tt r}$
\end_inset

,
\begin_inset Formula 
\begin{equation}
\left\Vert f_{6}\left(x,t\right)-f_{6}\left(x_{d},t\right)\right\Vert \le\sigma_{1}\left(\left\Vert x-x_{d}\right\Vert \right)\left\Vert x-x_{d}\right\Vert .\label{eq:lipschitz-like-bound}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Lemma
\begin_inset CommandInset label
LatexCommand label
name "lem:non-decreasing-continuous-bound"

\end_inset

 For the map 
\begin_inset Formula $f_{6}$
\end_inset

 in Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:non-decreasing-bound"
plural "false"
caps "false"
noprefix "false"

\end_inset

, assume instead that 
\begin_inset Formula $x\mapsto f_{6}\left(x,t\right)$
\end_inset

 is of class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 on 
\begin_inset Formula $D$
\end_inset

 and that 
\begin_inset Formula $h_{0}:D\to\mathbb{R}_{\geq0}$
\end_inset

 defined as 
\begin_inset Formula $h_{0}\left(x\right)\triangleq\sup_{t\in\mathbb{R}_{\ge0}}\left\Vert \nabla_{x}f_{6}\left(x,t\right)\right\Vert $
\end_inset

 is continuous on 
\begin_inset Formula $D$
\end_inset

.
 Then, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:lipschitz-like-bound"
plural "false"
caps "false"
noprefix "false"

\end_inset

 holds for all 
\begin_inset Formula $\left(x,x_{d},t\right)\in D\times\overline{B}_{{\tt r}}\left(\boldsymbol{0}_{n}\right)\times\mathbb{R}_{\geq0}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert x-x_{d}\right\Vert <a_{6}-{\tt r}$
\end_inset

 and 
\begin_inset Formula $\sigma_{1}:\left[0,a_{6}-{\tt r}\right)\to\mathbb{R}_{\geq0}$
\end_inset

 is continuous.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Remark
If 
