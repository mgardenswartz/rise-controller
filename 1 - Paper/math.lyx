\end{align*}

\end_inset

NOTE:
\begin_inset Formula 
\begin{align*}
\left|P\left(t_{0}\right)\right| & \le K_{\text{RISE}}\left\Vert r_{1}\left(t_{0}\right)\right\Vert _{1}+\left\Vert r_{1}\left(t_{0}\right)\right\Vert \overline{D}\\
 & \le\sqrt{n}K_{\text{RISE}}\left\Vert r_{1}\left(t_{0}\right)\right\Vert +\left\Vert r_{1}\left(t_{0}\right)\right\Vert \overline{D}\\
 & \le\left(\sqrt{n}K_{\text{RISE}}+\overline{D}\right)\left\Vert r_{1}\left(t_{0}\right)\right\Vert 
\end{align*}

\end_inset

How do we know 
\begin_inset Formula $P\ge0$
\end_inset

 for all time? So sufficient conditions.
 An obvious first step is to ensure 
\begin_inset Formula $\left\Vert \zeta\left(t\right)\right\Vert \ge0$
\end_inset

 for all time.
 Since 
\begin_inset Formula $\left\Vert r\right\Vert _{1}\ge\left\Vert r\right\Vert $
\end_inset


\begin_inset Formula 
\begin{align*}
K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-r_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right) & \ge K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-\left\Vert r_{1}\left(t\right)\right\Vert \overline{D}\\
 & \ge K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert -\overline{D}\left\Vert r_{1}\left(t\right)\right\Vert \\
 & \ge\left(\underbrace{K_{\text{RISE}}-\overline{D}}_{b_{1}}\right)\left\Vert r_{1}\left(t\right)\right\Vert 
\end{align*}

\end_inset

To get 
\begin_inset Formula $b_{1}>0$
\end_inset

, select
\begin_inset Formula 
\[
K_{\text{RISE}}>\overline{D}
\]

\end_inset

and thus
\begin_inset Formula 
\[
\left\Vert \zeta\left(t\right)\right\Vert \ge b_{1}\left\Vert r_{1}\left(t\right)\right\Vert >0
\]

\end_inset

Next, we want: Let 
\begin_inset Formula $\lambda_{P}\in\left(0,k_{2}\right)$
\end_inset

 and 
\begin_inset Formula $b_{2}\triangleq k_{2}-\lambda_{P}$
\end_inset

.
 Thus 
\begin_inset Formula $b_{2}>0$
\end_inset

.
\begin_inset Formula 
\begin{align*}
r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)+\left(k_{2}-\lambda_{P}\right)\zeta\left(t\right) & =r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)+b_{2}\zeta\left(t\right)\\
 & >-\left\Vert r_{1}\left(t\right)\right\Vert \overline{\dot{D}}+b_{1}b_{2}\left\Vert r_{1}\left(t\right)\right\Vert \\
 & >\left(b_{1}b_{2}-\overline{\dot{D}}\right)\left\Vert r_{1}\left(t\right)\right\Vert 
\end{align*}

\end_inset

We need 
\begin_inset Formula 
\begin{align*}
b_{1}b_{2}-\overline{\dot{D}} & \ge0\\
b_{1}b_{2} & \ge\overline{\dot{D}}\\
b_{1} & \ge\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}\\
K_{\text{RISE}}-\overline{D} & \ge\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}\\
K_{\text{RISE}} & \ge\overline{D}+\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}
\end{align*}

\end_inset

So the only gain suggestion you need (well, it's sufficient)
\color green

\begin_inset Formula 
\[
K_{\text{RISE}}\ge\overline{D}+\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}
\]

\end_inset


\color inherit
NOTE: The above requires
\begin_inset Formula 
\[
\lambda_{P}\in\left(0,k_{2}\right)
\]

\end_inset

which can always be satisfied since 
\begin_inset Formula $k_{2}>0$
\end_inset

.
\end_layout

