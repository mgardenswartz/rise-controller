\dot{V}\left(z\right) & \underset{\text{a.e.}}{\le}-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}+\left\Vert r_{2}\right\Vert \rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert -k_{3}\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}+\left\Vert r_{2}\right\Vert \rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left(\left\Vert e\right\Vert +\left\Vert r_{1}\right\Vert +\left\Vert r_{2}\right\Vert \right)-k_{3}\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}+\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert e\right\Vert \left\Vert r_{2}\right\Vert +\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{1}\right\Vert \left\Vert r_{2}\right\Vert +\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}+\frac{1}{2}\left\Vert e\right\Vert ^{2}+\frac{1}{2}\rho_{0}^{2}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}+\frac{1}{2}\left\Vert r_{1}\right\Vert ^{2}+\frac{1}{2}\rho_{0}^{2}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}+\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-1\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-1\right)\left\Vert r_{1}\right\Vert ^{2}+\frac{1}{2}\rho_{0}^{2}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}+\frac{1}{2}\rho_{0}^{2}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}+\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert r_{2}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-1\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-1\right)\left\Vert r_{1}\right\Vert ^{2}-\left(k_{3}-\left(\underbrace{\rho_{0}^{2}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)+\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}_{\rho\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\right)\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{\text{a.e.}}{\le}-\left(k_{1}-1\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-1\right)\left\Vert r_{1}\right\Vert ^{2}-\left(k_{3}-\rho\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\right)\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P
\end{align*}

\end_inset

Pick 
\begin_inset Formula $\Delta,\lambda_{V}\in\mathbb{R}_{>0}$
\end_inset

.
 Let the desired region of attraction (for 
\begin_inset Formula $z$
\end_inset

 not 
\begin_inset Formula $z_{P}$
\end_inset

!) be 
\begin_inset Formula $\mathcal{S}\triangleq\left\{ \zeta\in\mathbb{R}^{5n}:\left\Vert \zeta\right\Vert \le\Delta\right\} $
\end_inset

.
 The gain conditions should be selected to ensure that for all 
\begin_inset Formula $z\in\mathcal{S}$
\end_inset

,
\begin_inset Formula 
\[
\dot{V}\left(z\right)\underset{\text{a.e.}}{\le}-\frac{\lambda_{V}}{2}\left\Vert z\right\Vert ^{2}-\lambda_{P}P
\]

\end_inset

So,
\begin_inset Formula 
\begin{align*}
-\left(k_{1}-1\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-1\right)\left\Vert r_{1}\right\Vert ^{2}-\left(k_{3}-\rho\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\right)\left\Vert r_{2}\right\Vert ^{2}-\lambda_{P}P & \underset{\text{a.e.}}{\le}-\min\left\{ k_{1}-1,k_{2}-1,k_{3}-\rho\left(k_{1},k_{2},\Delta\right)\right\} \left\Vert z\right\Vert ^{2}-\lambda_{P}P
\end{align*}

\end_inset

Compare
\begin_inset Formula 
\begin{align*}
-\min\left\{ k_{1}-1,k_{2}-1,k_{3}-\rho\left(k_{1},k_{2},\Delta\right)\right\} \left\Vert z\right\Vert ^{2} & \underset{\text{a.e.}}{\le}-\frac{\lambda_{V}}{2}\left\Vert z\right\Vert ^{2}\\
\min\left\{ k_{1}-1,k_{2}-1,k_{3}-\rho\left(k_{1},k_{2},\Delta\right)\right\}  & \underset{\text{a.e.}}{\ge}\frac{\lambda_{V}}{2}
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\dot{V}\left(z\right) & \underset{\text{a.e.}}{\le}-\frac{\lambda_{V}}{2}\left\Vert z\right\Vert ^{2}-\lambda_{P}P\\
 & \underset{\text{a.e.}}{\le}-\min\left\{ \lambda_{V},\lambda_{P}\right\} \left(\frac{1}{2}\left\Vert z\right\Vert ^{2}+P\right)
\end{align*}

\end_inset

Let
\begin_inset Formula 
\[
\lambda\triangleq\frac{1}{2}\min\left\{ \lambda_{V},\lambda_{P}\right\} 
\]

\end_inset

Thus,
\begin_inset Formula 
\[
\dot{V}\left(z\right)\underset{\text{a.e.}}{\le}-2\lambda\left(V\left(z\right)\right)
\]

\end_inset

Let 
\begin_inset Formula $z_{0}\triangleq z\left(t_{0}\right)$
\end_inset

.
 Solve the above.
\begin_inset Formula 
\begin{align*}
s\mathcal{L}\left\{ V\left(z\right)\right\} -V\left(z\left(t_{0}\right)\right) & \underset{\text{a.e.}}{\le}-2\lambda\mathcal{L}\left\{ V\left(z\right)\right\} \\
\left(s+2\lambda\right)\mathcal{L}\left\{ V\left(z\right)\right\}  & \underset{\text{a.e.}}{\le}V\left(z\left(t_{0}\right)\right)\\
\mathcal{L}\left\{ V\left(z\right)\right\}  & \underset{\text{a.e.}}{\le}\frac{V\left(z\left(t_{0}\right)\right)}{s+2\lambda}\\
\mathcal{L}^{-1}\left\{ \mathcal{L}\left\{ V\left(z\right)\right\} \right\}  & \underset{\text{a.e.}}{\le}\mathcal{L}^{-1}\left\{ \frac{V\left(z\left(t_{0}\right)\right)}{s+2\lambda}\right\} \\
V\left(z\left(t\right)\right) & \underset{\text{a.e.}}{\le}V\left(z_{0}\right){\rm e}^{-2\lambda\left(t-t_{0}\right)}
\end{align*}

\end_inset

Since
\begin_inset Formula 
\begin{align*}
V\left(z\left(t_{0}\right)\right) & =\frac{1}{2}z_{0}^{\top}z_{0}+P\left(t_{0}\right)\\
V\left(z\left(t\right)\right) & =\frac{1}{2}z^{\top}\left(t\right)z\left(t\right)+P\left(t\right)
\end{align*}

\end_inset

and (recall)
\begin_inset Formula 
\[
\left|P\left(t_{0}\right)\right|\le\left(\sqrt{n}K_{\text{RISE}}+\overline{D}\right)\left\Vert r_{1}\left(t_{0}\right)\right\Vert 
\]

\end_inset

then,
\begin_inset Formula 
\begin{align*}
\frac{1}{2}z^{\top}\left(t\right)z\left(t\right)+P\left(t\right) & \underset{\text{a.e.}}{\le}\left(\frac{1}{2}z_{0}^{\top}z_{0}+P\left(t_{0}\right)\right){\rm e}^{-2\lambda\left(t-t_{0}\right)}\\
\frac{1}{2}\left\Vert z\left(t\right)\right\Vert ^{2} & \underset{\text{a.e.}}{\le}\left(\frac{1}{2}\left\Vert z_{0}\right\Vert ^{2}+\left(\sqrt{n}K_{\text{RISE}}+\overline{D}\right)\left\Vert r_{1}\left(t_{0}\right)\right\Vert \right){\rm e}^{-2\lambda\left(t-t_{0}\right)}\\
\frac{1}{2}\left\Vert z\left(t\right)\right\Vert ^{2} & \underset{\text{a.e.}}{\le}\left(\frac{1}{2}\left\Vert z_{0}\right\Vert ^{2}+\left(\sqrt{n}K_{\text{RISE}}+\overline{D}\right)\left\Vert z_{0}\right\Vert \right){\rm e}^{-2\lambda\left(t-t_{0}\right)}\\
\left\Vert z\left(t\right)\right\Vert ^{2} & \underset{\text{a.e.}}{\le}\left(\left\Vert z_{0}\right\Vert ^{2}+2\left(\sqrt{n}K_{\text{RISE}}+\overline{D}\right)\left\Vert z_{0}\right\Vert \right){\rm e}^{-2\lambda\left(t-t_{0}\right)}\\
\left\Vert z\left(t\right)\right\Vert  & \underset{\text{a.e.}}{\le}\sqrt{\left(\left\Vert z_{0}\right\Vert ^{2}+2\left(\sqrt{n}K_{\text{RISE}}+\overline{D}\right)\left\Vert z_{0}\right\Vert \right){\rm e}^{-2\lambda\left(t-t_{0}\right)}}\\
\left\Vert z\left(t\right)\right\Vert  & \underset{\text{a.e.}}{\le}\underbrace{\underbrace{\sqrt{\left(\left\Vert z_{0}\right\Vert ^{2}+2\left(\sqrt{n}K_{\text{RISE}}+\overline{D}\right)\left\Vert z_{0}\right\Vert \right)}}_{\alpha\in\mathcal{K}_{\infty}}{\rm e}^{-\lambda\left(t-t_{0}\right)}}_{\beta\in\mathcal{KL}_{\infty}}
\end{align*}

\end_inset


\begin_inset Newline newline
\end_inset

GAIN CONDITIONS
\end_layout

\begin_layout Standard
Let 
\begin_inset Formula $\lambda$
\end_inset

 be a desired convergence rate and let 
\begin_inset Formula $\Delta$
\end_inset

 be the size of desired initial conditions (radius of 
\begin_inset Formula $\mathcal{S}$
\end_inset

).
 The sufficient gain conditions are:
\begin_inset Formula 
\begin{align*}
\lambda_{V} & \ge2\lambda\\
\lambda_{P} & \ge2\lambda\\
k_{1} & >1+\frac{\lambda_{V}}{2}\\
k_{2} & >\max\left\{ 1+\frac{\lambda_{V}}{2},\lambda_{P}\right\} \\
k_{3} & >\rho\left(k_{1},k_{2},\Delta\right)+\frac{\lambda_{V}}{2}\\
K_{\text{RISE}} & \ge\overline{D}+\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}
\end{align*}

\end_inset


\end_layout

