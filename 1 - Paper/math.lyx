{\color{blue}c_{1}\left(k_{1}\right)} & {\color{blue}\ge\frac{\overline{\dot{g}}}{k_{1}-\lambda_{P}}}\\
\beta-\overline{g}\left(k_{1}\right) & \ge\frac{\overline{\dot{g}}}{k_{1}-\lambda_{P}}\\
