\begin{align*}
\dot{R} & =k_{1}Q\left(t\right)+e^{\top}\dot{g}\left(t\right)-\lambda_{P}\left(Q+R\right)\\
\dot{R} & =k_{1}Q\left(t\right)+e^{\top}\dot{g}\left(t\right)-\lambda_{P}-\lambda_{P}Q-\lambda_{P}R\\
\dot{R}+\lambda_{P}R & =e^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\\
\dot{R}+\lambda_{P}R & =e^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\\
{\rm e}^{\lambda_{P}\left(t-t_{0}\right)}\left(\dot{R}+\lambda_{P}R\right) & ={\rm e}^{\lambda_{P}\left(t-t_{0}\right)}\left(e^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\right)\\
\frac{d}{dt}\left({\rm e}^{\lambda_{P}\left(t-t_{0}\right)}R\right) & ={\rm e}^{\lambda_{P}\left(t-t_{0}\right)}\left(e^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\right)\\
\intop_{t_{0}}^{t}\frac{d}{d\tau}\left({\rm e}^{\lambda_{P}\left(\tau-t_{0}\right)}R\left(\tau\right)\right)d\tau & =\intop_{t_{0}}^{t}{\rm e}^{\lambda_{P}\left(\tau-t_{0}\right)}\left(e\left(\tau\right)^{\top}\dot{g}\left(\tau\right)+\left(k_{1}-\lambda_{P}\right)Q\left(\tau\right)\right)d\tau\\
{\rm e}^{\lambda_{P}\left(t-t_{0}\right)}R\left(t\right)-\cancelto{0}{R\left(t_{0}\right)} & =\intop_{t_{0}}^{t}{\rm e}^{\lambda_{P}\left(\tau-t_{0}\right)}\left(e\left(\tau\right)^{\top}\dot{g}\left(\tau\right)+\left(k_{1}-\lambda_{P}\right)Q\left(\tau\right)\right)d\tau\\
R\left(t\right) & ={\rm e}^{-\lambda_{P}\left(t-t_{0}\right)}\intop_{t_{0}}^{t}{\rm e}^{\lambda_{P}\left(\tau-t_{0}\right)}\left(e\left(\tau\right)^{\top}\dot{g}\left(\tau\right)+\left(k_{1}-\lambda_{P}\right)Q\left(\tau\right)\right)d\tau\\
R\left(t\right) & =\intop_{t_{0}}^{t}{\rm e}^{\lambda_{P}\left(\tau-t\right)}\left(e\left(\tau\right)^{\top}\dot{g}\left(\tau\right)+\left(k_{1}-\lambda_{P}\right)Q\left(\tau\right)\right)d\tau\\
R\left(t\right) & ={\rm e}^{\lambda_{P}t}\ast\left(e\left(t\right)^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\left(t\right)\right)
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
P & =\beta\left\Vert e\right\Vert _{1}-e\left(t\right)^{\top}g\left(t\right)+{\rm e}^{\lambda_{P}t}\ast\left(e\left(t\right)^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\left(t\right)\right)\\
P & ={\color{green}\beta\left\Vert e\right\Vert _{1}-e\left(t\right)^{\top}g\left(t\right)+{\rm e}^{\lambda_{P}t}\ast\left(e\left(t\right)^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)\left(\beta\left\Vert e\left(t\right)\right\Vert _{1}-e\left(t\right)^{\top}g\left(t\right)\right)\right)}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsection
Bounding 1
\end_layout

\begin_layout Plain Layout
Let
\begin_inset Formula 
\[
g\left(t\right)=\widetilde{N}\left(e_{d},\kappa_{d},\theta^{\ast},\widehat{\theta}\right)-N\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)
\]

\end_inset

We need to bound
\begin_inset Formula 
\[
N\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)=-\Psi\left(\kappa_{d},\theta^{\ast}\right)+\Psi\left(\kappa_{d},\widehat{\theta}\right)
\]

\end_inset

and
\begin_inset Formula 
\begin{align*}
\widetilde{N}\left(e_{d},\kappa_{d},\theta^{\ast},\widehat{\theta}\right) & \triangleq-N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)+N\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\\
 & =\Psi\left(\kappa,\theta^{\ast}\right)-\Psi\left(\kappa,\widehat{\theta}\right)-\Psi\left(\kappa_{d},\theta^{\ast}\right)+\Psi\left(\kappa_{d},\widehat{\theta}\right)\\
 & =\underbrace{\Psi\left(\kappa,\theta^{\ast}\right)-\Psi\left(\kappa_{d},\theta^{\ast}\right)}+\underbrace{\Psi\left(\kappa_{d},\widehat{\theta}\right)-\Psi\left(\kappa,\widehat{\theta}\right)}
\end{align*}

\end_inset

Derivative 1
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{\widetilde{N}}\left(e_{d},\kappa_{d},\theta^{\ast},\widehat{\theta}\right) & =\frac{d}{dt}\left(\underbrace{\Psi\left(\kappa,\theta^{\ast}\right)-\Psi\left(\kappa_{d},\theta^{\ast}\right)}+\underbrace{\Psi\left(\kappa_{d},\widehat{\theta}\right)-\Psi\left(\kappa,\widehat{\theta}\right)}\right)\\
 & =\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x,u,\theta^{\ast}\right)}\dot{\kappa}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\theta^{\ast}\right)}\dot{\kappa}+\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\widehat{\theta}\right)}\dot{\kappa}_{d}+\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x_{d},u,\widehat{\theta}\right)}\dot{\widehat{\theta}}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x,u,\widehat{\theta}\right)}\dot{\kappa}_{d}-\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,u,\widehat{\theta}\right)}\dot{\widehat{\theta}}\\
 & =\left(\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x_{d},u,\widehat{\theta}\right)}-\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,u,\widehat{\theta}\right)}\right)\dot{\widehat{\theta}}+\left(\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x,u,\theta^{\ast}\right)}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\theta^{\ast}\right)}\right)\dot{\kappa}+\left(\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\widehat{\theta}\right)}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x,u,\widehat{\theta}\right)}\right)\dot{\kappa}_{d}
\end{align*}

\end_inset

Derivative 2
\begin_inset Formula 
\begin{align*}
\dot{N}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right) & =\frac{d}{dt}\left(\Psi\left(\kappa_{d},\widehat{\theta}\right)-\Psi\left(\kappa_{d},\theta^{\ast}\right)\right)\\
 & =\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\widehat{\theta}\right)}\dot{\kappa}_{d}+\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x_{d},u,\widehat{\theta}\right)}\dot{\widehat{\theta}}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\theta^{\ast}\right)}\dot{\kappa}_{d}\\
 & =\left(\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\widehat{\theta}\right)}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\theta^{\ast}\right)}\right)\dot{\kappa}_{d}+\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x_{d},u,\widehat{\theta}\right)}\dot{\widehat{\theta}}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 1
\end_layout

\begin_layout Plain Layout
First we need to bound 
\begin_inset Formula $\Psi\left(\kappa,\theta^{\ast}\right)-\Psi\left(\kappa_{d},\theta^{\ast}\right)=\Psi\left(x,u,\theta^{\ast}\right)-\Psi\left(x_{d},u,\theta^{\ast}\right)$
\end_inset

.
 Because the map 
\begin_inset Formula $\Psi$
\end_inset

 is jointly 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 on 
\begin_inset Formula $\mathbb{R}^{n}\times\mathbb{R}^{m}\times\mathbb{R}^{p}$
\end_inset

, for each fixed 
\begin_inset Formula $u\in\mathbb{R}^{m}$
\end_inset

, the map 
\begin_inset Formula $\zeta\mapsto\Psi\left(\zeta,u,\theta^{\ast}\right)$
\end_inset

 is 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 on 
\begin_inset Formula $\mathbb{R}^{n}\times\mathbb{R}^{p}$
\end_inset

.
 Thus, for each fixed 
\begin_inset Formula $u$
\end_inset

, there exists a continuous strictly increasing function 
\begin_inset Formula $\rho_{1}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that for all 
\begin_inset Formula $\left(x,x_{d}\right)\in\mathbb{R}^{n}\times\overline{B}_{r}\left(\boldsymbol{0}_{n}\right)$
\end_inset

,
\begin_inset Formula 
\[
\left\Vert \Psi\left(x,u,\theta^{\ast}\right)-\Psi\left(x_{d},u,\theta^{\ast}\right)\right\Vert \le\rho_{1}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert 
\]

\end_inset

To extend to 
\begin_inset Formula $u\in\overline{B}_{\overline{u}}\left(\boldsymbol{0}_{m}\right)$
\end_inset

, there exists a continuous strictly increasing function 
\begin_inset Formula $\rho_{2}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset


\begin_inset Formula 
\[
\rho_{2}\left(\left\Vert e\right\Vert \right)\triangleq\sup_{u\in\overline{B}_{\overline{u}}\left(\boldsymbol{0}_{m}\right)}\left(\rho_{1}\left(\left\Vert e\right\Vert \right)\right)
\]

\end_inset

and thus for all 
\begin_inset Formula $\left(u,x,x_{d}\right)\in\overline{B}_{\overline{u}}\left(\boldsymbol{0}_{m}\right)\times\mathbb{R}^{n}\times\overline{B}_{r}\left(\boldsymbol{0}_{n}\right)$
\end_inset

,
\begin_inset Formula 
\[
\left\Vert \Psi\left(x,u,\theta^{\ast}\right)-\Psi\left(x_{d},u,\theta^{\ast}\right)\right\Vert \le\rho_{2}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert 
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 2
\end_layout

\begin_layout Plain Layout
Second, we need to bound 
\begin_inset Formula $\Psi\left(\kappa_{d},\widehat{\theta}\right)-\Psi\left(\kappa,\widehat{\theta}\right)=\Psi\left(x_{d},u,\widehat{\theta}\right)-\Psi\left(x,u,\widehat{\theta}\right)$
\end_inset

.
 By MVT or fundamental theorem of calculus, for all 
\begin_inset Formula $\left(u,x,x_{d},\widehat{\theta}\right)\in\overline{B}_{\overline{u}}\left(\boldsymbol{0}_{m}\right)\times\mathbb{R}^{n}\times\overline{B}_{r}\left(\boldsymbol{0}_{n}\right)\times\text{\overline{B}_{\overline{\theta}}\left(\boldsymbol{0}_{p}\right)}$
\end_inset

,
\begin_inset Formula 
\[
\left\Vert \Psi\left(\kappa_{d},\widehat{\theta}\right)-\Psi\left(\kappa,\widehat{\theta}\right)\right\Vert \le\rho_{3}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert 
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 3
\end_layout

\begin_layout Plain Layout
Third, 
\begin_inset Formula $N\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)=\Psi\left(x_{d},u,\widehat{\theta}\right)-\Psi\left(x_{d},u,\theta^{\ast}\right)$
\end_inset

.
 Bound by EVT:
\begin_inset Formula 
\begin{align*}
\left\Vert \Psi\left(x_{d},u,\widehat{\theta}\right)-\Psi\left(x_{d},u,\theta^{\ast}\right)\right\Vert  & \le\sup_{\left(u,\theta^{\ast},x_{d},\widehat{\theta}\right)\in\overline{B}_{\overline{u}}\left(\boldsymbol{0}_{m}\right)\times\overline{B}_{\overline{\theta}}\left(\boldsymbol{0}_{p}\right)\times\overline{B}_{r}\left(\boldsymbol{0}_{n}\right)\times\text{\overline{B}_{\overline{\theta}}\left(\boldsymbol{0}_{p}\right)}}\left(\left\Vert \Psi\left(x_{d},u,\widehat{\theta}\right)-\Psi\left(x_{d},u,\theta^{\ast}\right)\right\Vert \right)\\
 & \le C_{1}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 4
\end_layout

\begin_layout Plain Layout
\begin_inset Formula $\frac{\partial\Psi}{\partial\kappa}$
\end_inset

 has to be jointly 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

.
 Similar to Lemma 1,
\begin_inset Formula 
\[
\left\Vert \left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x,u,\theta^{\ast}\right)}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\theta^{\ast}\right)}\right\Vert \le\rho_{4}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert 
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 5
\end_layout

\begin_layout Plain Layout
\begin_inset Formula $\frac{\partial\Psi}{\partial\theta}$
\end_inset

 has to be jointly 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

.
 Similar to Lemma 2,
\begin_inset Formula 
\[
\left\Vert \left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x_{d},u,\widehat{\theta}\right)}-\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,u,\widehat{\theta}\right)}\right\Vert \le\rho_{5}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert 
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 6
\end_layout

\begin_layout Plain Layout
Similar to Lemma 3,
\begin_inset Formula 
\[
\left\Vert \left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\widehat{\theta}\right)}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x,u,\widehat{\theta}\right)}\right\Vert \le\rho_{6}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert 
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 7
\end_layout

\begin_layout Plain Layout
We have to assume 
\begin_inset Formula $\left\Vert \dot{\widehat{\theta}}\right\Vert \le\eta_{1}$
\end_inset

 and thus by EVT,
\begin_inset Formula 
\begin{align*}
\left\Vert \left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x_{d},u,\widehat{\theta}\right)}\dot{\widehat{\theta}}\right\Vert  & \le\eta_{1}\left\Vert \left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x_{d},u,\widehat{\theta}\right)}\right\Vert \\
 & \le C_{2}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 8
\end_layout

\begin_layout Plain Layout
Since 
\begin_inset Formula $f\in\mathcal{C}^{2}$
\end_inset

,
\begin_inset Formula 
\begin{align*}
\left\Vert \frac{\partial f}{\partial x}\left(x\right)-\frac{\partial f}{\partial x}\left(\boldsymbol{0}_{n}\right)\right\Vert  & \le\rho_{8}\left(\left\Vert x\right\Vert \right)\left\Vert x\right\Vert \\
\left|\left\Vert \frac{\partial f}{\partial x}\left(x\right)\right\Vert -\left\Vert \frac{\partial f}{\partial x}\left(\mathbf{0}_{n}\right)\right\Vert \right| & \le\rho_{8}\left(\left\Vert x\right\Vert \right)\left\Vert x\right\Vert \\
\left\Vert \frac{\partial f}{\partial x}\left(x\right)\right\Vert  & \le\left\Vert \frac{\partial f}{\partial x}\left(\mathbf{0}_{n}\right)\right\Vert +\rho_{8}\left(\left\Vert x\right\Vert \right)\left\Vert x\right\Vert \\
 & \le\left\Vert \frac{\partial f}{\partial x}\left(\mathbf{0}_{n}\right)\right\Vert +\rho_{8}\left(\overline{x}_{d}+\left\Vert e\right\Vert \right)\left(\overline{x}_{d}+\left\Vert e\right\Vert \right)\\
 & \le\rho_{9}\left(\left\Vert e\right\Vert \right)
\end{align*}

\end_inset

Therefore,
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\left\Vert \frac{\partial f}{\partial x}d\left(t\right)+\dot{d}\left(t\right)\right\Vert  & \le\overline{\dot{d}}+\left\Vert \frac{\partial f}{\partial x}\right\Vert \overline{d}\\
 & \le\overline{\dot{d}}+\rho_{9}\left(\left\Vert e\right\Vert \right)\overline{d}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 9
\end_layout

\begin_layout Plain Layout
Since 
\begin_inset Formula $f\in\mathcal{C}^{3}$
\end_inset

,
\begin_inset Formula 
\begin{align*}
\left\Vert \frac{\partial^{2}f}{\partial x^{2}}\left(x\right)-\frac{\partial^{2}f}{\partial x^{2}}\left(\boldsymbol{0}_{n}\right)\right\Vert  & \le\rho_{10}\left(\left\Vert x\right\Vert \right)\left\Vert x\right\Vert \\
\left|\left\Vert \frac{\partial^{2}f}{\partial x^{2}}\left(x\right)\right\Vert -\left\Vert \frac{\partial^{2}f}{\partial x^{2}}\left(\mathbf{0}_{n}\right)\right\Vert \right| & \le\rho_{10}\left(\left\Vert x\right\Vert \right)\left\Vert x\right\Vert \\
\left\Vert \frac{\partial^{2}f}{\partial x^{2}}\left(x\right)\right\Vert  & \le\left\Vert \frac{\partial^{2}f}{\partial x^{2}}\left(\mathbf{0}_{n}\right)\right\Vert +\rho_{10}\left(\left\Vert x\right\Vert \right)\left\Vert x\right\Vert \\
 & \le\left\Vert \frac{\partial^{2}f}{\partial x^{2}}\left(\mathbf{0}_{n}\right)\right\Vert +\rho_{10}\left(\overline{x}_{d}+\left\Vert e\right\Vert \right)\left(\overline{x}_{d}+\left\Vert e\right\Vert \right)\\
 & \le\rho_{11}\left(\left\Vert e\right\Vert \right)
\end{align*}

\end_inset

Therefore,
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\left\Vert \underbrace{\frac{\partial^{2}f}{\partial x^{2}}\left(x\right)d\left(t\right)+\frac{\partial f}{\partial x}\dot{d}\left(t\right)+\ddot{d}\left(t\right)}_{\dot{D}\left(x,t\right)}\right\Vert  & \le\overline{\ddot{d}}+\left\Vert \frac{\partial f}{\partial x}\left(x\right)\right\Vert \overline{\dot{d}}+\left\Vert \frac{\partial^{2}f}{\partial x^{2}}\right\Vert \overline{d}\\
 & \le\overline{\ddot{d}}+\rho_{9}\left(\left\Vert e\right\Vert \right)\overline{\dot{d}}+\rho_{11}\left(\left\Vert e\right\Vert \right)\overline{d}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection
Summary
\end_layout

\begin_layout Plain Layout
Let 
\begin_inset Formula $z\triangleq\left[\begin{array}{cc}
e^{\top} & r^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{2n}$
\end_inset

.
 To start,
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
r & =\dot{e}+k_{1}e\\
r & =\dot{x}_{d}-\dot{x}+k_{1}e\\
\dot{x} & =\dot{x}_{d}-r+k_{1}e\\
\left\Vert \dot{x}\right\Vert  & \le\left\Vert \dot{x}_{d}\right\Vert +\left\Vert r\right\Vert +k_{1}\left\Vert e\right\Vert \\
\left\Vert \dot{x}\right\Vert  & \le\overline{\dot{x}}_{d}+\left\Vert r\right\Vert +k_{1}\left\Vert e\right\Vert 
\end{align*}

\end_inset

Also, 
\begin_inset Formula $\dot{u}\in\mathcal{L}_{\infty}\left(\mathbb{R}_{\ge t_{0}};\mathbb{R}^{m}\right)$
\end_inset

 is needed.
\color red

\begin_inset Formula 
\[
\left\Vert \dot{u}\right\Vert \le\rho_{7}\left(\left\Vert z\right\Vert \right)
\]

\end_inset


\color inherit
Derivative 1:
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{\widetilde{N}}\left(e_{d},\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert  & \le\left\Vert \left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x_{d},u,\widehat{\theta}\right)}-\left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x,u,\widehat{\theta}\right)}\right\Vert \left\Vert \dot{\widehat{\theta}}\right\Vert +\left\Vert \left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x,u,\theta^{\ast}\right)}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\theta^{\ast}\right)}\right\Vert \left\Vert \dot{\kappa}\right\Vert +\left\Vert \left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\widehat{\theta}\right)}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x,u,\widehat{\theta}\right)}\right\Vert \left\Vert \dot{\kappa}_{d}\right\Vert \\
 & \le\eta_{1}\rho_{5}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert +\rho_{4}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert \left\Vert \dot{\kappa}\right\Vert +\rho_{6}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert \left\Vert \dot{\kappa}_{d}\right\Vert \\
 & \le\eta_{1}\rho_{5}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert +\rho_{4}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert \left({\color{red}\left\Vert \dot{x}\right\Vert +\left\Vert \dot{u}\right\Vert }\right)+\rho_{6}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert \left(\left\Vert \dot{x}_{d}\right\Vert +\left\Vert \dot{u}\right\Vert \right)\\
 & \le\eta_{1}\rho_{5}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert +\rho_{4}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert \left(\overline{\dot{x}}_{d}+\left\Vert r\right\Vert +k_{1}\left\Vert e\right\Vert +\left\Vert \dot{u}\right\Vert \right)+\rho_{6}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert \left(\overline{\dot{x}}_{d}+\overline{\dot{u}}\right)\\
 & \le\rho_{12}\left(\left\Vert z\right\Vert \right)
\end{align*}

\end_inset

Derivative 2:
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{N}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert  & \le\left\Vert \left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\widehat{\theta}\right)}-\left.\frac{\partial\Psi}{\partial\kappa}\right|_{\left(x_{d},u,\theta^{\ast}\right)}\right\Vert \left\Vert \dot{\kappa}_{d}\right\Vert +\left\Vert \left.\frac{\partial\Psi}{\partial\theta}\right|_{\left(x_{d},u,\widehat{\theta}\right)}\right\Vert \left\Vert \dot{\widehat{\theta}}\right\Vert \\
 & \le C_{1}\left(\left\Vert \dot{x}_{d}\right\Vert +\left\Vert \dot{u}\right\Vert \right)+C_{2}\eta_{1}\\
 & \le C_{1}\overline{\dot{x}}_{d}+C_{1}\rho_{7}\left(\left\Vert z\right\Vert \right)+C_{2}\eta_{1}
\end{align*}

\end_inset

If 
\begin_inset Formula $x_{d},u\in\mathcal{L}_{\infty}\left(\mathbb{R}_{\ge t_{0}};\mathbb{R}^{n}\right)$
\end_inset

, then 
\begin_inset Formula $\left\Vert \varepsilon\left(\kappa\right)\right\Vert \le\overline{\varepsilon}$
\end_inset

, where 
\begin_inset Formula $\overline{\varepsilon}$
\end_inset

 depends on 
\begin_inset Formula $e$
\end_inset

.
\begin_inset Formula 
\begin{align*}
\left\Vert g\left(t\right)\right\Vert  & \le\left\Vert \widetilde{N}\left(e_{d},\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert +\left\Vert N\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert +\left\Vert \varepsilon\left(\kappa\right)\right\Vert +\left\Vert D\left(x,t\right)\right\Vert \\
 & \le\rho_{2}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert +\rho_{3}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert +C_{1}+\overline{\varepsilon}+\overline{\dot{d}}+\rho_{9}\left(\left\Vert e\right\Vert \right)\overline{d}\\
 & \le\rho_{10}\left(\left\Vert e\right\Vert \right)
\end{align*}

\end_inset

Finally,
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{g}\left(t\right)\right\Vert  & \le\left\Vert \dot{\widetilde{N}}\left(e_{d},\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert +\left\Vert \dot{N}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert +\left\Vert \left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa}\dot{\kappa}\right\Vert +\left\Vert \dot{D}\left(x,t\right)\right\Vert \\
 & \le\rho_{12}\left(\left\Vert z\right\Vert \right)+C_{1}\overline{\dot{x}}_{d}+C_{1}\rho_{7}\left(\left\Vert z\right\Vert \right)+C_{2}\eta_{1}+\left\Vert \left.\frac{d\varepsilon}{d\kappa}\right|_{\kappa}\right\Vert \left(\left\Vert \dot{x}\right\Vert +\left\Vert \dot{u}\right\Vert \right)+\overline{\ddot{d}}+\rho_{9}\left(\left\Vert e\right\Vert \right)\overline{\dot{d}}+\rho_{11}\left(\left\Vert e\right\Vert \right)\overline{d}\\
