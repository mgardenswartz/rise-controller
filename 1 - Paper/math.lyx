Thus,
\begin_inset Formula 
\begin{align*}
\left\Vert N_{B}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert  & \le\overline{N}_{B}\triangleq\sup_{\left\Vert \kappa_{d}\right\Vert \le\overline{\kappa}_{d},\left\Vert \theta^{\ast}\right\Vert \le\overline{\theta},\left\Vert \widehat{\theta}\right\Vert \le\overline{\theta}}\left(\left\Vert N_{B}\left(\kappa_{d},\theta^{\ast},\widehat{\theta}\right)\right\Vert \right)\\
 & =\sup_{\left\Vert \kappa_{d}\right\Vert \le\overline{\kappa}_{d},\left\Vert \theta^{\ast}\right\Vert \le\overline{\theta},\left\Vert \widehat{\theta}\right\Vert \le\overline{\theta}}\left(\left\Vert \Phi\left(\kappa_{d},\widehat{\theta}\right)-\Phi\left(\kappa_{d},\theta^{\ast}\right)\right\Vert \right)
\end{align*}

