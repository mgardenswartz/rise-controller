 & \le\overline{\dot{x}_{d}}+\sigma_{f}\left(\left\Vert e\right\Vert \right)\left\Vert e\right\Vert +C_{f}+\overline{d}+k_{1}\left\Vert e\right\Vert +\left\Vert r\right\Vert \\
 & \le\rho_{u}\left(0\right)+\sigma_{f}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\left(k_{1}+1\right)\left\Vert z\right\Vert 
\end{align*}

