So,
\begin_inset Formula 
\begin{align*}
\dot{P}\left(t\right) & \in\dot{\zeta}\left(t\right)+\dot{\eta}\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\eta\left(t\right)+\phi\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\cancel{r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)}-\lambda_{P}\eta\left(t\right)+\cancel{r_{1}^{\top}\left(t\right)\dot{D}\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)}+\left(k_{2}-\lambda_{P}\right)\zeta\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\eta\left(t\right)+\left(k_{2}-\lambda_{P}\right)\zeta\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\eta\left(t\right)+k_{2}\zeta\left(t\right)-\lambda_{P}\zeta\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\left(\eta\left(t\right)+\zeta\left(t\right)\right)+k_{2}\left(K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-r_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-k_{2}r_{1}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\left(\dot{r}_{1}^{\top}\left(t\right)+k_{2}r_{1}^{\top}\left(t\right)\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}\left\Vert r_{1}\left(t\right)\right\Vert _{1}\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-r_{2}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}\left\Vert r_{1}\left(t\right)\right\Vert _{1}\\
 & \in K_{\text{RISE}}\dot{r}_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-r_{2}^{\top}\left(t\right)D\left(\kappa_{d},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}r_{1}^{\top}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)\\
