u\left(t\right)-u\left(t_{0}\right) & =\intop_{t_{0}}^{t}\left(-\Psi\left(\kappa\left(s\right),\widehat{\theta}\left(s\right)\right)+\beta\text{sgn}\left(e\left(s\right)\right)+\left(k_{1}k_{2}+1\right)e\left(s\right)\right)ds+\intop_{t_{0}}^{t}\left(k_{1}+k_{2}\right)\dot{e}\left(s\right)ds+\intop_{t_{0}}^{t}\ddot{x}_{d}\left(s\right)ds\\
u\left(t\right)-u\left(t_{0}\right) & =\intop_{t_{0}}^{t}\left(-\Psi\left(\kappa\left(s\right),\widehat{\theta}\left(s\right)\right)+\beta\text{sgn}\left(e\left(s\right)\right)+\left(k_{1}k_{2}+1\right)e\left(s\right)\right)ds+\left(k_{1}+k_{2}\right)e\left(t\right)-\left(k_{1}+k_{2}\right)e\left(t_{0}\right)+\dot{x}_{d}\left(t\right)-\dot{x}_{d}\left(t_{0}\right)\\
u\left(t\right)-u\left(t_{0}\right) & =\intop_{t_{0}}^{t}\left(-\Psi\left(\kappa\left(s\right),\widehat{\theta}\left(s\right)\right)+\beta\text{sgn}\left(e\left(s\right)\right)+\left(k_{1}k_{2}+1\right)e\left(s\right)\right)ds+\left(k_{1}+k_{2}\right)\left(e\left(t\right)-e\left(t_{0}\right)\right)+\dot{x}_{d}\left(t\right)-\dot{x}_{d}\left(t_{0}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Subsection
Stability Analysis
\end_layout

\begin_layout Plain Layout
We have
\begin_inset Formula 
\[
\dot{r}=N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\beta\text{sgn}\left(e\right)-e-k_{2}r
\]

\end_inset

And
\begin_inset Formula 
\[
V=\frac{1}{2}e^{\top}e+\frac{1}{2}r^{\top}r+P
\]

\end_inset

Let
\begin_inset Formula 
\[
\dot{P}=-\lambda_{P}P-r^{\top}\left(N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\beta\text{sgn}\left(e\right)\right)
\]

\end_inset

So
\begin_inset Formula 
\begin{align*}
\dot{\widetilde{V}} & =e^{\top}\dot{e}+r^{\top}\dot{r}+\dot{P}\\
 & =e^{\top}\left(r-k_{1}e\right)+r^{\top}\left(N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\beta\text{sgn}\left(e\right)\right)-r^{\top}e-k_{2}r^{\top}r+\dot{P}\\
 & =-k_{1}e^{\top}e-k_{2}r^{\top}r+r^{\top}\left(N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\beta\text{sgn}\left(e\right)\right)+\dot{P}\\
 & =-k_{1}e^{\top}e-k_{2}r^{\top}r+r^{\top}\left(N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\beta\text{sgn}\left(e\right)\right)\\
 & -\lambda_{P}P-r^{\top}\left(N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\beta\text{sgn}\left(e\right)\right)\\
 & =-k_{1}e^{\top}e-k_{2}r^{\top}r-\lambda_{P}P
\end{align*}

\end_inset


\series bold
\bar under
This will be exponentially convergent semi-globally.
\end_layout

\begin_layout Subsection
Solve P Function
\end_layout

\begin_layout Plain Layout
The convolutional integral is defined as the map 
\begin_inset Formula $\mathscr{C}(t):\mathbb{R}_{\geq0}\mapsto\mathbb{R}$
\end_inset

, where
\begin_inset Formula 
\begin{equation}
e^{-\lambda_{P}t}\ast\mathscr{C}(t)=\int_{t_{0}}^{t}e^{-\lambda_{P}(t-\tau)}\mathscr{C}(\tau){\rm d\tau}.\label{eq:convolution-def}
\end{equation}

\end_inset

Using Leibniz's rule, the time derivative of a convolutional integral satisfies
 
\begin_inset Formula $\frac{{\rm d}}{{\rm dt}}(e^{-\lambda_{P}t}\ast\mathscr{C})=\mathscr{C}(t)-\lambda_{P}\int_{t_{0}}^{t}e^{-\lambda_{P}(t-\tau)}\mathscr{C}(\tau){\rm d}\tau$
\end_inset

, which simplifies to 
\begin_inset Formula 
\begin{equation}
\frac{{\rm d}}{{\rm d}t}(e^{-\lambda_{P}t}\ast\mathscr{C})=\mathscr{C}(t)-\lambda_{P}e^{-\lambda_{P}t}\ast\mathscr{C}(t).\label{eq:convolution-fact}
\end{equation}

\end_inset

Facts:
\end_layout

\begin_layout Itemize
Firstly,
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\[
\frac{{\rm d}}{{\rm d}t}\left\Vert x\right\Vert _{1}\overset{\text{a.e.}}{\in}\dot{x}^{\top}K[\text{sgn}](x)
\]

\end_inset


\end_layout

\begin_layout Itemize
Additionally,
\begin_inset Formula 
\begin{align}
\left\Vert x\right\Vert _{1} & =x^{\top}\text{sgn}(x)\nonumber \\
\implies\left\Vert x\right\Vert _{1} & =x^{\top}K[\text{sgn}](x).\label{eq:signum-fact}
\end{align}

\end_inset


\end_layout

\begin_layout Itemize
We also rely heavily on the fact that
\begin_inset Formula 
\[
r=\dot{e}+k_{1}e
\]

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Plain Layout
Write
\begin_inset Formula 
\begin{align*}
\dot{P} & \overset{\text{a.a.t}}{\in}-\lambda_{P}P-r^{\top}\left(N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\beta K[\text{sgn}]\left(e\right)\right)\\
 & \overset{\text{a.a.t}}{\in}-\lambda_{P}P-\left(\dot{e}+k_{1}e\right)^{\top}\left(N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)-\beta K[\text{sgn}]\left(e\right)\right)\\
 & \overset{\text{a.a.t}}{\in}-\lambda_{P}P-\left(\dot{e}+k_{1}e\right)^{\top}\left(\underbrace{N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)-\varepsilon\left(\kappa\right)-D\left(x,t\right)}_{g\left(t\right)}\right)+\left(\dot{e}+k_{1}e\right)^{\top}\beta K[\text{sgn}]\left(e\right)\\
 & \overset{\text{a.a.t}}{\in}-\lambda_{P}P-\dot{e}^{\top}g\left(t\right)-k_{1}e^{\top}g\left(t\right)+\beta\dot{e}^{\top}K[\text{sgn}]\left(e\right)+k_{1}\beta\left\Vert e\right\Vert _{1}
\end{align*}

\end_inset

Let
\begin_inset Formula 
\begin{align*}
Q & =-e^{\top}g\left(t\right)+\beta\left\Vert e\right\Vert _{1}\\
\dot{Q} & =-\dot{e}^{\top}g\left(t\right)-e^{\top}\dot{g}\left(t\right)+\beta\dot{e}^{\top}K[\text{sgn}]\left(e\right)
\end{align*}

\end_inset

So
\begin_inset Formula 
\begin{align*}
\dot{P} & \overset{\text{a.a.t}}{\in}\underbrace{-\lambda_{P}P+k_{1}Q+e^{\top}\dot{g}\left(t\right)}_{\dot{R}}+\dot{Q}\\
 & \overset{\text{a.a.t}}{\in}\dot{R}+\dot{Q}
\end{align*}

\end_inset

Thus
\begin_inset Formula 
\[
P=Q+R
\]

\end_inset

Continue by writing
\begin_inset Formula 
\begin{align*}
\dot{R} & =k_{1}Q+e^{\top}\dot{g}\left(t\right)-\lambda_{P}\left(Q+R\right)\\
\dot{R} & =k_{1}Q+e^{\top}\dot{g}\left(t\right)-\lambda_{P}Q-\lambda_{P}R\\
\dot{R}+\lambda_{P}R & =e^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\\
\dot{R}+\lambda_{P}R & =e^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\\
{\rm e}^{\lambda_{P}\left(t-t_{0}\right)}\left(\dot{R}+\lambda_{P}R\right) & ={\rm e}^{\lambda_{P}\left(t-t_{0}\right)}\left(e^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\right)\\
\frac{d}{dt}\left({\rm e}^{\lambda_{P}\left(t-t_{0}\right)}R\right) & ={\rm e}^{\lambda_{P}\left(t-t_{0}\right)}\left(e^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\right)\\
\intop_{t_{0}}^{t}\frac{d}{d\tau}\left({\rm e}^{\lambda_{P}\left(\tau-t_{0}\right)}R\left(\tau\right)\right)d\tau & =\intop_{t_{0}}^{t}{\rm e}^{\lambda_{P}\left(\tau-t_{0}\right)}\left(e\left(\tau\right)^{\top}\dot{g}\left(\tau\right)+\left(k_{1}-\lambda_{P}\right)Q\left(\tau\right)\right)d\tau\\
{\rm e}^{\lambda_{P}\left(t-t_{0}\right)}R\left(t\right)-\cancelto{0}{R\left(t_{0}\right)} & =\intop_{t_{0}}^{t}{\rm e}^{\lambda_{P}\left(\tau-t_{0}\right)}\left(e\left(\tau\right)^{\top}\dot{g}\left(\tau\right)+\left(k_{1}-\lambda_{P}\right)Q\left(\tau\right)\right)d\tau\\
R\left(t\right) & ={\rm e}^{-\lambda_{P}\left(t-t_{0}\right)}\intop_{t_{0}}^{t}{\rm e}^{\lambda_{P}\left(\tau-t_{0}\right)}\left(e\left(\tau\right)^{\top}\dot{g}\left(\tau\right)+\left(k_{1}-\lambda_{P}\right)Q\left(\tau\right)\right)d\tau\\
R\left(t\right) & =\intop_{t_{0}}^{t}{\rm e}^{-\lambda_{P}\left(t-\tau\right)}\left(e\left(\tau\right)^{\top}\dot{g}\left(\tau\right)+\left(k_{1}-\lambda_{P}\right)Q\left(\tau\right)\right)d\tau\\
R\left(t\right) & ={\rm e}^{\lambda_{P}t}\ast\left(e\left(t\right)^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\left(t\right)\right)
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
P & =\beta\left\Vert e\right\Vert _{1}-e\left(t\right)^{\top}g\left(t\right)+{\rm e}^{\lambda_{P}t}\ast\left(e\left(t\right)^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)Q\left(t\right)\right)\\
 & =\beta\left\Vert e\right\Vert _{1}-e\left(t\right)^{\top}g\left(t\right)+{\rm e}^{\lambda_{P}t}\ast\left(e\left(t\right)^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)\left(-e^{\top}g\left(t\right)+\beta\left\Vert e\right\Vert _{1}\right)\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Subsection
Bounds on d
\end_layout

\begin_layout Plain Layout
We need 
\begin_inset Formula $\left\Vert g\left(t\right)\right\Vert \le\overline{g}$
\end_inset

.
 Assume 
\begin_inset Formula $\left\Vert u\right\Vert \le\overline{u}$
\end_inset

 a priori and 
\begin_inset Formula $x\in\Omega$
\end_inset

 (
\begin_inset Formula $x\in\overline{B}_{R_{\Omega}}\left(\mathbf{0}_{n}\right)$
\end_inset

) a priori and 
\begin_inset Formula $\theta^{\ast},\widehat{\theta}\in\overline{B}_{\overline{\theta}}\left(\boldsymbol{0}_{n}\right)$
\end_inset

 where 
\begin_inset Formula $\overline{\theta}$
\end_inset

 is known.
 Thus,
\begin_inset Formula 
\begin{align*}
\left\Vert g\left(t\right)\right\Vert  & \le\left\Vert N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)\right\Vert +\left\Vert \varepsilon\left(\kappa\right)\right\Vert +\left\Vert D\left(x,t\right)\right\Vert \\
 & \le\overline{N}+\overline{\varepsilon}+\left\Vert \frac{\partial f}{\partial x}d\left(t\right)\right\Vert +\left\Vert \dot{d}\left(t\right)\right\Vert \\
 & \le\underbrace{\overline{f^{\prime}}\overline{d}+\overline{\dot{d}}+\overline{N}+\overline{\varepsilon}}_{\overline{g}}
\end{align*}

\end_inset

Assume 
\begin_inset Formula $\overline{d}$
\end_inset

, 
\begin_inset Formula $\overline{\dot{d}}$
\end_inset

, 
\begin_inset Formula $\overline{f^{\prime}}$
\end_inset

, 
\begin_inset Formula $\overline{\theta}$
\end_inset

, 
\begin_inset Formula $\overline{\varepsilon}$
\end_inset

 and 
\begin_inset Formula $\overline{N}$
\end_inset

 are known where
\begin_inset Formula 
\[
\overline{N}\triangleq\left(\sup_{\kappa,\widehat{\theta},\theta^{\ast}\in\Omega\times B_{\overline{u}}\left(\mathbf{0}_{n}\right)\times\overline{B}_{\overline{\theta}}\left(\boldsymbol{0}_{n}\right)\times\overline{B}_{\overline{\theta}}\left(\boldsymbol{0}_{n}\right)}\left(\Psi\left(\kappa,\widehat{\theta}\right)-\Psi\left(\kappa,\theta^{\ast}\right)\right)\right)
\]

\end_inset


\begin_inset Formula 
\[
\overline{\varepsilon}\triangleq\sup_{\kappa\in\Omega\times B_{\overline{u}}\left(\mathbf{0}_{n}\right)}\left(\varepsilon\left(\kappa\right)\right)
\]

\end_inset

Note that 
\begin_inset Formula $\overline{N}$
\end_inset

 and 
\begin_inset Formula $\overline{\varepsilon}$
\end_inset

 exist by EVT and because the architecture is jointly continuous and 
\begin_inset Formula $h$
\end_inset

 is (at least) 
\begin_inset Formula $\mathcal{C}^{0}$
\end_inset

.
\end_layout

\begin_layout Subsection
Bounds on d_dot
\end_layout

\begin_layout Plain Layout
Recall
\begin_inset Formula 
\[
N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)\triangleq-\Psi\left(\kappa,\theta^{\ast}\right)+\Psi\left(\kappa,\widehat{\theta}\right)
\]

\end_inset

and that
\begin_inset Formula 
\[
D\left(x,t\right)\triangleq\frac{\partial f}{\partial x}d\left(t\right)+\dot{d}\left(t\right)
\]

\end_inset

We have to assume that 
\begin_inset Formula $\left\Vert \dot{u}\right\Vert \le\overline{\dot{u}}$
\end_inset

 a priori and 
\begin_inset Formula $\left\Vert \dot{\widehat{\theta}}\right\Vert \le\eta_{1}$
\end_inset

 (constants are known) a priori.
\end_layout

\begin_layout Subsubsection
Lemma 1
\end_layout

\begin_layout Plain Layout
Since 
\begin_inset Formula $f\in\mathcal{C}^{0}$
\end_inset

, by EVT
\begin_inset Formula 
\[
\overline{f}\triangleq\sup_{x\in\Omega}\left(f\left(x\right)\right)
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 2
\end_layout

\begin_layout Plain Layout
Since 
\begin_inset Formula $f\in\mathcal{C}^{1}$
\end_inset

, by EVT
\begin_inset Formula 
\[
\overline{f^{\prime}}\triangleq\sup_{x\in\Omega}\left(\frac{\partial f}{\partial x}\left(x\right)\right)
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 3
\end_layout

\begin_layout Plain Layout
Since 
\begin_inset Formula $f\in\mathcal{C}^{2}$
\end_inset

, by EVT
\begin_inset Formula 
\[
\overline{f^{\prime\prime}}\triangleq\sup_{x\in\Omega}\left(\frac{\partial^{2}f}{\partial x^{2}}\left(x\right)\right)
\]

\end_inset

We could just have easily have done rho functions but we would need 
\begin_inset Formula $f^{\prime\prime}$
\end_inset

 locally Lipschitz continuous or 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

.
\end_layout

\begin_layout Subsubsection
Lemma 4
\end_layout

\begin_layout Plain Layout
We need
\begin_inset Formula 
\begin{align*}
\frac{d\varepsilon}{d\kappa} & =\frac{d}{d\kappa}h\left(x,u\right)-\frac{\partial\Psi}{\partial\kappa}\left(\kappa,\theta^{\ast}\right)\\
\left\Vert \frac{d\varepsilon}{d\kappa}\right\Vert  & \le\left\Vert \frac{d}{dx}\left(\frac{\partial f}{\partial x}f\left(x\right)+\frac{\partial f}{\partial x}u\right)\right\Vert +\left\Vert \frac{d}{du}\left(\frac{\partial f}{\partial x}f\left(x\right)+\frac{\partial f}{\partial x}u\right)\right\Vert +C_{1}\\
\left\Vert \frac{d\varepsilon}{d\kappa}\right\Vert  & \le\left\Vert \frac{\partial^{2}f}{\partial x^{2}}\right\Vert \left\Vert f\left(x\right)\right\Vert +\left\Vert \frac{\partial f}{\partial x}\right\Vert ^{2}+\left\Vert \frac{\partial^{2}f}{\partial x^{2}}\right\Vert \left\Vert u\right\Vert +\left\Vert \frac{\partial f}{\partial x}\right\Vert +C_{1}\\
\left\Vert \frac{d\varepsilon}{d\kappa}\right\Vert  & \le\underbrace{\overline{f^{\prime\prime}}\overline{f}+\overline{f^{\prime}}^{2}+\overline{f^{\prime\prime}}\overline{u}+\overline{f^{\prime}}+C_{1}}_{\overline{\varepsilon^{\prime}}}
\end{align*}

\end_inset

where
\begin_inset Formula 
\[
C_{1}\triangleq\sup_{\left(\theta^{\ast},\kappa\right)\in\overline{B}_{\overline{\theta}}\left(\boldsymbol{0}_{n}\right)\times\Omega\times B_{\overline{u}}\left(\mathbf{0}_{n}\right)}\left(\left\Vert \frac{\partial\Psi}{\partial\kappa}\left(\kappa,\theta^{\ast}\right)\right\Vert \right)
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 5
\end_layout

\begin_layout Plain Layout
First,
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{x}\right\Vert  & \le\left\Vert f\text{\left(x\right)}\right\Vert +\overline{u}+\overline{d}\\
 & \le\overline{f}+\overline{u}+\overline{d}
\end{align*}

\end_inset

so
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{\kappa}\right\Vert  & \le\left\Vert \dot{x}\right\Vert +\left\Vert \dot{u}\right\Vert \\
 & \le\overline{f}+\overline{u}+\overline{d}+\overline{\dot{u}}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 6
\end_layout

\begin_layout Plain Layout
Let
\begin_inset Formula 
\[
C_{2}\triangleq\sup_{\left(\widehat{\theta},\kappa\right)\in\overline{B}_{\overline{\theta}}\left(\boldsymbol{0}_{n}\right)\times\Omega\times B_{\overline{u}}\left(\mathbf{0}_{n}\right)}\left(\left\Vert \frac{\partial\Psi}{\partial\kappa}\left(\kappa,\widehat{\theta}\right)\right\Vert \right)
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Lemma 7
\end_layout

\begin_layout Plain Layout
Let
\begin_inset Formula 
\[
C_{3}\triangleq\sup_{\left(\widehat{\theta},\kappa\right)\in\overline{B}_{\overline{\theta}}\left(\boldsymbol{0}_{n}\right)\times\Omega\times B_{\overline{u}}\left(\mathbf{0}_{n}\right)}\left(\left\Vert \frac{\partial\Psi}{\partial\theta}\left(\kappa,\widehat{\theta}\right)\right\Vert \right)
\]

\end_inset


\end_layout

\begin_layout Subsubsection
Actually Bounding d dot
\end_layout

\begin_layout Plain Layout
We want 
\begin_inset Formula $\left\Vert \dot{g}\left(t\right)\right\Vert \le\overline{\dot{g}}$
\end_inset

.
\begin_inset Formula 
\begin{align*}
\dot{g} & =\frac{d}{dt}\left(N\left(\kappa,\theta^{\ast},\widehat{\theta}\right)\right)-\frac{d}{dt}\left(\varepsilon\left(\kappa\right)\right)-\frac{d}{dt}\left(D\left(x,t\right)\right)\\
 & =\frac{d}{dt}\left(-\Psi\left(\kappa,\theta^{\ast}\right)+\Psi\left(\kappa,\widehat{\theta}\right)\right)-\frac{d}{dt}\left(\varepsilon\left(\kappa\right)\right)-\frac{d}{dt}\left(\frac{\partial f}{\partial x}d\left(t\right)+\dot{d}\left(t\right)\right)\\
 & =-\frac{\partial\Psi}{\partial\kappa}\left(\kappa,\theta^{\ast}\right)\dot{\kappa}+\frac{\partial\Psi}{\partial\kappa}\left(\kappa,\widehat{\theta}\right)\dot{\kappa}+\frac{\partial\Psi}{\partial\theta}\left(\kappa,\widehat{\theta}\right)\dot{\widehat{\theta}}-\frac{d\varepsilon}{d\kappa}\dot{\kappa}-\left(\frac{\partial^{2}f}{\partial x^{2}}\dot{x}d\left(t\right)+\frac{\partial f}{\partial x}\dot{d}\left(t\right)\right)-\ddot{d}\left(t\right)\\
 & \le\left\Vert \frac{\partial\Psi}{\partial\kappa}\left(\kappa,\theta^{\ast}\right)\right\Vert \left\Vert \dot{\kappa}\right\Vert +\left\Vert \frac{\partial\Psi}{\partial\kappa}\left(\kappa,\widehat{\theta}\right)\right\Vert \left\Vert \dot{\kappa}\right\Vert +\left\Vert \frac{\partial\Psi}{\partial\theta}\left(\kappa,\widehat{\theta}\right)\right\Vert \left\Vert \dot{\widehat{\theta}}\right\Vert +\overline{\varepsilon^{\prime}}\left\Vert \dot{\kappa}\right\Vert +\left\Vert \frac{\partial^{2}f}{\partial x^{2}}\right\Vert \left\Vert \dot{x}\right\Vert \left\Vert d\left(t\right)\right\Vert +\left\Vert \frac{\partial f}{\partial x}\right\Vert \left\Vert \dot{d}\left(t\right)\right\Vert +\left\Vert \ddot{d}\left(t\right)\right\Vert \\
 & \le\underbrace{C_{1}\left(\overline{f}+\overline{u}+\overline{d}+\overline{\dot{u}}\right)+C_{2}\left(\overline{f}+\overline{u}+\overline{d}+\overline{\dot{u}}\right)+C_{3}\eta_{1}+\overline{\varepsilon^{\prime}}\left(\overline{f}+\overline{u}+\overline{d}+\overline{\dot{u}}\right)+\overline{f^{\prime\prime}}\overline{d}\left(\overline{f}+\overline{u}+\overline{d}\right)+\overline{f^{\prime}}\overline{\dot{d}}+\overline{\ddot{d}}}_{\overline{\dot{g}}}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsection
Gain Conditions on P (First Part)
\end_layout

\begin_layout Plain Layout
To make sure 
\begin_inset Formula 
\[
\beta\left\Vert e\right\Vert _{1}-e^{\top}g\left(t\right)\ge0
\]

\end_inset

By Cauchy-Schwartz
\begin_inset Formula 
\begin{align*}
\beta\left\Vert e\right\Vert _{1}-e^{\top}g\left(t\right) & \ge\beta\left\Vert e\right\Vert _{1}-\left\Vert e\right\Vert \left\Vert g\right\Vert 
\end{align*}

\end_inset

By 
\begin_inset Formula $\left\Vert e\right\Vert _{1}\ge\left\Vert e\right\Vert _{2}$
\end_inset

 and Cauchy-Schwartz,
\begin_inset Formula 
\[
\beta\left\Vert e\right\Vert _{1}-e^{\top}g\left(t\right)\ge\beta\left\Vert e\right\Vert -\left\Vert e\right\Vert \left\Vert g\right\Vert 
\]

\end_inset

By 
\begin_inset Formula $\left\Vert g\left(t\right)\right\Vert \le\overline{g}$
\end_inset

,
\begin_inset Formula 
\begin{align*}
\beta\left\Vert e\right\Vert _{1}-e^{\top}g\left(t\right) & \ge\beta\left\Vert e\right\Vert -\left\Vert e\right\Vert \overline{g}\\
 & \ge\left(\beta-\overline{g}\right)\left\Vert e\right\Vert 
\end{align*}

\end_inset

We need (yes, strict)
\begin_inset Formula 
\[
\beta>\overline{g}
\]

\end_inset

and thus it will be that
\begin_inset Formula 
\[
\beta\left\Vert e\left(t\right)\right\Vert _{1}-e\left(t\right)^{\top}g\left(t\right)>0
\]

\end_inset


\end_layout

\begin_layout Subsection
Gain Conditions on P (Second Part)
\end_layout

\begin_layout Plain Layout
For the next gain condition, we need
\begin_inset Formula 
\begin{align*}
e\left(t\right)^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)\left(\underbrace{\beta\left\Vert e\left(t\right)\right\Vert _{1}-e\left(t\right)^{\top}g\left(t\right)}_{c}\right) & \ge0\\
e\left(t\right)^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)c & \ge0
\end{align*}

\end_inset

By Cauchy-Schwartz
\begin_inset Formula 
\[
e\left(t\right)^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)c\ge-\left\Vert e\right\Vert \left\Vert \dot{g}\right\Vert +\left(k_{1}-\lambda_{P}\right)c
\]

\end_inset

By 
\begin_inset Formula $\left\Vert \dot{g}\left(t\right)\right\Vert \le\overline{\dot{g}}$
\end_inset

,
\begin_inset Formula 
\[
e\left(t\right)^{\top}\dot{g}\left(t\right)+\left(k_{1}-\lambda_{P}\right)c\ge-\left\Vert e\right\Vert \overline{\dot{g}}+\left(k_{1}-\lambda_{P}\right)c
\]

\end_inset

Using the bound from before,
