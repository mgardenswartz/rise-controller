\begin_layout Standard
Assume that 
\begin_inset Formula $\left\Vert \nu\right\Vert \le\eta_{1}$
\end_inset

,
 
\begin_inset Formula $\left\Vert \dot{\nu}\right\Vert \le\eta_{2}$
\end_inset

,
 and 
\begin_inset Formula $\left\Vert \ddot{\nu}\right\Vert \le\eta_{3}+\eta_{4}\left\Vert z\right\Vert +\rho_{21}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert $
\end_inset

.
 Thus,
 
\begin_inset Formula $\gamma_{1},\gamma_{3},\gamma_{4}\in\mathbb{R}_{\ge0}$
\end_inset

 and 
\begin_inset Formula $\left\Vert N_{B}\right\Vert \le\gamma_{1}$
\end_inset

,
 
\begin_inset Formula $\left\Vert \dot{N}_{B}\right\Vert \le\gamma_{3}+\gamma_{4}\left\Vert z\right\Vert +\rho_{2}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert $
\end_inset

 and 
\begin_inset Formula $\left\Vert \widetilde{N}\right\Vert \le\gamma_{2}\left\Vert z\right\Vert +\rho_{1}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert $
\end_inset

.
 Proof:
 
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
First,
 let 
\begin_inset Formula $\nu=\widehat{\theta}$
\end_inset

.
\begin_inset Formula 
\begin{align*}
f\left(x,\nu,t\right) & =f_{1}\left(x,t\right)-\Phi\left(x,\widehat{\theta}\right)\\
 & =\Phi\left(x,\theta^{\ast}\right)+\varepsilon\left(x\right)-\Phi\left(x,\widehat{\theta}\right)\\
 & =\frac{\partial\Phi}{\partial\widehat{\theta}}\widetilde{\theta}+R\left(x,\widetilde{\theta}\right)+\varepsilon\left(x\right)
\end{align*}

\end_inset

First
\begin_inset Formula 
\[
\frac{d}{dt}\left(f\left(x_{d},\nu,t\right)\right)=\frac{\partial f}{\partial t}+\left.\frac{\partial f}{\partial x}\right|_{x_{d}}\dot{x}_{d}+\frac{\partial f}{\partial\nu}\dot{\nu}
\]

\end_inset

Assume that 
\begin_inset Formula $\frac{\partial f}{\partial t}$
\end_inset

 is bounded by a constant globally.
 Assume 
\begin_inset Formula $f$
\end_inset

 is 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

.
\begin_inset Formula 
\[
\left\Vert N_{B}\right\Vert \le\left\Vert \frac{\partial f}{\partial t}+\left.\frac{\partial f}{\partial x}\right|_{x_{d}}\dot{x}_{d}+\frac{\partial f}{\partial\nu}\dot{\nu}\right\Vert \le\gamma_{1}
\]

\end_inset

Instead suppose
\begin_inset Formula 
\[
\left\Vert \ddot{\nu}\right\Vert \le\rho_{\nu}\left(\left\Vert z\right\Vert \right)
\]

\end_inset

Write,
\begin_inset Formula 
\begin{align*}
\dot{N}_{B} & =\frac{d}{dt}\left(\frac{\partial f}{\partial t}+\left.\frac{\partial f}{\partial x}\right|_{x_{d}}\dot{x}_{d}+\frac{\partial f}{\partial\nu}\dot{\nu}\right)\\
 & =\frac{\partial^{2}f}{\partial t^{2}}+\left.\frac{\partial f}{\partial x}\right|_{x_{d}}\ddot{x}_{d}+\left.\frac{\partial^{2}f}{\partial x^{2}}\right|_{x_{d}}\dot{x}_{d}+\frac{\partial^{2}f}{\partial\nu^{2}}\dot{\nu}+\frac{\partial f}{\partial\nu}\ddot{\nu}\\
 & \le\rho_{N_{B}}\left(\left\Vert z\right\Vert \right)
\end{align*}

\end_inset

What about 
\begin_inset Formula $\dot{x}$
\end_inset

?
\begin_inset Formula 
\begin{align*}
\dot{e} & =\dot{x}_{d}-\dot{x}\\
\dot{x} & =\dot{e}+\dot{x}_{d}\\
\left\Vert \dot{x}\right\Vert  & \le\left\Vert \dot{e}\right\Vert +\left\Vert \dot{x}_{d}\right\Vert \\
 & \le\overline{\dot{x}}_{d}+\left\Vert r-\alpha e\right\Vert \\
 & \le\overline{\dot{x}}_{d}+\left\Vert r\right\Vert +\alpha\left\Vert e\right\Vert \\
 & \le\overline{\dot{x}}_{d}+\left(\alpha+1\right)\left\Vert z\right\Vert 
\end{align*}

\end_inset

What about 
\begin_inset Formula $\widetilde{N}$
\end_inset

?
\begin_inset Formula 
\begin{align*}
\widetilde{N} & =\frac{d}{dt}\left(f\left(x,\nu,t\right)\right)-\frac{d}{dt}\left(f\left(x_{d},\nu,t\right)\right)\\
 & =\frac{\partial f}{\partial t}+\left.\frac{\partial f}{\partial x}\right|_{x}\dot{x}+\frac{\partial f}{\partial\nu}\dot{\nu}-\frac{\partial f}{\partial t}-\left.\frac{\partial f}{\partial x}\right|_{x_{d}}\dot{x}_{d}-\frac{\partial f}{\partial\nu}\dot{\nu}\\
\left\Vert \widetilde{N}\right\Vert  & \le\left.\frac{\partial f}{\partial x}\right|_{x}\dot{x}-\left.\frac{\partial f}{\partial x}\right|_{x_{d}}\dot{x}_{d}\\
 & {\color{red}\le\left.\frac{\partial f}{\partial x}\right|_{x}\left(\overline{\dot{x}}_{d}+\left(\alpha+1\right)\left\Vert z\right\Vert \right)-\left.\frac{\partial f}{\partial x}\right|_{x_{d}}\dot{x}_{d}}\\
 & {\color{red}\le c_{1}+c_{2}\left\Vert z\right\Vert }\\
 & {\color{red}\le\rho_{\widetilde{N}}\left(\left\Vert z\right\Vert \right)}
\end{align*}

\end_inset

Try again.
 
\begin_inset Formula $g\in\mathcal{C}^{1}$
\end_inset

:
\begin_inset Formula 
\[
g\left(\xi,\dot{\xi}\right)=f\left(\xi\right)\dot{\xi}
\]

\end_inset

By Rushi's lemma,
\begin_inset Formula 
\[
\left\Vert g\left(\xi,\dot{\xi}\right)-g\left(\xi_{d},\dot{\xi}_{d}\right)\right\Vert \le\rho_{g}\left(\left\Vert e_{\xi}\right\Vert \right)\left\Vert e_{\xi}\right\Vert 
\]

\end_inset

where
\begin_inset Formula 
\begin{align*}
e_{\xi} & \triangleq\left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\\
\left\Vert e_{\xi}\right\Vert  & \le\left\Vert e\right\Vert +\left\Vert \dot{e}\right\Vert \\
 & \le\left\Vert r-\alpha e\right\Vert +\left\Vert e\right\Vert \\
 & \le\left\Vert r\right\Vert +\alpha\left\Vert e\right\Vert +\left\Vert e\right\Vert \\
 & \le\left\Vert r\right\Vert +\left(\alpha+1\right)\left\Vert e\right\Vert \\
 & \le\left(\alpha+2\right)\left\Vert z\right\Vert 
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\left\Vert g\left(\xi,\dot{\xi}\right)-g\left(\xi_{d},\dot{\xi}_{d}\right)\right\Vert  & \le\rho_{g}\left(\left(\alpha+2\right)\left\Vert z\right\Vert \right)\left(\alpha+2\right)\left\Vert z\right\Vert \\
 & \le\rho_{\widetilde{N}}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

