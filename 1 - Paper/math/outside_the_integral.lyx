\noun off
\color none
E Error derivative
\begin_inset Formula 
\[
\dot{e}=r_{1}-k_{1}e
\]

\end_inset

R1 Error derivative
\begin_inset Formula 
\[
\dot{r}_{1}=r_{2}-k_{2}r_{1}
\]

\end_inset

Let
\begin_inset Formula 
\[
Q\left(t\right)\triangleq\left[\begin{array}{cccc}
q^{\top}\left(t\right) & \dot{q}^{\top}\left(t\right) & q^{\top}_{d}\left(t\right) & \dot{q}^{\top}_{d}\left(t\right)\end{array}\right]^{\top}\in\mathbb{R}^{4n}
\]

\end_inset


\begin_inset Formula 
\[
Q_{d}\left(t\right)\triangleq\left[\begin{array}{cccc}
q^{\top}_{d}\left(t\right) & \dot{q}^{\top}_{d}\left(t\right) & q^{\top}_{d}\left(t\right) & \dot{q}^{\top}_{d}\left(t\right)\end{array}\right]^{\top}\in\mathbb{R}^{4n}
\]

\end_inset

R2 Error
\begin_inset Formula 
\begin{align*}
r_{2} & =\dot{r}_{1}+k_{2}r_{1}\\
 & =\ddot{e}+k_{1}\dot{e}+k_{2}r_{1}\\
 & =\ddot{q}_{d}-\ddot{q}+k_{1}\dot{e}+k_{2}r_{1}\\
 & =\ddot{q}_{d}-\ddot{q}+k_{1}\dot{e}+k_{2}r_{1}\\
 & =\underbrace{h\left(q_{d},\dot{q}_{d}\right)-f\left(q,\dot{q}\right)}_{F\left(Q\right)}-u-d\left(t\right)+k_{1}\dot{e}+k_{2}r_{1}\\
 & =F\left(Q\right)-u-d+k_{1}\dot{e}+k_{2}r_{1}
\end{align*}

\end_inset

Let
\begin_inset Formula 
\[
u=\Phi\left(Q,\widehat{\theta}\right)+u_{1}
\]

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
r_{2} & =F\left(Q\right)-\left(\Phi\left(Q,\widehat{\theta}\right)+u_{1}\right)-d\left(t\right)+k_{1}\dot{e}+k_{2}r_{1}\\
 & =F\left(Q\right)-\Phi\left(Q,\widehat{\theta}\right)-u_{1}-d\left(t\right)+k_{1}\dot{e}+k_{2}r_{1}\\
 & =\underbrace{F\left(Q\right)-\Phi\left(Q,\theta^{\ast}\right)}_{\varepsilon\left(Q,\theta^{\ast}\right)}+\Phi\left(Q,\theta^{\ast}\right)-\Phi\left(Q,\widehat{\theta}\right)-u_{1}-d\left(t\right)+k_{1}\dot{e}+k_{2}r_{1}\\
 & =\varepsilon\left(Q,\theta^{\ast}\right)+\Phi\left(Q,\theta^{\ast}\right)-\Phi\left(Q,\widehat{\theta}\right)-u_{1}-d\left(t\right)+k_{1}\dot{e}+k_{2}r_{1}\\
 & =\varepsilon\left(Q,\theta^{\ast}\right)+\Phi\left(Q,\theta^{\ast}\right)-\Phi\left(Q,\widehat{\theta}\right)-u_{1}-d\left(t\right)+k_{1}\left(r_{1}-k_{1}e\right)+k_{2}r_{1}\\
 & =\varepsilon\left(Q,\theta^{\ast}\right)-\varepsilon\left(Q_{d},\theta^{\ast}\right)+\varepsilon\left(Q_{d},\theta^{\ast}\right)+\underbrace{\Phi\left(Q,\theta^{\ast}\right)-\Phi\left(Q,\widehat{\theta}\right)}_{N_{0}\left(Q,\theta^{\ast},\hat{\theta}\right)}-u_{1}-d\left(t\right)+\left(k_{1}+k_{2}\right)r_{1}-k^{2}_{1}e\\
 & =\underbrace{\varepsilon\left(Q,\theta^{\ast}\right)-\varepsilon\left(Q_{d},\theta^{\ast}\right)}_{\widetilde{N}_{\varepsilon}\left(Q,Q_{d},\theta^{\ast}\right)}+\varepsilon\left(Q_{d},\theta^{\ast}\right)+\underbrace{N_{0}\left(Q,\theta^{\ast},\hat{\theta}\right)-N_{0}\left(Q_{d},\theta^{\ast},\hat{\theta}\right)}_{\widetilde{N}_{1}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)}+N_{0}\left(Q_{d},\theta^{\ast},\hat{\theta}\right)-u_{1}-d\left(t\right)+\left(k_{1}+k_{2}\right)r_{1}-k^{2}_{1}e\\
 & =\underbrace{\widetilde{N}_{\varepsilon}\left(Q,Q_{d},\theta^{\ast}\right)+\widetilde{N}_{1}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)}_{\widetilde{N}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)}+\underbrace{\varepsilon\left(Q_{d},\theta^{\ast}\right)+N_{0}\left(Q_{d},\theta^{\ast},\hat{\theta}\right)-d\left(t\right)}_{D\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)}-u_{1}+\left(k_{1}+k_{2}\right)r_{1}-k^{2}_{1}e\\
 & =\widetilde{N}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)+D\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)-u_{1}+\left(k_{1}+k_{2}\right)r_{1}-k^{2}_{1}e
\end{align*}

\end_inset

R2 Error derivative
\begin_inset Formula 
\begin{align*}
\dot{r}_{2} & =\dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)+\dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)-\dot{u}_{1}+\left(k_{1}+k_{2}\right)\dot{r}_{1}-k^{2}_{1}\dot{e}\\
 & =\dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)+\dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)-\dot{u}_{1}+\left(k_{1}+k_{2}\right)\left(r_{2}-k_{2}r_{1}\right)-k^{2}_{1}\left(r_{1}-k_{1}e\right)\\
 & =\dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)+\dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)-\dot{u}_{1}+\left(k_{1}+k_{2}\right)\left(r_{2}-k_{2}r_{1}\right)-k^{2}_{1}r_{1}+k^{3}_{1}e\\
 & =\dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)+\dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)-\dot{u}_{1}+\left(k_{1}+k_{2}\right)r_{2}-\left(k_{1}+k_{2}\right)k_{2}r_{1}-k^{2}_{1}r_{1}+k^{3}_{1}e\\
 & =\dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)+\dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)-\dot{u}_{1}+\left(k_{1}r_{2}+k_{2}r_{2}\right)-\left(k_{1}k_{2}+k^{2}_{2}+k^{2}_{1}\right)r_{1}+k^{3}_{1}e
\end{align*}

\end_inset

Design
\begin_inset Formula 
\[
\dot{u}_{1}=\left(k_{1}+k_{2}+k_{3}\right)r_{2}+\left(1-k_{1}k_{2}-k^{2}_{2}-k^{2}_{1}\right)r_{1}+k^{3}_{1}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)
\]

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
\dot{r}_{2} & =\dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)+\dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)-\left(\left(k_{1}+k_{2}+k_{3}\right)r_{2}+\left(1-k_{1}k_{2}-k^{2}_{2}-k^{2}_{1}\right)r_{1}+k^{3}_{1}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)\right)+\left(k_{1}r_{2}+k_{2}r_{2}\right)-\left(k_{1}k_{2}+k^{2}_{2}+k^{2}_{1}\right)r_{1}+k^{3}_{1}e\\
 & =\dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)+\dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)-\left(\cancel{k_{1}+k_{2}}+k_{3}\right)r_{2}-\left(1\cancel{-k_{1}k_{2}-k^{2}_{2}-k^{2}_{1}}\right)r_{1}-\cancel{k^{3}_{1}e}-K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\cancel{\left(k_{1}r_{2}+k_{2}r_{2}\right)}-\cancel{\left(k_{1}k_{2}+k^{2}_{2}+k^{2}_{1}\right)r_{1}}+\cancel{k^{3}_{1}e}\\
 & =\dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)+\dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}-r_{1}-K_{\text{RISE}}\text{sgn}\left(r_{1}\right)\\
 & \in\dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)+\dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}-r_{1}-K_{\text{RISE}}K[\text{sgn}]\left(r_{1}\right)
\end{align*}

\end_inset


