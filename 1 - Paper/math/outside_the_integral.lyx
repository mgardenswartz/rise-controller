\begin_layout Subsubsection*
BOUNDING LEMMA 1.1
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert  & \le\left\Vert e\right\Vert +\left\Vert \dot{e}\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert r_{1}-k_{1}e\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert r_{1}\right\Vert +k_{1}\left\Vert e\right\Vert \\
 & \le\left(k_{1}+1\right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 1.2
\end_layout

\begin_layout Standard
Since 
\begin_inset Formula $q_{d}$
\end_inset

 and 
\begin_inset Formula $\dot{q}_{d}$
\end_inset

 are bounded and 
\begin_inset Formula $f$
\end_inset

 is class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

 in fact),
 there exists a 
\begin_inset Formula $\mathcal{C}^{0}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 in fact) nondecreasing function 
\begin_inset Formula $\sigma_{f}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that
\begin_inset Formula 
\begin{align*}
\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert  & \le\sigma_{f}\left(\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \\
\sigma_{f}\left(s\right) & \triangleq\sup_{\left[\begin{array}{cc}
q^{\top} & \dot{q}^{\top}\end{array}\right]^{\top}\in\overline{B}_{\overline{q}_{d}+\overline{\dot{q}}_{d}+s}\left(0_{2n}\right)}\left(\left\Vert \left.\frac{df}{d\left[\begin{array}{cc}
q^{\top} & \dot{q}^{\top}\end{array}\right]^{\top}}\right|_{\left(q,\dot{q}\right)}\right\Vert \right)
\end{align*}

\end_inset

There exists a class 
\begin_inset Formula $\mathcal{P}_{\infty}$
\end_inset

 function 
\begin_inset Formula $\rho_{f}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that (for some 
\begin_inset Formula $c>0$
\end_inset

)
\begin_inset Formula 
\begin{align*}
\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert  & \le\rho_{f1}\left(\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \\
\rho_{f1}\left(s\right) & \triangleq\sigma_{f}\left(s\right)+cs
\end{align*}

\end_inset

By Bounding Lemma 1.1,
\begin_inset Formula 
\begin{align*}
\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert  & \le\rho_{f1}\left(\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \\
 & \le\underbrace{\rho_{f1}\left(\left(k_{1}+1\right)\left\Vert z\right\Vert \right)\left(k_{1}+1\right)}_{\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)}\left\Vert z\right\Vert \\
 & \le\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Note Note
status collapsed

\begin_layout Subsubsection*
BOUNDING LEMMA 2.1
\end_layout

\begin_layout Plain Layout
The ideal controller 
\begin_inset Formula $u_{d}$
\end_inset

 satisfies
\begin_inset Formula 
\begin{align*}
\ddot{q}_{d} & =f\left(q_{d},\dot{q}_{d}\right)+u_{d}+d\left(t\right)\\
\ddot{q}_{d}-f\left(q_{d},\dot{q}_{d}\right)-d\left(t\right) & =u_{d}\\
u_{d} & =\ddot{q}_{d}-f\left(q_{d},\dot{q}_{d}\right)-d\left(t\right)
\end{align*}

\end_inset

By the stated assumptions and EVT,
 there exists an unknown constant
\begin_inset Formula 
\[
\overline{u}_{d}\triangleq\overline{\ddot{q}}_{d}+\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left(\left\Vert f\left(q_{d},\dot{q}_{d}\right)\right\Vert \right)+\overline{d}
\]

\end_inset

such that
\begin_inset Formula 
\[
\left\Vert u_{d}\right\Vert \le\overline{u}_{d}
\]

\end_inset

We assume this constant is known.
\end_layout

\begin_layout Plain Layout
\begin_inset Note Note
status open

\begin_layout Subsubsection*
BOUNDING LEMMA 2.2
\end_layout

\begin_layout Plain Layout
Taking the derivative of the ideal controller gives
\begin_inset Formula 
\[
\dot{u}_{d}=\dddot{q}_{d}-\left.\frac{\partial f}{\partial q}\right|_{\left(q_{d},\dot{q}_{d}\right)}\dot{q}_{d}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\ddot{q}_{d}-\dot{d}\left(t\right)
\]

\end_inset

By the stated assumptions and EVT,
 there exists an unknown constant
\begin_inset Formula 
\[
\overline{\dot{u}}_{d}\triangleq\overline{\dddot{q}}_{d}+\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left(\left\Vert \left.\frac{\partial f}{\partial q}\right|_{\left(q_{d},\dot{q}_{d}\right)}\right\Vert \right)\overline{\dot{q}}_{d}+\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left(\left\Vert \left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\right\Vert \right)\overline{\ddot{q}}_{d}+\overline{\dot{d}}
\]

\end_inset

such that
\begin_inset Formula 
\[
\left\Vert \dot{u}_{d}\right\Vert \le\overline{\dot{u}}_{d}
\]

\end_inset

We assume this constant is known.
\end_layout

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 2.3
\end_layout

\begin_layout Plain Layout
Define
\begin_inset Formula 
\[
\widetilde{u}\triangleq u_{d}-u
\]

\end_inset

Recall 
\begin_inset Formula $u_{d}$
\end_inset

 satisfies
\begin_inset Formula 
\[
\ddot{q}_{d}=d\left(t\right)+f\left(q_{d},\dot{q}_{d}\right)+u_{d}
\]

\end_inset

Recall 
\begin_inset Formula $u$
\end_inset

 satisfies
\begin_inset Formula 
\[
\ddot{q}=d\left(t\right)+f\left(q,\dot{q}\right)+u
\]

\end_inset

Subtract them
\begin_inset Formula 
\begin{align*}
\ddot{q}_{d}-\ddot{q} & =f\left(q_{d},\dot{q}_{d}\right)+u_{d}-f\left(q,\dot{q}\right)-u\\
\ddot{e} & =f\left(q_{d},\dot{q}_{d}\right)+\widetilde{u}-f\left(q,\dot{q}\right)\\
\ddot{e}-f\left(q_{d},\dot{q}_{d}\right)+f\left(q,\dot{q}\right) & =\widetilde{u}\\
\widetilde{u} & =\ddot{e}-f\left(q_{d},\dot{q}_{d}\right)+f\left(q,\dot{q}\right)
\end{align*}

\end_inset

Recall
\begin_inset Formula 
\begin{align*}
r_{1} & \triangleq\dot{e}+k_{1}e\\
\dot{r}_{1} & =\ddot{e}+k_{1}\dot{e}\\
r_{2} & \triangleq\dot{r}_{1}+k_{2}r_{1}
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
r_{2} & =\ddot{e}+k_{1}\dot{e}+k_{2}r_{1}\\
r_{2}-k_{1}\dot{e}-k_{2}r_{1} & =\ddot{e}\\
\ddot{e} & =r_{2}-k_{1}\dot{e}-k_{2}r_{1}
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\[
\widetilde{u}=r_{2}-k_{1}\dot{e}-k_{2}r_{1}-f\left(q_{d},\dot{q}_{d}\right)+f\left(q,\dot{q}\right)
\]

\end_inset

By Bounding Lemma 1.2,
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{u}\right\Vert  & \le\left\Vert r_{2}\right\Vert +k_{1}\left\Vert \dot{e}\right\Vert +k_{2}\left\Vert r_{1}\right\Vert +\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert \\
 & \le\left\Vert r_{2}\right\Vert +k_{1}\left\Vert r_{1}-k_{1}e\right\Vert +k_{2}\left\Vert r_{1}\right\Vert +\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left\Vert r_{2}\right\Vert +k_{1}\left\Vert r_{1}\right\Vert +k^{2}_{1}\left\Vert e\right\Vert +k_{2}\left\Vert r_{1}\right\Vert +\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left\Vert z\right\Vert +k_{1}\left\Vert z\right\Vert +k^{2}_{1}\left\Vert z\right\Vert +k_{2}\left\Vert z\right\Vert +\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(\underbrace{1+k_{1}+k^{2}_{1}+k_{2}+\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)}_{\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\left\Vert z\right\Vert \\
\left\Vert \widetilde{u}\right\Vert  & \le\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 2.4
\end_layout

\begin_layout Standard
Aside:
\begin_inset Formula 
\begin{align*}
r_{2} & =\dot{r}_{1}+k_{2}r_{1}\\
r_{2} & =\ddot{e}+k_{1}\dot{e}+k_{2}r_{1}\\
r_{2}-k_{1}\dot{e}-k_{2}r_{1} & =\ddot{e}\\
\ddot{e} & =r_{2}-k_{1}\dot{e}-k_{2}r_{1}\\
\ddot{e} & =r_{2}-k_{1}\left(r_{1}-k_{1}e\right)-k_{2}r_{1}\\
\ddot{e} & =r_{2}-k_{1}r_{1}+k^{2}_{1}e-k_{2}r_{1}\\
\ddot{e} & =r_{2}-\left(k_{1}+k_{2}\right)r_{1}+k^{2}_{1}e
\end{align*}

\end_inset

Algebra:
\begin_inset Formula 
\begin{align*}
\ddot{q} & =f\left(q,\dot{q}\right)+u+d\left(t\right)\\
\ddot{q}-f\left(q,\dot{q}\right)-d\left(t\right) & =u\\
u & =\ddot{q}-f\left(q,\dot{q}\right)-d\left(t\right)\\
u & =\ddot{q}-\ddot{q}_{d}+\ddot{q}_{d}-f\left(q,\dot{q}\right)+f\left(q_{d},\dot{q}_{d}\right)-d\left(t\right)\\
u & =\ddot{e}+\ddot{q}_{d}-f\left(q,\dot{q}\right)+f\left(q_{d},\dot{q}_{d}\right)-d\left(t\right)\\
u & =r_{2}-\left(k_{1}+k_{2}\right)r_{1}+k^{2}_{1}e+\ddot{q}_{d}-f\left(q,\dot{q}\right)+f\left(q_{d},\dot{q}_{d}\right)-d\left(t\right)
\end{align*}

\end_inset

So,
\begin_inset Formula 
\begin{align*}
\left\Vert u\right\Vert  & \le\left\Vert r_{2}\right\Vert +\left(k_{1}+k_{2}\right)\left\Vert r_{1}\right\Vert +k^{2}_{1}\left\Vert e\right\Vert +\left\Vert \ddot{q}_{d}\right\Vert +\left\Vert f\left(q_{d},\dot{q}_{d}\right)-f\left(q,\dot{q}\right)\right\Vert +\left\Vert d\left(t\right)\right\Vert \\
 & \le\underbrace{\left\Vert z\right\Vert +\left(k_{1}+k_{2}\right)\left\Vert z\right\Vert +k^{2}_{1}\left\Vert z\right\Vert +\overline{\ddot{q}}_{d}+\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\overline{d}}_{\rho_{u}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\\
 & \le\rho_{u}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.1
\end_layout

\begin_layout Standard
Bound
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{Q}\right\Vert  & \le\overline{\dot{q}}_{d}+\overline{\ddot{q}}_{d}+\left\Vert \ddot{q}\right\Vert +\left\Vert \dot{q}\right\Vert \\
 & \le\overline{\dot{q}}_{d}+\overline{\ddot{q}}_{d}+\left\Vert \ddot{q}\right\Vert +\left\Vert \dot{q}_{d}-\dot{e}\right\Vert \\
 & \le\overline{\dot{q}}_{d}+\overline{\ddot{q}}_{d}+\left\Vert f\left(q,\dot{q}\right)+u+d\left(t\right)\right\Vert +\left\Vert \dot{q}_{d}-\dot{e}\right\Vert \\
 & \le\overline{\dot{q}}_{d}+\overline{\ddot{q}}_{d}+\left\Vert f\left(q,\dot{q}\right)\right\Vert +\left\Vert u\left(t\right)\right\Vert +\left\Vert d\left(t\right)\right\Vert +\overline{\dot{q}}_{d}+\left\Vert \dot{e}\right\Vert \\
 & \le\overline{\dot{q}}_{d}+\overline{\ddot{q}}_{d}+\left\Vert f\left(q,\dot{q}\right)\right\Vert +\left\Vert u\left(t\right)\right\Vert +\left\Vert d\left(t\right)\right\Vert +\overline{\dot{q}}_{d}+\left\Vert r_{1}-k_{1}e\right\Vert \\
 & \le2\overline{\dot{q}}_{d}+\overline{\ddot{q}}_{d}+\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)+f\left(q_{d},\dot{q}_{d}\right)\right\Vert +\left\Vert u\left(t\right)\right\Vert +\left\Vert d\left(t\right)\right\Vert +\left\Vert r_{1}\right\Vert +k_{1}\left\Vert e\right\Vert \\
 & \le2\overline{\dot{q}}_{d}+\overline{\ddot{q}}_{d}+\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert +\left\Vert f\left(q_{d},\dot{q}_{d}\right)\right\Vert +\rho_{u}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)+\overline{d}+\left\Vert z\right\Vert +k_{1}\left\Vert z\right\Vert \\
 & \le\underbrace{2\overline{\dot{q}}_{d}+\overline{\ddot{q}}_{d}+\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\left\Vert f\left(q_{d},\dot{q}_{d}\right)\right\Vert +\rho_{u}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)+\overline{d}+\left\Vert z\right\Vert +k_{1}\left\Vert z\right\Vert }_{\rho_{\dot{Q}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\\
 & \le\rho_{\dot{Q}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.2
\end_layout

\begin_layout Standard
Note that
\begin_inset Formula 
\[
\left\Vert \dot{Q}_{d}\right\Vert \le2\overline{\dot{q}}_{d}+2\overline{\ddot{q}}_{d}
\]

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.3
\end_layout

\begin_layout Standard
Write
\begin_inset Formula 
\begin{align*}
\left\Vert \left[\begin{array}{cc}
Q^{\top} & \dot{Q}^{\top}\end{array}\right]^{\top}-\left[\begin{array}{cc}
Q^{\top}_{d} & \dot{Q}^{\top}_{d}\end{array}\right]^{\top}\right\Vert  & \le\left\Vert e\right\Vert +2\left\Vert \dot{e}\right\Vert +\left\Vert \ddot{e}\right\Vert \\
 & \le\left\Vert e\right\Vert +2\left\Vert r_{1}-k_{1}e\right\Vert +\left\Vert r_{2}-\left(k_{1}+k_{2}\right)r_{1}+k^{2}_{1}e\right\Vert \\
 & \le\left\Vert e\right\Vert +2\left\Vert r_{1}\right\Vert +2k_{1}\left\Vert e\right\Vert +\left\Vert r_{2}\right\Vert +\left(k_{1}+k_{2}\right)\left\Vert r_{1}\right\Vert +k^{2}_{1}\left\Vert e\right\Vert \\
 & \le\left\Vert z\right\Vert +2\left\Vert z\right\Vert +2k_{1}\left\Vert z\right\Vert +\left\Vert z\right\Vert +\left(k_{1}+k_{2}\right)\left\Vert z\right\Vert +k^{2}_{1}\left\Vert z\right\Vert \\
 & \le\left(4+3k_{1}+k_{2}+k^{2}_{1}\right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.4
\end_layout

\begin_layout Standard
Since 
\begin_inset Formula $\Phi$
\end_inset

 is class 2 and 
\begin_inset Formula $\theta^{\ast}$
\end_inset

 is bounded...
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\left\Vert \left(\left.\frac{\partial\Phi}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}\right)\right\Vert  & \le\rho_{\Phi1}\left(\left\Vert \left[\begin{array}{cc}
Q^{\top} & \dot{Q}^{\top}\end{array}\right]^{\top}-\left[\begin{array}{cc}
Q^{\top}_{d} & \dot{Q}^{\top}_{d}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
Q^{\top} & \dot{Q}^{\top}\end{array}\right]^{\top}-\left[\begin{array}{cc}
Q^{\top}_{d} & \dot{Q}^{\top}_{d}\end{array}\right]^{\top}\right\Vert \\
 & \le\underbrace{\rho_{\Phi1}\left(\left(4+3k_{1}+k_{2}+k^{2}_{1}\right)\left\Vert z\right\Vert \right)\left(4+3k_{1}+k_{2}+k^{2}_{1}\right)}_{\rho_{\Phi^{\ast}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\left\Vert z\right\Vert \\
 & \le\rho_{\Phi^{\ast}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset

and also since 
\begin_inset Formula $\widehat{\theta}$
\end_inset

 is bounded...
\begin_inset Formula 
\[
\left\Vert \left(\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}-\left.\frac{\partial\Phi}{\partial Q}\right|_{\left(Q,\widehat{\theta}\right)}\dot{Q}\right)\right\Vert \le\rho_{\widehat{\Phi}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\]

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.5
\end_layout

\begin_layout Standard
Since 
\begin_inset Formula $\varepsilon$
\end_inset

 is class 2 and 
\begin_inset Formula $\widehat{\theta}$
\end_inset

 and 
\begin_inset Formula $\theta^{\ast}$
\end_inset

 are bounded...
\begin_inset Formula 
\begin{align*}
\left\Vert \left(\left.\frac{\partial\varepsilon}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}\right)\right\Vert  & \le\rho_{\varepsilon^{\prime}1}\left(\left\Vert \left[\begin{array}{cc}
Q^{\top} & \dot{Q}^{\top}\end{array}\right]^{\top}-\left[\begin{array}{cc}
Q^{\top}_{d} & \dot{Q}^{\top}_{d}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
Q^{\top} & \dot{Q}^{\top}\end{array}\right]^{\top}-\left[\begin{array}{cc}
Q^{\top}_{d} & \dot{Q}^{\top}_{d}\end{array}\right]^{\top}\right\Vert \\
 & \le\underbrace{\rho_{\varepsilon^{\prime}1}\left(\left(4+3k_{1}+k_{2}+k^{2}_{1}\right)\left\Vert z\right\Vert \right)\left(4+3k_{1}+k_{2}+k^{2}_{1}\right)}_{\rho_{\varepsilon^{\prime}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\left\Vert z\right\Vert \\
 & \le\rho_{\varepsilon^{\prime}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.6
\end_layout

\begin_layout Standard
Since 
\begin_inset Formula $\Phi$
\end_inset

 is class 2 and 
\begin_inset Formula $\widehat{\theta}$
\end_inset

 is bounded...
\begin_inset Formula 
\begin{align*}
\left\Vert \left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q_{d},\widehat{\theta}\right)}-\left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q,\widehat{\theta}\right)}\right\Vert  & \le\rho_{\Phi1}\left(\left\Vert Q_{d}-Q\right\Vert \right)\left\Vert Q_{d}-Q\right\Vert \\
 & \le\rho_{\Phi1}\left(\left\Vert e\right\Vert +\left\Vert \dot{e}\right\Vert \right)\left(\left\Vert e\right\Vert +\left\Vert \dot{e}\right\Vert \right)\\
 & \le\rho_{\Phi1}\left(\left\Vert e\right\Vert +\left\Vert r_{1}-k_{1}e\right\Vert \right)\left(\left\Vert e\right\Vert +\left\Vert r_{1}-k_{1}e\right\Vert \right)\\
 & \le\rho_{\Phi1}\left(\left\Vert e\right\Vert +\left\Vert r_{1}\right\Vert +k_{1}\left\Vert e\right\Vert \right)\left(\left\Vert e\right\Vert +\left\Vert r_{1}\right\Vert +k_{1}\left\Vert e\right\Vert \right)\\
 & \le\underbrace{\rho_{\Phi1}\left(2\left\Vert z\right\Vert +k_{1}\left\Vert z\right\Vert \right)\left(2+k_{1}\right)}_{\rho_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)}\left\Vert z\right\Vert \\
 & \le\rho_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 3.7
\end_layout

\begin_layout Standard
Recall:
\begin_inset Formula 
\begin{align*}
\dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right) & =\dot{\widetilde{N}}_{\varepsilon}\left(Q,Q_{d},\theta^{\ast}\right)+\dot{\widetilde{N}}_{1}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)\\
 & =\frac{d}{dt}\left(\varepsilon\left(Q,\theta^{\ast}\right)-\varepsilon\left(Q_{d},\theta^{\ast}\right)\right)+\frac{d}{dt}\left(N_{0}\left(Q,\theta^{\ast},\hat{\theta}\right)-N_{0}\left(Q_{d},\theta^{\ast},\hat{\theta}\right)\right)\\
 & =\left.\frac{\partial\varepsilon}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}+\left.\frac{\partial\varepsilon}{\partial\theta^{\ast}}\right|_{\left(Q,\theta^{\ast}\right)}\cancelto{0}{\dot{\theta}^{\ast}}-\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}-\left.\frac{\partial\varepsilon}{\partial\theta^{\ast}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\cancelto{0}{\dot{\theta}^{\ast}}+\frac{d}{dt}\left(\Phi\left(Q,\theta^{\ast}\right)-\Phi\left(Q,\widehat{\theta}\right)-\Phi\left(Q_{d},\theta^{\ast}\right)+\Phi\left(Q_{d},\widehat{\theta}\right)\right)\\
 & =\left.\frac{\partial\varepsilon}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}+\frac{d}{dt}\left(\Phi\left(Q,\theta^{\ast}\right)-\Phi\left(Q_{d},\theta^{\ast}\right)-\Phi\left(Q,\widehat{\theta}\right)+\Phi\left(Q_{d},\widehat{\theta}\right)\right)\\
 & =\left.\frac{\partial\varepsilon}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}+\left.\frac{\partial\Phi}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}+\left.\frac{\partial\Phi}{\partial\theta^{\ast}}\right|_{\left(Q,\theta^{\ast}\right)}\cancelto{0}{\dot{\theta}^{\ast}}-\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}-\left.\frac{\partial\Phi}{\partial\theta^{\ast}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\cancelto{0}{\dot{\theta}^{\ast}}+\frac{d}{dt}\left(\Phi\left(Q_{d},\widehat{\theta}\right)-\Phi\left(Q,\widehat{\theta}\right)\right)\\
 & =\left(\left.\frac{\partial\varepsilon}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}\right)+\left(\left.\frac{\partial\Phi}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}\right)+\frac{d}{dt}\left(\Phi\left(Q_{d},\widehat{\theta}\right)-\Phi\left(Q,\widehat{\theta}\right)\right)\\
 & =\left(\left.\frac{\partial\varepsilon}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}\right)+\left(\left.\frac{\partial\Phi}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}\right)+\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}+\left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{\widehat{\theta}}-\left.\frac{\partial\Phi}{\partial Q}\right|_{\left(Q,\widehat{\theta}\right)}\dot{Q}-\left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q,\widehat{\theta}\right)}\dot{\widehat{\theta}}\\
 & =\left(\left.\frac{\partial\varepsilon}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}\right)+\left(\left.\frac{\partial\Phi}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}\right)+\left(\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}-\left.\frac{\partial\Phi}{\partial Q}\right|_{\left(Q,\widehat{\theta}\right)}\dot{Q}\right)+\left(\left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q_{d},\widehat{\theta}\right)}-\left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q,\widehat{\theta}\right)}\right)\dot{\widehat{\theta}}
\end{align*}

\end_inset

In order to develop bounds,
 
\begin_inset Formula $\Phi$
\end_inset

 must be C2.
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{\widetilde{N}}\left(Q,Q_{d},\theta^{\ast},\hat{\theta}\right)\right\Vert  & \le\left\Vert \left.\frac{\partial\varepsilon}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}\right\Vert +\left\Vert \left.\frac{\partial\Phi}{\partial Q}\right|_{\left(Q,\theta^{\ast}\right)}\dot{Q}-\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}\right\Vert +\left\Vert \left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}-\left.\frac{\partial\Phi}{\partial Q}\right|_{\left(Q,\widehat{\theta}\right)}\dot{Q}\right\Vert +\left\Vert \left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q_{d},\widehat{\theta}\right)}-\left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q,\widehat{\theta}\right)}\right\Vert \left\Vert \dot{\widehat{\theta}}\right\Vert \\
 & \le\rho_{\varepsilon^{\prime}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\Phi^{\ast}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\rho_{\widehat{\Phi}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert +\eta_{1}\rho_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(\underbrace{\rho_{\varepsilon^{\prime}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)+\rho_{\Phi^{\ast}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)+\rho_{\widehat{\Phi}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)+\eta_{1}\rho_{\Phi}\left(k_{1},\left\Vert z\right\Vert \right)}_{\rho_{0}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 4.1
\end_layout

\begin_layout Standard
Recall
\begin_inset Formula 
\begin{align*}
\dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right) & =\frac{d}{dt}\left(\varepsilon\left(Q_{d},\theta^{\ast}\right)+N_{0}\left(Q_{d},\theta^{\ast},\hat{\theta}\right)-d\left(t\right)\right)\\
 & =\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}+\left.\frac{\partial\varepsilon}{\partial\theta^{\ast}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\cancelto{0}{\dot{\theta}^{\ast}}-\dot{d}\left(t\right)+\frac{d}{dt}\left(N_{0}\left(Q_{d},\theta^{\ast},\hat{\theta}\right)\right)\\
 & =\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}-\dot{d}\left(t\right)+\frac{d}{dt}\left(\Phi\left(Q_{d},\theta^{\ast}\right)-\Phi\left(Q_{d},\widehat{\theta}\right)\right)\\
 & =\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}-\dot{d}\left(t\right)+\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}+\left.\frac{\partial\Phi}{\partial\theta^{\ast}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\cancelto{0}{\dot{\theta}^{\ast}}-\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}-\left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{\widehat{\theta}}
\end{align*}

\end_inset

By formulation and EVT,
 there exists a constant such that
\begin_inset Formula 
\[
\left\Vert \dot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)\right\Vert \le\overline{\dot{D}}
\]

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 4.2
\end_layout

\begin_layout Standard
Derivative
\begin_inset Formula 
\begin{align*}
\ddot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right) & =\frac{d}{dt}\left(\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}-\dot{d}\left(t\right)+\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}-\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}-\left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{\widehat{\theta}}\right)\\
 & =\left(\left.\frac{\partial^{2}\varepsilon}{\partial^{2}Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}+\left.\frac{\partial^{2}\varepsilon}{\partial Q_{d}\partial\theta^{\ast}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\cancelto{0}{\dot{\theta}^{\ast}}\right)\dot{Q}_{d}+\left.\frac{\partial\varepsilon}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\ddot{Q}_{d}-\ddot{d}\left(t\right)-\left(\left.\frac{\partial^{2}\Phi}{\partial^{2}Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\dot{Q}_{d}+\left.\frac{\partial^{2}\Phi}{\partial Q_{d}\partial\theta^{\ast}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\cancelto{0}{\dot{\theta}^{\ast}}\right)\dot{Q}_{d}-\left.\frac{\partial\Phi}{\partial Q_{d}}\right|_{\left(Q_{d},\theta^{\ast}\right)}\ddot{Q}_{d}-\left(\left.\frac{\partial^{2}\Phi}{\partial\widehat{\theta}\partial Q_{d}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{Q}_{d}+\left.\frac{\partial^{2}\Phi}{\partial^{2}\widehat{\theta}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\dot{\widehat{\theta}}\right)\dot{\widehat{\theta}}-\left.\frac{\partial\Phi}{\partial\widehat{\theta}}\right|_{\left(Q_{d},\widehat{\theta}\right)}\ddot{\widehat{\theta}}
\end{align*}

\end_inset

By formulation and EVT,
 there exists a constant such that
\begin_inset Formula 
\[
\left\Vert \ddot{D}\left(Q_{d},\theta^{\ast},\hat{\theta},t\right)\right\Vert \le\overline{\ddot{D}}
\]

\end_inset


