0.1\\
-0.5\\
0.25\\
1
\end{array}\right]\right)\\
 & =V^{\top}_{0,1}\tanh\left(\left[\begin{array}{c}
-0.4650\\
-0.1250
\end{array}\right]\right)\\
 & =\left[\begin{array}{ccc}
-0.1 & 0.2 & 0.5\\
0.0 & 0.3 & 0.6\\
0.1 & 0.4 & 0.7
