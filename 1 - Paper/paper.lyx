\begin_layout Subsubsection
Forward Propagation:
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\Psi\left(\kappa,\Theta\right) & =\kappa_{1}\\
 & =\Phi_{0}\left(\kappa_{0}^{a},\theta_{0}\right)\\
 & =\varphi_{0,k_{0}}\left(\kappa_{0}^{a}\right)\\
 & =V_{0,k_{0}}^{\top}\phi_{0,k_{0}}\left(\varphi_{0,k_{0}-1}\left(\kappa_{0}^{a}\right)\right)\\
 & =V_{0,k_{0}}^{\top}\phi_{0,k_{0}}\left(V_{0,k_{0}-1}^{\top}\phi_{0,k_{0}-1}\left(\varphi_{0,k_{0}-2}\left(\kappa_{0}^{a}\right)\right)\right)\\
 & =V_{0,k_{0}}^{\top}\phi_{0,k_{0}}\left(V_{0,k_{0}-1}^{\top}\phi_{0,k_{0}-1}\left(V_{0,k_{0}-2}^{\top}\phi_{0,k_{0}-2}\left(\varphi_{0,k_{0}-3}\left(\kappa_{0}^{a}\right)\right)\right)\right)\\
 & =V_{0,k_{0}}^{\top}\phi_{0,k_{0}}\left(V_{0,k_{0}-1}^{\top}\phi_{0,k_{0}-1}\left(V_{0,k_{0}-2}^{\top}\phi_{0,k_{0}-2}\left(\ldots V_{0,1}^{\top}\phi_{0,1}\left(V_{0,0}^{\top}\kappa_{0}^{a}\right)\right)\right)\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\Psi\left(\kappa,\Theta\right) & =V_{0,k_{0}}^{\top}\phi_{0,k_{0}}\left(V_{0,k_{0}-1}^{\top}\phi_{0,k_{0}-1}\left(V_{0,k_{0}-2}^{\top}\phi_{0,k_{0}-1}\left(\ldots\phi_{0,1}\left(V_{0,0}^{\top}\kappa_{0}^{a}\right)\right)\right)\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection
Backward Propagation:
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\[
\nabla_{\Theta}\Psi\left(\kappa,\Theta\right)=\left[\begin{array}{cccc}
\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}\Psi\left(\kappa,\Theta\right) & \frac{\partial}{\partial\mathrm{vec}\left(V_{0,1}\right)}\Psi\left(\kappa,\Theta\right) & \cdots & \frac{\partial}{\partial\mathrm{vec}\left(V_{0,k_{0}}\right)}\Psi\left(\kappa,\Theta\right)\end{array}\right]
\]

\end_inset


\begin_inset Formula $\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}\Psi\left(\kappa,\theta\right)$
\end_inset

 is
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}\Psi\left(\kappa,\Theta\right) & =\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}\Phi_{0}\left(\kappa_{0}^{a},\theta_{0}\right)\\
 & =\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}V_{0,k_{0}}^{\top}\phi_{0,k_{0}}\left(V_{0,k_{0}-1}^{\top}\phi_{0,k_{0}-1}\left(V_{0,k_{0}-2}^{\top}\phi_{0,k_{0}-2}\left(\ldots V_{0,1}^{\top}\phi_{0,1}\left(V_{0,0}^{\top}\kappa_{0}^{a}\right)\right)\right)\right)\\
 & =V_{0,k_{0}}^{\top}\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}\phi_{0,k_{0}}\left(V_{0,k_{0}-1}^{\top}\phi_{0,k_{0}-1}\left(V_{0,k_{0}-2}^{\top}\phi_{0,k_{0}-2}\left(\ldots V_{0,1}^{\top}\phi_{0,1}\left(V_{0,0}^{\top}\kappa_{0}^{a}\right)\right)\right)\right)\\
 & =V_{0,k_{0}}^{\top}\frac{\partial\phi_{0,k_{0}}}{\partial\varphi_{0,k_{0}-1}}\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}V_{0,k_{0}-1}^{\top}\phi_{0,k_{0}-1}\left(V_{0,k_{0}-2}^{\top}\phi_{0,k_{0}-2}\left(\ldots V_{0,1}^{\top}\phi_{0,1}\left(V_{0,0}^{\top}\kappa_{0}^{a}\right)\right)\right)\\
 & =V_{0,k_{0}}^{\top}\frac{\partial\phi_{0,k_{0}}}{\partial\varphi_{0,k_{0}-1}}V_{0,k_{0}-1}^{\top}\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}\phi_{0,k_{0}-1}\left(V_{0,k_{0}-2}^{\top}\phi_{0,k_{0}-2}\left(\ldots V_{0,1}^{\top}\phi_{0,1}\left(V_{0,0}^{\top}\kappa_{0}^{a}\right)\right)\right)\\
 & =V_{0,k_{0}}^{\top}\frac{\partial\phi_{0,k_{0}}}{\partial\varphi_{0,k_{0}-1}}V_{0,k_{0}-1}^{\top}\frac{\partial\phi_{0,k_{0}-1}}{\partial\varphi_{0,k_{0}-2}}\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}V_{0,k_{0}-2}^{\top}\phi_{0,k_{0}-2}\left(\ldots V_{0,1}^{\top}\phi_{0,1}\left(V_{0,0}^{\top}\kappa_{0}^{a}\right)\right)\\
 & =V_{0,k_{0}}^{\top}\frac{\partial\phi_{0,k_{0}}}{\partial\varphi_{0,k_{0}-1}}V_{0,k_{0}-1}^{\top}\frac{\partial\phi_{0,k_{0}-1}}{\partial\varphi_{0,k_{0}-2}}V_{0,k_{0}-2}^{\top}\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}\phi_{0,k_{0}-2}\left(\ldots V_{0,1}^{\top}\phi_{0,1}\left(V_{0,0}^{\top}\kappa_{0}^{a}\right)\right)\\
 & =V_{0,k_{0}}^{\top}\frac{\partial\phi_{0,k_{0}}}{\partial\varphi_{0,k_{0}-1}}V_{0,k_{0}-1}^{\top}\frac{\partial\phi_{0,k_{0}-1}}{\partial\varphi_{0,k_{0}-2}}V_{0,k_{0}-2}^{\top}\frac{\phi_{0,k_{0}-2}}{\varphi_{0,k_{0}-3}}\ldots\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}V_{0,1}^{\top}\phi_{0,1}\left(V_{0,0}^{\top}\kappa_{0}^{a}\right)\\
 & =V_{0,k_{0}}^{\top}\frac{\partial\phi_{0,k_{0}}}{\partial\varphi_{0,k_{0}-1}}V_{0,k_{0}-1}^{\top}\frac{\partial\phi_{0,k_{0}-1}}{\partial\varphi_{0,k_{0}-2}}V_{0,k_{0}-2}^{\top}\frac{\phi_{0,k_{0}-2}}{\varphi_{0,k_{0}-3}}\ldots V_{0,1}^{\top}\frac{\partial}{\partial\mathrm{vec}\left(V_{0,0}\right)}\phi_{0,1}\left(V_{0,0}^{\top}\kappa_{0}^{a}\right)\\
