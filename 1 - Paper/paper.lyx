0.4 & -0.7 & 0.2\\
0.1 & 0.0 & -0.1
\end{array}\right]\cdot\frac{\partial\phi_{2,1}}{\partial\left[\begin{array}{c}
0.3481\\
0.2564
\end{array}\right]}\left(I_{L_{2,1}}\otimes\psi_{2}\left(\kappa_{2}\right)\right)\\
 & =\left[\begin{array}{ccc}
0.7 & 0.6 & 0.5\\
0.4 & -0.7 & 0.2\\
