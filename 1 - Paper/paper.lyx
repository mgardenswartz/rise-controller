, and 
\begin_inset Formula $\left\Vert \dddot{q}_{d}\left(t\right)\right\Vert \le\overline{\dddot{q}}_{d}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge0}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
The control objective to is to design a controller such that 
\begin_inset Formula $q$
\end_inset

 converges exponentially to 
\begin_inset Formula $q_{d}$
\end_inset

 despite the presence of non-vanishing disturbances, unknown dynamics, and
 lack of knowledge of 
\begin_inset Formula $\ddot{q}_{d}$
\end_inset

.
 We introduce the tracking component of the ideal controller 
\begin_inset Formula $u_{d}:\mathbb{R}_{\ge0}\to\mathbb{R}^{n}$
\end_inset

 as
\begin_inset Formula 
\begin{equation}
u_{d}\left(t\right)\triangleq d\left(t\right)+f\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-\ddot{q}_{d}\left(t\right).\label{eq:u_d}
\end{equation}

\end_inset

Note that since all terms in (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:u_d"
plural "false"
caps "false"
noprefix "false"

\end_inset

) are unknown, 
\begin_inset Formula $u_{d}$
\end_inset

 is unknown.
\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "asm:ud_bounded"

\end_inset

 There exist a known constants 
\begin_inset Formula $\overline{f},\overline{\dot{f}}\in\mathbb{R}_{\ge0}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert f\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)\right\Vert \le\overline{f}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{f}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)\right\Vert \le\overline{\dot{f}}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge0}$
\end_inset

.
\begin_inset Foot
status collapsed

\begin_layout Plain Layout
We emphasize that 
\begin_inset Formula $f$
\end_inset

 and 
\begin_inset Formula $\dot{f}$
\end_inset

 themselves need not be bounded.
 Since 
\begin_inset Formula $f$
\end_inset

 is of class 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

 and 
\begin_inset Formula $q_{d}$
\end_inset

 and 
\begin_inset Formula $\dot{q}_{d}$
\end_inset

 are bounded, there exists a bound follows by extreme value theorem.
 Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:ud_bounded"
plural "false"
caps "false"
noprefix "false"

\end_inset

 assumes that a bound on 
\begin_inset Formula $f$
\end_inset

 and 
\begin_inset Formula $\dot{f}$
\end_inset

 long these trajectories is known.
\end_layout

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
By Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:ud_bounded"
plural "false"
caps "false"
noprefix "false"

\end_inset

, there exist known bounds 
\begin_inset Formula $\overline{u}_{d}\triangleq\overline{d}+\overline{f}+\overline{\ddot{q}}_{d}$
\end_inset

 and 
\begin_inset Formula $\overline{\dot{u}}_{d}\triangleq\overline{\dddot{q}}_{d}+\overline{\dot{f}}\overline{\dot{q}}_{d}+\overline{\dot{f}}\overline{\ddot{q}}_{d}+\overline{\dot{d}}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert u_{d}\left(t\right)\right\Vert \le\overline{u}_{d}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{u}_{d}\left(t\right)\right\Vert \le\overline{\dot{u}}_{d}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge0}$
\end_inset

.
\begin_inset Note Note
status collapsed

\begin_layout Subsubsection*
BOUNDING LEMMA 2.1
\end_layout

\begin_layout Plain Layout
The ideal controller 
\begin_inset Formula $u_{d}$
\end_inset

 satisfies
\begin_inset Formula 
\begin{align*}
\ddot{q}_{d} & =f\left(q_{d},\dot{q}_{d}\right)+u_{d}+d\left(t\right)\\
\ddot{q}_{d}-f\left(q_{d},\dot{q}_{d}\right)-d\left(t\right) & =u_{d}\\
u_{d} & =\ddot{q}_{d}-f\left(q_{d},\dot{q}_{d}\right)-d\left(t\right)
\end{align*}

\end_inset

By the stated assumption and EVT, there exists a known constant
\begin_inset Formula 
\begin{align*}
\overline{u}_{d} & \triangleq\overline{\ddot{q}}_{d}+\underbrace{\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left(\left\Vert f\left(q_{d},\dot{q}_{d}\right)\right\Vert \right)}_{\overline{f}}+\overline{d}\\
 & =\overline{\ddot{q}}_{d}+\overline{f}+\overline{d}
\end{align*}

\end_inset

such that
\begin_inset Formula 
\[
\left\Vert u_{d}\right\Vert \le\overline{u}_{d}
\]

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 2.2
\end_layout

\begin_layout Plain Layout
Taking the derivative of the ideal controller gives
\begin_inset Formula 
\[
\dot{u}_{d}=\dddot{q}_{d}-\left.\frac{\partial f}{\partial q}\right|_{\left(q_{d},\dot{q}_{d}\right)}\dot{q}_{d}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\ddot{q}_{d}-\dot{d}\left(t\right)
\]

\end_inset

By the stated assumptions and EVT, there exists a known constant
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{u}_{d}\right\Vert  & \le\overline{\dddot{q}}_{d}+\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left(\left\Vert \left.\frac{\partial f}{\partial q}\right|_{\left(q_{d},\dot{q}_{d}\right)}\right\Vert \right)\overline{\dot{q}}_{d}+\sup_{\left(q_{d},\dot{q}_{d}\right)\in\overline{B}_{\overline{q}_{d}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{d}}\left(0_{n}\right)}\left(\left\Vert \left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\right\Vert \right)\overline{\ddot{q}}_{d}+\overline{\dot{d}}\\
 & \le\underbrace{\overline{\dddot{q}}_{d}+\overline{\dot{f}}\overline{\dot{q}}_{d}+\overline{\dot{f}}\overline{\ddot{q}}_{d}+\overline{\dot{d}}}_{\overline{\dot{u}}_{d}}
\end{align*}

\end_inset

such that
\begin_inset Formula 
\[
\left\Vert \dot{u}_{d}\right\Vert \le\overline{\dot{u}}_{d}
\]

\end_inset


\end_layout

\end_inset

 Subsequent analysis requires a bound on the difference 
\begin_inset Formula $\widetilde{u}\triangleq u_{d}-u$
\end_inset

 in terms of the ensemble system state 
\begin_inset Formula $z:\mathcal{I}\to\mathbb{R}^{3n}$
\end_inset

 defined as 
\begin_inset Formula $z\left(t\right)\triangleq\left[\begin{array}{ccc}
e^{\top}\left(t\right) & r_{1}^{\top}\left(t\right) & r_{2}^{\top}\left(t\right)\end{array}\right]^{\top}$
\end_inset

.
\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "asm:rho_f"

\end_inset

 There exists a known function 
\begin_inset Formula $\rho_{f}:\mathbb{R}_{\ge0}\times\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 that is class 
\begin_inset Formula $\mathcal{P}_{\infty}$
\end_inset

 with respect to each argument such that 
\begin_inset Formula $\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert \le\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert $
\end_inset

 for all 
\begin_inset Formula $q_{d}$
\end_inset

 and 
\begin_inset Formula $\dot{q}_{d}$
\end_inset

 satisfying Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:h-C2-bounded"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Remove continuity requirements.
\end_layout

\end_inset


\begin_inset Note Note
status collapsed

\begin_layout Subsubsection*
BOUNDING LEMMA 1.1
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert  & \le\left\Vert e\right\Vert +\left\Vert \dot{e}\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert r_{1}-k_{1}e\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert r_{1}\right\Vert +k_{1}\left\Vert e\right\Vert \\
 & \le\left(k_{1}+1\right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 1.2
\end_layout

\begin_layout Plain Layout
Since 
\begin_inset Formula $q_{d}$
\end_inset

 and 
\begin_inset Formula $\dot{q}_{d}$
\end_inset

 are bounded and 
\begin_inset Formula $f$
\end_inset

 is class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

 in fact), by Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:non-decreasing-continuous-bound"
plural "false"
caps "false"
noprefix "false"

\end_inset

, there exists a 
\begin_inset Formula $\mathcal{C}^{0}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 in fact) nondecreasing function 
\begin_inset Formula $\sigma_{f}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that
\begin_inset Formula 
\begin{align*}
\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert  & \le\sigma_{f}\left(\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \\
\sigma_{f}\left(s\right) & \triangleq\sup_{\left[\begin{array}{cc}
q^{\top} & \dot{q}^{\top}\end{array}\right]^{\top}\in\overline{B}_{\overline{q}_{d}+\overline{\dot{q}}_{d}+s}\left(0_{2n}\right)}\left(\left\Vert \left.\frac{df}{d\left[\begin{array}{cc}
q^{\top} & \dot{q}^{\top}\end{array}\right]^{\top}}\right|_{\left(q,\dot{q}\right)}\right\Vert \right)
\end{align*}

\end_inset

By Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:strictly-increasing"
plural "false"
caps "false"
noprefix "false"

\end_inset

, there exists a class 
\begin_inset Formula $\mathcal{P}_{\infty}$
\end_inset

 function 
\begin_inset Formula $\rho_{f}:\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 such that (for some 
\begin_inset Formula $c>0$
\end_inset

)
\begin_inset Formula 
\begin{align*}
\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert  & \le\rho_{f1}\left(\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \\
\rho_{f1}\left(s\right) & \triangleq\sigma_{f}\left(s\right)+cs
\end{align*}

\end_inset

By Bounding Lemma 1.1,
\begin_inset Formula 
\begin{align*}
\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert  & \le\rho_{f1}\left(\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \right)\left\Vert \left[\begin{array}{cc}
e^{\top} & \dot{e}^{\top}\end{array}\right]^{\top}\right\Vert \\
 & \le\underbrace{\rho_{f1}\left(\left(k_{1}+1\right)\left\Vert z\right\Vert \right)\left(k_{1}+1\right)}_{\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)}\left\Vert z\right\Vert \\
 & \le\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
Subtracting (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:u_d"
plural "false"
caps "false"
noprefix "false"

\end_inset

) from (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:agent-dynamics"
plural "false"
caps "false"
noprefix "false"

\end_inset

) and using (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:r1_def"
plural "false"
caps "false"
noprefix "false"

\end_inset

), (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:r2_def"
plural "false"
caps "false"
noprefix "false"

\end_inset

), and the time derivative of (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:r2_def"
plural "false"
caps "false"
noprefix "false"

\end_inset

) gives that
\begin_inset Formula 
\begin{equation}
\widetilde{u}\left(t\right)=r_{2}\left(t\right)-k_{1}\dot{e}\left(t\right)-k_{2}r_{1}\left(t\right)-f\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)+f\left(q\left(t\right),\dot{q}\left(t\right)\right),\label{eq:u_tilde}
\end{equation}

\end_inset

for all 
\begin_inset Formula $t\in\mathcal{I}$
\end_inset

.
 (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:u_tilde"
plural "false"
caps "false"
noprefix "false"

\end_inset

) can be bound as 
\begin_inset Formula $\left\Vert \widetilde{u}\right\Vert \le\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert $
\end_inset

 by Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:rho_f"
plural "false"
caps "false"
noprefix "false"

\end_inset

 where 
\begin_inset Formula $\rho_{\widetilde{u}}:\mathbb{R}_{\ge0}\times\mathbb{R}_{\ge0}\times\mathbb{R}_{\ge0}\to\mathbb{R}_{\ge0}$
\end_inset

 is class 
\begin_inset Formula $\mathcal{P}_{\infty}$
\end_inset

 with respect to each argument defined as 
\begin_inset Formula $\rho_{\widetilde{u}}\left(k_{1},k_{2},s\right)\triangleq1+k_{1}+k_{1}^{2}+k_{2}+\rho_{f}\left(k_{1},s\right)$
\end_inset

.
\begin_inset Note Note
status collapsed

\begin_layout Subsubsection*
BOUNDING LEMMA 2.4
\end_layout

\begin_layout Plain Layout
Define
\begin_inset Formula 
\[
\widetilde{u}\triangleq u_{d}-u
\]

\end_inset

Recall 
\begin_inset Formula $u_{d}$
\end_inset

 satisfies
\begin_inset Formula 
\[
\ddot{q}_{d}=d\left(t\right)+f\left(q_{d},\dot{q}_{d}\right)+u_{d}
\]

\end_inset

Recall 
\begin_inset Formula $u$
\end_inset

 satisfies
\begin_inset Formula 
\[
\ddot{q}=d\left(t\right)+f\left(q,\dot{q}\right)+u
\]

\end_inset

Subtract them
\begin_inset Formula 
\begin{align*}
\ddot{q}_{d}-\ddot{q} & =f\left(q_{d},\dot{q}_{d}\right)+u_{d}-f\left(q,\dot{q}\right)-u\\
\ddot{e} & =f\left(q_{d},\dot{q}_{d}\right)+\widetilde{u}-f\left(q,\dot{q}\right)\\
\ddot{e}-f\left(q_{d},\dot{q}_{d}\right)+f\left(q,\dot{q}\right) & =\widetilde{u}\\
\widetilde{u} & =\ddot{e}-f\left(q_{d},\dot{q}_{d}\right)+f\left(q,\dot{q}\right)
\end{align*}

\end_inset

Recall
\begin_inset Formula 
\begin{align*}
r_{1} & \triangleq\dot{e}+k_{1}e\\
\dot{r}_{1} & =\ddot{e}+k_{1}\dot{e}\\
r_{2} & \triangleq\dot{r}_{1}+k_{2}r_{1}
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\begin{align*}
r_{2} & =\ddot{e}+k_{1}\dot{e}+k_{2}r_{1}\\
r_{2}-k_{1}\dot{e}-k_{2}r_{1} & =\ddot{e}\\
\ddot{e} & =r_{2}-k_{1}\dot{e}-k_{2}r_{1}
\end{align*}

\end_inset

Thus,
\begin_inset Formula 
\[
\widetilde{u}=r_{2}-k_{1}\dot{e}-k_{2}r_{1}-f\left(q_{d},\dot{q}_{d}\right)+f\left(q,\dot{q}\right)
\]

\end_inset

By Bounding Lemma 1.2,
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{u}\right\Vert  & \le\left\Vert r_{2}\right\Vert +k_{1}\left\Vert \dot{e}\right\Vert +k_{2}\left\Vert r_{1}\right\Vert +\left\Vert f\left(q,\dot{q}\right)-f\left(q_{d},\dot{q}_{d}\right)\right\Vert \\
 & \le\left\Vert r_{2}\right\Vert +k_{1}\left\Vert r_{1}-k_{1}e\right\Vert +k_{2}\left\Vert r_{1}\right\Vert +\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left\Vert r_{2}\right\Vert +k_{1}\left\Vert r_{1}\right\Vert +k_{1}^{2}\left\Vert e\right\Vert +k_{2}\left\Vert r_{1}\right\Vert +\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left\Vert z\right\Vert +k_{1}\left\Vert z\right\Vert +k_{1}^{2}\left\Vert z\right\Vert +k_{2}\left\Vert z\right\Vert +\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(\underbrace{1+k_{1}+k_{1}^{2}+k_{2}+\rho_{f}\left(k_{1},\left\Vert z\right\Vert \right)}_{\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\left\Vert z\right\Vert \\
\left\Vert \widetilde{u}\right\Vert  & \le\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

