reference "eq:r1_def"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

),
 (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:r2_def"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

),
 and (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:r2-step-2"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

),
 the evolution of 
\begin_inset Formula $z$
\end_inset

 is a Filippov solution to the initial value problem,
\begin_inset Formula 
\begin{equation}
\dot{z}\in G\left(t,z\right),\quad z\left(t_{0}\right)=z_{0},\label{IVP}
\end{equation}

\end_inset

where 
\begin_inset Formula $z_{0}\in\mathbb{R}^{3n}$
\end_inset

 is the initial ensemble error and 
\begin_inset Formula $G:\mathbb{R}^{3n}\times\mathbb{R}_{\geq0}\rightrightarrows\mathbb{R}^{3n}$
\end_inset

 is the set-valued map
\begin_inset Formula 
\begin{align*}
G\left(z,t\right) & \triangleq\left\{ \left[\begin{array}{c}
r_{1}-k_{1}e\\
r_{2}-k_{2}r_{1}\\
\widetilde{N}\left(\kappa,\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}-r_{1}-K_{\text{RISE}}\nu+D_{t}
\end{array}\right]\right.\\
 & \left.:\nu\in K[\text{sgn}]\left(r_{1}\right)\right\} .
\end{align*}

\end_inset

To establish exponential convergence to the origin for the system given by (
\begin_inset CommandInset ref
LatexCommand ref
reference "IVP"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

),
 an auxiliary function called a 
\begin_inset Formula $P$
\end_inset

-function is introduced.
 Sufficient conditions to ensure that the 
\begin_inset Formula $P$
\end_inset

-function is nonnegative are presented next.
\end_layout

\begin_layout Standard
Consider an arbitrary Filippov solution 
\begin_inset Formula $t\mapsto z\left(t\right)$
\end_inset

 of (
\begin_inset CommandInset ref
LatexCommand ref
reference "IVP"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) on 
\begin_inset Formula $\mathcal{T}$
\end_inset

.
 Define 
\begin_inset Formula $\zeta\left(t\right)\triangleq K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-r^{\top}_{1}\left(t\right)D_{t}$
\end_inset

 and 
\begin_inset Formula $\phi\left(t\right)\triangleq r^{\top}_{1}\left(t\right)\dot{D}_{t}+\left(k_{2}-\lambda_{P}\right)\zeta\left(t\right)$
\end_inset

,
 where 
\begin_inset Formula $\lambda_{P}\in\mathbb{R}_{>0}$
\end_inset

.
 Since 
\begin_inset Formula $r_{1}$
\end_inset

 is absolutely continuous on 
\begin_inset Formula $\mathcal{T}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \cdot\right\Vert _{1}$
\end_inset

 is globally Lipschitz,
 
\begin_inset Formula $t\mapsto\left\Vert r_{1}\left(t\right)\right\Vert _{1}$
\end_inset

 is absolutely continuous;
 since 
\begin_inset Formula $t\mapsto D_{t}$
\end_inset

 is absolutely continuous,
 
\begin_inset Formula $\zeta$
\end_inset

 is absolutely continuous and 
\begin_inset Formula $\phi$
\end_inset

 is measurable and locally integrable on 
\begin_inset Formula $\mathcal{T}$
\end_inset

.
 Let 
\begin_inset Formula $\eta:\mathcal{T}\to\mathbb{R}$
\end_inset

 be the unique absolutely continuous solution of 
\begin_inset Formula $\dot{\eta}\left(t\right)=-\lambda_{P}\eta\left(t\right)+\phi\left(t\right)$
\end_inset

 with 
\begin_inset Formula $\eta\left(t_{0}\right)=0$
\end_inset

,
 and define the 
\begin_inset Formula $P$
\end_inset

-function 
\begin_inset Formula $P:\mathcal{T}\to\mathbb{R}$
\end_inset

 as
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
P\left(t\right)\triangleq\zeta\left(t\right)+\eta\left(t\right).\label{P-function}
\end{equation}

\end_inset

By the nonsmooth chain rule in 
\begin_inset CommandInset citation
LatexCommand cite
after "Theorem 2.2"
key "Shevitz1994"
literal "false"

\end_inset

,
 
\begin_inset Formula $\frac{{\rm d}}{{\rm d}t}\left\Vert r_{1}\left(t\right)\right\Vert _{1}\in\dot{r}^{\top}_{1}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)$
\end_inset

 for almost all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

,
 and 
\begin_inset Formula $r^{\top}_{1}\nu=\left\Vert r_{1}\right\Vert _{1}$
\end_inset

 for all 
\begin_inset Formula $\nu\in K[\text{sgn}]\left(r_{1}\right)$
\end_inset

.
 Therefore,
 differentiating (
\begin_inset CommandInset ref
LatexCommand ref
reference "P-function"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) and using (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:r2_def"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) and (
\begin_inset CommandInset ref
LatexCommand ref
reference "P-function"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) yields
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{P}\left(t\right) & \in\dot{\zeta}\left(t\right)+\dot{\eta}\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}^{\top}_{1}\left(t\right)K[\text{sgn}\left(r_{1}\left(t\right)\right)-\dot{r}^{\top}_{1}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-r^{\top}_{1}\left(t\right)\dot{D}\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\eta\left(t\right)+\phi\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}^{\top}_{1}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}^{\top}_{1}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\cancel{r^{\top}_{1}\left(t\right)\dot{D}\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)}-\lambda_{P}\eta\left(t\right)+\cancel{r^{\top}_{1}\left(t\right)\dot{D}\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)}+\left(k_{2}-\lambda_{P}\right)\zeta\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}^{\top}_{1}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}^{\top}_{1}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\eta\left(t\right)+\left(k_{2}-\lambda_{P}\right)\zeta\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}^{\top}_{1}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}^{\top}_{1}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\eta\left(t\right)+k_{2}\zeta\left(t\right)-\lambda_{P}\zeta\left(t\right)\\
 & \in K_{\text{RISE}}\dot{r}^{\top}_{1}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}^{\top}_{1}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}\left(\eta\left(t\right)+\zeta\left(t\right)\right)+k_{2}\left(K_{\text{RISE}}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-r^{\top}_{1}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)\right)\\
 & \in K_{\text{RISE}}\dot{r}^{\top}_{1}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\dot{r}^{\top}_{1}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}\left\Vert r_{1}\left(t\right)\right\Vert _{1}-k_{2}r^{\top}_{1}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)\\
 & \in K_{\text{RISE}}\dot{r}^{\top}_{1}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-\left(\dot{r}^{\top}_{1}\left(t\right)+k_{2}r^{\top}_{1}\left(t\right)\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}\left\Vert r_{1}\left(t\right)\right\Vert _{1}\\
 & \in K_{\text{RISE}}\dot{r}^{\top}_{1}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-r^{\top}_{2}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}\left\Vert r_{1}\left(t\right)\right\Vert _{1}\\
 & \in K_{\text{RISE}}\dot{r}^{\top}_{1}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-r^{\top}_{2}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)+K_{\text{RISE}}k_{2}r^{\top}_{1}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)\\
 & \in K_{\text{RISE}}\left(\dot{r}^{\top}_{1}\left(t\right)+k_{2}r^{\top}_{1}\left(t\right)\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-r^{\top}_{2}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)\\
 & \in K_{\text{RISE}}r^{\top}_{2}\left(t\right)K[\text{sgn}]\left(r_{1}\left(t\right)\right)-r^{\top}_{2}\left(t\right)D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-\lambda_{P}P\left(t\right)\\
 & \in-\lambda_{P}P\left(t\right)+r^{\top}_{2}\left(t\right)\left(K_{\text{RISE}}K[\text{sgn}]\left(r_{1}\left(t\right)\right)-D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{alignat}{1}
\dot{P} & \in\left\{ -\lambda_{P}P+r^{\top}_{2}\left(t\right)\left(K_{\text{RISE}}\nu-D_{t}\right):\nu\in K[\text{sgn}]\left(r_{1}\left(t\right)\right)\right\} .\label{eq:PDot}
\end{alignat}

\end_inset


\end_layout

\begin_layout Proposition
\begin_inset CommandInset label
LatexCommand label
name "prop:P-positive"

\end_inset

 For the 
\begin_inset Formula $P$
\end_inset

-function defined in (
\begin_inset CommandInset ref
LatexCommand ref
reference "P-function"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

),
 if 
\begin_inset Formula $K_{\text{RISE}}\ge\overline{D}+\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}$
\end_inset

 where 
\begin_inset Formula $k_{2}>\lambda_{P}$
\end_inset

,
 then 
\begin_inset Formula $P\left(t\right)\geq0$
\end_inset

 for all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

.
\end_layout

\begin_layout Proof
Since the architecture mapping 
\begin_inset Formula $\Phi$
\end_inset

,
 domain of approximation 
\begin_inset Formula $\Omega$
\end_inset

,
 function 
\begin_inset Formula $F$
\end_inset

,
 and parameter search space 
\begin_inset Formula $\mho$
\end_inset

 are all time-invariant,
 
\begin_inset Formula $\Theta^{\ast}$
\end_inset

 is also time-invariant.
 Thus,
 
\begin_inset Formula $\dot{\theta}^{\ast}=0_{{\tt p}}$
\end_inset

 for any 
\begin_inset Formula $\theta^{\ast}\in\mho$
\end_inset

.
 Using this fact,
 the continuity of 
\begin_inset Formula $\Phi$
\end_inset

,
 and the fact that 
\begin_inset Formula $\left\Vert \kappa_{\text{d}}\left(t\right)\right\Vert $
\end_inset

,
 
\begin_inset Formula $\left\Vert \dot{\kappa}_{\text{d}}\left(t\right)\right\Vert $
\end_inset

,
 
\begin_inset Formula $\left\Vert \varepsilon\left(\kappa_{\text{d}}\left(t\right),\theta^{\ast}\right)\right\Vert $
\end_inset

,
 and 
\begin_inset Formula $\left\Vert \left.\frac{\partial\varepsilon}{\partial\kappa}\right|_{\left(\kappa_{\text{d}}\left(t\right),\theta^{\ast}\right)}\right\Vert $
\end_inset

 are bounded by known constants for all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

,
 EVT,
 Property 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:bounded-weights"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

,
 and Assumptions 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:qd-bounds"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

,
 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:d-bounds"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

,
 and 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:f-prime"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 ensure that there exist known constants 
\begin_inset Formula $\overline{D},\overline{\dot{D}}\in\mathbb{R}_{\ge0}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert D_{t}\right\Vert \le\overline{D}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{D}_{t}\right\Vert \le\overline{\dot{D}}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

.
\begin_inset Note Note
status open

\begin_layout Subsubsection*
BOUNDING LEMMA 4.1
\end_layout

\begin_layout Plain Layout
Recall
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right) & \triangleq-\dot{d}\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}d\left(t\right)+\varepsilon\left(\kappa_{\text{d}},\theta^{\ast}\right)+N_{0}\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta}\right)\\
 & =-\dot{d}\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}d\left(t\right)+\varepsilon\left(\kappa_{\text{d}},\theta^{\ast}\right)+\Phi\left(\kappa_{\text{d}},\theta^{\ast}\right)-\Phi\left(\kappa_{\text{d}},\hat{\theta}\right)
\end{align*}

\end_inset

By Bounding Lemma 2.3 and 
\begin_inset Formula $f\in\mathcal{C}^{1}$
\end_inset

 and EVT,
 there exists a known constant
\begin_inset Formula 
\begin{align*}
\overline{D} & \triangleq\overline{\dot{d}}+\overline{d}\sup_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)\in\overline{B}_{\overline{q}_{\text{d}}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{\text{d}}}\left(0_{n}\right)}\left\Vert \left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\right\Vert \\
 & +\sup_{\left(\kappa_{\text{d}},\theta^{\ast},\widehat{\theta}\right)\in\overline{B}_{\overline{\kappa}_{\text{d}}}\left(0_{5n}\right)\times\overline{B}_{\overline{\theta}}\left(0_{p}\right)\times\overline{B}_{\overline{\theta}}\left(0_{p}\right)}\left\Vert \Phi\left(\kappa_{\text{d}},\theta^{\ast}\right)-\Phi\left(\kappa_{\text{d}},\hat{\theta}\right)\right\Vert +\sup_{\left(\kappa_{\text{d}},\theta^{\ast}\right)\in\overline{B}_{\overline{\kappa}_{\text{d}}}\left(0_{5n}\right)\times\overline{B}_{\overline{\theta}}\left(0_{{\tt p}}\right)}\left\Vert \varepsilon\left(\kappa_{\text{d}},\theta^{\ast}\right)\right\Vert \\
\\\left\Vert D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)\right\Vert  & \le\overline{D}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 4.2
\end_layout

\begin_layout Plain Layout
Differentiate
\begin_inset Formula 
\begin{align*}
\dot{D}\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right) & =-\ddot{d}\left(t\right)-\left(\left.\frac{\partial f}{\partial\dot{q}\partial q}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\dot{q}_{\text{d}}+\left.\frac{\partial^{2}f}{\partial\dot{q}^{2}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\ddot{q}_{\text{d}}\right)d\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\dot{d}\left(t\right)+\left.\frac{\partial\varepsilon}{\partial\kappa}\right|_{\left(\kappa_{\text{d}}\left(t\right),\theta^{\ast}\right)}\dot{\kappa}_{\text{d}}\\
 & +\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{\text{d}},\theta^{\ast}\right)}\dot{\kappa}_{\text{d}}+\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{\text{d}},\theta^{\ast}\right)}\cancelto{0_{p}}{\dot{\theta}^{\ast}}-\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{\text{d}},\widehat{\theta}\right)}\dot{\kappa}_{\text{d}}-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{\text{d}},\widehat{\theta}\right)}\dot{\widehat{\theta}}\\
\\ & =-\ddot{d}\left(t\right)-\left(\left.\frac{\partial f}{\partial\dot{q}\partial q}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\dot{q}_{\text{d}}+\left.\frac{\partial^{2}f}{\partial\dot{q}^{2}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\ddot{q}_{\text{d}}\right)d\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\dot{d}\left(t\right)+\left.\frac{\partial\varepsilon}{\partial\kappa}\right|_{\left(\kappa_{\text{d}}\left(t\right),\theta^{\ast}\right)}\dot{\kappa}_{\text{d}}\\
 & +\left(\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{\text{d}},\theta^{\ast}\right)}-\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{\text{d}},\widehat{\theta}\right)}\right)\dot{\kappa}_{\text{d}}-\left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{\text{d}},\widehat{\theta}\right)}\dot{\widehat{\theta}}
\end{align*}

\end_inset

By 
\begin_inset Formula $\frac{d\varepsilon}{d\kappa}\in\mathcal{C}^{0}$
\end_inset

,
 
\begin_inset Formula $\frac{\partial\Phi}{\partial\theta}\in\mathcal{C}^{0}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 in fact),
 
\begin_inset Formula $\frac{\partial\Phi}{\partial\kappa}\in\mathcal{C}^{0}$
\end_inset

 (
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 in fact),
 EVT and Bounding Lemma 2.6,
 there exists a known constant
\begin_inset Formula 
\begin{align*}
\overline{\dot{D}} & \triangleq\overline{\ddot{d}}+\overline{d}\overline{\dot{q}}_{\text{d}}\sup_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)\in\overline{B}_{\overline{q}_{\text{d}}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{\text{d}}}\left(0_{n}\right)}\left\Vert \left.\frac{\partial f}{\partial\dot{q}\partial q}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\right\Vert +\overline{d}\overline{\ddot{q}}_{\text{d}}\sup_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)\in\overline{B}_{\overline{q}_{\text{d}}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{\text{d}}}\left(0_{n}\right)}\left\Vert \left.\frac{\partial^{2}f}{\partial\dot{q}^{2}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\right\Vert \\
 & +\overline{\dot{d}}\sup_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)\in\overline{B}_{\overline{q}_{\text{d}}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{\text{d}}}\left(0_{n}\right)}\left\Vert \left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\right\Vert +\overline{\dot{\kappa}}_{\text{d}}\overline{\varepsilon}_{d}\\
 & +\overline{\dot{\kappa}}_{\text{d}}\sup_{\left(\kappa_{\text{d}},\theta^{\ast},\widehat{\theta}\right)\in\overline{B}_{\overline{\kappa}_{\text{d}}}\left(0_{5n}\right)\times\overline{B}_{\overline{\theta}}\left(0_{p}\right)\times\overline{B}_{\overline{\theta}}\left(0_{p}\right)}\left\Vert \left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{\text{d}},\theta^{\ast}\right)}-\left.\frac{\partial\Phi}{\partial\kappa}\right|_{\left(\kappa_{\text{d}},\widehat{\theta}\right)}\right\Vert \\
 & +\overline{\dot{\theta}}\sup_{\left(\kappa_{\text{d}},\widehat{\theta}\right)\in\overline{B}_{\overline{\kappa}_{\text{d}}}\left(0_{5n}\right)\times\overline{B}_{\overline{\theta}}\left(0_{p}\right)}\left\Vert \left.\frac{\partial\Phi}{\partial\theta}\right|_{\left(\kappa_{\text{d}},\widehat{\theta}\right)}\right\Vert 
\end{align*}

\end_inset


\end_layout

\end_inset

 Using the Cauchy-Schwarz inequality and 
\begin_inset Formula $\left\Vert r_{1}\right\Vert \leq\left\Vert r_{1}\right\Vert _{1}$
\end_inset

 yields 
\begin_inset Formula $-r^{\top}_{1}\left(t\right)D_{t}\geq-\left\Vert r_{1}\left(t\right)\right\Vert \left\Vert D_{t}\right\Vert \geq-\overline{D}\left\Vert r_{1}\left(t\right)\right\Vert _{1}$
\end_inset

 and 
\begin_inset Formula $r^{\top}_{1}\left(t\right)\dot{D}_{t}\geq-\left\Vert r_{1}\left(t\right)\right\Vert \left\Vert \dot{D}_{t}\right\Vert \geq-\overline{\dot{D}}\left\Vert r_{1}\left(t\right)\right\Vert _{1}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

.
 Hence,
 
\begin_inset Formula $\zeta\left(t\right)\geq\left(K_{\text{RISE}}-\overline{D}\right)\left\Vert r_{1}\left(t\right)\right\Vert _{1}$
\end_inset

 and 
\begin_inset Formula $\phi\left(t\right)\geq\left(\left(k_{2}-\lambda_{P}\right)\left(K_{\text{RISE}}-\overline{D}\right)-\overline{\dot{D}}\right)\left\Vert r_{1}\left(t\right)\right\Vert _{1}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

.
 If 
\begin_inset Formula $K_{\text{RISE}}\ge\overline{D}+\frac{\overline{\dot{D}}}{k_{2}-\lambda_{P}}$
\end_inset

 where 
\begin_inset Formula $k_{2}>\lambda_{P}$
\end_inset

,
 then 
\begin_inset Formula $\left(k_{2}-\lambda_{P}\right)\left(K_{\text{RISE}}-\overline{D}\right)-\overline{\dot{D}}>0$
\end_inset

,
 so 
\begin_inset Formula $\phi\left(t\right)\geq0$
\end_inset

 for all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

.
 The definition of 
\begin_inset Formula $\dot{\eta}$
\end_inset

 yields 
\begin_inset Formula $\eta\left(t\right)=\int^{t}_{t_{0}}{\rm e}^{-\lambda_{P}\left(t-\tau\right)}\phi\left(\tau\right){\rm d}\tau$
\end_inset

.
 Because 
\begin_inset Formula ${\rm e}^{-\lambda_{P}\left(t-\tau\right)}\geq0$
\end_inset

 for all 
\begin_inset Formula $\tau\in\left[t_{0},t\right]$
\end_inset

 and 
\begin_inset Formula $\phi\left(\tau\right)\geq0$
\end_inset

 for all 
\begin_inset Formula $\tau\in\left[t_{0},t\right]$
\end_inset

,
 it follows that 
\begin_inset Formula $\eta\left(t\right)\geq0$
\end_inset

 for all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

.
 Moreover,
 
\begin_inset Formula $K_{\text{RISE}}>\overline{D}$
\end_inset

 implies 
\begin_inset Formula $\zeta\left(t\right)\geq0$
\end_inset

 for all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

.
 Therefore,
 
\begin_inset Formula $P\left(t\right)=\zeta\left(t\right)+\eta\left(t\right)\geq0$
\end_inset

 for all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
Define the augmented ensemble error state 
\begin_inset Formula $z_{P}:\mathcal{T}\to\mathbb{R}^{3n+1}$
\end_inset

 as 
\begin_inset Formula $z_{P}\triangleq\left[\begin{array}{cc}
z^{\top} & P\end{array}\right]^{\top}$
\end_inset

.
 Using (
\begin_inset CommandInset ref
LatexCommand ref
reference "IVP"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) and (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:PDot"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

),
 the evolution of 
\begin_inset Formula $z_{P}$
\end_inset

 is a Filippov solution to the augmented initial value problem 
\begin_inset Formula 
\begin{equation}
\dot{z}_{P}\in\psi\left(z_{P},t\right),\hspace{1em}z_{P}\left(t_{0}\right)=z_{P,0},\label{eq:closed-loop-error-system}
\end{equation}

\end_inset

where 
\begin_inset Formula $z_{P,0}\triangleq\left[\begin{array}{cc}
z^{\top}_{0} & P\left(t_{0}\right)\end{array}\right]^{\top}$
\end_inset

 and 
\begin_inset Formula $\psi:\mathbb{R}^{4n+1}\times\mathbb{R}_{\geq0}\rightrightarrows\mathbb{R}^{4n+1}$
\end_inset

 is the set-valued map
\begin_inset Formula 
\begin{align*}
\psi\left(z_{P},t\right) & \triangleq\left\{ \left[\begin{array}{c}
\xi\\
-\lambda_{P}P+r^{\top}_{2}\left(K_{\text{RISE}}\upsilon_{P}-D_{t}\right)
\end{array}\right]\right..\\
 & \left.:\left(\begin{array}{c}
\xi\in G\left(z,t\right),\\
\upsilon_{P}\in K[\text{sgn}]\left(r_{1}\right)
\end{array}\right)\right\} .
\end{align*}

\end_inset

Since 
\begin_inset Formula $K[\text{sgn}]\left(r_{1}\right)$
\end_inset

 is nonempty,
 compact,
 convex for every 
\begin_inset Formula $r_{1}\in\mathbb{R}^{n}$
\end_inset

,
 and since 
\begin_inset Formula $G\left(z,t\right)$
\end_inset

 is formed from affine functions of 
\begin_inset Formula $z$
\end_inset

,
 
\begin_inset Formula $D_{t}$
\end_inset

,
 and 
\begin_inset Formula $\nu$
\end_inset

,
 
\begin_inset Formula $G\left(z,t\right)$
\end_inset

 is a nonempty,
 compact,
 convex subset of 
\begin_inset Formula $\mathbb{R}^{3n}$
\end_inset

.
 Thus,
 each value of 
\begin_inset Formula $\psi\left(z_{P},t\right)$
\end_inset

 is a nonempty,
 compact,
 convex subset of 
\begin_inset Formula $\mathbb{R}^{3n+1}$
\end_inset

.
 The graph of 
\begin_inset Formula $K[\text{sgn}]\left(r_{1}\right)$
\end_inset

 is closed,
 
\begin_inset Formula $t\mapsto D_{t}$
\end_inset

 is continuous,
 and all remaining dependencies in 
\begin_inset Formula $G$
\end_inset

 and in 
\begin_inset Formula $\left(z_{P},\upsilon_{P},t\right)\mapsto-\lambda_{P}P+r^{\top}_{2}\left(K_{\text{RISE}}\upsilon_{P}-D_{t}\right)$
\end_inset

 are continuous in their corresponding variables,
 so 
\begin_inset Formula $\psi$
\end_inset

 is upper semicontinuous in 
\begin_inset Formula $\left(z_{P},t\right)$
\end_inset

.
 For every bounded cylinder 
\begin_inset Formula $Z_{P}\subset\mathbb{R}_{\geq0}\times\mathbb{R}^{3n+1}$
\end_inset

,
 the quantities 
\begin_inset Formula $e,r_{1},r_{2}$
\end_inset

 and 
\begin_inset Formula $P$
\end_inset

 are bounded on 
\begin_inset Formula $Z_{P}$
\end_inset

,
 and every 
\begin_inset Formula $\nu\in\text{SGN}\left(s\right)$
\end_inset

 satisfies 
\begin_inset Formula $\left\Vert \nu\right\Vert \leq\sqrt{n}$
\end_inset

.
 Since 
\begin_inset Formula $\left|-\lambda_{P}P+r^{\top}_{2}\left(K_{\text{RISE}}\upsilon_{P}-D_{t}\right)\right|\leq\lambda_{P}\left|P\right|+\left\Vert r_{2}\right\Vert \left(\overline{D}+K_{\text{RISE}}\sqrt{n}\right)$
\end_inset

,
 all the components of 
\begin_inset Formula $G\left(z,t\right)$
\end_inset

 are bounded on 
\begin_inset Formula $Z_{P}$
\end_inset

.
 Thus,
 
\begin_inset Formula $\psi$
\end_inset

 has nonempty,
 bounded,
 closed convex values,
 is upper semicontinuous,
 and is locally bounded on bounded cylinders.
 By Filippov’s existence theorem for differential inclusions in 
\begin_inset CommandInset citation
LatexCommand cite
after "Chapter 2, §7, Theorem 1"
key "Filippov1988"
literal "false"

\end_inset

,
 for each 
\begin_inset Formula $z_{P,0}\in\mathbb{R}^{4n+1}$
\end_inset

,
 there exists a maximal existence time 
\begin_inset Formula $T_{\max}\in\left(t_{0},\infty\right]$
\end_inset

 and at least one absolutely continuous Filippov solution 
\begin_inset Formula $z_{P}:\mathcal{T}\to\mathbb{R}^{3n+1}$
\end_inset

 satisfying 
\begin_inset Formula $\dot{z}_{P}\in\psi\left(z_{P},t\right)$
\end_inset

 for almost all 
\begin_inset Formula $t\in\mathcal{T}$
\end_inset

 and 
\begin_inset Formula $z_{P}\left(t_{0}\right)=z_{P,0}$
\end_inset

.
 A solution similarly exists for (
\begin_inset CommandInset ref
LatexCommand ref
reference "IVP"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

).
\end_layout

\begin_layout Standard
By studying solutions to (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:closed-loop-error-system"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

),
 sufficient conditions are presented next to ensure completeness and exponential convergence of all Filippov solutions to (
\begin_inset CommandInset ref
LatexCommand ref
reference "IVP"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) with initial states 
\begin_inset Formula $z_{0}$
\end_inset

 lying in a prescribed compact ball that can be made arbitrarily large.
\end_layout

\begin_layout Theorem
Let 
\begin_inset Formula $\lambda\in\mathbb{R}_{>0}$
\end_inset

 be a desired convergence rate.
 Let 
\begin_inset Formula $\Delta\in\mathbb{R}_{>0}$
\end_inset

 be a radius for a desired region of attraction for an initial ensemble error 
\begin_inset Formula $z_{0}\in\mathcal{S}\triangleq\left\{ \zeta\in\mathbb{R}^{3n}:\left\Vert \zeta\right\Vert \le\Delta\right\} $
\end_inset

.
 Select 
\begin_inset Formula $k_{1},k_{2},k_{3},K_{\text{RISE}}\in\mathbb{R}_{>0}$
\end_inset

 such that 
\begin_inset Formula $k_{1}\ge1+\lambda$
\end_inset

,
 
\begin_inset Formula $k_{2}>\max\left\{ 1+\lambda,2\lambda\right\} $
\end_inset

,
 
\begin_inset Formula $K_{\text{RISE}}\ge\overline{D}+\frac{\overline{\dot{D}}}{k_{2}-2\lambda}$
\end_inset

,
 and 
\begin_inset Formula $k_{3}\ge\lambda+\rho\left(k_{1},k_{2},C_{\Delta}\right)$
\end_inset

,
 where 
\begin_inset Formula $C_{\Delta}\triangleq\sqrt{\Delta^{2}+2C_{P}\Delta}$
\end_inset

,
 
\begin_inset Formula $C_{P}\triangleq\overline{D}+K_{\text{RISE}}\sqrt{n}$
\end_inset

,
 and 
\begin_inset Formula $\rho\left(k_{1},k_{2},s\right)\triangleq\rho^{2}_{0}\left(k_{1},k_{2},s\right)+\rho_{0}\left(k_{1},k_{2},s\right)$
\end_inset

.
 Suppose that Assumptions 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:qd-bounds"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

-
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:f-prime"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 hold and that the chosen update law and initialization method for 
\begin_inset Formula $\widehat{\theta}$
\end_inset

 satisfy Properties 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:theta_bar"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

-
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:weight-initialization"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 for the approximation domain 
\begin_inset Formula $\Omega$
\end_inset

 with radius 
\begin_inset Formula $R_{\Omega}=\overline{\kappa}$
\end_inset

,
 where 
\begin_inset Formula $\overline{\kappa}$
\end_inset

 is defined according to the 
\begin_inset Formula $C_{\Delta}$
\end_inset

 that follows from the given 
\begin_inset Formula $\Delta$
\end_inset

 and selected gains.
 Then,
 the controller in 
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:u_implementable"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 guarantees that all Filippov solutions to (
\begin_inset CommandInset ref
LatexCommand ref
reference "IVP"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

)
\emph on
 
\emph default
with 
\begin_inset Formula $\left(z_{0},t_{0}\right)\in\mathcal{S}\times\mathbb{R}_{\ge0}$
\end_inset

 are complete and converge to the origin with the estimate
\begin_inset Formula 
\begin{equation}
\left\Vert z\left(t\right)\right\Vert \le\alpha\left(\left\Vert z_{0}\right\Vert \right){\rm e}^{-\lambda\left(t-t_{0}\right)},\label{eq:envelope}
\end{equation}

\end_inset

for almost all 
\begin_inset Formula $t\in\mathbb{R}_{\ge t_{0}}$
\end_inset

,
 where 
\begin_inset Formula $\alpha\left(s\right)\triangleq\sqrt{s^{2}+2C_{P}s}.$
\end_inset

 Consequentially,
 
\begin_inset Formula $z=0_{3n}$
\end_inset

 is uniformly semi-globally asymptotically stable (USAS) for (
\begin_inset CommandInset ref
LatexCommand ref
reference "IVP"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

).
 Further,
 
\begin_inset Formula $t\mapsto u\left(t\right)$
\end_inset

 and 
\begin_inset Formula $t\mapsto\dot{u}\left(t\right)$
\end_inset

 belong to the class 
\begin_inset Formula $\mathcal{L_{\infty}}\left(\mathbb{R}_{\ge0};\mathbb{R}^{n}\right)$
\end_inset

 and 
\begin_inset Formula $\kappa\left(t\right)\in\Omega$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge t_{0}}$
\end_inset

.
\end_layout

\begin_layout Proof
Consider any 
\begin_inset Formula $t_{0}\in\mathbb{R}_{\ge0}$
\end_inset

.
 Select 
\begin_inset Formula $\lambda_{P}=2\lambda$
\end_inset

.
 Since 
\begin_inset Formula $k_{2}>2\lambda$
\end_inset

,
 the interval 
\begin_inset Formula $\left(0,k_{2}\right)$
\end_inset

 is nonempty.
 Thus,
 the condition on 
\begin_inset Formula $K_{\text{RISE}}$
\end_inset

