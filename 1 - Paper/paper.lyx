\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Section
Control Design
\end_layout

\begin_layout Standard
To facilitate subsequent control design,
 the first and second auxiliary tracking errors are defined as
\begin_inset Formula 
\begin{align}
r_{1}\left(t\right) & \triangleq\dot{e}\left(t\right)+k_{1}e\left(t\right),\label{eq:r1_def}\\
r_{2}\left(t\right) & \triangleq\dot{r}_{1}\left(t\right)+k_{2}r_{1}\left(t\right),\label{eq:r2_def}
\end{align}

\end_inset

where 
\begin_inset Formula $k_{1},k_{2}\in\mathbb{R}_{>0}$
\end_inset

