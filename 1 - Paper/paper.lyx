\dot{V}\left(t\right) & =e^{\top}\left(r_{1}-k_{1}e\right)+r^{\top}_{1}\left(r_{2}-k_{2}r_{1}\right)+r^{\top}_{2}\left(\widetilde{N}\left(\kappa,\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}-r_{1}-K_{\text{RISE}}\nu_{1}+D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)\right)\\
