\begin_layout Subsection
Observer Design
\end_layout

\begin_layout Plain Layout
The control design requires knowledge of the auxiliary tracking error 
\begin_inset Formula $r$
\end_inset


\color red
 (NO IT DOESN'T)
\color inherit
 defined previously.
 However, since 
\begin_inset Formula $r$
\end_inset

 depends on the unknown target dynamics through 
\begin_inset Formula $h\left(q_{d}\right)$
\end_inset

, it cannot be directly computed.
 To address this challenge, an estimate 
\begin_inset Formula $\hat{r}\in\mathbb{R}^{n}$
\end_inset

 of 
\begin_inset Formula $r$
\end_inset

 must be constructed.
 To enable the design of the state estimate, the filtered tracking error
 
\begin_inset Formula $s_{1}\in\mathbb{R}^{n}$
\end_inset

 is defined as
\begin_inset Formula 
\begin{equation}
s_{1}\triangleq e-\mu,\label{filtered tracking error}
\end{equation}

\end_inset

where the internal dynamic filter state 
\color blue

\begin_inset Formula $\mu:\mathbb{R}_{\geq t_{0}}\to\mathbb{R}^{n}$
\end_inset


\color inherit
 evolves according to the first-order dynamics
\begin_inset Formula 
\begin{equation}
\dot{\mu}=-k_{1}\mu+\hat{r},\hspace{1em}\mu\left(t_{0}\right)=\mu_{0},\label{eq:mu}
\end{equation}

\end_inset

where 
\begin_inset Formula $\mu_{0}\in{\color{red}\mathbb{R}_{\geq0}}$
\end_inset

.
 The estimation error 
\color blue

\begin_inset Formula $\tilde{r}:\mathbb{R}_{\geq t_{0}}\to\mathbb{R}^{n}$
\end_inset


\color inherit
 between the true auxiliary tracking error and its estimate is defined as
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align}
\tilde{r} & \triangleq r-\hat{r}.\label{eq:r_tilde}
\end{align}

\end_inset

Here, the state estimate 
\color blue

\begin_inset Formula $\hat{r}:\mathbb{R}_{\geq t_{0}}\to\mathbb{R}^{n}$
\end_inset


\color inherit
 is defined as
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{\hat{r}} & =-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+k_{3}\tilde{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+k_{3}\left(r-\hat{r}\right)+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+k_{3}r-k_{3}\hat{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-e-\left(k_{2}-k_{3}\right)r-\alpha_{1}\text{sgn}\left(e\right)-k_{3}\hat{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-e-\left(k_{2}-k_{3}\right)\left(\dot{e}+k_{1}e\right)-\alpha_{1}\text{sgn}\left(e\right)-k_{3}\hat{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-e-\left(k_{2}-k_{3}\right)\dot{e}-k_{1}\left(k_{2}-k_{3}\right)e-\alpha_{1}\text{sgn}\left(e\right)-k_{3}\hat{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-\left(k_{2}-k_{3}\right)\dot{e}-\left(1+k_{1}\left(k_{2}-k_{3}\right)\right)e-\alpha_{1}\text{sgn}\left(e\right)-k_{3}\hat{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
\implies\int_{t_{0}}^{t}\frac{{\rm d}}{{\rm d}\tau}\hat{r}\left(\tau\right){\rm d}\tau & =\int_{t_{0}}^{t}\left(-\left(k_{2}-k_{3}\right)\dot{e}\left(\tau\right)-\left(1+k_{1}\left(k_{2}-k_{3}\right)\right)e\left(\tau\right)-\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)-k_{3}\hat{r}\left(\tau\right)+\alpha_{2}\text{sgn}\left(s_{1}\left(\tau\right)\right)+s_{1}\left(\tau\right)\right){\rm d}\tau\\
\implies\left.\hat{r}\left(\tau\right)\right|_{t_{0}}^{t} & =-\left(k_{2}-k_{3}\right)\int_{t_{0}}^{t}\frac{{\rm d}}{{\rm d}\tau}e\left(\tau\right){\rm d}\tau+\int_{t_{0}}^{t}\left(-\left(1+k_{1}\left(k_{2}-k_{3}\right)\right)e\left(\tau\right)-\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\alpha_{2}\text{sgn}\left(s_{1}\left(\tau\right)\right)-k_{3}\hat{r}\left(\tau\right)+s_{1}\left(\tau\right)\right){\rm d}\tau\\
\implies\hat{r}\left(t\right)-\hat{r}\left(t_{0}\right) & =-\left(k_{2}-k_{3}\right)\left(\left.e\left(\tau\right)\right|_{t_{0}}^{t}\right)+\int_{t_{0}}^{t}\left(-\left(1+k_{1}\left(k_{2}-k_{3}\right)\right)e\left(\tau\right)-\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\alpha_{2}\text{sgn}\left(s_{1}\left(\tau\right)\right)-k_{3}\hat{r}\left(\tau\right)+s_{1}\left(\tau\right)\right){\rm d}\tau\\
\implies\hat{r}\left(t\right) & =\hat{r}\left(t_{0}\right)-\left(k_{2}-k_{3}\right)\left(e\left(t\right)-e\left(t_{0}\right)\right)+\int_{t_{0}}^{t}\left(\underbrace{-\left(1+k_{1}\left(k_{2}-k_{3}\right)\right)e\left(\tau\right)-\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\alpha_{2}\text{sgn}\left(s_{1}\left(\tau\right)\right)-k_{3}\hat{r}\left(\tau\right)+s_{1}\left(\tau\right)}_{\psi}\right){\rm d}\tau
\end{align*}

\end_inset


\end_layout

\end_inset


\color red

\begin_inset Formula 
\begin{align}
\hat{r} & =-\left(k_{2}+k_{3}\right)e\left(t\right)+\psi\left(t\right),\label{eq:rHat-1}
\end{align}

\end_inset


\color inherit
where 
\begin_inset Formula ${\color{blue}\psi:\mathbb{R}_{\geq t_{0}}\to\mathbb{R}^{n}}$
\end_inset

 is the generalized solution to
\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{\psi} & =s_{1}-\left(1+k_{1}\left(k_{2}+k_{3}\right)\right)e-k_{3}\hat{r}\\
 & +\alpha_{2}\text{sgn}\left(s_{1}\right)-\alpha_{1}\text{sgn}\left(e\right),\hspace{1em}\psi\left(t_{0}\right)=\psi_{0}.
\end{aligned}
\label{eq:u integrand-1}
\end{equation}

\end_inset

Here, 
\begin_inset Formula $k_{3},\alpha_{2}\in\mathbb{R}_{>0}$
\end_inset

 are constant control gains.
 Taking the time derivative of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rHat-1"

\end_inset

 and using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:u integrand-1"

\end_inset

 yields
\begin_inset Formula 
\begin{equation}
\dot{\hat{r}}=-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+k_{3}\tilde{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1},\label{eq:rHatDot}
\end{equation}

\end_inset

Substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rDot-2"
plural "false"
caps "false"
noprefix "false"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rHatDot"

\end_inset

 into the time derivative of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:r_tilde"

\end_inset

 yields
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{\tilde{r}} & =\dot{r}-\dot{\hat{r}}\\
 & =\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+\varepsilon\left(q_{d}\right)-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)-\left(-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+k_{3}\tilde{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\right)\\
 & =\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+\varepsilon\left(q_{d}\right)-\cancel{e}-\cancel{k_{2}r}-\cancel{\alpha_{1}\text{sgn}\left(e\right)}+\cancel{e}+\cancel{k_{2}r}+\cancel{\alpha_{1}\text{sgn}\left(e\right)}-k_{3}\tilde{r}-\alpha_{2}\text{sgn}\left(s_{1}\right)-s_{1}\\
 & =\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+\varepsilon\left(q_{d}\right)-k_{3}\tilde{r}-\alpha_{2}\text{sgn}\left(s_{1}\right)-s_{1}\\
 & =\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+\varepsilon\left(q_{d}\right)-k_{3}\tilde{r}-\alpha_{2}\text{sgn}\left(s_{1}\right)-s_{1}
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\dot{\tilde{r}}=\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+\varepsilon\left(q_{d}\right)-k_{3}\tilde{r}-\alpha_{2}\text{sgn}\left(s_{1}\right)-s_{1}.\label{eq:rTildeDot}
\end{equation}

\end_inset

Substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:mu"

\end_inset

 into the time derivative of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "filtered tracking error"

\end_inset

 and using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:r_tilde"

\end_inset

 yields
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{s}_{1} & =\dot{e}-\dot{\mu}\\
 & =r-k_{1}e-\left(-k_{1}\mu+\hat{r}\right)\\
 & =r-k_{1}e+k_{1}\mu-\hat{r}\\
 & =\tilde{r}-k_{1}\left(e-\mu\right)\\
 & =\tilde{r}-k_{1}s
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\dot{s}_{1}=\tilde{r}-k_{1}s_{1}.\label{eq:sDot}
\end{equation}

\end_inset


\end_layout

\begin_layout Subsection
Stability
\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\[
V=\frac{1}{2}s_{1}^{\top}s_{1}+\frac{1}{2}\widetilde{r}^{\top}\widetilde{r}+\frac{1}{2}r^{\top}r+\frac{1}{2}e^{\top}e+P
\]

\end_inset

Derivative
\begin_inset Formula 
\begin{align*}
V & =s_{1}^{\top}\dot{s}_{1}+\widetilde{r}^{\top}\dot{\widetilde{r}}+r^{\top}\dot{r}+e^{\top}\dot{e}+\dot{P}\\
 & =s_{1}^{\top}\left(\tilde{r}-k_{1}s_{1}\right)+\widetilde{r}^{\top}\left(\varepsilon\left(q_{d}\right)-\alpha_{2}\text{sgn}\left(s_{1}\right)-k_{3}\tilde{r}-s_{1}+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)\right)+r^{\top}\left(\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+\varepsilon\left(q_{d}\right)-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)\right)+e^{\top}\left(r-k_{1}e\right)+\dot{P}\\
 & =s_{1}^{\top}\tilde{r}-k_{1}s_{1}^{\top}s_{1}+\widetilde{r}^{\top}\varepsilon\left(q_{d}\right)-\alpha_{2}\widetilde{r}^{\top}\text{sgn}\left(s_{1}\right)-k_{3}\widetilde{r}^{\top}\tilde{r}-\widetilde{r}^{\top}s_{1}+\widetilde{r}^{\top}\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+r^{\top}\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+r^{\top}\varepsilon\left(q_{d}\right)-r^{\top}e-k_{2}r^{\top}r-\alpha_{1}r^{\top}\text{sgn}\left(e\right)+e^{\top}r-k_{1}e^{\top}e+\dot{P}\\
 & =\cancel{s_{1}^{\top}\tilde{r}}-k_{1}e^{\top}e-k_{1}s_{1}^{\top}s_{1}-k_{2}r^{\top}r-k_{3}\widetilde{r}^{\top}\tilde{r}+\widetilde{r}^{\top}\varepsilon\left(q_{d}\right)-\alpha_{2}\widetilde{r}^{\top}\text{sgn}\left(s_{1}\right)-\cancel{\widetilde{r}^{\top}s_{1}}+\widetilde{r}^{\top}\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+r^{\top}\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+r^{\top}\varepsilon\left(q_{d}\right)-\cancel{r^{\top}e}-\alpha_{1}r^{\top}\text{sgn}\left(e\right)+\cancel{e^{\top}r}+\dot{P}\\
 & =-k_{1}e^{\top}e-k_{1}s_{1}^{\top}s_{1}-k_{2}r^{\top}r-k_{3}\widetilde{r}^{\top}\tilde{r}+2\widetilde{r}^{\top}\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+2r^{\top}\varepsilon\left(q_{d}\right)+\dot{P}-\alpha_{2}\widetilde{r}^{\top}\text{sgn}\left(s_{1}\right)-\alpha_{1}r^{\top}\text{sgn}\left(e\right)
\end{align*}

\end_inset

We need
\begin_inset Formula 
\begin{align*}
\dot{P} & =-\lambda_{P}P-\widetilde{r}^{\top}\left(2\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)-\alpha_{2}K[\text{sgn}]\left(s_{1}\left(t\right)\right)\right)-r^{\top}\left(2\varepsilon\left(q_{d}\right)-\alpha_{1}\text{sgn}\left(e\right)\right)\\
 & =-\lambda_{P}P-2\widetilde{r}^{\top}\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+\alpha_{2}\widetilde{r}^{\top}K[\text{sgn}]\left(s_{1}\left(t\right)\right)-2r^{\top}\varepsilon\left(q_{d}\right)+\alpha_{1}r^{\top}\text{sgn}\left(e\right)
\end{align*}

\end_inset

So
\begin_inset Formula 
\begin{align*}
 & =-k_{1}e^{\top}e-k_{1}s_{1}^{\top}s_{1}-k_{2}r^{\top}r-k_{3}\widetilde{r}^{\top}\tilde{r}-\lambda_{P}P+\cancel{2\widetilde{r}^{\top}\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)}+r^{\top}\left(2\varepsilon\left(q_{d}\right)-\alpha_{1}\text{sgn}\left(e\right)\right)\\
 & -\alpha_{2}\widetilde{r}^{\top}\text{sgn}\left(s_{1}\right)-\cancel{2\widetilde{r}^{\top}\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)}+\alpha_{2}\widetilde{r}^{\top}K[\text{sgn}]\left(s_{1}\left(t\right)\right)-2r^{\top}\varepsilon\left(q_{d}\right)+\alpha_{1}r^{\top}\text{sgn}\left(e\right)\\
\\
 & =-k_{1}e^{\top}e-k_{1}s_{1}^{\top}s_{1}-k_{2}r^{\top}r-k_{3}\widetilde{r}^{\top}\tilde{r}-\lambda_{P}P+\cancel{r^{\top}\left(2\varepsilon\left(q_{d}\right)-\alpha_{1}\text{sgn}\left(e\right)\right)}\\
 & \cancel{-\alpha_{2}\widetilde{r}^{\top}\text{sgn}\left(s_{1}\right)+\alpha_{2}\widetilde{r}^{\top}K[\text{sgn}]\left(s_{1}\left(t\right)\right)}-\cancel{2r^{\top}\varepsilon\left(q_{d}\right)+\alpha_{1}r^{\top}\text{sgn}\left(e\right)}\\
\\
 & =-k_{1}\left\Vert e\right\Vert ^{2}-k_{1}\left\Vert s_{1}\right\Vert ^{2}-k_{2}\left\Vert r\right\Vert ^{2}-k_{3}\left\Vert \tilde{r}\right\Vert ^{2}-\lambda_{P}P
\end{align*}

\end_inset

We must ensure 
\begin_inset Formula $P\ge0$
\end_inset

.
 Then, solve for 
\begin_inset Formula $P$
\end_inset

.
\end_layout

\end_inset


\end_layout

