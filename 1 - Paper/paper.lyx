 & \le\left(k_{1}+2\right)\left\Vert z\right\Vert +\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(\underbrace{k_{1}+2+\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}_{\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\left\Vert z\right\Vert \\
 & \le\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\end_inset

