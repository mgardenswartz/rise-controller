\end_inset

,
 where 
\begin_inset Formula $\kappa:\mathcal{I}\to\mathbb{R}^{5n}$
\end_inset

 is defined as 
\begin_inset Formula $\kappa\left(t\right)\triangleq\left[\begin{array}{ccccc}
q^{\top}\left(t\right) & \dot{q}^{\top}\left(t\right) & q^{\top}_{\text{d}}\left(t\right) & \dot{q}^{\top}_{\text{d}}\left(t\right) & u^{\top}\left(t\right)\end{array}\right]^{\top}$
\end_inset

 and 
\begin_inset Formula $F:\mathbb{R}^{5n}\to\mathbb{R}^{n}$
\end_inset

 is defined as 
\begin_inset Formula $F\left(\kappa\right)\triangleq\left.\frac{\partial h}{\partial q_{\text{d}}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\dot{q}_{\text{d}}+\left.\frac{\partial h}{\partial\dot{q}_{\text{d}}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}h\left(q_{\text{d}},\dot{q}_{\text{d}}\right)-\left.\frac{\partial f}{\partial q}\right|_{\left(q,\dot{q}\right)}\dot{q}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}f\left(q,\dot{q}\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}u$
\end_inset

.
