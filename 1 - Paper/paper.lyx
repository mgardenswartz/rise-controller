 & \hspace{1em}\cdot\left(\stackrel{\curvearrowleft}{\stackrel[\ell=j+1]{k_{i}}{\prod}}V_{i,\ell}^{\top}\frac{\partial\phi_{i,\ell}}{\partial\varphi_{i,\ell-1}}\right)\left(I_{L_{i,j+1}}\otimes\varkappa_{i,j}^{\top}\right),
\end{align*}

\end_inset

where 
\begin_inset Formula $\varkappa_{i,j}\triangleq\kappa_{0}^{a}$
\end_inset

