 & -\dot{u}-\dot{d}\left(t\right)+k_{1}\dot{r}_{1}-k_{1}^{2}\left(r_{1}-k_{1}e\right)+k_{2}\dot{r}_{1}\\
\\
 & =\underbrace{\left.\frac{\partial h}{\partial q_{d}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\dot{q}_{d}+\left.\frac{\partial h}{\partial\dot{q}_{d}}\right|_{\left(q_{d},\dot{q}_{d}\right)}h\left(q_{d},\dot{q}_{d}\right)-\left.\frac{\partial f}{\partial q}\right|_{\left(q,\dot{q}\right)}\dot{q}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}f\left(q,\dot{q}\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}u}_{F\left(\kappa\right)}\\
 & -\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}d\left(t\right)-\dot{u}-\dot{d}\left(t\right)+\left(k_{1}+k_{2}\right)\dot{r}_{1}-k_{1}^{2}r_{1}+k_{1}^{3}e\\
\\
 & =F\left(\kappa\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}d\left(t\right)-\dot{u}-\dot{d}\left(t\right)+\left(k_{1}+k_{2}\right)\left(r_{2}-k_{2}r_{1}\right)-k_{1}^{2}r_{1}+k_{1}^{3}e\\
 & =F\left(\kappa\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}d\left(t\right)-\dot{u}-\dot{d}\left(t\right)+\left(k_{1}+k_{2}\right)r_{2}-\left(k_{1}+k_{2}\right)k_{2}r_{1}-k_{1}^{2}r_{1}+k_{1}^{3}e\\
 & =F\left(\kappa\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}d\left(t\right)-\dot{u}-\dot{d}\left(t\right)+\left(k_{1}+k_{2}\right)r_{2}+\left(-k_{1}k_{2}-k_{2}^{2}-k_{1}^{2}\right)r_{1}+k_{1}^{3}e
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\dot{r}_{2}\left(t\right)=F\left(\kappa\left(t\right)\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q\left(t\right),\dot{q}\left(t\right)\right)}d\left(t\right)-\dot{u}-\dot{d}\left(t\right)+\left(k_{1}+k_{2}\right)r_{2}\left(t\right)-\left(k_{1}k_{2}+k_{2}^{2}+k_{1}^{2}\right)r_{1}\left(t\right)+k_{1}^{3}e\left(t\right),\label{eq:r2-step-1}
\end{equation}

\end_inset

for all 
\begin_inset Formula $t\in\mathcal{I}$
\end_inset

, where 
\begin_inset Formula $\kappa\triangleq\left[\begin{array}{ccccc}
q^{\top} & \dot{q}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{5n}$
\end_inset

 and 
\begin_inset Formula $F:\mathbb{R}^{5n}\to\mathbb{R}^{n}$
\end_inset

 is defined as 
\begin_inset Formula $F\left(\kappa\right)\triangleq\left.\frac{\partial h}{\partial q_{d}}\right|_{\left(q_{d},\dot{q}_{d}\right)}\dot{q}_{d}+\left.\frac{\partial h}{\partial\dot{q}_{d}}\right|_{\left(q_{d},\dot{q}_{d}\right)}h\left(q_{d},\dot{q}_{d}\right)-\left.\frac{\partial f}{\partial q}\right|_{\left(q,\dot{q}\right)}\dot{q}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}f\left(q,\dot{q}\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}u$
\end_inset

.
 Since 
\begin_inset Formula $f$
\end_inset

 and 
\begin_inset Formula $h$
\end_inset

 are unknown, 
\begin_inset Formula $F$
\end_inset

 is unknown and will be approximated online with a user-selected parametric
 universal approximator as 
\begin_inset Formula $\Phi\left(\kappa,\widehat{\theta}\right)$
\end_inset

 where 
\begin_inset Formula $\Phi:\mathbb{R}^{L_{\text{in}}}\times\mathbb{R}^{{\tt p}}\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

 is a class 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

 approximator architecture mapping, 
\begin_inset Formula $\widehat{\theta}\in\mathbb{R}^{{\tt p}}$
\end_inset

 is a parameter, where 
\begin_inset Formula $L_{\text{out}}=n$
\end_inset

, 
\begin_inset Formula $L_{\text{in}}=5n$
\end_inset

, and 
\begin_inset Formula ${\tt p}\in\mathbb{Z}_{\ge1}$
\end_inset

 is the number of parameters.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Remark
In this work, any class 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

 parametric approximator which satisfies a universal approximation theorem
 like Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:Universal-Approximation-Theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

 can be used for 
\begin_inset Formula $\Phi$
\end_inset

, in which there must exist a sufficiently sized architecture (e.g., network
 width for shallow neural networks, network depth for deep neural networks,
 or number of blocks for ResNets) and a corresponding ideal parameter 
\begin_inset Formula $\theta^{\ast}\in\mathbb{R}^{{\tt p}}$
\end_inset

 such that any continuous function can be approximated to arbitrarily small
 precision under the 
\color red
uniform norm
\color inherit
 on a compact set 
\begin_inset Formula $\Omega\subsetneq\mathbb{R}^{L_{\text{in}}}$
\end_inset

.
