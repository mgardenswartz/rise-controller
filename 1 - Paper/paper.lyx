\begin_layout Subsubsection*
BOUNDING LEMMA 2.1
\end_layout

\begin_layout Plain Layout
The ideal controller 
\begin_inset Formula $u_{\text{d}}$
\end_inset

 satisfies
\begin_inset Formula 
\begin{align*}
\ddot{q}_{\text{d}} & =f\left(q_{\text{d}},\dot{q}_{\text{d}}\right)+u_{\text{d}}+d\left(t\right)\\
\ddot{q}_{\text{d}}-f\left(q_{\text{d}},\dot{q}_{\text{d}}\right)-d\left(t\right) & =u_{\text{d}}\\
u_{\text{d}} & =\ddot{q}_{\text{d}}-f\left(q_{\text{d}},\dot{q}_{\text{d}}\right)-d\left(t\right)
\end{align*}

\end_inset

By the stated assumption and EVT,
 there exists a known constant
\begin_inset Formula 
\begin{align*}
\overline{u}_{\text{d}} & \triangleq\overline{\ddot{q}}_{\text{d}}+\underbrace{\sup_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)\in\overline{B}_{\overline{q}_{\text{d}}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{\text{d}}}\left(0_{n}\right)}\left(\left\Vert f\left(q_{\text{d}},\dot{q}_{\text{d}}\right)\right\Vert \right)}_{\overline{f}}+\overline{d}\\
 & =\overline{\ddot{q}}_{\text{d}}+\overline{f}+\overline{d}
\end{align*}

\end_inset

such that
\begin_inset Formula 
\[
\left\Vert u_{\text{d}}\right\Vert \le\overline{u}_{\text{d}}
\]

\end_inset


\end_layout

\begin_layout Subsubsection*
