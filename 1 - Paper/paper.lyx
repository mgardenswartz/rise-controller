\begin_inset Formula 
\begin{align*}
\Phi_{2}\left(\psi_{2}\left(\kappa_{2}\right),\theta_{2}\right) & =\varphi_{2,1}\left(\psi_{2}\left(\kappa_{2}\right)\right)\\
 & =V^{\top}_{2,1}\phi_{2,1}\left(\varphi_{2,0}\left(\psi_{2}\left(\kappa_{2}\right)\right)\right)\\
