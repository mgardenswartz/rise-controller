\end_layout

\begin_layout Section
Problem Formulation
\end_layout

\begin_layout Standard
Consider the second-order nonlinear dynamical system described by the differential equation,
\begin_inset Formula 
\begin{equation}
\ddot{q}\left(t\right)=f\left(q\left(t\right),\dot{q}\left(t\right)\right)+u\left(t\right)+d\left(t\right),\label{eq:agent-dynamics}
\end{equation}

\end_inset

where 
\begin_inset Formula $t\in\mathbb{R}_{\ge0}$
\end_inset

 denotes time,
 
\begin_inset Formula $u:\mathbb{R}_{\ge0}\to\mathbb{R}^{n}$
\end_inset

 denotes the control input,
 
\begin_inset Formula $f:\mathbb{R}^{n}\times\mathbb{R}^{n}\to\mathbb{R}^{n}$
\end_inset

 denotes unknown drift dynamics of class 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

,
 and 
\begin_inset Formula $d:\mathbb{R}_{\ge0}\to\mathbb{R}^{n}$
\end_inset

 denotes an unknown,
 time-variant exogenous disturbance of class 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

.
 For an initial condition set 
\begin_inset Formula $\left(t_{0},q_{0},\dot{q}_{0}\right)\in\mathbb{R}_{\ge0}\times\mathbb{R}^{n}\times\mathbb{R}^{n}$
\end_inset

,
 let 
\begin_inset Formula $q:\mathcal{I}\to\mathbb{R}^{n}$
\end_inset

,
 
\begin_inset Formula $\dot{q}:\mathcal{I}\to\mathbb{R}^{n}$
\end_inset

,
 and 
\begin_inset Formula $\ddot{q}:\mathcal{I}\to\mathbb{R}^{n}$
\end_inset

 denote the generalized position,
 velocity,
 and acceleration,
 respectively,
 of the resulting solution to (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:agent-dynamics"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) such that 
\begin_inset Formula $q\left(t_{0}\right)=q_{0}$
\end_inset

,
 
\begin_inset Formula $\dot{q}\left(t_{0}\right)=\dot{q}_{0}$
\end_inset

,
 and 
\begin_inset Formula $\mathcal{I}\triangleq\left[0,T_{\max}\right)$
\end_inset

 is the interval of existence for 
\begin_inset Formula $T_{\max}\in\left(t_{0},\infty\right]$
\end_inset

.
\end_layout

\begin_layout Standard
The desired trajectory for (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:agent-dynamics"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) is governed by the autonomous second-order system,
\begin_inset Formula 
\begin{equation}
\ddot{q}_{\text{d}}\left(t\right)=h\left(q_{\text{d}}\left(t\right),\dot{q}_{\text{d}}\left(t\right)\right),\label{eq:reference-dynamics}
\end{equation}

\end_inset

where 
\begin_inset Formula $h:\mathbb{R}^{n}\times\mathbb{R}^{n}\to\mathbb{R}^{n}$
\end_inset

 is an unknown function of class 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

.
 For an initial condition set 
\begin_inset Formula $\left(t_{0},q_{\text{d},0},\dot{q}_{\text{d},0}\right)\in\mathbb{R}_{\ge0}\times\mathbb{R}^{n}\times\mathbb{R}^{n}$
\end_inset

,
 let 
\begin_inset Formula $q_{\text{d}}:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

,
 
\begin_inset Formula $\dot{q}_{\text{d}}:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 and 
\begin_inset Formula $\ddot{q}_{\text{d}}:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 denote generalized desired position,
 velocity,
 and acceleration,
 respectively,
 of the resulting solution to (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:reference-dynamics"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) such that 
\begin_inset Formula $q_{\text{d}}\left(t_{0}\right)=q_{\text{d},0}$
\end_inset

 and 
\begin_inset Formula $\dot{q}_{\text{d}}\left(t_{0}\right)=\dot{q}_{\text{d},0}$
\end_inset

.
\end_layout

\begin_layout Standard
Let the tracking error be 
\begin_inset Formula $e\left(t\right)\triangleq q_{\text{d}}\left(t\right)-q\left(t\right)$
\end_inset

.
 The control objective is to design a controller such that 
\begin_inset Formula $\left\Vert e\right\Vert $
\end_inset

 converges exponentially to zero despite the presence of non-vanishing disturbances and unknown dynamics.
 Since 
\begin_inset Formula $\ddot{q}_{\text{d}}$
\end_inset

 is unknown and 
\begin_inset Formula $h$
\end_inset

 is time-invariant,
 the objective is said to be target tracking rather than trajectory tracking.
 The subsequent assumptions ensure feasibility of this objective.
\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "asm:qd-bounds"

\end_inset


\begin_inset CommandInset citation
LatexCommand cite
after "Assumption 1"
key "Nino.Patil.ea2025"
literal "false"

\end_inset

.
 There exist known constants 
\begin_inset Formula $\overline{q}_{\text{d}},\overline{\dot{q}}_{\text{d}},\overline{\ddot{q}}_{\text{d}},\overline{\dddot{q}}_{\text{d}}\in\mathbb{R}_{\ge0}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert q_{\text{d}}\left(t\right)\right\Vert \le\overline{q}_{\text{d}}$
\end_inset

,
 
\begin_inset Formula $\left\Vert \dot{q}_{\text{d}}\left(t\right)\right\Vert \le\overline{\dot{q}}_{\text{d}}$
\end_inset

,
 
\begin_inset Formula $\left\Vert \ddot{q}_{\text{d}}\left(t\right)\right\Vert \le\overline{\ddot{q}}_{\text{d}}$
\end_inset

,
 and 
\begin_inset Formula $\left\Vert \dddot{q}_{\text{d}}\left(t\right)\right\Vert \le\overline{\dddot{q}}_{\text{d}}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge0}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "asm:d-bounds"

\end_inset


\begin_inset CommandInset citation
LatexCommand cite
key "Nino.Patil.ea2025"
literal "false"

\end_inset

.
 There exist known constants 
\begin_inset Formula $\overline{d},\overline{\dot{d}},\overline{\ddot{d}}\in\mathbb{R}_{\ge0}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert d\left(t\right)\right\Vert \le\overline{d}$
\end_inset

,
 
\begin_inset Formula $\left\Vert \dot{d}\left(t\right)\right\Vert \le\overline{\dot{d}}$
\end_inset

,
 and 
\begin_inset Formula $\left\Vert \ddot{d}\left(t\right)\right\Vert \le\overline{\ddot{d}}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge0}$
\end_inset

.
