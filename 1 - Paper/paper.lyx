\begin_layout Standard
In order for ResNets to act as universal approximators of continuous functions on compact domains,
 their activation functions must be selected to belong to a class of functions called 
\begin_inset Formula $\mathcal{A}_{\text{quad}}$
\end_inset

.
\end_layout

\begin_layout Definition

\emph on
\begin_inset CommandInset label
LatexCommand label
name "def:a-quad"

\end_inset


\begin_inset CommandInset citation
LatexCommand cite
after "Definition 3.1"
key "Tabuada.Gharesifard2020a"
literal "false"

\end_inset

 The activation function 
\begin_inset Formula $\varsigma:\mathbb{R}\to\mathbb{R}$
\end_inset

 is said to be of class 
\begin_inset Formula $\mathcal{A}_{\text{quad}}$
\end_inset

 (denoted 
\begin_inset Formula $\varsigma\in\mathcal{A}_{\text{quad}}$
\end_inset

) if it is (i) nondecreasing,
 (ii) non-constant,
 and (iii) there exists an 
\begin_inset Formula $\ell\in\mathbb{Z}_{\ge0}$
\end_inset

 such that 
\begin_inset Formula $\varsigma$
\end_inset

 is a globally-defined solution to 
\begin_inset Formula $\frac{d\zeta}{ds}=a_{0}+a_{1}\zeta+a_{2}\zeta^{2}$
\end_inset

,
 where 
\begin_inset Formula $\zeta\triangleq\frac{d^{(\ell)}\varsigma}{ds^{(\ell)}}$
\end_inset

 is injective,
 
\begin_inset Formula $a_{0},a_{1},a_{2}\in\mathbb{R}$
\end_inset

,
 
\begin_inset Formula $a_{2}\ne0$
\end_inset

,
 and 
\begin_inset Formula $\frac{d^{(0)}\varsigma}{ds^{(0)}}=\varsigma$
\end_inset

.
\emph default

\begin_inset Foot
status collapsed

\begin_layout Plain Layout
By consequence of Definition 
\begin_inset CommandInset ref
LatexCommand ref
reference "def:a-quad"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

,
 any 
\begin_inset Formula $\varsigma\in\mathcal{A}_{\text{quad}}$
\end_inset

 is necessarily an analytical function.
 Thus,
 
\begin_inset Formula $\varsigma$
\end_inset

 and all its derivatives are locally Lipschitz on 
\begin_inset Formula $\mathbb{R}$
\end_inset

.
 Hyperbolic tangent,
 sigmoid,
 and softplus are of class 
\begin_inset Formula $\mathcal{A}_{\text{quad}}$
\end_inset

 but ReLU,
 swish,
 and the identity mapping are not.
 The function 
\begin_inset Formula $\varsigma\left(s\right)=\frac{1}{c}\log\left(1+{\rm e}^{cs}\right)$
\end_inset

 approximates ReLU for large 
\begin_inset Formula $c\in\mathbb{R}_{>0}$
\end_inset

 and is of class 
\begin_inset Formula $\mathcal{A}_{\text{quad}}$
\end_inset

.
 Leaky ReLU is given as 
\begin_inset Formula $\varsigma\left(s\right)=s$
\end_inset

 for all 
\begin_inset Formula $s\in\mathbb{R}_{\ge0}$
\end_inset

 and 
\begin_inset Formula $\varsigma\left(s\right)=rs$
\end_inset

 (with 
\begin_inset Formula $r\in\mathbb{R}_{>0}$
\end_inset

) for all 
\begin_inset Formula $s<0$
\end_inset

.
 The function 
\begin_inset Formula $\varsigma\left(s\right)=rs+\frac{1}{c}\log\left(1+{\rm e}^{\left(1-r\right)cs}\right)$
\end_inset

 approximates leaky ReLU for large 
\begin_inset Formula $c\in\mathbb{R}_{>0}$
\end_inset

 and is of class 
\begin_inset Formula $\mathcal{A}_{\text{quad}}$
\end_inset

.
\end_layout

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Theorem
\begin_inset CommandInset label
LatexCommand label
name "thm:Universal-Approximation-Theorem"

\end_inset


\begin_inset CommandInset citation
LatexCommand cite
after "Corollary 5.2"
key "Tabuada.Gharesifard2020a"
literal "false"

\end_inset

 (Universal Approximation Theorem for Residual Neural Networks).
 For any compact domain 
\begin_inset Formula $\Omega\subsetneq\mathbb{R}^{L_{\text{in}}}$
\end_inset

,
 continuous function 
\begin_inset Formula $F:\Omega\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

,
 and approximation accuracy 
\begin_inset Formula $\overline{\varepsilon}\in\mathbb{R}_{>0}$
\end_inset

,
 there exists a number of blocks 
\begin_inset Formula $b\in\mathbb{Z}_{\ge1}$
\end_inset

 (thus,
 a 
\begin_inset Formula ${\tt p}\in\mathbb{Z}_{\ge1}$
\end_inset

) and a parameter 
\begin_inset Formula $\theta^{\ast}\in\mathbb{R}^{{\tt p}}$
\end_inset

 such that for a ResNet architecture 
\begin_inset Formula $\Psi:\mathbb{R}^{L_{\text{in}}}\times\mathbb{R}^{{\tt p}}\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

 with activation functions 
\begin_inset Formula $\varsigma_{i,j}\in\mathcal{A}_{\text{quad}}$
\end_inset

 for all 
\begin_inset Formula $\left(i,j\right)\in\left\{ 0,\ldots,b\right\} \times\left\{ 0,\ldots,k_{i}\right\} $
\end_inset

,
 blocks of width 
\begin_inset Formula $w=\max\left(L_{\text{in}},L_{\text{out}}\right)+1$
\end_inset

 (i.e.,
 
\begin_inset Formula $L_{i,j}\ge w$
\end_inset

 for all 
\begin_inset Formula $\left(i,j\right)\in\left\{ 0,\ldots,b\right\} \times\left\{ 1,\ldots,k_{i}\right\} $
\end_inset

) and depth 1 (i.e.,
 
\begin_inset Formula $k_{i}\ge1$
\end_inset

 for all 
\begin_inset Formula $i\in\left\{ 0,\ldots,b\right\} $
\end_inset

),
\begin_inset Formula 
\begin{equation}
\sup_{x\in\Omega}\left\Vert \varepsilon\left(x,\theta^{\ast}\right)\right\Vert \le\overline{\varepsilon},\label{eq:lemma-ufat-1}
\end{equation}

\end_inset

where 
\begin_inset Formula $\varepsilon\left(x,\theta^{\ast}\right)\triangleq F\left(x\right)-\Psi\left(x,\theta^{\ast}\right)$
\end_inset

.
\end_layout

