\begin_inset Formula 
\[
\dot{u}_{d}=\dddot{q}_{\text{d}}-\left.\frac{\partial f}{\partial q}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\dot{q}_{\text{d}}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\ddot{q}_{\text{d}}-\dot{d}\left(t\right)
\]

\end_inset

By the stated assumptions and EVT,
 there exists a known constant
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{u}_{d}\right\Vert  & \le\overline{\dddot{q}}_{\text{d}}+\sup_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)\in\overline{B}_{\overline{q}_{\text{d}}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{\text{d}}}\left(0_{n}\right)}\left(\left\Vert \left.\frac{\partial f}{\partial q}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\right\Vert \right)\overline{\dot{q}}_{\text{d}}+\sup_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)\in\overline{B}_{\overline{q}_{\text{d}}}\left(0_{n}\right)\times\overline{B}_{\overline{\dot{q}}_{\text{d}}}\left(0_{n}\right)}\left(\left\Vert \left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\right\Vert \right)\overline{\ddot{q}}_{\text{d}}+\overline{\dot{d}}\\
 & \le\underbrace{\overline{\dddot{q}}_{\text{d}}+\overline{\dot{f}}\overline{\dot{q}}_{\text{d}}+\overline{\dot{f}}\overline{\ddot{q}}_{\text{d}}+\overline{\dot{d}}}_{\overline{\dot{u}}_{\text{d}}}
\end{align*}

\end_inset

such that
\begin_inset Formula 
\[
\left\Vert \dot{u}_{d}\right\Vert \le\overline{\dot{u}}_{\text{d}}
\]

\end_inset


\end_layout

\end_inset

