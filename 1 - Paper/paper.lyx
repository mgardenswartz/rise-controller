 & =h\left(q_{\text{d}},\dot{q}_{\text{d}}\right)-\left(f\left(q,\dot{q}\right)+u+d\left(t\right)\right)+k_{1}r_{1}-k^{2}_{1}e\\
 & =h\left(q_{\text{d}},\dot{q}_{\text{d}}\right)-f\left(q,\dot{q}\right)-u-d\left(t\right)+k_{1}r_{1}-k^{2}_{1}e
