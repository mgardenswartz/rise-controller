\begin_inset Formula 
\begin{align*}
e & \triangleq q_{\text{d}}-q\\
r_{1} & \triangleq\dot{e}+k_{1}e\\
\dot{r}_{1} & =\ddot{e}+k_{1}\dot{e}\\
r_{2} & \triangleq\dot{r}_{1}+k_{2}r_{1}
\end{align*}

\end_inset

Simplify:
\begin_inset Formula 
\begin{align*}
\dot{u} & =\left(k_{1}+k_{2}+k_{3}\right)r_{2}+\left(1-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}\right)r_{1}+k^{3}_{1}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
 & =\left(k_{1}+k_{2}+k_{3}\right)\left(\dot{r}_{1}+k_{2}r_{1}\right)+\left(1-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}\right)\left(\dot{e}+k_{1}e\right)+k^{3}_{1}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
 & =\left(k_{1}+k_{2}+k_{3}\right)\left(\ddot{e}+k_{1}\dot{e}+k_{2}\left(\dot{e}+k_{1}e\right)\right)+\left(1-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}\right)\left(\dot{e}+k_{1}e\right)+k^{3}_{1}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
 & =\left(k_{1}+k_{2}+k_{3}\right)\left(\ddot{e}+k_{1}\dot{e}+k_{2}\dot{e}+k_{1}k_{2}e\right)+\left(1-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}\right)\dot{e}+\left(1-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}\right)k_{1}e+k^{3}_{1}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
\\ & =\left(\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(k_{1}+k_{2}+k_{3}\right)k_{1}\dot{e}+\left(k_{1}+k_{2}+k_{3}\right)k_{2}\dot{e}+\left(k_{1}+k_{2}+k_{3}\right)k_{1}k_{2}e\right)\\
 & +\left(1-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}\right)\dot{e}+\left(k_{1}-k^{3}_{1}-k_{1}k^{2}_{2}-k^{2}_{1}k_{2}\right)e+k^{3}_{1}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
\\ & =\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(k^{2}_{1}+k_{1}k_{2}+k_{1}k_{3}\right)\dot{e}+\left(k_{1}k_{2}+k^{2}_{2}+k_{2}k_{3}\right)\dot{e}+\left(k^{2}_{1}k_{2}+k_{1}k^{2}_{2}+k_{1}k_{2}k_{3}\right)e\\
 & +\left(1-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}\right)\dot{e}+\left(k_{1}-k^{3}_{1}-k_{1}k^{2}_{2}-k^{2}_{1}k_{2}\right)e+k^{3}_{1}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
\\ & =\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(k^{2}_{1}+k_{1}k_{2}+k_{1}k_{3}+1-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}+k_{1}k_{2}+k^{2}_{2}+k_{2}k_{3}\right)\dot{e}\\
 & +\left(k^{2}_{1}k_{2}+k_{1}k^{2}_{2}+k_{1}k_{2}k_{3}+k_{1}-k^{3}_{1}-k_{1}k^{2}_{2}-k^{2}_{1}k_{2}+k^{3}_{1}\right)e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
\\ & =\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(\cancel{k^{2}_{1}}+k_{1}k_{2}+k_{1}k_{3}+1-\cancel{k^{2}_{1}}-\cancel{k^{2}_{2}}\cancel{-k_{1}k_{2}+k_{1}k_{2}}+\cancel{k^{2}_{2}}+k_{2}k_{3}\right)\dot{e}\\
 & +\left(\cancel{k^{2}_{1}k_{2}}+\cancel{k_{1}k^{2}_{2}}+k_{1}k_{2}k_{3}+k_{1}-\cancel{k^{3}_{1}}-\cancel{k_{1}k^{2}_{2}}-\cancel{k^{2}_{1}k_{2}}+\cancel{k^{3}_{1}}\right)e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
\\ & =\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(k_{1}k_{2}+k_{1}k_{3}+k_{2}k_{3}+1\right)\dot{e}+\left(k_{1}k_{2}k_{3}+k_{1}\right)e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)
\end{align*}

\end_inset


\family default
\series default
\shape default
\size default
