Integrate
\begin_inset Newline newline
\end_inset


\begin_inset Formula 
\begin{align*}
\intop^{t}_{t_{0}}\dot{u}\left(\tau\right)d\tau & =\intop^{t}_{t_{0}}\left(\left(k_{1}k_{2}k_{3}+k_{1}\right)e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\right)d\tau\\
 & +\intop^{t}_{t_{0}}\left(\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(k_{1}k_{2}+k_{1}k_{3}+k_{2}k_{3}+1\right)\dot{e}\right)d\tau\\
\\u\left(t\right)-u\left(t_{0}\right) & =\intop^{t}_{t_{0}}\left(\left(k_{1}k_{2}k_{3}+k_{1}\right)e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\right)d\tau\\
 & +\left(k_{1}+k_{2}+k_{3}\right)\left(\dot{e}\left(t\right)-\dot{e}\left(t_{0}\right)\right)+\left(k_{1}k_{2}+k_{1}k_{3}+k_{2}k_{3}+1\right)\left(e\left(t\right)-e\left(t_{0}\right)\right)
\end{align*}

\end_inset

Let 
\begin_inset Formula $u\left(t_{0}\right)$
\end_inset

 cancel the other initial conditions:
 
\begin_inset Formula $u\left(t_{0}\right)=\left(k_{1}+k_{2}+k_{3}\right)\dot{e}\left(t_{0}\right)+\left(k_{1}k_{2}+k_{1}k_{3}+k_{2}k_{3}+1\right)e\left(t_{0}\right)$
\end_inset

.
 So,
\begin_inset Formula 
\begin{align*}
u\left(t\right) & =\left(k_{1}+k_{2}+k_{3}\right)\dot{e}\left(t\right)+\left(k_{1}k_{2}+k_{1}k_{3}+k_{2}k_{3}+1\right)e\left(t\right)\\
 & +\intop^{t}_{t_{0}}\left(K_{\text{RISE}}\text{sgn}\left(r_{1}\left(\tau\right)\right)+\Phi\left(\kappa\left(\tau\right),\hat{\theta}\left(\tau\right)\right)+\left(k_{1}k_{2}k_{3}+k_{1}\right)e\left(\tau\right)\right)d\tau
\end{align*}

\end_inset


\color green
Simplify:
\begin_inset Formula 
\[
u\left(t\right)=K_{\text{P}}e\left(t\right)+K_{\text{D}}\dot{e}\left(t\right)+\intop^{t}_{t_{0}}\left(K_{\text{I}}e\left(\tau\right)+K_{\text{RISE}}\text{sgn}\left(r_{1}\left(\tau\right)\right)+\Phi\left(\kappa\left(\tau\right),\hat{\theta}\left(\tau\right)\right)\right)d\tau
\]

\end_inset

where
\begin_inset Formula 
\begin{align*}
K_{\text{P}} & \triangleq k_{1}k_{2}+k_{1}k_{3}+k_{2}k_{3}+1\\
K_{\text{I}} & \triangleq k_{1}k_{2}k_{3}+k_{1}\\
K_{\text{D}} & \triangleq k_{1}+k_{2}+k_{3}
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\begin{alignedat}{1}u\left(t\right) & =u_{\text{PID}}\left(t\right)+u_{\text{RISE}}\left(t\right)+\intop^{t}_{t_{0}}\left(\Phi\left(\kappa\left(\tau\right),\hat{\theta}\left(\tau\right)\right)\right)d\tau\end{alignedat}
,\label{eq:u_implementable}
\end{equation}

\end_inset

where 
\begin_inset Formula 
\begin{align*}
u_{\text{PID}}\left(t\right) & \triangleq K_{\text{P}}e\left(t\right)+K_{\text{D}}\dot{e}\left(t\right)+K_{\text{I}}\intop^{t}_{t_{0}}e\left(\tau\right)d\tau,\\
u_{\text{RISE}}\left(t\right) & \triangleq K_{\text{RISE}}\intop^{t}_{t_{0}}\text{sgn}\left(r_{1}\left(\tau\right)\right)d\tau,\\
K_{\text{P}} & \triangleq k_{1}k_{2}+k_{1}k_{3}+k_{2}k_{3}+1,\\
K_{\text{I}} & \triangleq k_{1}k_{2}k_{3}+k_{1},\\
K_{\text{D}} & \triangleq k_{1}+k_{2}+k_{3}.
\end{align*}

\end_inset

Define the idealized input 
\begin_inset Formula $\kappa_{\text{d}}:\mathbb{R}_{\ge0}\to\mathbb{R}^{5n}$
\end_inset

 seen when (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:agent-dynamics"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) perfectly tracks (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:reference-dynamics"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) as 
\begin_inset Formula $\kappa_{\text{d}}\triangleq\left[\begin{array}{ccccc}
q^{\top}_{\text{d}} & \dot{q}^{\top}_{\text{d}} & q^{\top}_{\text{d}} & \dot{q}^{\top}_{\text{d}} & u^{\top}_{\text{d}}\end{array}\right]^{\top}\in\mathbb{R}^{5n}$
\end_inset

,
 where 
\begin_inset Formula $u_{\text{d}}:\mathbb{R}_{\ge0}\to\mathbb{R}^{n}$
\end_inset

 is the ideal tracking component of the controller obtained from feedback linearization,
\begin_inset Formula 
\begin{equation}
u_{\text{d}}\left(t\right)\triangleq d\left(t\right)+f\left(q_{\text{d}}\left(t\right),\dot{q}_{\text{d}}\left(t\right)\right)-\ddot{q}_{\text{d}}\left(t\right).\label{eq:u_d}
\end{equation}

\end_inset

Substituting (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:u_dot"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) and (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:reconstruction_error"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) into (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:r2-step-1"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

),
 using the definition of 
\begin_inset Formula $\kappa_{\text{d}}$
\end_inset

 and performing algebraic manipulation gives that 
\begin_inset Formula $r_{2}:\mathcal{I}\to\mathbb{R}^{n}$
\end_inset

 is a Filippov solution to
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{r}_{2} & =\Phi\left(\kappa,\theta^{\ast}\right)+\varepsilon\left(\kappa,\theta^{\ast}\right)-\left(\left(k_{1}+k_{2}+k_{3}\right)r_{2}+\left(1-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}\right)r_{1}+k^{3}_{1}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\right)\\
 & -\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}d\left(t\right)-\dot{d}\left(t\right)+\left(k_{1}+k_{2}\right)r_{2}+\left(-k_{1}k_{2}-k^{2}_{2}-k^{2}_{1}\right)r_{1}+k^{3}_{1}e\\
\\ & =\Phi\left(\kappa,\theta^{\ast}\right)+\varepsilon\left(\kappa,\theta^{\ast}\right)-\left(\left(\cancel{k_{1}+k_{2}}+k_{3}\right)r_{2}+\left(1\cancel{-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}}\right)r_{1}+\cancel{k^{3}_{1}e}+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\right)\\
 & -\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}d\left(t\right)-\dot{d}\left(t\right)+\cancel{\left(k_{1}+k_{2}\right)r_{2}}+\cancel{\left(-k_{1}k_{2}-k^{2}_{2}-k^{2}_{1}\right)r_{1}}+\cancel{k^{3}_{1}e}\\
\\ & =\Phi\left(\kappa,\theta^{\ast}\right)+\varepsilon\left(\kappa,\theta^{\ast}\right)-\left(k_{3}r_{2}+r_{1}+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}d\left(t\right)-\dot{d}\left(t\right)\\
 & =\Phi\left(\kappa,\theta^{\ast}\right)+\varepsilon\left(\kappa,\theta^{\ast}\right)-k_{3}r_{2}-r_{1}-K_{\text{RISE}}\text{sgn}\left(r_{1}\right)-\Phi\left(\kappa,\hat{\theta}\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}d\left(t\right)-\dot{d}\left(t\right)\\
\\ & =\underbrace{\Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa,\hat{\theta}\right)}_{N_{0}\left(\kappa,\theta^{\ast},\hat{\theta}\right)}+\varepsilon\left(\kappa,\theta^{\ast}\right)-k_{3}r_{2}-r_{1}-K_{\text{RISE}}\text{sgn}\left(r_{1}\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}d\left(t\right)-\dot{d}\left(t\right)\\
 & -\varepsilon\left(\kappa_{\text{d}},\theta^{\ast}\right)+\varepsilon\left(\kappa_{\text{d}},\theta^{\ast}\right)+N_{0}\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta}\right)-N_{0}\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta}\right)+\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}d\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}d\left(t\right)\\
\\ & =\underbrace{N_{0}\left(\kappa,\theta^{\ast},\hat{\theta}\right)-N_{0}\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta}\right)}_{\widetilde{N}_{1}\left(\kappa,\kappa_{\text{d}},\theta^{\ast},\hat{\theta}\right)}+\underbrace{\varepsilon\left(\kappa,\theta^{\ast}\right)-\varepsilon\left(\kappa_{\text{d}},\theta^{\ast}\right)}_{\widetilde{N}_{\varepsilon}\left(\kappa,\kappa_{\text{d}},\theta^{\ast}\right)}-k_{3}r_{2}-r_{1}-K_{\text{RISE}}\text{sgn}\left(r_{1}\right)\\
 & +\left(\underbrace{\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}}_{\widetilde{N}_{2}\left(q,\dot{q},q_{\text{d}},\dot{q}_{\text{d}}\right)}\right)d\left(t\right)-\dot{d}\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}d\left(t\right)+\varepsilon\left(\kappa_{\text{d}},\theta^{\ast}\right)+N_{0}\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta}\right)\\
\\ & =\underbrace{\widetilde{N}_{1}\left(\kappa,\kappa_{\text{d}},\theta^{\ast},\hat{\theta}\right)+\widetilde{N}_{\varepsilon}\left(\kappa,\kappa_{\text{d}},\theta^{\ast}\right)+\widetilde{N}_{2}\left(q,\dot{q},q_{\text{d}},\dot{q}_{\text{d}}\right)d\left(t\right)}_{\widetilde{N}\left(\kappa,\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)}-k_{3}r_{2}-r_{1}-K_{\text{RISE}}\text{sgn}\left(r_{1}\right)\\
 & \underbrace{-\dot{d}\left(t\right)-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}d\left(t\right)+\varepsilon\left(\kappa_{\text{d}},\theta^{\ast}\right)+N_{0}\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta}\right)}_{D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)}\\
\\ & =\widetilde{N}\left(\kappa,\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}-r_{1}-K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Plain Layout
Regularizing
\begin_inset Formula 
\[
\dot{r}_{2}\in\widetilde{N}\left(\kappa,\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}-r_{1}-K_{\text{RISE}}K[\text{sgn}]\left(r_{1}\right)+D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)
\]

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\begin{alignedat}{1}\dot{r}_{2}\left(t\right) & \in\{\widetilde{N}\left(\kappa,\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-k_{3}r_{2}\left(t\right)-r_{1}\left(t\right)-K_{\text{RISE}}\nu_{1}\\
 & +D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right):\nu_{1}\in K[\text{sgn}]\left(r_{1}\right)\},
\end{alignedat}
\label{eq:r2-step-2}
\end{equation}

\end_inset

where
\begin_inset Formula 
\begin{align*}
D_{t} & \triangleq-\dot{d}\left(t\right)+\varepsilon\left(\kappa_{\text{d}}\left(t\right),\theta^{\ast}\right)\\
 & +N_{0}\left(\kappa_{\text{d}}\left(t\right),\theta^{\ast},\hat{\theta}\left(t\right)\right)\\
 & -\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q_{\text{d}}\left(t\right),\dot{q}_{\text{d}}\left(t\right)\right)}d\left(t\right),\\
N_{0}\left(s,\theta^{\ast},\hat{\theta}\right) & \triangleq\Phi\left(s,\theta^{\ast}\right)-\Phi\left(s,\hat{\theta}\right),\\
\widetilde{N}_{t} & \triangleq\widetilde{N}_{1}\left(\kappa\left(t\right),\kappa_{\text{d}}\left(t\right),\theta^{\ast},\hat{\theta}\left(t\right)\right)\\
 & +\widetilde{N}_{\varepsilon}\left(\kappa\left(t\right),\kappa_{\text{d}}\left(t\right)\right)\\
 & +\widetilde{N}_{2}\left(q\left(t\right),\dot{q}\left(t\right),q_{\text{d}}\left(t\right),\dot{q}_{\text{d}}\left(t\right)\right)d\left(t\right),\\
