\begin_inset Formula 
\begin{align*}
\Phi_{1}\left(\psi_{1}\left(\kappa_{1}\right),\theta_{1}\right) & =\varphi_{1,1}\left(\psi_{1}\left(\kappa_{1}\right)\right)\\
 & =V^{\top}_{1,1}\phi_{1,1}\left(\varphi_{1,0}\left(\psi_{1}\left(\kappa_{1}\right)\right)\right)\\
 & =V^{\top}_{1,1}\phi_{1,1}\left(V^{\top}_{1,0}\psi_{1}\left(\kappa_{1}\right)\right)
\end{align*}

\end_inset

We have
\begin_inset Formula 
\begin{align*}
\kappa_{1} & =\Phi_{0}\left(\kappa^{a}_{0},\theta_{0}\right)\\
 & =\left[\begin{array}{c}
0.1434\\
0.2759\\
0.4083
\end{array}\right]
\end{align*}

\end_inset

So 
\begin_inset Formula 
\begin{align*}
\psi_{1}\left(\kappa_{1}\right) & =\psi_{1}\left(\left[\begin{array}{c}
0.1434\\
0.2759\\
0.4083
\end{array}\right]\right)\\
 & =\left[\begin{array}{c}
0.1424\\
0.2691\\
0.3870\\
1
\end{array}\right].
