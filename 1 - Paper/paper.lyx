\end{align*}

\end_inset

The general formula is given by:
 
\begin_inset Formula 
\begin{align*}
\frac{\partial\Psi}{\partial\mathrm{vec}\left(V_{i,j}\right)} & =\left(\stackrel{\curvearrowleft}{\stackrel[m=i+1]{b}{\prod}}\left(I_{L_{\text{out}}}+\left(\stackrel{\curvearrowleft}{\stackrel[\ell=1]{k_{m}}{\prod}}V^{\top}_{m,\ell}\frac{\partial\phi_{m,\ell}}{\partial\varphi_{m,\ell-1}}\right)V^{\top}_{m,0}\frac{\partial\psi_{m}}{\partial\kappa_{m}}\right)\right)\left(\stackrel{\curvearrowleft}{\stackrel[\ell=j+1]{k_{i}}{\prod}}V^{\top}_{i,\ell}\frac{\partial\phi_{i,\ell}}{\partial\varphi_{i,\ell-1}}\right)\left(I_{L_{i,j+1}}\otimes\varrho^{\top}_{i,j}\right),
\end{align*}

\end_inset

where 
\begin_inset Formula $\varrho_{i,j}\triangleq\mathbf{1}_{\left\{ i=0\right\} }\left(\kappa^{a}_{0}\mathbf{1}_{\left\{ j=0\right\} }+\phi_{0,j}\left(\varphi_{0,j-1}\left(\kappa^{a}_{0}\right)\right)\mathbf{1}_{\left\{ j>0\right\} }\right)+\mathbf{1}_{\left\{ i>0\right\} }\left(\psi_{i}\left(\kappa_{i}\right)\mathbf{1}_{\left\{ j=0\right\} }+\phi_{i,j}\left(\varphi_{i,j-1}\left(\psi_{i}\left(\kappa_{i}\right)\right)\right)\mathbf{1}_{\left\{ j>0\right\} }\right)$
\end_inset

.
\end_layout

