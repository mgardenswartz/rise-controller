 & =\left.\frac{\partial h}{\partial q_{\text{d}}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\dot{q}_{\text{d}}+\left.\frac{\partial h}{\partial\dot{q}_{\text{d}}}\right|_{\left(q_{\text{d}},\dot{q}_{\text{d}}\right)}\ddot{q}_{\text{d}}-\left.\frac{\partial f}{\partial q}\right|_{\left(q,\dot{q}\right)}\dot{q}-\left.\frac{\partial f}{\partial\dot{q}}\right|_{\left(q,\dot{q}\right)}\ddot{q}-\dot{u}-\dot{d}\left(t\right)+k_{1}\dot{r}_{1}-k^{2}_{1}\dot{e}+k_{2}\dot{r}_{1}\\
