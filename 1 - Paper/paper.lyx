:
\begin_inset Formula 
\begin{align*}
\frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial{\rm vec}\left(V_{2,0}\right)} & =\left(\stackrel{\curvearrowleft}{\stackrel[m=3]{2}{\prod}}\left(I_{L_{\text{out}}}+\left(\stackrel{\curvearrowleft}{\stackrel[\ell=1]{k_{m}}{\prod}}V^{\top}_{m,\ell}\frac{\partial\phi_{m,\ell}}{\partial\varphi_{m,\ell-1}}\right)V^{\top}_{m,0}\frac{\partial\psi_{m}}{\partial\kappa_{m}}\right)\right)\left(\stackrel{\curvearrowleft}{\stackrel[\ell=1]{1}{\prod}}V^{\top}_{2,\ell}\frac{\partial\phi_{i,\ell}}{\partial\varphi_{i,\ell-1}}\right)\left(I_{L_{2,1}}\otimes\varrho^{\top}_{2,0}\right)\\
 & =V^{\top}_{2,1}\frac{\partial\phi_{2,1}}{\partial\varphi_{2,0}}\left(I_{L_{2,1}}\otimes\varrho^{\top}_{2,0}\right)\\
 & =\left[\begin{array}{ccc}
0.7 & 0.6 & 0.5\\
