\begin_layout Subsection
Function Approximation
\end_layout

\begin_layout Standard
Since 
\begin_inset Formula $f$
\end_inset

 and 
\begin_inset Formula $h$
\end_inset

 are unknown,
 
\begin_inset Formula $F$
\end_inset

 is unknown and will be approximated online with a user-selected parametric universal approximator as 
\begin_inset Formula $\Phi\left(\kappa,\widehat{\theta}\right)$
\end_inset

 where 
\begin_inset Formula $\Phi:\mathbb{R}^{L_{\text{in}}}\times\mathbb{R}^{{\tt p}}\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

 is a function approximator architecture mapping of class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

,
 
\begin_inset Formula $\widehat{\theta}\in\mathbb{R}^{{\tt p}}$
\end_inset

 is a vectorized set of parameters,
 
\begin_inset Formula $L_{\text{out}}=n$
\end_inset

,
 
\begin_inset Formula $L_{\text{in}}=5n$
\end_inset

,
 and 
\begin_inset Formula ${\tt p}\in\mathbb{Z}_{\ge1}$
\end_inset

 is the number of parameters.
 In this work,
 any class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 parametric approximator which satisfies a universal approximation theorem like Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:Universal-Approximation-Theorem"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 can be used for 
\begin_inset Formula $\Phi$
\end_inset

,
 like radial basis functions,
 ResNets,
 transformers (e.g.,
 
\begin_inset CommandInset citation
LatexCommand cite
key "Vaswani.2017"
literal "false"

\end_inset

),
 or LSTMs (e.g.,
 
\begin_inset CommandInset citation
LatexCommand cite
key "Griffis.Patil.ea23_2"
literal "false"

\end_inset

).
 The parameter 
\begin_inset Formula $\widehat{\theta}$
\end_inset

 is intended to dynamically estimate 
\begin_inset Formula $\theta^{\ast}$
\end_inset

 and evolve continuously but be constrained to a user-defined compact search space 
\begin_inset Formula $\mho\subseteq\overline{B}_{\overline{\theta}}\left(0_{{\tt p}}\right)$
\end_inset

,
 where 
\begin_inset Formula $\overline{\theta}\in\mathbb{R}_{>0}$
\end_inset

.
 The rule governing the trajectory of 
\begin_inset Formula $t\mapsto\widehat{\theta}\left(t\right)$
\end_inset

 is called the update law and is chosen by the user but must satisfy the following properties.
\end_layout

\begin_layout Property
\begin_inset CommandInset label
LatexCommand label
name "prop:theta_bar"

\end_inset


\begin_inset CommandInset citation
LatexCommand cite
after "Assumption 1"
key "Patil.Isaly.ea2022"
literal "false"

\end_inset

 The parameter's trajectory 
\begin_inset Formula $\widehat{\theta}:\mathbb{R}_{\ge0}\to\mathbb{R}^{{\tt p}}$
\end_inset

 is of class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 and there exist known constants 
\begin_inset Formula $\overline{\theta},\overline{\dot{\theta}}\in\mathbb{R}_{>0}$
\end_inset

 such that the trajectory and its first time derivative 
\begin_inset Formula $\dot{\widehat{\theta}}:\mathbb{R}_{\ge0}\to\mathbb{R}^{{\tt p}}$
\end_inset

 satisfy 
\begin_inset Formula $\left\Vert \widehat{\theta}\left(t\right)\right\Vert \le\overline{\theta}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{\widehat{\theta}}\left(t\right)\right\Vert \le\overline{\dot{\theta}}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge0}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Property
\begin_inset CommandInset label
LatexCommand label
name "prop:weight-initialization"

\end_inset

 There exists a known constant 
\begin_inset Formula $\overline{\varepsilon}_{\text{d}}\in\mathbb{R}_{>0}$
\end_inset

 such that parameter's trajectory satisfies 
\begin_inset Formula $E_{\Omega}\left(\widehat{\theta}\left(t\right)\right)\le\overline{\varepsilon}_{\text{d}}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge0}$
\end_inset

,
 where the reconstruction error is defined as
\begin_inset Formula 
\begin{equation}
\varepsilon\left(\kappa,\theta\right)\triangleq\Phi\left(\kappa,\theta\right)-F\left(\kappa\right),\label{eq:reconstruction_error}
\end{equation}

\end_inset

the approximation accuracy is 
\begin_inset Formula $E_{\Omega}\left(\theta\right)\triangleq\sup_{\kappa\in\Omega}\left\Vert \varepsilon\left(\kappa,\theta\right)\right\Vert +\sup_{\kappa\in\Omega}\left\Vert \left.\frac{\partial\varepsilon}{\partial\kappa}\right|_{\left(\kappa,\theta\right)}\right\Vert $
\end_inset

,
 and the desired domain where the approximation of 
\begin_inset Formula $F\left(\kappa\right)$
\end_inset

 by 
\begin_inset Formula $\Phi\left(\kappa,\widehat{\theta}\right)$
\end_inset

 must hold is
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
\Omega\triangleq\left\{ \zeta\in\mathbb{R}^{5n}:\left\Vert \zeta\right\Vert \le R_{\Omega}\right\} ,\label{eq:Omega}
\end{equation}

\end_inset

for 
\begin_inset Formula $R_{\Omega}\in\mathbb{R}_{>0}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Remark
Since the design of the update law and the choice of parametric approximator for 
\begin_inset Formula $\Phi$
\end_inset

 are at the user's discretion,
 the approach in this work is said to be modular.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
Property 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:theta_bar"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 can be met,
 for instance,
 by using a projection algorithm and limiting the speed of parameter changes.
 Satisfying Property 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:weight-initialization"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 requires careful consideration of both parameter initialization and the update law.
 The initial parameter 
\begin_inset Formula $\widehat{\theta}\left(t_{0}\right)$
\end_inset

 must either be obtained by pre-training the function approximator on input-output pairs generated by a function representative of 
\begin_inset Formula $F$
\end_inset

 or by using the following approach.
 Notice that extreme value theorem (EVT) ensures that 
\begin_inset Formula $\left\Vert F\right\Vert +\left\Vert \frac{dF}{d\kappa}\right\Vert $
\end_inset

 achieves a finite maximum over 
\begin_inset Formula $\Omega$
\end_inset

 since 
\begin_inset Formula $\Omega$
\end_inset

 is compact and 
\begin_inset Formula $F$
\end_inset

 is of class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

.
 Assume a bound 
\begin_inset Formula $\overline{F}\in\mathbb{R}_{\ge0}$
\end_inset

 on such a maximum is known.
 Pick 
\begin_inset Formula $\widehat{\theta}\left(t_{0}\right)$
\end_inset

 and a suitable 
\begin_inset Formula $\mho$
\end_inset

 such that 
\begin_inset Formula $\Phi\left(\kappa,\widehat{\theta}\left(t_{0}\right)\right)=0_{n}$
\end_inset

 for all 
\begin_inset Formula $\kappa\in\Omega$
\end_inset

.
 Finally,
 select 
\begin_inset Formula $\overline{\varepsilon}_{\text{d}}=\overline{F}$
\end_inset

.
 Satisfying Property 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:weight-initialization"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 beyond the initial time requires that any information gained online to refine the parameter not result in a 
\begin_inset Formula $E_{\Omega}\left(\widehat{\theta}\left(t\right)\right)$
\end_inset

 that exceeds 
\begin_inset Formula $\overline{\varepsilon}_{\text{d}}$
\end_inset

.
 Heuristically,
 this phenomena,
 called catastrophic forgetting,
 can be avoided by using experience replay methods like concurrent learning (CL).
\begin_inset Foot
status collapsed

\begin_layout Plain Layout
For example,
 a first-order CL-based update law for parameters in universal approximators like 
\begin_inset Formula $\Phi$
\end_inset

 can be found in 
\begin_inset CommandInset citation
LatexCommand cite
key "Hart.Patil.ea2025"
literal "false"

\end_inset

.
 Note that any discrete updates to a history stack made online may not satisfy the 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 requirement of Property 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:theta_bar"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

.
 However,
 online history stack management is not required to prevent catastrophic forgetting.
\end_layout

\end_inset


\end_layout

\begin_layout Standard
The expressive powers of ResNets and many similar approximators rely on the ability to select 
\begin_inset Formula $\theta^{\ast}$
\end_inset

 from the whole of 
\begin_inset Formula $\mathbb{R}^{{\tt p}}$
\end_inset

 (cf.
 Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:Universal-Approximation-Theorem"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) to approximate any continuous function.
 Since in practice 
\begin_inset Formula $\widehat{\theta}$
\end_inset

 must be constrained to lie in a prescribed compact search space 
\begin_inset Formula $\mho$
\end_inset

,
 it is assumed a suitable 
\begin_inset Formula $\theta^{\ast}$
\end_inset

 satisfying Property 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:weight-initialization"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 also lies in 
\begin_inset Formula $\mho$
\end_inset

.
 The following assumption formalizes this requirement and the need for simultaneous approximation of 
\begin_inset Formula $\frac{dF}{d\kappa}$
\end_inset

 in subsequent analysis.
\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "asm:bounded-weights"

\end_inset

 The function 
\begin_inset Formula $F$
\end_inset

 and its first derivative 
\begin_inset Formula $\frac{dF}{d\kappa}$
\end_inset

 can be uniformly approximated to arbitrary precision using bounded weights for a sufficiently large approximator architecture.
 Formally,
 
\begin_inset Formula $F\in\{\mathcal{C}^{1}(\Omega;\mathbb{R}^{n}):\forall\overline{\varepsilon}\in\mathbb{R}_{>0},\exists{\tt p}\in\mathbb{Z}_{\ge1}:\exists\mho\subsetneq\mathbb{R}^{{\tt p}}:\exists\theta^{\ast}\in\mho:E_{\Omega}(\theta^{\ast})\le\overline{\varepsilon}\}\subsetneq\mathcal{C}^{1}(\Omega;\mathbb{R}^{n})$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:bounded-weights"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 is required because in parametric nonlinear regression,
 the user can only pick two of the following three desirable qualities for their approximator:
 (i) 
\begin_inset Formula $F$
\end_inset

 can be any sufficiently smooth function (e.g.,
 of class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 
\color blue
as needed in this work
\color inherit
) ,
 (ii) 
\begin_inset Formula $F$
\end_inset

 can be approximated arbitrarily well (
\begin_inset Formula $\overline{\varepsilon}_{\text{d}}\to0$
\end_inset

 as 
\begin_inset Formula ${\tt p}\to\infty$
\end_inset

),
 and (iii) the weights needed to achieve the desired accuracy for the target function lies in a prescribed set 
\begin_inset Formula $\mho$
\end_inset

 with a known circumradius 
\begin_inset Formula $\overline{\theta}$
\end_inset

.
 Without (ii),
 there will exist sufficiently small values of 
\begin_inset Formula $\overline{\varepsilon}_{\text{d}}$
\end_inset

 that are not achievable for the given 
\begin_inset Formula $\mho$
\end_inset

,
 
\begin_inset Formula $F$
\end_inset

,
 and 
\begin_inset Formula $\Omega$
\end_inset

 even as 
\begin_inset Formula ${\tt p}\to\infty$
\end_inset

.
 That is,
 the infimum of all values 
\begin_inset Formula $\overline{\varepsilon}_{\text{d}}$
\end_inset

 may achieve is an unknown positive value (rather than zero) that might be arbitrarily large.
 Thus,
 (ii) is required.
 Since computers possess finite memory to store 
\begin_inset Formula $\widehat{\theta}$
\end_inset

,
 (iii) is required.
 Subsequent analysis also relies on (iii).
 Thus,
 (i) must be sacrificed in place of Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:bounded-weights"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

.
 Under Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:bounded-weights"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

,
 the set 
\begin_inset Formula $\Theta^{\ast}\triangleq\arg\min_{\theta\in\mho}E_{\Omega}\left(\theta\right)$
\end_inset

 is nonempty and all 
\begin_inset Formula $\theta^{\ast}\in\Theta^{\ast}$
\end_inset

 satisfy 
\begin_inset Formula $\left\Vert \theta^{\ast}\right\Vert \le\overline{\theta}$
\end_inset

.
 
\end_layout

\begin_layout Subsection
Control Law
\end_layout

\begin_layout Standard
Motivated by the form of (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:r2-step-1"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

),
 the controller is designed as
\begin_inset Formula 
\begin{equation}
\begin{alignedat}{1}\dot{u}\left(t\right) & =\left(k_{1}+k_{2}+k_{3}\right)r_{2}\left(t\right)+k^{3}_{1}e\left(t\right)\\
 & +\left(1-k^{2}_{1}-k^{2}_{2}-k_{1}k_{2}\right)r_{1}\left(t\right)\\
 & +K_{\text{RISE}}\text{sgn}\left(r_{1}\left(t\right)\right)+\Phi\left(\kappa\left(t\right),\hat{\theta}\left(t\right)\right),
\end{alignedat}
\label{eq:u_dot}
\end{equation}

\end_inset

where 
\begin_inset Formula $K_{\text{RISE}},k_{3}\in\mathbb{R}_{>0}$
\end_inset

 are user-defined constants.
 Integrating both sides of (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:u_dot"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) and picking the initial condition 
\begin_inset Formula $u\left(t_{0}\right)=K_{\text{P}}e\left(t_{0}\right)+K_{\text{D}}\dot{e}\left(t_{0}\right)$
\end_inset

 yields the implementable form
\begin_inset Foot
status collapsed

\begin_layout Plain Layout
Although 
\begin_inset Formula $\ddot{q}$
\end_inset

 is not assumed to be measurable,
 it appears in (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:u_dot"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) by virtue of 
\begin_inset Formula $r_{2}$
\end_inset

.
 However,
 note that the implementable form in (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:u_implementable"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) only requires 
\begin_inset Formula $q$
\end_inset

 and 
\begin_inset Formula $\dot{q}$
\end_inset

.
\end_layout

\end_inset


\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Recall
