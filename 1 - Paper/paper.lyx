\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\Psi\left(\kappa,\Theta\right) & =\kappa_{1}\\
 & =\Phi_{0}\left(\kappa^{a}_{0},\theta_{0}\right)\\
 & =\varphi_{0,k_{0}}\left(\kappa^{a}_{0}\right)\\
 & =V^{\top}_{0,k_{0}}\phi_{0,k_{0}}\left(\varphi_{0,k_{0}-1}\left(\kappa^{a}_{0}\right)\right)\\
 & =V^{\top}_{0,k_{0}}\phi_{0,k_{0}}\left(V^{\top}_{0,k_{0}-1}\phi_{0,k_{0}-1}\left(\varphi_{0,k_{0}-2}\left(\kappa^{a}_{0}\right)\right)\right)\\
 & =V^{\top}_{0,k_{0}}\phi_{0,k_{0}}\left(V^{\top}_{0,k_{0}-1}\phi_{0,k_{0}-1}\left(V^{\top}_{0,k_{0}-2}\phi_{0,k_{0}-2}\left(\varphi_{0,k_{0}-3}\left(\kappa^{a}_{0}\right)\right)\right)\right)\\
 & =V^{\top}_{0,k_{0}}\phi_{0,k_{0}}\left(V^{\top}_{0,k_{0}-1}\phi_{0,k_{0}-1}\left(V^{\top}_{0,k_{0}-2}\phi_{0,k_{0}-2}\left(\ldots V^{\top}_{0,1}\phi_{0,1}\left(V^{\top}_{0,0}\kappa^{a}_{0}\right)\right)\right)\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
