\\ & ={\color{blue}e^{\top}r_{1}}-k_{1}e^{\top}e+\cancel{r^{\top}_{1}r_{2}}-k_{2}r^{\top}_{1}r_{1}+r^{\top}_{2}\widetilde{N}\left(\kappa,\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)-k_{3}r^{\top}_{2}r_{2}-\cancel{r^{\top}_{2}r_{1}}-K_{\text{RISE}}r^{\top}_{2}\nu_{1}+\cancel{r^{\top}_{2}D\left(\kappa_{\text{d}},\theta^{\ast},\hat{\theta},t\right)}\\
