Assume
\begin_inset Formula 
\begin{align*}
\left\Vert q_{\text{d}}\left(t\right)\right\Vert  & \le\overline{q}_{\text{d}}\\
\left\Vert \dot{q}_{\text{d}}\left(t\right)\right\Vert  & \le\overline{\dot{q}}_{\text{d}}\\
\left\Vert \ddot{q}_{\text{d}}\left(t\right)\right\Vert  & \le\overline{\ddot{q}}_{\text{d}}
\end{align*}

\end_inset

are known constants.
 Define
\begin_inset Formula 
\begin{align*}
e & \triangleq q_{\text{d}}-q\\
r_{1} & \triangleq\dot{e}+k_{1}e
\end{align*}

\end_inset


\family default
\series default
\shape default
\size default
\emph default
\bar default
\strikeout default
\xout default
