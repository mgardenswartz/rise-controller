\begin_layout Standard
To construct the compact domain of inputs over which the approximation of
 
\begin_inset Formula $F$
\end_inset

 by 
\begin_inset Formula $\Phi\left(\kappa,\widehat{\theta}\right)$
\end_inset

 is of interest, the idealized input if (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:agent-dynamics"
plural "false"
caps "false"
noprefix "false"

\end_inset

) were perfectly tracking (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:reference-dynamics"
plural "false"
caps "false"
noprefix "false"

\end_inset

) is 
\begin_inset Formula $\kappa_{d}\triangleq\left[\begin{array}{ccccc}
q_{d}^{\top} & \dot{q}_{d}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u_{d}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{5n}$
\end_inset

.
 By Assumptions 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:h-C2-bounded"
plural "false"
caps "false"
noprefix "false"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:ud_bounded"
plural "false"
caps "false"
noprefix "false"

\end_inset

, there exist known constants 
\begin_inset Formula $\overline{\kappa}_{d}\triangleq2\overline{q}_{d}+2\overline{\dot{q}}_{d}+\overline{u}_{d}$
\end_inset

 and 
\begin_inset Formula $\overline{\dot{\kappa}}_{d}\triangleq2\overline{\dot{q}}_{d}+2\overline{\ddot{q}}_{d}+\overline{\dot{u}}_{d}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert \kappa_{d}\right\Vert \le\overline{\kappa}_{d}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{\kappa}_{d}\right\Vert \le\overline{\dot{\kappa}}_{d}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge0}$
\end_inset

.
\begin_inset Note Note
status collapsed

\begin_layout Subsubsection*
BOUNDING LEMMA 2.3
\end_layout

\begin_layout Plain Layout
Recall
\begin_inset Formula 
\[
\kappa_{d}\triangleq\left[\begin{array}{ccccc}
q_{d}^{\top} & \dot{q}_{d}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u_{d}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{5n}
\]

\end_inset

Thus, by Bounding Lemma 2.1,
\begin_inset Formula 
\begin{align*}
\left\Vert \kappa_{d}\right\Vert  & \le\overline{\kappa}_{d}\\
\overline{\kappa}_{d} & \triangleq2\overline{q}_{d}+2\overline{\dot{q}}_{d}+\overline{u}_{d}
\end{align*}

\end_inset


\end_layout

\begin_layout Subsubsection*
BOUNDING LEMMA 2.6
\end_layout

\begin_layout Plain Layout
Notice
\begin_inset Formula 
\[
\dot{\kappa}_{d}=\left[\begin{array}{ccccc}
\dot{q}_{d}^{\top} & \ddot{q}_{d}^{\top} & \dot{q}_{d}^{\top} & \ddot{q}_{d}^{\top} & \dot{u}_{d}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{5n}
\]

\end_inset

By Bounding Lemma 2.2,
\begin_inset Formula 
\begin{align*}
\left\Vert \dot{\kappa}_{d}\right\Vert  & \le\overline{\dot{\kappa}}_{d}\\
\overline{\dot{\kappa}}_{d} & \triangleq2\overline{\dot{q}}_{d}+2\overline{\ddot{q}}_{d}+\overline{\dot{u}}_{d}
\end{align*}

\end_inset


\end_layout

\end_inset

 Using (
\begin_inset Formula $\ref{eq:r1_def}$
\end_inset

), Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:rho_f"
plural "false"
caps "false"
noprefix "false"

\end_inset

, and the definition of 
\begin_inset Formula $\rho_{\widetilde{u}}$
\end_inset

, there exists a known function that is 
\begin_inset Formula $\mathcal{P}_{\infty}$
\end_inset

 with respect to each argument such that 
\begin_inset Formula $\left\Vert \widetilde{\kappa}\right\Vert \le\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert $
\end_inset

, where 
\begin_inset Formula $\widetilde{\kappa}\triangleq\kappa_{d}-\kappa$
\end_inset

 and 
\begin_inset Formula $\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},s\right)\triangleq k_{1}+2+\rho_{\widetilde{u}}\left(k_{1},k_{2},s\right)$
\end_inset

.
\begin_inset Note Note
status collapsed

\begin_layout Subsubsection*
BOUNDING LEMMA 2.5
\end_layout

\begin_layout Plain Layout
Recall
\begin_inset Formula 
\begin{align*}
\kappa & \triangleq\left[\begin{array}{ccccc}
q^{\top} & \dot{q}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{5n}\\
\kappa_{d} & \triangleq\left[\begin{array}{ccccc}
q_{d}^{\top} & \dot{q}_{d}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u_{d}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{5n}\\
\widetilde{u} & \triangleq u_{d}-u
\end{align*}

\end_inset

Let
\begin_inset Formula 
\begin{align*}
\widetilde{\kappa} & \triangleq\kappa_{d}-\kappa\\
 & =\left[\begin{array}{ccccc}
q_{d}^{\top} & \dot{q}_{d}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u_{d}^{\top}\end{array}\right]^{\top}-\left[\begin{array}{ccccc}
q^{\top} & \dot{q}^{\top} & q_{d}^{\top} & \dot{q}_{d}^{\top} & u^{\top}\end{array}\right]^{\top}\\
 & =\left[\begin{array}{ccccc}
e^{\top} & \dot{e}^{\top} & 0_{1\times n} & 0_{1\times n} & \widetilde{u}^{\top}\end{array}\right]^{\top}
\end{align*}

\end_inset

By Bounding Lemma 2.4,
\begin_inset Formula 
\begin{align*}
\left\Vert \widetilde{\kappa}\right\Vert  & \le\left\Vert e\right\Vert +\left\Vert \dot{e}\right\Vert +\left\Vert \widetilde{u}\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert r_{1}-k_{1}e\right\Vert +\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left\Vert e\right\Vert +\left\Vert r_{1}\right\Vert +k_{1}\left\Vert e\right\Vert +\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(k_{1}+2\right)\left\Vert z\right\Vert +\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \\
 & \le\left(\underbrace{k_{1}+2+\rho_{\widetilde{u}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}_{\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)}\right)\left\Vert z\right\Vert \\
 & \le\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},\left\Vert z\right\Vert \right)\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\end_inset

 The approximation domain of interest for all inputs 
\begin_inset Formula $\kappa$
\end_inset

 is
\begin_inset Formula 
\begin{equation}
\Omega\triangleq\left\{ \zeta\in\mathbb{R}^{5n}:\left\Vert \zeta\right\Vert \le\overline{\kappa}\right\} ,\quad\overline{\kappa}\triangleq\overline{\kappa}_{d}+\rho_{\widetilde{\kappa}}\left(k_{1},k_{2},C_{\Delta}\right)C_{\Delta},\label{eq:Omega}
\end{equation}

\end_inset

where 
\begin_inset Formula $C_{\Delta}\in\mathbb{R}_{>0}$
\end_inset

 is a subsequently defined constant.
\end_layout

\begin_layout Standard
The parameter 
\begin_inset Formula $\widehat{\theta}$
\end_inset

 is intended to dynamically estimate 
\begin_inset Formula $\theta^{\ast}$
\end_inset

 and evolve continuously but be constrained to a user-defined bounded search
 space 
\begin_inset Formula $\mho\subseteq\overline{B}_{\overline{\theta}}\left(0_{{\tt p}}\right)$
\end_inset

 with a known circumradius 
\begin_inset Formula $\overline{\theta}\in\mathbb{R}_{>0}$
\end_inset

.
 The update law governing the trajectory of 
\begin_inset Formula $\widehat{\theta}$
\end_inset

 over time can be user-designed and need only satisfy the following property.
\end_layout

\begin_layout Property
\begin_inset CommandInset label
LatexCommand label
name "prop:theta_bar"

\end_inset

 The parameter estimate's trajectory 
\begin_inset Formula $\widehat{\theta}:\mathbb{R}_{\ge0}\to\mathbb{R}^{{\tt p}}$
\end_inset

 is of class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 and there exists known constants 
\begin_inset Formula $\overline{\theta},\eta_{1}\in\mathbb{R}_{>0}$
\end_inset

 such that the trajectory and its first time derivative 
\begin_inset Formula $\dot{\widehat{\theta}}:\mathbb{R}_{\ge0}\to\mathbb{R}^{{\tt p}}$
\end_inset

 satisfy 
\begin_inset Formula $\left\Vert \widehat{\theta}\left(t\right)\right\Vert \le\overline{\theta}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{\widehat{\theta}}\left(t\right)\right\Vert \le\eta_{1}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge0}$
\end_inset

.
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Why did Omkar need higher-order bounds?
\end_layout

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
Property 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:theta_bar"
plural "false"
caps "false"
noprefix "false"

\end_inset

 can be met, for instance, by using a projection algorithm and limiting
 the speed of parameter changes.
 Note that 
\begin_inset Formula $F$
\end_inset

 is of class 
\begin_inset Formula $\mathcal{C}^{1}$
\end_inset

 by Assumptions 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:f-C2"
plural "false"
caps "false"
noprefix "false"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:h-C2-bounded"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
 Pick a desired approximation accuracy 
\begin_inset Formula $\overline{\varepsilon}_{\text{d}}\in\mathbb{R}_{>0}$
\end_inset

 and pick a sufficiently sized network (
\begin_inset Formula $\Phi$
\end_inset

 and 
\begin_inset Formula ${\tt p}$
\end_inset

).
 Since the expressive powers of ResNets and many similar approximators relies
 on the ability to select 
\begin_inset Formula $\theta^{\ast}$
\end_inset

 from the whole of 
\begin_inset Formula $\mathbb{R}^{{\tt p}}$
\end_inset

 (cf.
 Theorem 
\begin_inset CommandInset ref
LatexCommand ref
reference "thm:Universal-Approximation-Theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

), 
\begin_inset Formula $F$
\end_inset

 must belong to a strict subset of all continuous functions as a consequence
 of Property 
\begin_inset CommandInset ref
LatexCommand ref
reference "prop:theta_bar"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
 
\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "asm:bounded-weights"

\end_inset

 The function 
\begin_inset Formula $F$
\end_inset

 belongs the class of functions that can be uniformly approximated along
 with their first derivatives using bounded weights.
 Formally, 
\begin_inset Formula $F\in\mathcal{F}\triangleq\left\{ \mathcal{C}^{1}\left(\Omega;\mathbb{R}^{n}\right):\exists\theta^{\ast}\in\mho:\sup_{\kappa\in\Omega}\left\Vert \varepsilon\left(\kappa,\theta^{\ast}\right)\right\Vert +\sup_{\kappa\in\Omega}\left\Vert \left.\frac{d\varepsilon}{d\kappa}\right|_{\left(\kappa,\theta^{\ast}\right)}\right\Vert \le\overline{\varepsilon}_{\text{d}}\right\} $
\end_inset

, where 
\begin_inset Formula $\varepsilon\left(\kappa,\theta^{\ast}\right)\triangleq\Phi\left(\kappa,\theta^{\ast}\right)-F\left(\kappa\right)$
\end_inset

.
\begin_inset Foot
status collapsed

\begin_layout Plain Layout
Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:bounded-weights"
plural "false"
caps "false"
noprefix "false"

\end_inset

 is simply a formal statement of an implicit assumption common to many previous
 adaptive controls works using parametric approximators.
\end_layout

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:bounded-weights"
plural "false"
caps "false"
noprefix "false"

\end_inset

 is required because of the following tradeoff.
 In parametric nonlinear regression, the user is forced may only pick two
 of the following three desirable qualities for their approximator: (i)
 
\begin_inset Formula $F$
\end_inset

 can be any 
\begin_inset Formula $\mathcal{C}^{0}$
\end_inset

 function, (ii) 
\begin_inset Formula $F$
\end_inset

 can be approximated arbitrarily well (
\begin_inset Formula $\overline{\varepsilon}_{\text{d}}\to0$
\end_inset

), (iii) a known bound exists on the weights needed to achieve the desired
 accuracy for the target function.
 Without (2), there will exists sufficiently small values of 
\begin_inset Formula $\overline{\varepsilon}_{\text{d}}$
\end_inset

 that are not achievable for the given 
\begin_inset Formula $\mho$
\end_inset

.
 That is, 
\begin_inset Formula $\overline{\varepsilon}_{\text{d}}$
\end_inset

 may be arbitrarily large and can no longer be user-defined.
 Thus, (ii) is required.
 Practical implementation of a neural network on a computer with finite
 memory requires (iii).
 Thus, (i) must be sacrificed in place of Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:bounded-weights"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
\end_layout

\begin_layout Standard
By Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:bounded-weights"
plural "false"
caps "false"
noprefix "false"

\end_inset

, the set 
\begin_inset Formula $\Theta^{\ast}\triangleq\arg\min_{\vartheta\in\mho}\left(\sup_{\kappa\in\Omega}\left\Vert \varepsilon\left(\kappa,\theta^{\ast}\right)\right\Vert +\sup_{\kappa\in\Omega}\left\Vert \left.\frac{d\varepsilon}{d\kappa}\right|_{\left(\kappa,\theta^{\ast}\right)}\right\Vert \right)$
\end_inset

 is nonempty and any 
\begin_inset Formula $\theta^{\ast}\in\Theta^{\ast}$
\end_inset

 satisfies
\begin_inset Formula $\left\Vert \theta^{\ast}\right\Vert \le\overline{\theta}$
\end_inset

.
 Since the design of the update law for 
\begin_inset Formula $\widehat{\theta}$
\end_inset

 and the choice of parametric approximator for 
\begin_inset Formula $\Phi$
\end_inset

 are at the user's discretion, the approach in this work is said to be modular.
 Motivated by the form of (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:r2-step-1"
plural "false"
caps "false"
noprefix "false"

\end_inset

), the controller is designed as a Fil
\begin_inset Formula 
\begin{equation}
\dot{u}\left(t\right)=\left(k_{1}+k_{2}+k_{3}\right)r_{2}\left(t\right)+\left(1-k_{1}^{2}-k_{2}^{2}-k_{1}k_{2}\right)r_{1}\left(t\right)+k_{1}^{3}e\left(t\right)+K_{\text{RISE}}\text{sgn}\left(r_{1}\left(t\right)\right)+\Phi\left(\kappa\left(t\right),\hat{\theta}\left(t\right)\right),\label{eq:u_dot}
\end{equation}

\end_inset

where 
\begin_inset Formula $K_{\text{RISE}},k_{3}\in\mathbb{R}_{>0}$
\end_inset

 are user-defined constants.
 Integrating both sides of (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:u_dot"
plural "false"
caps "false"
noprefix "false"

\end_inset

) and picking the initial condition as 
\begin_inset Formula $u\left(t_{0}\right)=K_{P}e\left(t_{0}\right)+K_{D}\dot{e}\left(t_{0}\right)$
\end_inset

 yields the implementable form
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Recall
\family roman
\series medium
\shape up
\size normal
\emph off
\bar no
\strikeout off
\xout off
\uuline off
\uwave off
\noun off
\color none

\begin_inset Formula 
\begin{align*}
e & \triangleq q_{d}-q\\
r_{1} & \triangleq\dot{e}+k_{1}e\\
\dot{r}_{1} & =\ddot{e}+k_{1}\dot{e}\\
r_{2} & \triangleq\dot{r}_{1}+k_{2}r_{1}
\end{align*}

\end_inset

Simplify:
\begin_inset Formula 
\begin{align*}
\dot{u} & =\left(k_{1}+k_{2}+k_{3}\right)r_{2}+\left(1-k_{1}^{2}-k_{2}^{2}-k_{1}k_{2}\right)r_{1}+k_{1}^{3}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
 & =\left(k_{1}+k_{2}+k_{3}\right)\left(\dot{r}_{1}+k_{2}r_{1}\right)+\left(1-k_{1}^{2}-k_{2}^{2}-k_{1}k_{2}\right)\left(\dot{e}+k_{1}e\right)+k_{1}^{3}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
 & =\left(k_{1}+k_{2}+k_{3}\right)\left(\ddot{e}+k_{1}\dot{e}+k_{2}\left(\dot{e}+k_{1}e\right)\right)+\left(1-k_{1}^{2}-k_{2}^{2}-k_{1}k_{2}\right)\left(\dot{e}+k_{1}e\right)+k_{1}^{3}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
 & =\left(k_{1}+k_{2}+k_{3}\right)\left(\ddot{e}+k_{1}\dot{e}+k_{2}\dot{e}+k_{1}k_{2}e\right)+\left(1-k_{1}^{2}-k_{2}^{2}-k_{1}k_{2}\right)\dot{e}+\left(1-k_{1}^{2}-k_{2}^{2}-k_{1}k_{2}\right)k_{1}e+k_{1}^{3}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
\\
 & =\left(\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(k_{1}+k_{2}+k_{3}\right)k_{1}\dot{e}+\left(k_{1}+k_{2}+k_{3}\right)k_{2}\dot{e}+\left(k_{1}+k_{2}+k_{3}\right)k_{1}k_{2}e\right)\\
 & +\left(1-k_{1}^{2}-k_{2}^{2}-k_{1}k_{2}\right)\dot{e}+\left(k_{1}-k_{1}^{3}-k_{1}k_{2}^{2}-k_{1}^{2}k_{2}\right)e+k_{1}^{3}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
\\
 & =\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(k_{1}^{2}+k_{1}k_{2}+k_{1}k_{3}\right)\dot{e}+\left(k_{1}k_{2}+k_{2}^{2}+k_{2}k_{3}\right)\dot{e}+\left(k_{1}^{2}k_{2}+k_{1}k_{2}^{2}+k_{1}k_{2}k_{3}\right)e\\
 & +\left(1-k_{1}^{2}-k_{2}^{2}-k_{1}k_{2}\right)\dot{e}+\left(k_{1}-k_{1}^{3}-k_{1}k_{2}^{2}-k_{1}^{2}k_{2}\right)e+k_{1}^{3}e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
\\
 & =\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(k_{1}^{2}+k_{1}k_{2}+k_{1}k_{3}+1-k_{1}^{2}-k_{2}^{2}-k_{1}k_{2}+k_{1}k_{2}+k_{2}^{2}+k_{2}k_{3}\right)\dot{e}\\
 & +\left(k_{1}^{2}k_{2}+k_{1}k_{2}^{2}+k_{1}k_{2}k_{3}+k_{1}-k_{1}^{3}-k_{1}k_{2}^{2}-k_{1}^{2}k_{2}+k_{1}^{3}\right)e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
\\
 & =\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(\cancel{k_{1}^{2}}+k_{1}k_{2}+k_{1}k_{3}+1-\cancel{k_{1}^{2}}-\cancel{k_{2}^{2}}\cancel{-k_{1}k_{2}+k_{1}k_{2}}+\cancel{k_{2}^{2}}+k_{2}k_{3}\right)\dot{e}\\
 & +\left(\cancel{k_{1}^{2}k_{2}}+\cancel{k_{1}k_{2}^{2}}+k_{1}k_{2}k_{3}+k_{1}-\cancel{k_{1}^{3}}-\cancel{k_{1}k_{2}^{2}}-\cancel{k_{1}^{2}k_{2}}+\cancel{k_{1}^{3}}\right)e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)\\
\\
 & =\left(k_{1}+k_{2}+k_{3}\right)\ddot{e}+\left(k_{1}k_{2}+k_{1}k_{3}+k_{2}k_{3}+1\right)\dot{e}+\left(k_{1}k_{2}k_{3}+k_{1}\right)e+K_{\text{RISE}}\text{sgn}\left(r_{1}\right)+\Phi\left(\kappa,\hat{\theta}\right)
\end{align*}

