\begin{align*}
\left\Vert d\left(t\right)\right\Vert  & \le\overline{d}\\
\left\Vert \dot{d}\left(t\right)\right\Vert  & \le\overline{\dot{d}}
\end{align*}

\end_inset

are known constants.

