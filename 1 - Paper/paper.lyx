Deep Residual Neural Network Model 
\end_layout

\begin_layout Standard

\color blue
The residual neural network (ResNet) architecture,
 characterized by skip connections and hierarchical feature extraction,
 models incremental changes rather than complete transformations of the underlying nonlinear mapping.
 This architecture learns the differences (or 
\begin_inset Quotes eld
\end_inset

residuals
\begin_inset Quotes erd
\end_inset

) between the input and desired output at each layer,
 thereby enabling effective function approximation for complex nonlinear systems without requiring explicit governing equations.
 A fully-connected feedforward ResNet is constructed as follows.
\end_layout

\begin_layout Standard

\color blue
Let
\color inherit
 
\begin_inset Formula $b\in\mathbb{Z}_{\ge0}$
\end_inset

 
\color blue
be the number of residual
\color inherit
 blocks,
 
\color blue
let the input be
\color inherit
 
\begin_inset Formula $x\in\mathbb{R}^{L_{\text{in}}}$
\end_inset

,
 and 
\color blue
let the output be
\color inherit
 
\begin_inset Formula $y\in\mathbb{R}^{L_{\text{out}}}$
\end_inset

,
 
\color blue
where 
\begin_inset Formula $L_{\text{in}},L_{\text{out}}\in\mathbb{Z}_{\ge1}$
\end_inset


\color inherit
.
 For each block index 
\begin_inset Formula $i\in\left\{ 0,\ldots,b\right\} $
\end_inset

,
 let 
\begin_inset Formula $k_{i}\in\mathbb{Z}_{\ge1}$
\end_inset

 denote the number of hidden layers in the 
\begin_inset Formula $i^{\text{th}}$
\end_inset

 block,
 let 
\begin_inset Formula $\kappa_{i}\in\mathbb{R}^{L_{i,0}}$
\end_inset

 denote the block input,
 and let 
\begin_inset Formula $\theta_{i}\in\mathbb{R}^{p_{i}}$
\end_inset

 denote the vector of parameters (weights and biases) associated with the 
\begin_inset Formula $i^{\text{th}}$
\end_inset

 block.
 
\color blue
Note that 
\begin_inset Formula $\kappa_{0}\triangleq x$
\end_inset

 and 
\begin_inset Formula $L_{0,0}\triangleq L_{\text{in}}$
\end_inset

.
\end_layout

\begin_layout Standard
For all 
\begin_inset Formula $\left(i,j\right)\in\left\{ 0,\ldots,b\right\} \times\left\{ 0,\ldots,k_{i}+1\right\} $
\end_inset

,
 let 
\begin_inset Formula $L_{i,j}\in\mathbb{Z}_{\ge1}$
\end_inset

 denote the number of neurons in the 
\begin_inset Formula $j^{\text{th}}$
\end_inset

 layer for the 
\begin_inset Formula $i^{\text{th}}$
\end_inset

 block.
 For all 
\begin_inset Formula $\left(i,j\right)\in\left\{ 0,\ldots,b\right\} \times\left\{ 0,\ldots,k_{i}\right\} $
\end_inset

,
 define the augmented dimension 
\begin_inset Formula $L^{a}_{i,j}\triangleq L_{i,j}+1$
\end_inset

.
 Each block function 
\begin_inset Formula $\Phi_{i}:\mathbb{R}^{L^{a}_{i,0}}\times\mathbb{R}^{p_{i}}\to\mathbb{R}^{L_{i,k_{i}+1}}$
\end_inset

 is a fully connected,
 feedforward 
\color blue
deep neural network
\color inherit
 (DNN) with 
\color blue

\begin_inset Formula $L_{i,k_{i}+1}\triangleq L_{\text{out}}$
\end_inset

 for all 
\begin_inset Formula $i\in\left\{ 0,\ldots,b\right\} $
\end_inset

.

\color inherit
 For any input 
\begin_inset Formula $v\in\mathbb{R}^{L^{a}_{i,j}}$
\end_inset

,
 the DNN is defined recursively by
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
\varphi_{i,j}\left(v\right)\triangleq\begin{cases}
V^{\top}_{i,0}v, & j=0,\\
V^{\top}_{i,j}\phi_{i,j}\left(\varphi_{i,j-1}\left(v\right)\right), & j\in\left\{ 1,\ldots,k_{i}\right\} ,
\end{cases}\label{eq:DNN}
\end{equation}

\end_inset

with 
\begin_inset Formula $\Phi_{i}\left(v,\theta_{i}\right)=\varphi_{i,k_{i}}\left(v\right)$
\end_inset

.
\end_layout

\begin_layout Standard
For each 
\begin_inset Formula $j\in\left\{ 0,1,\ldots,k_{i}\right\} $
\end_inset

,
 the matrix 
\begin_inset Formula $V_{i,j}\in\mathbb{R}^{L^{a}_{i,j}\times L_{i,j+1}}$
\end_inset

 contains the weights and biases;
 in particular,
 if a layer has 
\begin_inset Formula $n$
\end_inset

 inputs 
\color blue
(including the appended bias) 
\color inherit
and the subsequent layer has 
\begin_inset Formula $m$
\end_inset

 nodes,
 then 
\begin_inset Formula $V\in\mathbb{R}^{n\times m}$
\end_inset

 is constructed so that its 
\color blue

\begin_inset Formula $\left(r,c\right)^{\text{th}}$
\end_inset

 
\color inherit
entry represents the weight from the 
\color blue

\begin_inset Formula $r^{\text{th}}$
\end_inset

 
\color inherit
node of the input to the 
\color blue

\begin_inset Formula $c^{\text{th}}$
\end_inset


\color inherit
 node of the output,
 with the last row corresponding to the bias terms.
 For the DNN architecture described by 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:DNN"
nolink "false"

\end_inset

,
 the vector of DNN weights of the 
\begin_inset Formula $i^{\text{th}}$
\end_inset

 block is 
\begin_inset Formula $\theta_{i}\triangleq\left[\begin{array}{ccc}
\text{vec}\left(V_{i,0}\right)^{\top} & \cdots & \text{vec}\left(V_{i,k_{i}}\right)^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{p_{i}}$
\end_inset

,
 where 
\begin_inset Formula $p_{i}\triangleq\sum^{k_{i}}_{j=0}L^{a}_{i,j}L_{i,j+1}$
\end_inset


\color blue
.
 For all 
\begin_inset Formula $\left(i,j\right)\in\left\{ 0,\ldots,b\right\} \times\left\{ 0,\ldots,k_{i}\right\} $
\end_inset

,

\color inherit
 the 
\color blue
ensemble
\color inherit
 activation function 
\color blue
of the 
\begin_inset Formula $j^{\text{th}}$
\end_inset

 layer of the 
\begin_inset Formula $i^{\text{th}}$
\end_inset

 block is given by 
\begin_inset Formula $\phi_{i,j}:\mathbb{R}^{L_{i,j}}\to\mathbb{R}^{L^{a}_{i,j}}$
\end_inset

,
 where
\color inherit
 
\color blue

\begin_inset Formula $\phi_{i,j}\left(\varphi_{i,j-1}\right)$
\end_inset

 
\begin_inset Formula $\triangleq$
\end_inset

 
\begin_inset Formula $\left[\varsigma_{i,j}\left(\left(\varphi_{i,j-1}\right)_{1}\right)\right.$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\varsigma_{i,j}\left(\left(\varphi_{i,j-1}\right)_{2}\right)\end{array}$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\cdots\end{array}$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\varsigma_{i,j}\left(\left(\varphi_{i,j-1}\right)_{L_{i,j}}\right)\end{array}$
\end_inset

 
\begin_inset Formula $\left.1\right]^{\top}$
\end_inset


\color inherit
 
\begin_inset Formula $\in\mathbb{R}^{L^{a}_{i,j}}$
\end_inset


\color blue
,
 the activation function is
\color inherit
 
\begin_inset Formula $\varsigma_{i,j}:\mathbb{R}\to\mathbb{R}$
\end_inset

,
 and 1 accounts for the bias term.
\end_layout

