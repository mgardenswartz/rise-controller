\end_inset

A pre-activation design is used so that,
 before each block (except block 
\begin_inset Formula $0$
\end_inset

),
 the output of the previous block is processed by an external activation function.
 Specifically,
 for each block 
\begin_inset Formula $i\in\left\{ 1,\ldots,b\right\} $
\end_inset

,
 define the pre-activation mapping 
\begin_inset Formula $\psi_{i}:\mathbb{R}^{L_{i,k_{i}+1}}\to\mathbb{R}^{L^{a}_{i,k_{i}+1}}$
\end_inset

 by 
\begin_inset Formula $\psi_{i}\left(\kappa_{i}\right)$
\end_inset

 
\begin_inset Formula $=$
\end_inset

 
\color blue

\begin_inset Formula $\left[\varrho_{i}\left(\left(\kappa_{i}\right)_{1}\right)\right.$
\end_inset

 
\begin_inset Formula $\varrho_{i}\left(\left(\kappa_{i}\right)_{2}\right)$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\cdots\end{array}$
\end_inset

 
\begin_inset Formula $\varrho_{i}\left(\left(\kappa_{i}\right)_{L_{i,k_{i}+1}}\right)$
\end_inset

 
\begin_inset Formula $\left.1\right]^{\top}$
\end_inset

 
\begin_inset Formula $\in\mathbb{R}^{L^{a}_{i,k_{i}+1}}$
\end_inset


\color inherit
 where 
\begin_inset Formula $\left(\kappa_{i}\right)_{\ell}$
\end_inset

 denotes the 
\begin_inset Formula $\ell^{\text{th}}$
\end_inset

 component of 
\begin_inset Formula $\kappa_{i}$
\end_inset

,
 the activation function is 
\begin_inset Formula $\varrho_{i}:\mathbb{R}\to\mathbb{R}$
\end_inset

,
 and 1 accounts for the bias term.
 The output of 
\begin_inset Formula $\psi_{i}$
\end_inset

 serves as the input to block 
\begin_inset Formula $i$
\end_inset

 and the residual connection is implemented by adding the current block output to the pre-activated output from the previous block.
 Hence,
 the ResNet recursion is defined by
\begin_inset Formula 
\begin{equation}
\kappa_{i+1}\triangleq\begin{cases}
\Phi_{0}\left(\kappa^{a}_{0},\theta_{0}\right), & i=0,\\
\kappa_{i}+\Phi_{i}\left(\psi_{i}\left(\kappa_{i}\right),\theta_{i}\right), & i\in\left\{ 1,\ldots,b\right\} ,
\end{cases}\label{eq:ResNet}
\end{equation}

\end_inset

with output 
\begin_inset Formula $y\in\mathbb{R}^{L_{\text{out}}}$
\end_inset

 and overall parameter vector 
\begin_inset Formula $\Theta\triangleq\left[\begin{array}{ccc}
\theta^{\top}_{0} & \cdots & \theta^{\top}_{b}\end{array}\right]^{\top}\in\mathbb{R}^{{\tt p}}$
\end_inset

,
 with 
\begin_inset Formula ${\tt p}\triangleq\sum^{b}_{i=0}p_{i}$
\end_inset

,
 where 
\begin_inset Formula $\kappa^{a}_{0}\triangleq\left[\begin{array}{cc}
\kappa^{\top}_{0} & 1\end{array}\right]^{\top}\in\mathbb{R}^{L^{a}_{0,0}}$
\end_inset

 denotes the augmented input to block 
\begin_inset Formula $i=0$
\end_inset

.
 Therefore,
 the complete ResNet is represented as 
\begin_inset Formula $\Psi:\mathbb{R}^{L_{\text{in}}}\times\mathbb{R}^{{\tt p}}\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

 expressed as 
\begin_inset Formula $\Psi\left({\color{blue}x},\Theta\right)=\kappa_{b+1}$
\end_inset

.
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
The partial derivative of the ResNet with respect to the parameters is represented as 
\begin_inset Formula $\frac{\partial}{\partial\Theta}\Psi\left(\kappa,\Theta\right)=\left[\begin{array}{ccc}
\frac{\partial}{\partial\theta_{0}}\Psi\left(\kappa,\Theta\right) & \cdots & \frac{\partial}{\partial\theta_{b}}\Psi\left(\kappa,\Theta\right)\end{array}\right]\in\mathbb{R}^{L_{\text{out}}\times{\tt p}}$
\end_inset

 and 
\begin_inset Formula $\frac{\partial}{\partial\theta_{i}}\Psi\left(\kappa,\Theta\right)=\left[\begin{array}{ccc}
\frac{\partial}{\partial{\rm vec}\left(V_{i,0}\right)}\Psi\left(\kappa,\Theta\right) & \cdots & \frac{\partial}{\partial{\rm vec}\left(V_{i,k_{i}}\right)}\Psi\left(\kappa,\Theta\right)\end{array}\right]\in\mathbb{R}^{L_{\text{out}}\times p_{i}}$
\end_inset

,
 where 
\begin_inset Formula $\frac{\partial}{\partial{\rm vec}\left(V_{i,j}\right)}\Psi\left(\kappa,\Theta\right)\in\mathbb{R}^{L_{\text{out}}\times L^{a}_{i,j}L_{i,j+1}}$
\end_inset

 for all 
\begin_inset Formula $j\in\left\{ 0,\ldots,k_{i}\right\} $
\end_inset

.
 Using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:DNN"
nolink "false"

\end_inset

,
 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:ResNet"
nolink "false"

\end_inset

,
 and the property of the vectorization operator yields
