\begin_layout Section
Problem Formulation
\end_layout

\begin_layout Plain Layout
Consider the first-order nonlinear dynamical system described by the differentia
l equation
\begin_inset Formula 
\begin{equation}
\dot{q}=u,\label{eq:Agent Dynamics}
\end{equation}

\end_inset

where 
\begin_inset Formula $q:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 represents the generalized position, 
\begin_inset Formula $\dot{q}:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 represents the generalized velocity and 
\begin_inset Formula $u:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 denotes the control input, where 
\begin_inset Formula $t_{0}\in\mathbb{R}_{\ge0}$
\end_inset

 is the initial time.
 The target trajectory is governed by the autonomous first-order system
\begin_inset Formula 
\begin{equation}
\dot{q}_{d}=f_{d}\left(q_{d}\right),\label{eq:Target Dynamics}
\end{equation}

\end_inset

where 
\begin_inset Formula $q_{d}:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 denotes the generalized target position, 
\begin_inset Formula $\dot{q}_{d}:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 denotes the generalized target velocity, and 
\begin_inset Formula $f_{d}:\mathbb{R}^{n}\to\mathbb{R}^{n}$
\end_inset

 represents the unknown target dynamics.
\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "asm:target-bounds"

\end_inset

There exist known constants 
\begin_inset Formula $\overline{q}_{d},\overline{\dot{q}}_{d}\in\mathbb{R}_{>0}$
\end_inset

 such that for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge t_{0}}$
\end_inset

, 
\begin_inset Formula $\left\Vert q_{d}\left(t\right)\right\Vert \le\overline{q}_{d},\left\Vert \dot{q}_{d}\left(t\right)\right\Vert \le\overline{\dot{q}}_{d}$
\end_inset

.
\end_layout

\begin_layout Plain Layout
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "asm:target-dynamics"

\end_inset

The function 
\begin_inset Formula $f_{d}$
\end_inset

 is of class 
\color red

\begin_inset Formula $\mathcal{C}^{1}$
\end_inset


\color inherit
 on 
\begin_inset Formula $\mathbb{R}^{n}$
\end_inset

.
\end_layout

\begin_layout Plain Layout
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Plain Layout
The control objectiv
\color black
e is to design a ResNet-based adaptive controller such that the trajectory
 of 
\color inherit

\begin_inset Formula $q$
\end_inset

 tracks 
\begin_inset Formula $q_{d}$
\end_inset


\color black
 despite the presence of unknown dynamics and bounded disturbances.

\color inherit
 To facilitate the control objective, define the tracking error 
\begin_inset Formula $e:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 as
\begin_inset Formula 
\begin{equation}
e\triangleq q_{d}-q.\label{eq:Tracking Error}
\end{equation}

\end_inset


\end_layout

\begin_layout Section
Control 
\color blue
Synthesis
\end_layout

\begin_layout Plain Layout
To facilitate the control design, the auxiliary tracking error function
 
\begin_inset Formula $r:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 is defined as
\begin_inset Formula 
\begin{equation}
r\triangleq\dot{e}+k_{1}e,\label{eq: Filtered Tracking Error}
\end{equation}

\end_inset

where 
\begin_inset Formula $k_{1}\in\mathbb{R}_{>0}$
\end_inset

 is a constant control gain.
 Differentiating 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

 with respect to time and substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

 and the time derivatives of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Agent Dynamics"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Target Dynamics"
plural "false"
caps "false"
noprefix "false"

\end_inset

 yields
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{e}+k_{1}\dot{e}\\
 & =\frac{{\rm d}}{{\rm d}t}\dot{q}_{d}\left(t\right)-\frac{{\rm d}}{{\rm d}t}\dot{q}+k_{1}\left(r-k_{1}e\right)\\
 & =\frac{{\rm d}}{{\rm d}t}f_{d}\left(q_{d}\right)-\frac{{\rm d}}{{\rm d}t}\dot{q}+k_{1}\left(r-k_{1}e\right)\\
 & =\frac{{\rm \partial}f_{d}}{\partial q_{d}}\frac{\partial q_{d}}{\partial t}-\frac{{\rm d}}{{\rm d}t}u+k_{1}r-k_{1}^{2}e\\
 & =\frac{{\rm \partial}f_{d}}{\partial q_{d}}\frac{{\rm d}}{{\rm d}t}q_{d}-\dot{u}+k_{1}r-k_{1}^{2}e\\
 & =\frac{{\rm \partial}f_{d}}{\partial q_{d}}\dot{q}_{d}-\dot{u}+k_{1}r-k_{1}^{2}e\\
 & =\frac{\partial f_{d}}{\partial q_{d}}f\left(q_{d}\right)-\dot{u}+k_{1}r-k_{1}^{2}e\\
 & =h\left(q_{d}\right)-\dot{u}+k_{1}r-k_{1}^{2}e
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{r} & =h\left(q_{d}\right)-\dot{u}+k_{1}r-k_{1}^{2}e,\end{aligned}
\label{eq:rDot-1}
\end{equation}

\end_inset

where 
\begin_inset Formula $h:\mathbb{R}^{n}\to\mathbb{R}^{n}$
\end_inset

 is defined as 
\begin_inset Formula $h\left(q_{d}\right)\triangleq\left.\frac{\partial f}{\partial\zeta}\right|_{\zeta=q_{d}}f_{d}\left(q_{d}\right)$
\end_inset

.
\end_layout

\begin_layout Subsection
Residual Neural Network Function Approximations
\end_layout

\begin_layout Plain Layout
A deep residual neural network, constructed as described in Section 
\begin_inset CommandInset ref
LatexCommand ref
reference "subsec:Deep-Residual-Neural"

\end_inset

, will approximate 
\begin_inset Formula $h\left(q_{d}\right)$
\end_inset

 in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rDot-1"
plural "false"
caps "false"
noprefix "false"

\end_inset

 as 
\begin_inset Formula $\Psi\left(q_{d},\widehat{\Theta}\right)$
\end_inset

, where the ResNet input vector is 
\begin_inset Formula $q_{d}\in\mathbb{R}^{n}$
\end_inset

, 
\begin_inset Formula $\Psi:\mathbb{R}^{n}\times\mathbb{R}^{p}\to\mathbb{R}^{n}$
\end_inset

 denotes the ResNet architecture mapping, and 
\begin_inset Formula $\widehat{\Theta}:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{{\tt p}}$
\end_inset

 denotes the subsequently-designed adaptive parameter estimate.
 Here, 
\begin_inset Formula $L_{\text{in}}=L_{\text{out}}=n$
\end_inset

.
 The activation functions 
\begin_inset Formula $\varsigma_{i,j}:\mathbb{R}\to\mathbb{R}$
\end_inset

 must be chosen to be of class 
\begin_inset Formula $\mathcal{A}_{\text{quad}}$
\end_inset

, defined as follows.
\end_layout

\begin_layout Definition

\emph on
\begin_inset CommandInset label
LatexCommand label
name "def:activation-func"

\end_inset


\begin_inset CommandInset citation
LatexCommand cite
after "Definition 3.1"
key "Tabuada.Gharesifard2023"
literal "false"

\end_inset

 The activation function 
\begin_inset Formula $\varsigma:\mathbb{R}\to\mathbb{R}$
\end_inset

 is said to be of class 
\begin_inset Formula $\mathcal{A}_{\text{quad}}$
\end_inset

 (denoted 
\begin_inset Formula $\varsigma\in\mathcal{A}_{\text{quad}}$
\end_inset

) if it is (i) non-decreasing (i.e., 
\begin_inset Formula $\left.\frac{d\varsigma}{ds}\right|_{s}\ge0$
\end_inset

 for all 
\begin_inset Formula $s\in\mathbb{R}$
\end_inset

) and (ii) non-constant and (iii) there exists an 
\begin_inset Formula $\ell\in\mathbb{Z}_{\ge0}$
\end_inset

 such that 
\begin_inset Formula $\varsigma$
\end_inset

 is a globally-defined solution to 
\begin_inset Formula $\frac{d\zeta}{ds}=a_{0}+a_{1}\zeta+a_{2}\zeta^{2}$
\end_inset

, where 
\begin_inset Formula $\zeta\triangleq\frac{d^{(\ell)}\varsigma}{ds^{(\ell)}}$
\end_inset

 is injective, 
\begin_inset Formula $a_{0},a_{1},a_{2}\in\mathbb{R}$
\end_inset

, 
\begin_inset Formula $a_{2}\ne0$
\end_inset

, and 
\begin_inset Formula $\frac{d^{(0)}\varsigma}{ds^{(0)}}=\varsigma$
\end_inset

.
\end_layout

\begin_layout Plain Layout
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Plain Layout
By consequence of Definition 
\begin_inset CommandInset ref
LatexCommand ref
reference "def:activation-func"
plural "false"
caps "false"
noprefix "false"

\end_inset

, any 
\begin_inset Formula $\varsigma\in\mathcal{A}_{\text{quad}}$
\end_inset

 is necessarily an analytical function.
 Thus, 
\begin_inset Formula $\varsigma$
\end_inset

 and all its derivatives are locally Lipschitz on 
\begin_inset Formula $\mathbb{R}$
\end_inset

.
 Hyperbolic tangent, sigmoid, and softplus are of class 
\begin_inset Formula $\mathcal{A}_{\text{quad}}$
\end_inset

 but ReLU, swish, and the identity mapping are not.
 The function 
\begin_inset Formula $\varsigma\left(s\right)=\frac{1}{c}\log\left(1+{\rm e}^{cs}\right)$
\end_inset

 approximates ReLU for large 
\begin_inset Formula $c\in\mathbb{R}_{>0}$
\end_inset

 and is of class 
\begin_inset Formula $\mathcal{A}_{\text{quad}}$
\end_inset

.
 Leaky ReLU is given as 
\begin_inset Formula $\varsigma\left(s\right)=s$
\end_inset

 for all 
\begin_inset Formula $s\in\mathbb{R}_{\ge0}$
\end_inset

 and 
\begin_inset Formula $\varsigma\left(s\right)=rs$
\end_inset

 (with 
\begin_inset Formula $r\in\mathbb{R}_{>0}$
\end_inset

) for all 
\begin_inset Formula $s<0$
\end_inset

.
 The function 
\begin_inset Formula $\varsigma\left(s\right)=rs+\frac{1}{c}\log\left(1+{\rm e}^{\left(1-r\right)cs}\right)$
\end_inset

 approximates leaky ReLU for large 
\begin_inset Formula $c\in\mathbb{R}_{>0}$
\end_inset

 and is of class 
\begin_inset Formula $\mathcal{A}_{\text{quad}}$
\end_inset

.
\end_layout

\begin_layout Plain Layout
The universal approximation theorem for ResNets is given as follows.
\end_layout

\begin_layout Lemma
\begin_inset CommandInset label
LatexCommand label
name "lem:Universal-Approximation-Theorem"

\end_inset


\begin_inset CommandInset citation
LatexCommand citep
after "Corollary 5.2"
key "Tabuada.Gharesifard2023"
literal "false"

\end_inset

 (Universal Approximation Theorem for Residual Neural Networks).
 For any compact domain 
\begin_inset Formula $\Omega\subsetneq\mathbb{R}^{L_{\text{in}}}$
\end_inset

, continuous function 
\begin_inset Formula $h:\Omega\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

, and approximation accuracy 
\begin_inset Formula $\overline{\varepsilon}\in\mathbb{R}_{>0}$
\end_inset

, there exists a number of blocks 
\begin_inset Formula $b\in\mathbb{Z}_{>0}$
\end_inset

 (thus, a 
\begin_inset Formula ${\tt p}\in\mathbb{Z}_{>0}$
\end_inset

) and a parameter vector 
\begin_inset Formula $\Theta^{\ast}\in\mathbb{R}^{{\tt p}}$
\end_inset

 such that for a ResNet architecture 
\begin_inset Formula $\Psi:\mathbb{R}^{L_{\text{in}}}\times\mathbb{R}^{{\tt p}}\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

 with blocks of width 
\begin_inset Formula $w=\max\left(L_{\text{in}},L_{\text{out}}\right)+1$
\end_inset

 (i.e., 
\begin_inset Formula $L_{i,j}\ge w$
\end_inset

 for all 
\begin_inset Formula $\left(i,j\right)\in\left\{ 0,\ldots,b\right\} \times\left\{ 1,\ldots,k_{i}\right\} $
\end_inset

) and depth 1 (i.e., 
\begin_inset Formula $k_{i}\ge1$
\end_inset

 for all 
\begin_inset Formula $i\in\left\{ 0,\ldots,b\right\} $
\end_inset

),
\begin_inset Formula 
\begin{equation}
\sup_{x\in\Omega}\left\Vert \varepsilon\left(x\right)\right\Vert \le\overline{\varepsilon},\label{eq:lemma-ufat}
\end{equation}

\end_inset

where 
\begin_inset Formula $\varepsilon\left(x\right)\triangleq h\left(x\right)-\Psi\left(x,\Theta^{\ast}\right)$
\end_inset

, provided that for all 
\begin_inset Formula $\left(i,j\right)\in\left\{ 0,\ldots,b\right\} \times\left\{ 0,\ldots,k_{i}\right\} $
\end_inset

, the activation functions 
\begin_inset Formula $\varsigma_{i,j}\in\mathcal{A}_{\text{quad}}$
\end_inset


\emph on
.
\end_layout

\begin_layout Plain Layout
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Plain Layout
By Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "asm:target-dynamics"
plural "false"
caps "false"
noprefix "false"

\end_inset

, 
\begin_inset Formula $h$
\end_inset

 is continuous on 
\begin_inset Formula $\mathbb{R}^{n}$
\end_inset

.
 Thus, for any given compact set 
\begin_inset Formula $\Omega\subsetneq\mathbb{R}^{n}$
\end_inset

, Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:Universal-Approximation-Theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

 applies to 
\begin_inset Formula $h$
\end_inset

.
 Consequently, there exists a corresponding ResNet architecture 
\begin_inset Formula $\Psi$
\end_inset

 and a 
\begin_inset Formula $\Theta^{\ast}\in\mathbb{R}^{{\tt p}}$
\end_inset

 such that 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:lemma-ufat"
plural "false"
caps "false"
noprefix "false"

\end_inset

 holds for all 
\begin_inset Formula $q_{d}\in\Omega$
\end_inset

.
 The ResNet-based approximation is written as
\begin_inset Formula 
\begin{equation}
h\left(q_{d}\right)=\Psi\left(q_{d},\Theta^{\ast}\right)+\varepsilon\left(q_{d}\right).\label{eq:UFAT}
\end{equation}

\end_inset


\end_layout

\begin_layout Plain Layout
Subsequent adaptive estimation of 
\begin_inset Formula $\Theta^{\ast}$
\end_inset

 requires a compact search space 
\begin_inset Formula $\mho\subsetneq\mathbb{R}^{{\tt p}}$
\end_inset

.
 The existence of such a 
\begin_inset Formula $\mho$
\end_inset

 is guaranteed as there exists an 
\begin_inset Formula $R>\left\Vert \Theta^{\ast}\right\Vert $
\end_inset

.
 Pick 
\begin_inset Formula $\mho\triangleq\left\{ \theta\in\mathbb{R}^{{\tt p}}:\left\Vert \theta\right\Vert \le R\right\} $
\end_inset

 for simplicity and thus 
\begin_inset Formula $\Theta^{\ast}\in\mho$
\end_inset

.
 However, since 
\begin_inset Formula $\overline{\varepsilon}$
\end_inset

 can be chosen to be arbitrarily small, the size of 
\begin_inset Formula $\left\Vert \Theta^{\ast}\right\Vert $
\end_inset

 is arbitrarily large.
 Consequently, 
\begin_inset Formula $\mho$
\end_inset

 may need to be arbitrarily large.
 This situation is a consequence of the fact that there exist continuous
 functions that cannot be approximated to arbitrary accuracy in the sense
 of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:lemma-ufat"
plural "false"
caps "false"
noprefix "false"

\end_inset

 on compact sets using ResNets with bounded weights.
 This challenge is shared by many function approximators.
 Thus, unless 
\begin_inset Formula $h$
\end_inset

 is restricted to a strict subclass of all continuous functions which may
 be difficult to describe, there exists a tradeoff: either the choice of
 
\begin_inset Formula $\mho$
\end_inset

 (and 
\begin_inset Formula $\Omega$
\end_inset

) makes it so that the minimum 
\begin_inset Formula $\overline{\varepsilon}$
\end_inset

 achievable might not be arbitrarily small or the choice of an arbitrarily
 small 
\begin_inset Formula $\overline{\varepsilon}$
\end_inset

 drives the choice of 
\begin_inset Formula $\mho$
\end_inset

.
 In practice, the informal design loop is to first select a desired accuracy
 
\begin_inset Formula $\overline{\varepsilon}\in\mathbb{R}_{>0}$
\end_inset

 and an 
\begin_inset Formula $R\in\mathbb{R}_{>0}$
\end_inset

.
 Second, increase the number of blocks 
\begin_inset Formula $b$
\end_inset

 (starting from 
\begin_inset Formula $b=1$
\end_inset

) until the trained network's approximation accuracy plateaus to some 
\begin_inset Formula $\overline{\varepsilon}_{\text{act}}\in\mathbb{R}_{>0}$
\end_inset

 on a representative dataset or via experiments on the target platform.
 If 
\begin_inset Formula $\overline{\varepsilon}_{\text{act}}>\overline{\varepsilon}$
\end_inset

, increase 
\begin_inset Formula $R\in\mathbb{R}_{>0}$
\end_inset

, then repeat the previous step until 
\begin_inset Formula $\overline{\varepsilon}_{\text{act}}\le\overline{\varepsilon}$
\end_inset

.
 These observations can be formalized as follows.
\end_layout

\begin_layout Plain Layout
Let 
\begin_inset Formula $S_{\Theta}^{\ast}\triangleq\arg\min_{\vartheta\in\mho}\sup_{\kappa\in\Omega}\left\Vert h\left(\kappa\right)-\Psi\left(\kappa,\vartheta\right)\right\Vert $
\end_inset

 for some chosen 
\begin_inset Formula $\mho\subsetneq\mathbb{R}^{{\tt p}}$
\end_inset

 and some fixed 
\begin_inset Formula $\Omega\subsetneq\mathbb{R}^{n}$
\end_inset

 and 
\family roman
\series medium
\shape up
\size normal
\emph off
\bar no
\strikeout off
\xout off
\uuline off
\uwave off
\noun off
\color none

\begin_inset Formula $\Psi:\mathbb{R}^{L_{\text{in}}}\times\mathbb{R}^{{\tt p}}\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

 resulting from
\family default
\series default
\shape default
\size default
\emph default
\bar default
\strikeout default
\xout default
\uuline default
\uwave default
\noun default
\color inherit
 Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:Universal-Approximation-Theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
 Define 
\begin_inset Formula $\overline{\varepsilon}_{\text{act}}\triangleq\sup_{\kappa\in\Omega}\left\Vert h\left(\kappa\right)-\Psi\left(\kappa,\Theta\right)\right\Vert \in\mathbb{R}_{>0}$
\end_inset

, which holds the same value for any 
\begin_inset Formula $\Theta\in S_{\Theta}^{\ast}$
\end_inset

.
 By joint continuity of 
\begin_inset Formula $\left(\kappa,\vartheta\right)\mapsto\left\Vert h\left(\kappa\right)-\Psi\left(\kappa,\vartheta\right)\right\Vert $
\end_inset

 on 
\begin_inset Formula $\Omega\times\mho$
\end_inset

 and compactness of 
\begin_inset Formula $\Omega$
\end_inset

, the map 
\begin_inset Formula $\vartheta\mapsto\sup_{\kappa\in\Omega}\left\Vert h\left(\kappa\right)-\Psi\left(\kappa,\vartheta\right)\right\Vert $
\end_inset

 is continuous.
 Thus, 
\begin_inset Formula $S_{\Theta}^{\ast}$
\end_inset

 is nonempty by Weierstrass's Theorem (e.g., 
\begin_inset CommandInset citation
LatexCommand cite
after "Theorem 10.55"
key "Laczkovich.Sos2015"
literal "false"

\end_inset

).
 Pick some 
\begin_inset Formula $\Theta\in S_{\Theta}^{\ast}$
\end_inset

 and fix 
\begin_inset Formula $\Theta^{\ast}\triangleq\Theta$
\end_inset

.
 Since 
\begin_inset Formula $h$
\end_inset

 and 
\begin_inset Formula $\kappa\mapsto\Psi\left(\kappa,\Theta^{\ast}\right)$
\end_inset

 are continuous on 
\begin_inset Formula $\Omega$
\end_inset

, 
\begin_inset Formula $\varepsilon$
\end_inset

 is continuous on 
\begin_inset Formula $\Omega$
\end_inset

.
 Because the Euclidean norm preserves continuity, 
\begin_inset Formula $\kappa\mapsto\left\Vert \varepsilon\left(\kappa\right)\right\Vert $
\end_inset

 is continuous on 
\begin_inset Formula $\Omega$
\end_inset

.
 Thus, by extreme value theorem, 
\begin_inset Formula $\sup_{x\in\Omega}\left\Vert \varepsilon\left(x\right)\right\Vert $
\end_inset

 is finite.
 Furthermore, 
\begin_inset Formula $\overline{\varepsilon}_{\text{act}}=\sup_{\xi\in\Omega}\left\Vert \varepsilon\left(\xi\right)\right\Vert $
\end_inset

 by construction.
 Since 
\begin_inset Formula $\overline{\varepsilon}_{\text{act}}$
\end_inset

 follows from the choice of 
\begin_inset Formula $\mho\subsetneq\mathbb{R}^{{\tt p}}$
\end_inset

, Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:Universal-Approximation-Theorem"
plural "false"
caps "false"
noprefix "false"

\end_inset

 implies that 
\begin_inset Formula $\mho$
\end_inset

 
\color red
must be driven to be arbritrarily large to
\color inherit
 ensure 
\begin_inset Formula $\overline{\varepsilon}_{\text{act}}\le\overline{\varepsilon}$
\end_inset

 for some desired accuracy 
\begin_inset Formula $\overline{\varepsilon}\in\mathbb{R}_{>0}$
\end_inset

.
 The example below provides a simple application to illustate the tradeoff
 further.
\end_layout

\begin_layout Example
Take 
\begin_inset Formula $f\left(x\right)=x$
\end_inset

 on 
\begin_inset Formula $\Omega=\left[-1,1\right]$
\end_inset

 and 
\begin_inset Formula $\Psi\left(x,\omega\right)=\omega x$
\end_inset

 with 
\begin_inset Formula $\omega\in\mho\triangleq\left[-R,R\right]$
\end_inset

 for some 
\begin_inset Formula $R\in\mathbb{R}_{>0}$
\end_inset

.
 Define
\begin_inset Formula 
\begin{equation}
\overline{\varepsilon}_{\text{act}}\triangleq\sup_{\left|x\right|\leq1}\left|f\left(x\right)-\Psi\left(x,\omega\right)\right|=\left|1-\omega\right|.\label{eq:example}
\end{equation}

\end_inset

Clearly, the 
\begin_inset Formula $\omega=1$
\end_inset

 would make 
\begin_inset Formula $\overline{\varepsilon}_{\text{act}}=0$
\end_inset

, but the choice of 
\begin_inset Formula $R$
\end_inset

makes it such that
\begin_inset Formula 
\[
\overline{\varepsilon}_{\text{act}}=\inf_{\left|\omega\right|\leq R}\left|1-\omega\right|=\max\left\{ 0,1-R\right\} .
\]

\end_inset

Restricting 
\begin_inset Formula $R<1$
\end_inset

 results in 
\begin_inset Formula $\overline{\varepsilon}_{\text{act}}>0$
\end_inset

, but any 
\begin_inset Formula $R\ge1$
\end_inset

 makes 
\begin_inset Formula $\overline{\varepsilon}_{\text{act}}=0$
\end_inset

.
 Here, the architecture 
\begin_inset Formula $\Psi$
\end_inset

 is sufficiently expressive and the approximation accuracy is only limited
 by 
\begin_inset Formula $R$
\end_inset

.
\end_layout

