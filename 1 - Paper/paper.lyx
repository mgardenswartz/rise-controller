\begin_layout Subsection
Backward Propagation
\end_layout

\begin_layout Plain Layout
Now,
 observe that
\begin_inset Formula 
\begin{align*}
q & =\sum^{b}_{i=0}p_{i}\\
 & =\sum^{2}_{i=0}\sum^{k_{i}}_{j=0}L^{a}_{i,j}L_{i,j+1}\\
 & =\sum^{2}_{i=0}\sum^{1}_{j=0}L^{a}_{i,j}L_{i,j+1}\\
 & =\sum^{2}_{i=0}\left(L^{a}_{i,0}L_{i,1}+L^{a}_{i,1}L_{i,2}\right)\\
 & =\left(L^{a}_{0,0}L_{0,1}+L^{a}_{0,1}L_{0,2}\right)+\left(L^{a}_{1,0}L_{1,1}+L^{a}_{1,1}L_{1,2}\right)+\left(L^{a}_{2,0}L_{2,1}+L^{a}_{2,1}L_{2,2}\right)\\
 & =\left(4\cdot2+3\cdot3\right)\cdot3\\
 & =51
\end{align*}

\end_inset

We now want to compute 
\begin_inset Formula $\nabla_{\Theta}\Psi\left(\kappa,\Theta\right)=\left[\begin{array}{c}
\begin{array}{ccc}
\frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial\theta_{0}} & \frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial\theta_{1}} & \frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial\theta_{2}}\end{array}\end{array}\right]\in\mathbb{R}^{3\times51}$
\end_inset

 and 
\begin_inset Formula $\frac{\partial}{\partial\theta_{i}}\Psi\left(\kappa,\Theta\right)=\left[\begin{array}{cc}
\frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial{\rm vec}\left(V_{i,0}\right)} & \frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial{\rm vec}\left(V_{i,1}\right)}\end{array}\right]\in\mathbb{R}^{3\times17}$
\end_inset

,
 where 
\begin_inset Formula $\frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial{\rm vec}\left(V_{i,0}\right)}\in\mathbb{R}^{3\times8}$
\end_inset

 and 
\begin_inset Formula $\frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial{\rm vec}\left(V_{i,1}\right)}\in\mathbb{R}^{L_{\text{out}}\times9}$
\end_inset

.
 Therefore,
\begin_inset Formula 
\begin{align*}
\nabla_{\Theta}\Psi\left(\kappa,\Theta\right) & =\left[\begin{array}{ccc}
\frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial\theta_{0}} & \frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial\theta_{1}} & \frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial\theta_{2}}\end{array}\right]\\
 & =\left[\begin{array}{ccc}
\left[\begin{array}{cc}
\frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial{\rm vec}\left(V_{0,0}\right)} & \frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial{\rm vec}\left(V_{0,1}\right)}\end{array}\right] & \left[\begin{array}{cc}
\frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial{\rm vec}\left(V_{1,0}\right)} & \frac{\partial\Psi\left(\kappa,\Theta\right)}{\partial{\rm vec}\left(V_{1,1}\right)}\end{array}\right] & \left[\begin{array}{cc}
