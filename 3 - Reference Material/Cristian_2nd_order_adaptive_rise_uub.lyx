\begin_layout Subsection
Deep Neural Network Model
\end_layout

\begin_layout Standard
Consider a fully connected feedforward deep neural network (DNN) with input
 
\begin_inset Formula $x\in\mathbb{R}^{L_{\text{in}}}$
\end_inset

 and output 
\begin_inset Formula $y\in\mathbb{R}^{L_{\text{out}}}$
\end_inset

.
 Let 
\begin_inset Formula $k\in\mathbb{Z}_{>0}$
\end_inset

 be the number of hidden layers and let 
\begin_inset Formula $\theta\in\mathbb{R}^{p}$
\end_inset

 be the vector of parameters (weights and biases).
 Furthermore, let 
\begin_inset Formula $L_{i}\in\mathbb{Z}_{>0}$
\end_inset

 denote the number of neurons in the 
\begin_inset Formula $i^{\text{th}}$
\end_inset

 layer for 
\begin_inset Formula $i\in\left\{ 0,\ldots,k+1\right\} $
\end_inset

 (with 
\begin_inset Formula $L_{0}\triangleq L_{\text{in}}$
\end_inset

 and 
\begin_inset Formula $L_{k+1}\triangleq L_{\text{out}}$
\end_inset

), and define the augmented dimension 
\begin_inset Formula $L_{i}^{a}\triangleq L_{i}+1$
\end_inset

 for all 
\begin_inset Formula $i\in\left\{ 0,\ldots,k\right\} $
\end_inset

.
 The DNN 
\begin_inset Formula $\Phi:\mathbb{R}^{L_{\text{in}}}\times\mathbb{R}^{p}\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

 is defined recursively by
\begin_inset Formula 
\begin{equation}
\varphi_{i}\triangleq\begin{cases}
V_{i}^{\top}x_{a}, & i=0,\\
V_{i}^{\top}\phi_{i}\left(\varphi_{i-1}\right), & i\in\left\{ 1,\ldots,k\right\} ,
\end{cases}\label{eq:DNN}
\end{equation}

\end_inset

where 
\begin_inset Formula $x_{a}\triangleq\left[x^{\top},1\right]^{\top}\in\mathbb{R}^{L_{0}^{a}}$
\end_inset

 denotes the augmented input that accounts for the bias terms and 
\begin_inset Formula $\Phi\left(x,\theta\right)=\varphi_{k}$
\end_inset

.
\end_layout

\begin_layout Standard
For each 
\begin_inset Formula $i\in\left\{ 0,1,\ldots,k\right\} $
\end_inset

 the matrix 
\begin_inset Formula $V_{i}\in\mathbb{R}^{L_{i}^{a}\times L_{i+1}}$
\end_inset

 contains the weights and biases; in particular, if a layer has 
\begin_inset Formula $n$
\end_inset

 (augmented) inputs and the subsequent layer has 
\begin_inset Formula $m$
\end_inset

 nodes, then 
\begin_inset Formula $V\in\mathbb{R}^{n\times m}$
\end_inset

 is constructed so that its 
\begin_inset Formula $\left(j,k\right)^{\text{th}}$
\end_inset

 entry represents the weight from the 
\begin_inset Formula $j^{\text{th}}$
\end_inset

 node of the input to the 
\begin_inset Formula $k^{\text{th}}$
\end_inset

 node of the output, with the last row corresponding to the bias terms.
 For the DNN architecture described by 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:DNN"

\end_inset

, the vector of DNN weights 
\begin_inset Formula $\theta\triangleq\left[\begin{array}{ccc}
\text{vec}\left(V_{0}\right)^{\top} & \cdots & \text{vec}\left(V_{k}\right)^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{p}$
\end_inset

, where 
\begin_inset Formula $p\triangleq\sum_{i=0}^{k}L_{i}^{a}L_{i+1}$
\end_inset

, and 
\begin_inset Formula $\text{vec}\left(V_{i}\right)$
\end_inset

 denotes the vectorization of 
\begin_inset Formula $V_{i}$
\end_inset

 performed in column-major order (i.e., the columns are stacked sequentially
 to form a vector).
 The activation function 
\begin_inset Formula $\phi_{i}:\mathbb{R}^{L_{i}}\to\mathbb{R}^{L_{i}^{a}}$
\end_inset

 is given by 
\begin_inset Formula $\phi_{i}\left(\varphi_{i-1}\right)$
\end_inset

 
\begin_inset Formula $=$
\end_inset

 
\begin_inset Formula $\left[\varsigma_{1}\left(\left(\varphi_{i-1}\right)_{1}\right)\right.$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\varsigma_{2}\left(\left(\varphi_{i-1}\right)_{2}\right)\end{array}$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\cdots\end{array}$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\varsigma_{L_{i}}\left(\left(\varphi_{i-1}\right)_{L_{i}}\right)\end{array}$
\end_inset

 
\begin_inset Formula $\left.1\right]^{\top}$
\end_inset

 
\begin_inset Formula $\in\mathbb{R}^{L_{i}^{a}}$
\end_inset

 where 
\begin_inset Formula $\left(\varphi_{i-1}\right)_{\ell}$
\end_inset

 denotes the 
\begin_inset Formula $\ell^{\text{th}}$
\end_inset

 component of 
\begin_inset Formula $\varphi_{i-1}$
\end_inset

, each 
\begin_inset Formula $\varsigma_{i}:\mathbb{R}\to\mathbb{R}$
\end_inset

 denotes a smooth activation function, and 1 denotes the augmented hidden
 layer that accounts for the bias term.
\end_layout

\begin_layout Standard
The Jacobian of the DNN with respect to the weights is represented as 
\begin_inset Formula $\frac{\partial}{\partial\theta}\Phi\left(\kappa,\theta\right)=\left[\begin{array}{ccc}
\frac{\partial}{\partial{\rm vec}\left(V_{0}\right)}\Phi\left(\kappa,\theta\right) & \cdots & \frac{\partial}{\partial{\rm vec}\left(V_{k}\right)}\Phi\left(\kappa,\theta\right)\end{array}\right]$
\end_inset


\begin_inset Formula $\in\mathbb{R}^{L_{k+1}\times p}$
\end_inset

, where 
\begin_inset Formula $\frac{\partial}{\partial{\rm vec}\left(V_{j}\right)}\Phi\left(\kappa,\theta\right)$
\end_inset


\begin_inset Formula $\in\mathbb{R}^{L_{k+1}\times L_{j-1}^{a}L_{j}}$
\end_inset

 for all 
\begin_inset Formula $j\in\left\{ 0,\ldots,k\right\} $
