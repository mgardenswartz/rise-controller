\begin_layout Standard
For a set 
\begin_inset Formula $A$
\end_inset

 and an input 
\begin_inset Formula $x$
\end_inset

, the indicator function is denoted by 
\begin_inset Formula $\boldsymbol{1}_{A}\left(x\right)$
\end_inset

, where 
\begin_inset Formula $\boldsymbol{1}_{A}\left(x\right)=1$
\end_inset

 if 
\begin_inset Formula $x\in A$
\end_inset

, and 
\begin_inset Formula $\boldsymbol{1}_{A}\left(x\right)=0$
\end_inset

 otherwise.
 For a vector 
\begin_inset Formula $\mathbf{x}\in\mathbb{R}^{n}$
\end_inset

, the element-wise signum function is given by 
\begin_inset Formula $\text{sgn}\left(\mathbf{x}\right)=\left[\begin{array}{ccc}
\text{sgn}\left(x_{1}\right) & \cdots & \text{sgn}\left(x_{n}\right)\end{array}\right]^{\top}\in\mathbb{R}^{n}$
\end_inset

, where each 
\begin_inset Formula $x_{i}\in\mathbb{R}$
\end_inset

 and 
\begin_inset Formula $\text{sgn}\left(x_{i}\right)=\mathbf{1}_{\left\{ x>0\right\} }\left(x_{i}\right)-\mathbf{1}_{\left\{ x<0\right\} }\left(x_{i}\right)$
\end_inset

.
 Denote by 
\begin_inset Formula $\mathbf{1}_{n}\in\mathbb{R}^{n}$
\end_inset

 the column vector of length 
\begin_inset Formula $n>1$
\end_inset

 whose entries are all ones.
 Similarly, 
\begin_inset Formula $\mathbf{0}_{n}\in\mathbb{R}^{n}$
\end_inset

 denotes the column vector of length 
\begin_inset Formula $n>1$
\end_inset

 whose entries are all zeroes.
 For 
\begin_inset Formula $m,n>1$
\end_inset

, 
\begin_inset Formula $\mathbf{0}_{m\times n}\in\mathbb{R}^{m\times n}$
\end_inset

 denotes the 
\begin_inset Formula $m\times n$
\end_inset

 zero matrix.
 The 
\begin_inset Formula $p\times p$
\end_inset

 identity matrix is denoted by 
\begin_inset Formula $I_{p}$
\end_inset

.
 Given 
\begin_inset Formula $M\in\mathbb{Z}_{>0}$
\end_inset

, the enumeration operation 
\begin_inset Formula $\left[\cdot\right]$
\end_inset

 is defined as 
\begin_inset Formula $\left[M\right]\triangleq\left\{ 1,2,\ldots,M\right\} $
\end_inset

.
 Let 
\begin_inset Formula $n,m\in\mathbb{Z}_{>0}$
\end_inset

 with 
\begin_inset Formula $m>n$
\end_inset

.
 The Euclidean norm of 
\begin_inset Formula $r\in\mathbb{R}^{n}$
\end_inset

 is 
\begin_inset Formula $\left\Vert r\right\Vert \triangleq\sqrt{r^{\top}r}$
\end_inset

.
 Given a positive integer 
\begin_inset Formula $N$
\end_inset

 and collection 
\begin_inset Formula $\left\{ x_{i}\right\} _{i\in\left[N\right]}\subset\mathbb{R}^{n}$
\end_inset

, let 
\begin_inset Formula $\left(x_{i}\right)_{i\in\left[n\right]}\triangleq\left[\begin{array}{ccc}
x_{1}^{\top} & \cdots & x_{N}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{nN}$
\end_inset

.
 Given 
\begin_inset Formula $H\in\mathbb{R}^{m\times m}$
\end_inset

 with columns 
\begin_inset Formula $\left\{ h_{i}\right\} _{i\in\left[n\right]}\subset\mathbb{R}^{m},\text{vec}\left(H\right)=\left[\begin{array}{ccc}
h_{1}^{\top} & \cdots & h_{n}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{mn}$
\end_inset

.
 Given any matrix 
\begin_inset Formula $A$
\end_inset

, the element located in the 
\begin_inset Formula $i^{\text{th}}$
\end_inset

 row and 
\begin_inset Formula $j^{\text{th}}$
\end_inset

 column is denoted by 
\begin_inset Formula $a_{ij}$
\end_inset

.
 The Kronecker product of 
\begin_inset Formula $A\in\mathbb{R}^{p\times q}$
\end_inset

 and 
\begin_inset Formula $B\in\mathbb{R}^{m\times n}$
\end_inset

 is denoted by 
\begin_inset Formula $A\otimes B\in\mathbb{R}^{pm\times qn}$
\end_inset

.
 Given any 
\begin_inset Formula $A\in\mathbb{R}^{p\times a}$
\end_inset

, 
\begin_inset Formula $B\in\mathbb{R}^{a\times r}$
\end_inset

, and 
\begin_inset Formula $C\in\mathbb{R}^{r\times s}$
\end_inset

, the vectorization operator satisfies the property 
\begin_inset Formula $\mathrm{vec}\left(ABC\right)=\left(C^{\top}\otimes A\right)\mathrm{vec}\left(B\right)$
\end_inset

.
 Differentiating on both sides with respect to 
\begin_inset Formula $\mathrm{vec}\left(B\right)$
\end_inset

 yields the property
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Proof of this property:
\end_layout

\begin_layout Plain Layout
Given any 
\begin_inset Formula $A\in\mathbb{R}^{p\times a}$
\end_inset

, 
\begin_inset Formula $B\in\mathbb{R}^{a\times r}$
\end_inset

, and 
\begin_inset Formula $C\in\mathbb{R}^{r\times s}$
\end_inset

, Let 
\begin_inset Formula $C=[c_{1},c_{2},\ldots,c_{s}]$
\end_inset

 and 
\begin_inset Formula $B=[b_{1},b_{2},\ldots,b_{r}]$
\end_inset

.
 Then, the 
\begin_inset Formula $k^{\text{th}}$
\end_inset

 column of 
\begin_inset Formula $ABC$
\end_inset

 is 
\begin_inset Formula 
\begin{align*}
(ABC)_{:,k} & =ABc_{k}\\
 & =A\sum_{i=1}^{r}b_{i}c_{i,k}\\
 & =\sum_{i=1}^{r}c_{i,k}Ab_{i}\\
 & =[c_{1,k}A,c_{2,k}A,\ldots,c_{r,k}A]\left[\begin{array}{c}
b_{1}\\
b_{2}\\
\vdots\\
b_{r}
\end{array}\right]\\
 & =\left([c_{1,k},c_{2,k},\ldots,c_{r,k}]\otimes A\right)\text{vec}B\\
 & =\left(c_{k}^{\top}\otimes A\right)\text{vec}B
\end{align*}

\end_inset

Stacking the columns together,
\begin_inset Formula 
\begin{align*}
{\rm vec}(ABC) & =\left[\begin{array}{c}
(ABC)_{:,k}\\
(ABC)_{:,k}\\
\vdots\\
(ABC)_{:,s}
\end{array}\right]\\
 & =\left[\begin{array}{c}
\left(c_{1}^{\top}\otimes A\right)\text{vec}B\\
\left(c_{2}^{\top}\otimes A\right)\text{vec}B\\
\vdots\\
\left(c_{s}^{\top}\otimes A\right)\text{vec}B
\end{array}\right]\\
 & =(C^{\top}\otimes A){\rm vec}(B).
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{eqnarray}
\frac{\partial}{\partial\mathrm{vec}\left(B\right)}\mathrm{vec}\left(ABC\right) & = & \left(C^{\top}\otimes A\right).\label{eq:vec_diff_prop}
\end{eqnarray}

\end_inset


\end_layout

\begin_layout Standard
The maximum and minimum eigenvalues of 
\begin_inset Formula $A=A^{\top}\in\mathbb{R}^{n\times n}$
\end_inset

 are denoted by 
\begin_inset Formula $\lambda_{1}\left(A\right)\in\mathbb{R}$
\end_inset

 and 
\begin_inset Formula $\lambda_{n}\left(A\right)\in\mathbb{R}$
\end_inset

, respectively.
 The spectral norm of 
\begin_inset Formula $A\in\mathbb{R}^{n\times n}$
\end_inset

 is defined as 
\begin_inset Formula $\left\Vert A\right\Vert \triangleq\sqrt{\lambda_{n}\left(A^{\top}A\right)}$
\end_inset

.
 The right Moore-Penrose inverse of the surjective matrix 
\begin_inset Formula $A\in\mathbb{R}^{m\times n}$
\end_inset

 is denoted as 
\begin_inset Formula $A^{+}:\mathbb{R}^{n}\to\mathbb{R}^{n\times m}$
\end_inset

 and is defined as 
\begin_inset Formula $A^{+}\left(\cdot\right)\triangleq A^{\top}\left(\cdot\right)\left(A\left(\cdot\right)A^{\top}\left(\cdot\right)\right)^{-1}$
\end_inset

.
 For 
\begin_inset Formula $A\in\mathbb{R}^{m_{A}\times n_{A}}$
\end_inset

 and 
\begin_inset Formula $B\in\mathbb{R}^{m_{B}\times n_{B}}$
\end_inset

, let the block diagonalization operator be defined as 
\begin_inset Formula $\text{blkdiag}\left\{ A,B\right\} =\left[\begin{array}{cc}
A & \mathbf{0}_{m_{A}\times n_{B}}\\
\mathbf{0}_{m_{B}\times n_{A}} & B
\end{array}\right]\in\mathbb{R}^{\left(m_{A}+m_{B}\right)\times\left(n_{A}+n_{B}\right)}$
\end_inset

.
 The right-to-left matrix product operator is represented by 
\begin_inset Formula $\stackrel{\curvearrowleft}{\prod}$
\end_inset

, i.e., 
\begin_inset Formula $\stackrel{\curvearrowleft}{\stackrel[p=1]{m}{\prod}}A_{p}=A_{m}\ldots A_{2}A_{1}$
\end_inset

 and 
\begin_inset Formula $\stackrel{\curvearrowleft}{\stackrel[p=a]{m}{\prod}}A_{p}=I$
\end_inset

 if 
\begin_inset Formula $a>m$
\end_inset

.
\end_layout

