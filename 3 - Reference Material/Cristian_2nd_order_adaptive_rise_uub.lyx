\begin_layout Standard
Let 
\begin_inset Formula $\xi:\mathcal{I}\to\mathbb{R}^{3nN+1}$
\end_inset

 be defined as 
\begin_inset Formula $\xi\left(t\right)=\left[\begin{array}{cc}
z^{\top}\left(t\right) & P\left(t\right)\end{array}\right]^{\top}$
\end_inset

, and 
\begin_inset Formula $\psi:\mathbb{R}^{3nN+1}\times\mathbb{R}_{\geq0}\rightrightarrows\mathbb{R}^{3nN+1}$
\end_inset

 denote the set-valued map
\begin_inset Formula 
\begin{equation}
\psi\left(\xi,t\right)\triangleq\left[\begin{array}{c}
r_{1}-k_{1}e\\
r_{2}-k_{2}r_{1}-e\\
\\
\\
\\
\\
-\lambda_{P}P-r_{2}^{\top}\left(D\left(q,\dot{q},t\right)-\gamma^{\ast}K\left[\text{sgn}\right]\left(r_{1}\right)\right)
\end{array}\right].\label{eq: set-valued map}
\end{equation}

\end_inset

Then using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Closed-Loop Error System"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:PDot"

\end_inset

, it follows that the trajectories 
\begin_inset Formula $t\mapsto\xi\left(t\right)$
\end_inset

 satisfy the differential inclusion 
\begin_inset Formula $\dot{\xi}\stackrel{{\rm a.e.}}{\in}\psi\left(\xi,t\right)$
\end_inset

.
\end_layout

\begin_layout Standard
Since the universal approximation property of the DNN holds only on the
 compact domain 
\begin_inset Formula $\Omega$
\end_inset

, the subsequent stability analysis requires ensuring 
\begin_inset Formula $\kappa\left(t\right)\in\Omega$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\geq t_{0}}$
\end_inset

.
 This is achieved by establishing a stability result which constrains the
 solution trajectory 
\begin_inset Formula $z\left(t\right)$
\end_inset

 to a compact domain.
 Consider the Lyapunov function candidate 
\begin_inset Formula $V:\mathbb{R}^{\varphi}\to\mathbb{R}_{\geq0}$
\end_inset

 defined as
\begin_inset Formula 
\begin{equation}
V\left(z\right)\triangleq\frac{1}{2}z^{\top}Qz,\label{eq:Lyapunov}
\end{equation}

\end_inset

where 
\begin_inset Formula $Q\triangleq\text{blkdiag}\left\{ I_{3n},\Gamma_{1}^{-1},\Gamma_{2}^{-1}\right\} \in\mathbb{R}^{\varphi\times\varphi}$
\end_inset

.
 By the Rayleigh quotient, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Lyapunov"

\end_inset

 satisfies
\begin_inset Formula 
\begin{equation}
\frac{1}{2}\lambda_{1}\left\Vert z\right\Vert ^{2}\leq V\left(z\right)\leq\frac{1}{2}\lambda_{\varphi}\left\Vert z\right\Vert ^{2},\label{eq: RQ}
\end{equation}

\end_inset

where 
\begin_inset Formula $\lambda_{1}\triangleq\lambda_{\min}\left\{ P\right\} =\min\left\{ 1,\lambda_{\min}\left\{ \Gamma^{-1}\right\} \right\} $
\end_inset

 and 
\begin_inset Formula $\lambda_{\varphi}\triangleq\lambda_{\max}\left\{ P\right\} =\max\left\{ 1,\lambda_{\max}\left\{ \Gamma^{-1}\right\} \right\} $
\end_inset

.
 Based on the subsequent analysis, define 
\begin_inset Formula $\delta\triangleq\frac{3\left(\overline{\omega}+\overline{\varepsilon}\right)^{2}}{4k_{2}}+\frac{k_{3}\overline{\Theta}^{2}}{2}$
\end_inset

 and 
\begin_inset Formula $k_{\min}\triangleq\min\left\{ k_{1},\frac{1}{3}k_{2},\frac{1}{2}k_{3}\right\} $
\end_inset

.
 Furthermore, let 
\begin_inset Formula $\rho:\mathbb{R}_{\geq0}\to\mathbb{R}_{\geq0}$
\end_inset

 denote a strictly increasing function and define 
\begin_inset Formula $\overline{\rho}\left(\cdot\right)\triangleq\rho\left(\cdot\right)-\rho\left(0\right)$
\end_inset

, where 
\begin_inset Formula $\overline{\rho}$
\end_inset

 is strictly increasing and invertible.
 The region to which the state trajectory is constrained is defined as
\begin_inset Formula 
\begin{equation}
\mathcal{D}\triangleq\left\{ \iota\in\mathbb{R}^{\varphi}:\left\Vert \iota\right\Vert \leq\overline{\rho}^{-1}\left(k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right)\right)\right\} ,\label{eq:state space}
\end{equation}

\end_inset

where 
\begin_inset Formula $\lambda_{V}\in\mathbb{R}_{>0}$
\end_inset

 is a user-defined rate of convergence parameter.
 The compact domain 
\begin_inset Formula $\Omega\subset\mathbb{R}^{4n}$
\end_inset

 over which the universal approximation property must hold is selected as
\begin_inset Formula 
\begin{equation}
\begin{aligned}\Omega & \triangleq\left\{ \iota\in\mathbb{R}^{4n}\right.:\left\Vert \iota\right\Vert \leq2\left(\overline{q}_{d}+\overline{\dot{q}}_{d}\right)\\
 & +\left(k_{1}+2\right)\overline{\rho}^{-1}\left.\left(k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right)\right)\right\} .
\end{aligned}
\label{eq:OmegaSet}
\end{equation}

\end_inset

For the dynamical system described by 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:IVP"

\end_inset

, the set of initial conditions 
\begin_inset Formula $\mathcal{S}\subset\mathcal{D}$
\end_inset

 is defined as
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
For feasibility of the set 
\begin_inset Formula $\mathcal{S}$
\end_inset

,
\begin_inset Formula 
\begin{align*}
\sqrt{\frac{\lambda_{1}}{\lambda_{\varphi}}}\overline{\rho}^{-1}\left(k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right)\right)-\sqrt{\frac{\delta}{\lambda_{V}}} & >0\\
\sqrt{\frac{\lambda_{1}}{\lambda_{\varphi}}}\overline{\rho}^{-1}\left(k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right)\right) & >\sqrt{\frac{\delta}{\lambda_{V}}}\\
\overline{\rho}^{-1}\left(k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right)\right) & >\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\\
k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right) & >\overline{\rho}\left(\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right)\\
k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right) & >\overline{\rho}\left(\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right)\\
k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right) & >\overline{\rho}\left(\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right)\\
k_{2}\left(k_{\min}-\lambda_{V}\right) & >\overline{\rho}\left(\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right)+\rho\left(0\right)\\
k_{2}\left(k_{\min}-\lambda_{V}\right) & >\rho\left(\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right)\\
k_{\min}-\lambda_{V} & >\frac{1}{k_{2}}\rho\left(\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right)\\
k_{\min} & >\lambda_{V}+\frac{1}{k_{2}}\rho\left(\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\mathcal{S}\triangleq\left\{ \iota\in\mathbb{R}^{\varphi}:\left\Vert \iota\right\Vert \leq\sqrt{\frac{\lambda_{1}}{\lambda_{\varphi}}}\overline{\rho}^{-1}\left(k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right)\right)-\sqrt{\frac{\delta}{\lambda_{V}}}\right\} ,\label{eq:initial conditions}
\end{equation}

\end_inset

and the uniform ultimate bound 
\begin_inset Formula $\mathcal{U}\subset\mathbb{R}^{\varphi}$
\end_inset

 is defined as
\begin_inset Formula 
\begin{equation}
\mathcal{U}\triangleq\left\{ \iota\in\mathbb{R}^{\varphi}:\left\Vert \iota\right\Vert \leq\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right\} .\label{eq:equilibrium set}
\end{equation}

\end_inset


\end_layout

\begin_layout Theorem
Consider the dynamical system described by 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Agent Dynamics"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Target Dynamics"

\end_inset

.
 For any initial conditions of the state vector 
\begin_inset Formula $z\left(t_{0}\right)\in\mathcal{S}$
\end_inset

, the controller given by 
\begin_inset CommandInset ref
