\color red
\begin_inset Formula 
\begin{alignat}{1}
\dot{P} & \stackrel{{\rm a.e.}}{\in}-\lambda_{P}P-r_{2}^{\top}\left(D\left(q,\dot{q},t\right)-\gamma^{\ast}K\left[\text{sgn}\right]\left(r_{1}\right)\right).\label{eq:PDot}
