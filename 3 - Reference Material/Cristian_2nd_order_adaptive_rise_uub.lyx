\begin_inset Formula 
\begin{align}
P & \triangleq k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}+\mathrm{e}^{-\lambda_{P}t}*r_{1}^{\top}\mathcal{H}^{\top}\dot{h}_{B}\nonumber \\
 & +\mathrm{e}^{-\lambda_{P}t}*\left(k_{4}\left(k_{2}-\lambda_{P}\right)\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-\left(k_{2}-\lambda_{P}\right)r_{1}^{\top}\mathcal{H}^{\top}h_{B}\right),\label{eq: P function}
\end{align}

\end_inset

where 
\begin_inset Formula $\lambda_{P}\in\mathbb{R}_{>0}$
\end_inset

 is a user-defined constant, and the symbol `
\begin_inset Formula $*$
\end_inset

' denotes the convolutional integral, defined for any given function 
\begin_inset Formula $\alpha\left(t\right):\mathcal{I}\to\mathbb{R}$
\end_inset

 as 
\begin_inset Formula $\mathrm{e}^{-\lambda_{P}t}*\alpha\left(t\right)=\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\alpha\left(t\right){\rm d}\tau$
\end_inset

.
 Using Leibniz's rule, the time derivative of a convolution integral satisfies
 
\begin_inset Formula $\frac{{\rm d}}{{\rm d}t}\left(\mathrm{e}^{-\lambda_{P}t}*\alpha\right)=\alpha\left(t\right)-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\alpha\left(\tau\right){\rm d}t$
\end_inset

 which simplifies to 
\begin_inset Formula $\frac{{\rm d}}{{\rm d}t}\left(\mathrm{e}^{-\lambda_{P}t}*\alpha\right)=\alpha\left(t\right)-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\alpha\left(t\right)$
\end_inset

.
 Using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: P function"

\end_inset

 and the definition of the convolutional integral yields
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
For initial conditions, 
\begin_inset Formula 
\begin{align*}
P(t_{0}) & =k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)+\mathrm{e}^{-\lambda_{P}t_{0}}*\left(r_{1}^{\top}(t_{0})\mathcal{H}^{\top}\dot{h}_{B}\left(q(t_{0}),t_{0}\right)+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)\right)\right)\\
 & =k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)+\mathrm{e}^{-\lambda_{P}t_{0}}*\underbrace{\left(r_{1}^{\top}(t_{0})\mathcal{H}^{\top}\dot{h}_{B}\left(q(t_{0}),t_{0}\right)+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)\right)\right)}_{\rho(t)}\\
 & =k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)+\mathrm{e}^{-\lambda_{P}t_{0}}*\rho(t)\\
 & =k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)+\int_{t_{0}}^{t_{0}}\mathrm{e}^{-\lambda_{P}(t-\tau)}\rho(t){\rm d}\tau\\
 & =k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)
\end{align*}

\end_inset


