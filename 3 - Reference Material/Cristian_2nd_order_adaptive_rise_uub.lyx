 & =\left[\begin{array}{cccc}
\frac{\partial\varsigma_{1}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{1}\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{1}} & \frac{\partial\varsigma_{1}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{1}\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{2}} & \cdots & \frac{\partial\varsigma_{1}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{1}\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}}\\
\frac{\partial\varsigma_{2}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{2}\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{1}} & \frac{\partial\varsigma_{2}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{2}\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{2}} & \cdots & \frac{\partial\varsigma_{2}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{2}\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}}\\
\vdots & \vdots & \ddots & \vdots\\
\frac{\partial\varsigma_{L_{i,j}}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{1}} & \frac{\partial\varsigma_{L_{i,j}}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{2}} & \cdots & \frac{\partial\varsigma_{L_{i,j}}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}}\\
\frac{\partial\left(1.0\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{1}} & \frac{\partial\left(1.0\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{2}} & \cdots & \frac{\partial\left(1.0\right)}{\partial\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}}
\end{array}\right]\\
 & =\left[\begin{array}{cccc}
\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{1}}\varsigma_{1}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{1}\right) & 0 & \cdots & 0\\
0 & \frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{2}}\varsigma_{2}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{2}\right) & \cdots & 0\\
\vdots & \vdots & \ddots & \vdots\\
0 & 0 & \cdots & \frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}}\varsigma_{L_{i,j}}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\right)\\
0 & 0 & \cdots & 0
\end{array}\right]\\
 & =\left[\begin{array}{c}
\left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{1}}\varsigma_{1}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{1}\right)\right)\mathbf{e}_{1}^{\top}\\
\left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{2}}\varsigma_{2}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{2}\right)\right)\mathbf{e}_{2}^{\top}\\
\vdots\\
\left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}}\varsigma_{L_{i,j}}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\right)\right)\mathbf{e}_{L_{i,j}}^{\top}\\
\mathbf{0}_{L_{i,j}}^{\top}
\end{array}\right]\\
 & =\left[\begin{array}{ccccc}
\left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{1}}\varsigma_{1}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{1}\right)\right)\mathbf{e}_{1}^{\top} & \left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{2}}\varsigma_{2}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{2}\right)\right)\mathbf{e}_{2}^{\top} & \cdots & \left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}}\varsigma_{L_{i,j}}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\right)\right)\mathbf{e}_{L_{i,j}}^{\top} & \mathbf{0}_{L_{i,j}}^{\top}\end{array}\right]^{\top}
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Section
Problem Formulation
\end_layout

\begin_layout Subsection
System Dynamics
\end_layout

\begin_layout Standard
Consider the second-order nonlinear system described by the differential
 equation
\begin_inset Formula 
\begin{equation}
\ddot{q}\left(t\right)=f\left(q\left(t\right),\dot{q}\left(t\right)\right)+u\left(t\right)+d\left(t\right),\label{eq:Agent Dynamics}
\end{equation}

\end_inset

where 
\begin_inset Formula $q:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 denotes the generalized position trajectory, with 
\begin_inset Formula $q\left(t\right)\in\mathbb{R}^{n}$
\end_inset

 for each 
\begin_inset Formula $t\in\mathbb{R}_{\geq0}$
\end_inset

, 
\begin_inset Formula $\dot{q}:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 denotes the generalized velocity trajectory, with 
\begin_inset Formula $\dot{q}\left(t\right)\in\mathbb{R}^{n}$
\end_inset

 for each 
\begin_inset Formula $t\in\mathbb{R}_{\geq0}$
\end_inset

, 
\begin_inset Formula $\ddot{q}:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 denotes the generalized acceleration trajectory, with 
\begin_inset Formula $\ddot{q}\left(t\right)\in\mathbb{R}^{n}$
\end_inset

 for each 
\begin_inset Formula $t\in\mathbb{R}_{\geq0}$
\end_inset

, 
\begin_inset Formula $f\in\mathcal{C}^{2}\left(\mathbb{R}^{n}\times\mathbb{R}^{n};\mathbb{R}^{n}\right)\cap\text{Lip}\left(\mathbb{R}^{n}\times\mathbb{R}^{n};\mathbb{R}^{n}\right)$
\end_inset

 represents unknown dynamics, 
\begin_inset Formula $d\in\mathcal{C}^{2}\left(\mathbb{R}_{\geq0};\mathbb{R}^{n}\right)$
\end_inset

 represents exogenous disturbances, and 
\begin_inset Formula $u:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 denotes the control input trajectory.
\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "disturbance bound"

\end_inset

There exist known constants 
\begin_inset Formula $\overline{d},\overline{\dot{d}}\in\mathbb{R}_{>0}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert d\left(t\right)\right\Vert \leq\overline{d}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{d}\left(t\right)\right\Vert \leq\overline{\dot{d}}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\geq0}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
The reference trajectory is governed by the autonomous second-order system
\begin_inset Formula 
\begin{equation}
\ddot{q}_{d}\left(t\right)=f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right),\label{eq:Target Dynamics}
\end{equation}

\end_inset

where 
\begin_inset Formula $q_{d}:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 denotes the reference position trajectory, with 
\begin_inset Formula $q_{d}\left(t\right)\in\mathbb{R}^{n}$
\end_inset

 for each 
\begin_inset Formula $t\in\mathbb{R}_{\geq0}$
\end_inset

, 
\begin_inset Formula $\dot{q}_{d}:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 denotes the reference velocity trajectory, with 
\begin_inset Formula $\dot{q}_{d}\left(t\right)\in\mathbb{R}^{n}$
\end_inset

 for each 
\begin_inset Formula $t\in\mathbb{R}_{\geq0}$
\end_inset

, 
\begin_inset Formula $\ddot{q}_{d}:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 denotes the reference acceleration trajectory, with 
\begin_inset Formula $\ddot{q}_{d}\left(t\right)\in\mathbb{R}^{n}$
\end_inset

 for each 
\begin_inset Formula $t\in\mathbb{R}_{\geq0}$
\end_inset

, and 
\begin_inset Formula $f_{d}\in\mathcal{C}^{2}\left(\mathbb{R}^{n}\times\mathbb{R}^{n};\mathbb{R}^{n}\right)$
\end_inset

 represents the unknown reference dynamics.
\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "targetbounds"

\end_inset

There exist known constants 
\begin_inset Formula $\overline{q}_{d},\overline{\dot{q}}_{d}\in\mathbb{R}_{>0}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert q_{d}\left(t\right)\right\Vert \leq\overline{q}_{d}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{q}_{d}\left(t\right)\right\Vert \leq\overline{\dot{q}}_{d}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\geq0}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
The control objective is to design a robust adaptive DNN-based controller
 such that the state trajectory 
\begin_inset Formula $q$
\end_inset

 is exponentially regulated to a neighborhood of the reference trajectory
 
\begin_inset Formula $q_{d}$
\end_inset

, despite the presence of unknown dynamics and bounded disturbances.
 To facilitate the control objective, define the tracking error 
\begin_inset Formula $e:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 as
\begin_inset Formula 
\begin{equation}
e\left(t\right)\triangleq q_{d}\left(t\right)-q\left(t\right).\label{eq:Tracking Error}
\end{equation}

\end_inset


\end_layout

\begin_layout Section
Control Synthesis
\end_layout

\begin_layout Standard
To facilitate the control design, the filtered tracking error 
\begin_inset Formula $r_{1}:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 is defined as
\begin_inset Formula 
\begin{equation}
r_{1}\left(t\right)\triangleq\dot{e}\left(t\right)+k_{1}e\left(t\right),\label{eq: Filtered Tracking Error}
\end{equation}

\end_inset

where 
\begin_inset Formula $k_{1}\in\mathbb{R}_{>0}$
\end_inset

 is a constant control gain, and the auxiliary tracking error 
\begin_inset Formula $r_{2}:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 is defined as
\begin_inset Formula 
\begin{equation}
r_{2}\left(t\right)\triangleq\dot{r}_{1}\left(t\right)+k_{2}r_{1}\left(t\right)+e\left(t\right),\label{eq:Auxiliary Tracking Error}
\end{equation}

\end_inset

where 
\begin_inset Formula $k_{2}\in\mathbb{R}_{>0}$
\end_inset

 is a constant control gain.
 Twice differentiating 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Tracking Error"

\end_inset

 with respect to time and substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Agent Dynamics"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Target Dynamics"

\end_inset

 into the resulting expression yields
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\ddot{e}\left(t\right) & =\ddot{q}_{d}\left(t\right)-\ddot{q}\left(t\right)\\
 & =f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-\left(f\left(q\left(t\right),\dot{q}\left(t\right)\right)+u\left(t\right)+d\left(t\right)\right)\\
 & =f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-f\left(q\left(t\right),\dot{q}\left(t\right)\right)-u\left(t\right)-d\left(t\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\begin{aligned}\ddot{e}\left(t\right) & =f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-f\left(q\left(t\right),\dot{q}\left(t\right)\right)\\
 & -u\left(t\right)-d\left(t\right).
\end{aligned}
\label{eq:Tracking Error Acceleration}
\end{equation}

\end_inset

Differentiating 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

 with respect to time, and substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Tracking Error Acceleration"

\end_inset

 yields
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{r}_{1}\left(t\right) & =\ddot{e}\left(t\right)+k_{1}\dot{e}\left(t\right)\\
 & =f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-f\left(q\left(t\right),\dot{q}\left(t\right)\right)-u\left(t\right)-d\left(t\right)+k_{1}\dot{e}\left(t\right)\\
 & =f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-f\left(q\left(t\right),\dot{q}\left(t\right)\right)-u\left(t\right)-d\left(t\right)+k_{1}\left(r_{1}\left(t\right)-k_{1}e\left(t\right)\right)\\
 & =f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-f\left(q\left(t\right),\dot{q}\left(t\right)\right)-u\left(t\right)-d\left(t\right)+k_{1}r_{1}\left(t\right)-k_{1}^{2}e\left(t\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{r}_{1}\left(t\right) & =f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-f\left(q\left(t\right),\dot{q}\left(t\right)\right)-u\left(t\right)\\
 & -d\left(t\right)+k_{1}r_{1}\left(t\right)-k_{1}^{2}e\left(t\right).
\end{aligned}
\label{eq: Filtered Tracking Error Derivative}
\end{equation}

\end_inset

Substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error Derivative"

\end_inset

 into 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Auxiliary Tracking Error"

\end_inset

, differentiating the resulting expression with respect to time, and using
 the chain rule and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

 yields
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{r}_{2}\left(t\right) & =\frac{{\rm d}}{{\rm d}t}\left(f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-f\left(q\left(t\right),\dot{q}\left(t\right)\right)-u\left(t\right)-d\left(t\right)+k_{1}r_{1}\left(t\right)-k_{1}^{2}e\left(t\right)\right)+k_{2}\dot{r}_{1}\left(t\right)+\dot{e}\left(t\right)\\
\\
 & =\frac{\partial f_{d}}{\partial q_{d}}\frac{\partial q_{d}}{\partial t}+\frac{\partial f_{d}}{\partial\dot{q}_{d}}\frac{\partial\dot{q}_{d}}{\partial t}-\frac{\partial f}{\partial q}\frac{\partial q}{\partial t}-\frac{\partial f}{\partial\dot{q}}\frac{\partial\dot{q}}{\partial t}-\dot{u}\left(t\right)-\dot{d}\left(t\right)+k_{1}\dot{r}_{1}\left(t\right)-k_{1}^{2}\dot{e}\left(t\right)+k_{2}\left(r_{2}\left(t\right)-k_{2}r_{1}\left(t\right)\right)+r_{1}\left(t\right)-k_{1}e\left(t\right)\\
\\
 & =\frac{\partial f_{d}}{\partial q_{d}}\dot{q}_{d}+\frac{\partial f_{d}}{\partial\dot{q}_{d}}\ddot{q}_{d}-\frac{\partial f}{\partial q}\dot{q}-\frac{\partial f}{\partial\dot{q}}\ddot{q}-\dot{u}\left(t\right)-\dot{d}\left(t\right)+k_{1}\left(r_{2}\left(t\right)-k_{2}r_{1}\left(t\right)\right)-k_{1}^{2}\left(r_{1}\left(t\right)-k_{1}e\left(t\right)\right)+k_{2}r_{2}\left(t\right)-k_{2}^{2}r_{1}\left(t\right)+r_{1}\left(t\right)-k_{1}e\left(t\right)\\
\\
 & =\frac{\partial f_{d}}{\partial q_{d}}\dot{q}_{d}+\frac{\partial f_{d}}{\partial\dot{q}_{d}}f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-\frac{\partial f}{\partial q}\dot{q}-\frac{\partial f}{\partial\dot{q}}\left(f\left(q\left(t\right),\dot{q}\left(t\right)\right)+u\left(t\right)+d\left(t\right)\right)-\dot{u}\left(t\right)-\dot{d}\left(t\right)\\
 & +k_{1}r_{2}\left(t\right)-k_{1}k_{2}r_{1}\left(t\right)-k_{1}^{2}r_{1}\left(t\right)+k_{1}^{3}e\left(t\right)+k_{2}r_{2}\left(t\right)-k_{2}^{2}r_{1}\left(t\right)+r_{1}\left(t\right)-k_{1}e\left(t\right)\\
\\
 & =\frac{\partial f_{d}}{\partial q_{d}}\dot{q}_{d}+\frac{\partial f_{d}}{\partial\dot{q}_{d}}f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-\frac{\partial f}{\partial q}\dot{q}-\frac{\partial f}{\partial\dot{q}}f\left(q\left(t\right),\dot{q}\left(t\right)\right)-\frac{\partial f}{\partial\dot{q}}u\left(t\right)-\frac{\partial f}{\partial\dot{q}}d\left(t\right)-\dot{u}\left(t\right)-\dot{d}\left(t\right)\\
 & +k_{1}r_{2}\left(t\right)+k_{2}r_{2}\left(t\right)-k_{1}k_{2}r_{1}\left(t\right)-k_{1}^{2}r_{1}\left(t\right)-k_{2}^{2}r_{1}\left(t\right)+r_{1}\left(t\right)+k_{1}^{3}e\left(t\right)-k_{1}e\left(t\right)\\
\\
 & =\frac{\partial f_{d}}{\partial q_{d}}\dot{q}_{d}+\frac{\partial f_{d}}{\partial\dot{q}_{d}}f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-\frac{\partial f}{\partial q}\dot{q}-\frac{\partial f}{\partial\dot{q}}\left(f\left(q\left(t\right),\dot{q}\left(t\right)\right)+u\left(t\right)\right)\\
 & -\dot{d}\left(t\right)-\frac{\partial f}{\partial\dot{q}}d\left(t\right)\\
 & +\left(k_{1}+k_{2}\right)r_{2}\left(t\right)-\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-1\right)r_{1}\left(t\right)+k_{1}\left(k_{1}^{2}-1\right)e\left(t\right)-\dot{u}\left(t\right)\\
\\
 & =\underbrace{\frac{\partial f_{d}}{\partial q_{d}}\dot{q}_{d}+\frac{\partial f_{d}}{\partial\dot{q}_{d}}f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-\frac{\partial f}{\partial q}\dot{q}-\frac{\partial f}{\partial\dot{q}}\left(f\left(q\left(t\right),\dot{q}\left(t\right)\right)+u\left(t\right)\right)}_{\triangleq h\left(q,\dot{q},q_{d},\dot{q}_{d},u\right)}\underbrace{-\frac{\partial f}{\partial\dot{q}}d\left(t\right)-\dot{d}\left(t\right)}_{\triangleq D\left(q,\dot{q},t\right)}-\dot{u}\left(t\right)\\
 & +k_{1}r_{2}\left(t\right)+k_{2}r_{2}\left(t\right)-k_{1}k_{2}r_{1}\left(t\right)-k_{1}^{2}r_{1}\left(t\right)-k_{2}^{2}r_{1}\left(t\right)+r_{1}\left(t\right)+k_{1}^{3}e\left(t\right)-k_{1}e\left(t\right)\\
 & =h\left(q,\dot{q},q_{d},\dot{q}_{d},u\right)+D\left(q,\dot{q},t\right)-\dot{u}\left(t\right)+\left(k_{1}+k_{2}\right)r_{2}\left(t\right)-\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-1\right)r_{1}\left(t\right)+k_{1}\left(k_{1}^{2}-1\right)e\left(t\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{r}_{2}\left(t\right) & =h\left(q,\dot{q},q_{d},\dot{q}_{d},u\right)+D\left(q,\dot{q},t\right)-\dot{u}\left(t\right)\\
 & +\left(k_{1}+k_{2}\right)r_{2}\left(t\right)-\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-1\right)r_{1}\left(t\right)\\
 & +k_{1}\left(k_{1}^{2}-1\right)e\left(t\right).
\end{aligned}
\label{eq: Auxiliary Tracking Error Derivative}
\end{equation}

\end_inset

where 
\begin_inset Formula $h:\mathbb{R}^{n}\times\mathbb{R}^{n}\times\mathbb{R}^{n}\times\mathbb{R}^{n}\times\mathbb{R}^{n}\to\mathbb{R}^{n}$
\end_inset

 is defined as 
\begin_inset Formula $h\left(q,\dot{q},q_{d},\dot{q}_{d},u\right)\triangleq\frac{\partial f_{d}}{\partial q_{d}}\dot{q}_{d}+\frac{\partial f_{d}}{\partial\dot{q}_{d}}f_{d}\left(q_{d}\left(t\right),\dot{q}_{d}\left(t\right)\right)-\frac{\partial f}{\partial q}\dot{q}-\frac{\partial f}{\partial\dot{q}}\left(f\left(q\left(t\right),\dot{q}\left(t\right)\right)+u\left(t\right)\right)$
\end_inset

 and 
\begin_inset Formula $D:\mathbb{R}^{n}\times\mathbb{R}^{n}\times\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 is defined as 
\begin_inset Formula $D\left(q,\dot{q},t\right)\triangleq-\frac{\partial f}{\partial\dot{q}}d\left(t\right)-\dot{d}\left(t\right)$
\end_inset

.
\end_layout

\begin_layout Subsection
Deep Neural Network Function Approximation
\end_layout

\begin_layout Standard
DNNs offer a promising alternative that can learn complex patterns from
 data without requiring explicit knowledge of the underlying physics.
 This function approximation capability motivates the use of DNN-based function
 approximation to develop more accurate and robust models for nonlinear
 dynamics.
\end_layout

\begin_layout Standard
To approximate the unknown dynamics given by 
\begin_inset Formula $h$
\end_inset

 in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Auxiliary Tracking Error Derivative"

\end_inset

, 
\begin_inset Formula $\kappa:\mathbb{R}_{\geq0}\to\mathbb{R}^{5n}$
\end_inset

 is defined as 
\begin_inset Formula $\kappa\left(t\right)\triangleq\left[\begin{array}{ccccc}
q^{\top}\left(t\right) & \dot{q}^{\top}\left(t\right) & q_{d}^{\top}\left(t\right) & \dot{q}_{d}^{\top}\left(t\right) & u^{\top}\left(t\right)\end{array}\right]^{\top}\in\Omega$
\end_inset

, where 
\begin_inset Formula $\Omega\subset\mathbb{R}^{5n}$
\end_inset

 is a compact set over which the universal approximation property holds.
 The DNN-based approximation of 
\begin_inset Formula $h\left(\kappa\right)$
\end_inset

 is given by 
\begin_inset Formula $\Phi\left(\kappa,\hat{\theta}\right)$
\end_inset

, where 
\begin_inset Formula $\Phi:\mathbb{R}^{5n}\times\mathbb{R}^{p}\to\mathbb{R}^{n}$
\end_inset

 denotes the DNN architecture mapping and 
\begin_inset Formula $\hat{\theta}\in\mathbb{R}^{p}$
\end_inset

 denotes the adaptive parameter estimates.
\end_layout

\begin_layout Standard
The approximation objective is to determine optimal estimates 
\begin_inset Formula $\hat{\theta}$
\end_inset

 such that the mapping 
\begin_inset Formula $\kappa\mapsto\Phi\left(\kappa,\hat{\theta}\right)$
\end_inset

 approximates 
\begin_inset Formula $\kappa\mapsto h\left(\kappa\right)$
\end_inset

 with minimal error for all 
\begin_inset Formula $\kappa\in\Omega$
\end_inset

.
 To quantify the approximation objective, an objective function 
\begin_inset Formula $\mathcal{J}:\mathbb{R}^{p}\to\mathbb{R}_{\geq0}$
\end_inset

 is defined as
\begin_inset Formula 
\begin{equation}
\mathcal{J}\left(\theta\right)\triangleq\int_{\Omega}\left(\left\Vert h\left(\kappa\right)-\Phi\left(\kappa,\theta\right)\right\Vert ^{2}\right){\rm d}\mu\left(\kappa\right),\label{eq:Loss Function}
\end{equation}

\end_inset

where 
\begin_inset Formula $\mu$
\end_inset

 denotes the Lebesgue measure on 
\begin_inset Formula $\mathbb{R}^{5n}$
\end_inset

 and 
\begin_inset Formula $\theta\in\mathbb{R}^{p}$
\end_inset

 is an arbitrary parameter vector.
 Let 
\begin_inset Formula $\mho\subset\mathbb{R}^{p}$
\end_inset

 denote a user-selected compact, convex parameter search space with a 
\begin_inset Formula $\mathcal{C}^{\infty}$
\end_inset

 boundary, satisfying 
\begin_inset Formula $\mathbf{0}_{p}\in\text{int}\left(\mho\right)$
\end_inset

, and define 
\begin_inset Formula $\overline{\theta}\triangleq\underset{\theta\in\mho}{\max}\left\Vert \theta\right\Vert .$
\end_inset


\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "thm:The-loss-function"

\end_inset

For the objective function 
\begin_inset Formula $\mathcal{J}$
\end_inset

, there exists a compact, convex set 
\begin_inset Formula $\mho\subset\mathbb{R}^{p}$
\end_inset

 containing the origin such that 
\begin_inset Formula $\mathcal{J}$
\end_inset

 is essentially strictly convex over 
\begin_inset Formula $\mho$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
This property ensures the uniqueness of the global minimizer.
 Consequently, due to the continuity of 
\begin_inset Formula $\mathcal{J}$
\end_inset

 and compactness of 
\begin_inset Formula $\mho$
\end_inset

, 
\begin_inset Formula $\mathcal{J}$
\end_inset

 has a unique global minimizer 
\begin_inset Formula $\theta^{\ast}\in\mho$
\end_inset

, defined as
\begin_inset Formula 
\begin{eqnarray}
\theta^{\ast} & \triangleq & \underset{\theta\in\mho}{\arg\min\ }\mathcal{J}\left(\theta\right).\label{eq:theta star}
\end{eqnarray}

\end_inset


\end_layout

\begin_layout Remark
\begin_inset CommandInset label
LatexCommand label
name "rem:Universal Function Approximation"

\end_inset

 The universal function approximation property of DNNs was not invoked in
 the definition of 
\begin_inset Formula $\theta^{\ast}$
\end_inset

.
 The universal function approximation theorem states that the function space
 of DNNs is dense in the space of continuous functions 
\begin_inset Formula $\mathcal{C}\left(\Omega\right)$
\end_inset

 
\begin_inset CommandInset citation
LatexCommand cite
key "Kidger.Lyons2020,Kratsios.Papon2022"
literal "false"

\end_inset

.
 Consequently, for any prescribed 
\begin_inset Formula $\overline{\varepsilon}>0$
\end_inset

, there exists a DNN 
\begin_inset Formula $\Phi$
\end_inset

 and a corresponding parameter vector 
\begin_inset Formula $\theta$
\end_inset

 such that 
\begin_inset Formula $\underset{\kappa\in\Omega}{\sup}\left\Vert h\left(\kappa\right)-\Phi\left(\kappa,\theta\right)\right\Vert <\overline{\varepsilon}$
\end_inset

.
 This implies 
\begin_inset Formula $\int_{\Omega}\left\Vert h\left(\kappa\right)-\Psi\left(\kappa,\theta\right)\right\Vert ^{2}{\rm d}\mu\left(\kappa\right)<\overline{\varepsilon}^{2}\mu\left(\Omega\right)$
\end_inset

.
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\int_{\Omega}\left\Vert h\left(\kappa\right)-\Psi\left(\kappa,\theta\right)\right\Vert ^{2}{\rm d}\mu\left(\kappa\right) & <\int_{\Omega}\overline{\varepsilon}^{2}{\rm d}\mu\left(\kappa\right)\\
 & =\overline{\varepsilon}^{2}\int_{\Omega}{\rm d}\mu\left(\kappa\right)\\
 & =\overline{\varepsilon}^{2}\mu\left(\Omega\right)
\end{align*}

\end_inset


\end_layout

\end_inset

 However, determining a search space 
\begin_inset Formula $\mho$
\end_inset

 for arbitrary 
\begin_inset Formula $\overline{\varepsilon}$
\end_inset

 remains an open challenge.
 Therefore, 
\begin_inset Formula $\mho$
\end_inset

 is arbitrarily selected, at the expense of guarantees on the approximation
 accuracy.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Subsection
Control Design
\end_layout

\begin_layout Standard
Following the previous discussion, the unknown dynamics in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Auxiliary Tracking Error Derivative"

\end_inset

 are modeled using a DNN as
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
h\left(\kappa\right)=\Phi\left(\kappa\left(t\right),\theta^{\ast}\right)+\varepsilon\left(\kappa\left(t\right)\right),\label{eq:UFAP}
\end{equation}

\end_inset

where 
\begin_inset Formula $\varepsilon:\mathbb{R}^{5n}\to\mathbb{R}^{n}$
\end_inset

 is an unknown function representing the reconstruction error that is bounded
 as
\begin_inset Formula 
\begin{equation}
\sup_{\kappa\in\Omega}\left\Vert \varepsilon\left(\kappa\right)\right\Vert <\overline{\varepsilon}.\label{eq: reconstruction error bound}
\end{equation}

\end_inset

Based on 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Auxiliary Tracking Error Derivative"

\end_inset

 and the subsequent stability analysis, the control input is designed as
 a Filippov solution to
\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{u}\left(t\right) & =\left(k_{1}+k_{2}+k_{3}\right)r_{2}\left(t\right)+k_{1}\left(k_{1}^{2}-1\right)e\left(t\right)\\
 & -\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-2\right)r_{1}\left(t\right)\\
 & +\gamma\left(t\right)\text{sgn}\left(r_{1}\left(t\right)\right)+\Phi\left(\kappa,\hat{\theta}\right),
\end{aligned}
\label{eq: uDot}
\end{equation}

\end_inset

where 
\begin_inset Formula $k_{3}\in\mathbb{R}_{>0}$
\end_inset

 is a constant control gain.
 Here, 
\begin_inset Formula $\gamma:\mathbb{R}_{\geq0}\to\mathbb{R}$
\end_inset

 is an adaptive RISE gain designed as a Filippov solution to
\begin_inset Formula 
\begin{equation}
\dot{\gamma}\left(t\right)=\Gamma_{1}\left(r_{2}^{\top}\left(t\right)\text{sgn}\left(r_{1}\left(t\right)\right)-k_{4}\gamma\left(t\right)\right),\label{eq:gammaDot}
\end{equation}

\end_inset

where 
\begin_inset Formula $k_{4}\in\mathbb{R}_{>0}$
\end_inset

 is a constant control gain and 
\begin_inset Formula $\Gamma_{1}\in\mathbb{R}_{>0}$
\end_inset

 is a user-defined RISE learning rate.
 Substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:UFAP"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: uDot"

\end_inset

 into 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Auxiliary Tracking Error Derivative"

\end_inset

 yields
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{r}_{2}\left(t\right) & =h\left(q,\dot{q},q_{d},\dot{q}_{d},u\right)+D\left(q,\dot{q},t\right)-\dot{u}\left(t\right)+\left(k_{1}+k_{2}\right)r_{2}\left(t\right)-\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-1\right)r_{1}\left(t\right)+k_{1}\left(k_{1}^{2}-1\right)e\left(t\right)\\
 & =\Phi\left(\kappa,\theta^{\ast}\right)+\varepsilon\left(\kappa\right)+D\left(q,\dot{q},t\right)-\left(\left(k_{1}+k_{2}+k_{3}\right)r_{2}\left(t\right)-\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-2\right)r_{1}\left(t\right)+k_{1}\left(k_{1}^{2}-1\right)e\left(t\right)+\gamma\left(t\right)\text{sgn}\left(r_{1}\left(t\right)\right)+\Phi\left(\kappa,\hat{\theta}\right)\right)\\
 & +\left(k_{1}+k_{2}\right)r_{2}\left(t\right)-\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-1\right)r_{1}\left(t\right)+k_{1}\left(k_{1}^{2}-1\right)e\left(t\right)\\
\\
 & =\Phi\left(\kappa,\theta^{\ast}\right)+\varepsilon\left(\kappa\right)+D\left(q,\dot{q},t\right)-\left(k_{1}+k_{2}+k_{3}\right)r_{2}\left(t\right)+\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-2\right)r_{1}\left(t\right)-k_{1}\left(k_{1}^{2}-1\right)e\left(t\right)-\gamma\left(t\right)\text{sgn}\left(r_{1}\left(t\right)\right)-\Phi\left(\kappa,\hat{\theta}\right)\\
 & +\left(k_{1}+k_{2}\right)r_{2}\left(t\right)-\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-1\right)r_{1}\left(t\right)+k_{1}\left(k_{1}^{2}-1\right)e\left(t\right)\\
\\
 & =-k_{3}r_{2}\left(t\right)-r_{1}\left(t\right)-\gamma\left(t\right)\text{sgn}\left(r_{1}\left(t\right)\right)+\Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa,\hat{\theta}\right)+D\left(q,\dot{q},t\right)+\varepsilon\left(\kappa\right)\\
 & +\left(k_{1}+k_{2}\right)r_{2}\left(t\right)-\left(k_{1}+k_{2}\right)r_{2}\left(t\right)\\
 & +\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-1\right)r_{1}\left(t\right)-\left(k_{1}^{2}+k_{1}k_{2}+k_{2}^{2}-1\right)r_{1}\left(t\right)\\
 & +k_{1}\left(k_{1}^{2}-1\right)e\left(t\right)-k_{1}\left(k_{1}^{2}-1\right)e\left(t\right)\\
\\
 & =\Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa,\hat{\theta}\right)-\gamma\left(t\right)\text{sgn}\left(r_{1}\left(t\right)\right)-k_{3}r_{2}\left(t\right)-r_{1}\left(t\right)+D\left(q,\dot{q},t\right)+\varepsilon\left(\kappa\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{r}_{2}\left(t\right) & =\Phi\left(\kappa\left(t\right),\theta^{\ast}\right)-\Phi\left(\kappa\left(t\right),\hat{\theta}\left(t\right)\right)\\
 & -\gamma\left(t\right)\text{sgn}\left(r_{1}\left(t\right)\right)-k_{3}r_{2}\left(t\right)-r_{1}\left(t\right)\\
 & +D\left(q,\dot{q},t\right)+\varepsilon\left(\kappa\right).
\end{aligned}
\label{eq: r2Dot}
\end{equation}

\end_inset

Based on the subsequent stability analysis, the adaptive update law is designed
 as
\size small

\begin_inset Formula 
\begin{equation}
\dot{\hat{\theta}}\left(t\right)=\text{proj}\left(\Gamma_{2}\left(\frac{\partial\Phi\left(\kappa\left(t\right),\hat{\theta}\left(t\right)\right)}{\partial\hat{\theta}}^{\top}\left(\left(k_{1}+k_{2}\right)\dot{e}\left(t\right)+\left(1+k_{1}k_{2}\right)e\left(t\right)\right)-k_{5}\hat{\theta}\left(t\right)\right)\right),\label{eq:Update Law}
\end{equation}

\end_inset


\size default
where 
\begin_inset Formula $k_{5}\in\mathbb{R}_{>0}$
\end_inset

 is a constant control gain, 
\begin_inset Formula $\Gamma_{2}\in\mathbb{R}^{p\times p}$
\end_inset

 is a user-defined positive-definite learning rate matrix, and the projection
 operator ensures 
\begin_inset Formula $\widehat{\Theta}\left(t\right)\in\mho$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\geq0}$
\end_inset

, defined as in 
\begin_inset CommandInset citation
LatexCommand cite
after "Appendix E"
key "Krstic.Kanellakopoulos.ea1995"
literal "false"

\end_inset

.
\end_layout

\begin_layout Section
Stability Analysis
\end_layout

\begin_layout Standard
The DNN described in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:UFAP"

\end_inset

 is inherently nonlinear with respect to its weights.
 Designing adaptive controllers and performing stability analyses for systems
 that are nonlinearly parameterizable presents significant theoretical challenge
s.
 A method to address the nonlinear structure of the uncertainty, especially
 for DNNs, is to use a first-order Taylor series approximation.
 To quantify the approximation, the parameter estimation error 
\begin_inset Formula $\tilde{\theta}:\mathbb{R}_{\geq0}\to\mathbb{R}^{p}$
\end_inset

 is defined as
\begin_inset Formula 
\begin{equation}
\tilde{\theta}\left(t\right)=\theta^{\ast}-\hat{\theta}\left(t\right).\label{eq: parameter estimation error}
\end{equation}

\end_inset

Applying first-order Taylor's theorem to 
\begin_inset Formula $\Phi\left(\kappa,\theta^{\ast}\right)$
\end_inset

 evaluated at 
\begin_inset Formula $\hat{\theta}$
\end_inset

 and using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: parameter estimation error"

\end_inset

 yields
\begin_inset Formula 
\begin{equation}
\Phi\left(\kappa,\theta^{\ast}\right)-\Phi\left(\kappa,\hat{\theta}\right)=\frac{\partial\Phi\left(\kappa,\hat{\theta}\right)}{\partial\hat{\theta}}\tilde{\theta}+R\left(\kappa,\tilde{\theta}\right),\label{eq: Taylors Theorem}
\end{equation}

\end_inset

where 
\begin_inset Formula $R:\mathbb{R}^{5n}\times\mathbb{R}^{p}\to\mathbb{R}^{n}$
\end_inset

 denotes the Lagrange remainder term.
 Substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Taylors Theorem"

\end_inset

 into 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: r2Dot"

\end_inset

 yields
\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{r}_{2}\left(t\right) & =\frac{\partial\Phi\left(\kappa,\hat{\theta}\right)}{\partial\hat{\theta}}\tilde{\theta}+R\left(\kappa,\tilde{\theta}\right)-\gamma\left(t\right)\text{sgn}\left(r_{1}\left(t\right)\right)\\
 & -k_{3}r_{2}\left(t\right)-r_{1}\left(t\right)+D\left(q,\dot{q},t\right)+\varepsilon\left(\kappa\right).
\end{aligned}
\label{eq:rDot-2}
\end{equation}

\end_inset

Based on the subsequent stability analysis, the adaptive RISE gain estimation
 error 
\begin_inset Formula $\tilde{\gamma}:\mathbb{R}_{\geq0}\to\mathbb{R}$
\end_inset

 is defined as
\begin_inset Formula 
\begin{equation}
\tilde{\gamma}\left(t\right)=\gamma^{\ast}-\gamma\left(t\right),\label{eq:gammaTilde}
\end{equation}

\end_inset

where 
\begin_inset Formula $\gamma^{\ast}\in\mathbb{R}_{\geq0}$
\end_inset

 denotes the ideal RISE gain.
 Let 
\begin_inset Formula $z:\mathbb{R}_{\geq0}\to\mathbb{R}^{\varphi}$
\end_inset

 denote the concatenated state vector 
\begin_inset Formula $z\left(t\right)\triangleq\left[\begin{array}{ccccc}
e^{\top}\left(t\right) & r_{1}^{\top}\left(t\right) & r_{2}^{\top}\left(t\right) & \tilde{\gamma}\left(t\right) & \tilde{\theta}^{\top}\left(t\right)\end{array}\right]^{\top}\in\mathbb{R}^{\varphi}$
\end_inset

, where 
\begin_inset Formula $\varphi\triangleq3n+1+p$
\end_inset

.
 The trajectory 
\begin_inset Formula $z\mapsto z\left(t\right)$
\end_inset

 is a solution to the initial value problem
\begin_inset Formula 
\begin{equation}
\dot{z}\left(t\right)=g\left(z\left(t\right),t\right),\ z\left(t_{0}\right)=z_{0},\label{eq:IVP}
\end{equation}

\end_inset

where, using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Tracking Error"

\end_inset

, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:gammaDot"

\end_inset

, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Update Law"

\end_inset

, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: parameter estimation error"

\end_inset

, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rDot-2"

\end_inset

, and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:gammaTilde"

\end_inset

, 
\begin_inset Formula $g:\mathbb{R}^{\varphi}\times\mathbb{R}_{\geq0}\to\mathbb{R}^{\varphi}$
\end_inset

 is defined as
\size small

\begin_inset Formula 
\begin{equation}
g\left(z\left(t\right),t\right)=\left[\begin{array}{c}
r_{1}-k_{1}e\\
r_{2}-k_{2}r_{1}-e\\
\left(\begin{array}{c}
\frac{\partial\Phi\left(\kappa\left(t\right),\hat{\theta}\right)}{\partial\hat{\theta}}\tilde{\theta}+R\left(\kappa\left(t\right),\tilde{\theta}\right)\\
-\gamma\left(t\right)\text{sgn}\left(r_{1}\right)-k_{3}r_{2}\\
-r_{1}+D\left(q,\dot{q},t\right)+\varepsilon\left(\kappa\left(t\right)\right).
\end{array}\right)\\
-\Gamma_{1}\left(r_{2}^{\top}\text{sgn}\left(r_{1}\right)-k_{4}\gamma\left(t\right)\right)\\
-\text{proj}\left(\Gamma_{2}\left(\frac{\partial\Phi\left(\kappa\left(t\right),\hat{\theta}\right)}{\partial\hat{\theta}}^{\top}\left(\left(k_{1}+k_{2}\right)\dot{e}+\left(1+k_{1}k_{2}\right)e\right)-k_{5}\hat{\theta}\right)\right)
\end{array}\right].\label{eq:CLES}
\end{equation}

\end_inset


\end_layout

\begin_layout Lemma
\begin_inset CommandInset label
LatexCommand label
name "Hb bounds"

\end_inset

There exist known constants 
\begin_inset Formula $\chi_{1},\chi_{2}\in\mathbb{R}_{>0}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert D\left(q,\dot{q},t\right)\right\Vert \leq\chi_{1}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \frac{{\rm d}}{{\rm d}t}D\left(q,\dot{q},t\right)\right\Vert \leq\chi_{2}$
\end_inset

.
\end_layout

\begin_layout Proof
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\left\Vert D\left(q,\dot{q},t\right)\right\Vert  & =\left\Vert -\frac{\partial f}{\partial\dot{q}}d\left(t\right)-\dot{d}\left(t\right)\right\Vert \\
 & \leq\left\Vert \frac{\partial f}{\partial\dot{q}}d\left(t\right)\right\Vert +\left\Vert \dot{d}\left(t\right)\right\Vert \\
 & \leq L_{1}\overline{d}+\overline{\dot{d}}
\end{align*}

\end_inset


\begin_inset Formula 
\begin{align*}
\left\Vert \frac{{\rm d}}{{\rm d}t}D\left(q,\dot{q},t\right)\right\Vert  & =\left\Vert \frac{{\rm d}}{{\rm d}t}\left(-\frac{\partial f}{\partial\dot{q}}d\left(t\right)-\dot{d}\left(t\right)\right)\right\Vert \\
 & =\left\Vert -\left(\frac{{\rm d}}{{\rm d}t}\frac{\partial f}{\partial\dot{q}}d\left(t\right)+\frac{{\rm d}}{{\rm d}t}\dot{d}\left(t\right)\right)\right\Vert \\
 & =\left\Vert -\left(\frac{\partial f}{\partial\dot{q}}\left(\frac{{\rm d}}{{\rm d}t}d\left(t\right)\right)+\left(\frac{{\rm d}}{{\rm d}t}\frac{\partial f}{\partial\dot{q}}\right)d\left(t\right)+\frac{{\rm d}}{{\rm d}t}\dot{d}\left(t\right)\right)\right\Vert \\
 & \leq\left\Vert \frac{\partial f}{\partial\dot{q}}\right\Vert \left\Vert \dot{d}\left(t\right)\right\Vert +\left\Vert \frac{\partial^{2}f}{\partial q\partial\dot{q}}\right\Vert \left\Vert \dot{q}\right\Vert \left\Vert d\left(t\right)\right\Vert +\left\Vert \frac{\partial^{2}f}{\partial\dot{q}^{2}}\right\Vert \left\Vert \ddot{q}\right\Vert \left\Vert d\left(t\right)\right\Vert +\left\Vert \dot{d}\left(t\right)\right\Vert \\
 & \leq L_{1}\overline{d}+L_{2}\overline{d}\left\Vert \dot{q}_{d}-\dot{e}\right\Vert +L_{3}\overline{d}\left\Vert \ddot{q}_{d}-\ddot{e}\right\Vert +\overline{\dot{d}}\\
 & \leq L_{1}\overline{d}+L_{2}\overline{d}\left(\left\Vert \dot{q}_{d}\right\Vert +\left\Vert r_{1}-k_{1}e\right\Vert \right)+L_{3}\overline{d}\left(\left\Vert \ddot{q}_{d}\right\Vert +\left\Vert \dot{r}_{1}-k_{1}\dot{e}\right\Vert \right)+\overline{\dot{d}}\\
 & \leq L_{1}\overline{d}+L_{2}\overline{d}\left(\overline{\dot{q}}_{d}+\left\Vert r_{1}\right\Vert +k_{1}\left\Vert e\right\Vert \right)+L_{3}\overline{d}\left(\overline{\ddot{q}}_{d}+\left\Vert r_{2}-k_{2}r_{1}-e\right\Vert +k_{1}\left\Vert r_{1}-k_{1}e\right\Vert \right)+\overline{\dot{d}}\\
 & \leq c_{1}+c_{2}\left\Vert z\right\Vert 
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Standard

\color red
To establish the convergence properties of the IVP given by 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:IVP"

\end_inset

, a 
\begin_inset Formula $P$
\end_inset

-function is introduced.
 This function is used to develop a strict Lyapunov function and is designed
 to be non-negative under specific gain conditions.
 The 
\begin_inset Formula $P$
\end_inset

-function 
\begin_inset Formula $P:\mathcal{I}\to\mathbb{R}_{\geq0}$
\end_inset

 is designed as
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Before proceeding, recall the Leibniz rule:
\begin_inset Formula 
\begin{eqnarray*}
\frac{{\rm d}}{{\rm d}x}\left(\int_{a(x)}^{b(x)}f(x,t){\rm d}t\right) & = & f\left(x,b(x)\right)\frac{{\rm d}b(x)}{{\rm d}x}-f\left(x,a(x)\right)\frac{{\rm d}a(x)}{{\rm d}x}+\int_{a(x)}^{b(x)}\frac{\partial}{\partial x}f(x,t){\rm d}t
\end{eqnarray*}

\end_inset

Thus, for any given 
\begin_inset Formula $\rho:[t_{0},\infty)\to\mathbb{R}$
\end_inset

, the function 
\begin_inset Formula $\mathrm{e}^{-\lambda_{P}t}$
\end_inset

 satisfies
\begin_inset Formula 
\begin{align*}
\frac{{\rm d}}{{\rm d}t}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right) & =\frac{{\rm d}}{{\rm d}t}\left(\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}\rho(\tau){\rm d}\tau\right),\\
 & =\mathrm{e}^{-\lambda_{P}(t-t)}\rho(t)\frac{{\rm d}t}{{\rm d}t}-\mathrm{e}^{-\lambda_{P}(t-t_{0})}\rho(t_{0})\frac{{\rm d}t_{0}}{{\rm d}t}+\int_{t_{0}}^{t}\frac{\partial}{\partial t}\left(\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau)\right){\rm d}\tau\\
 & =e^{0}\rho(t)-0-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau){\rm d}\tau\\
 & =\rho(t)-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}\rho(\tau){\rm d}t,\\
 & =-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\rho+\rho.
\end{align*}

\end_inset

Assume 
\begin_inset Formula 
\[
P=k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}+\mathrm{e}^{-\lambda_{P}t}*\left(r_{1}^{\top}\mathcal{H}^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}\right)\right)
\]

\end_inset

Then 
\begin_inset Formula 
\begin{align*}
