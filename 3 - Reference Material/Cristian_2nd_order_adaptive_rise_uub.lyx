\begin_inset Formula 
\begin{equation}
P\left(t_{0}\right)=k_{4}\left\Vert \mathcal{H}r_{1}\left(t_{0}\right)\right\Vert _{1}-r_{1}^{\top}\left(t_{0}\right)\mathcal{H}^{\top}h_{B}\left(t_{0}\right).\label{eq:Pt_0}
