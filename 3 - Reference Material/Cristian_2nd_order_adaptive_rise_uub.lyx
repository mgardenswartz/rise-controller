 & =-k_{1}e^{\top}e-k_{2}r_{1}^{\top}r_{1}-k_{3}r_{2}^{\top}r_{2}+e^{\top}r_{1}+\cancel{\dot{r}_{1}^{\top}\nabla_{\widehat{\theta}}\Phi(\kappa,\widehat{\theta})\widetilde{\theta}}+\cancel{k_{2}\widetilde{\theta}^{\top}\nabla_{\widehat{\theta}}^{\top}\Phi(\kappa,\widehat{\theta})r_{1}}-\cancel{\dot{r}_{1}^{\top}\nabla_{\widehat{\theta}}\Phi(\kappa,\widehat{\theta})\widetilde{\theta}}-\cancel{k_{2}\widetilde{\theta}^{\top}\nabla_{\widehat{\theta}}^{\top}\Phi(\kappa,\widehat{\theta})r_{1}}+k_{2}\sigma_{1}\widetilde{\theta}^{\top}\theta^{\ast}-k_{2}\sigma_{1}\widetilde{\theta}^{\top}\widetilde{\theta}-\sigma_{2}\tilde{\gamma}\tilde{\gamma}+\sigma_{2}\tilde{\gamma}\gamma^{\ast}\\
 & =-k_{1}e^{\top}e-k_{2}r_{1}^{\top}r_{1}-k_{3}r_{2}^{\top}r_{2}-k_{2}\sigma_{1}\widetilde{\theta}^{\top}\widetilde{\theta}-\sigma_{2}\tilde{\gamma}^{\top}\tilde{\gamma}+e^{\top}r_{1}+k_{2}\sigma_{1}\widetilde{\theta}^{\top}\theta^{\ast}+\sigma_{2}\tilde{\gamma}^{\top}\gamma^{\ast}\\
 & \leq-k_{1}\left\Vert e\right\Vert ^{2}-k_{2}\left\Vert r_{1}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}-k_{2}\sigma_{1}\left\Vert \widetilde{\theta}\right\Vert ^{2}-\sigma_{2}\left\Vert \tilde{\gamma}\right\Vert ^{2}+\frac{\left\Vert e\right\Vert ^{2}}{2}+\frac{\left\Vert r_{1}\right\Vert ^{2}}{2}+k_{2}\sigma_{1}\frac{\left\Vert \widetilde{\theta}\right\Vert ^{2}}{2}+k_{2}\sigma_{1}\frac{\left\Vert \theta^{\ast}\right\Vert ^{2}}{2}+\sigma_{2}\frac{\left\Vert \tilde{\gamma}\right\Vert ^{2}}{2}+\sigma_{2}\frac{\left\Vert \gamma^{\ast}\right\Vert ^{2}}{2}\\
 & =\left(-k_{1}+\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}+\left(-k_{2}+\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}+\left(-k_{2}\sigma_{1}+k_{2}\sigma_{1}\frac{1}{2}\right)\left\Vert \widetilde{\theta}\right\Vert ^{2}+\left(-\sigma_{2}+\sigma_{2}\frac{1}{2}\right)\left\Vert \tilde{\gamma}\right\Vert ^{2}+k_{2}\sigma_{1}\frac{\left\Vert \theta^{\ast}\right\Vert ^{2}}{2}+\sigma_{2}\frac{\left\Vert \gamma^{\ast}\right\Vert ^{2}}{2}\\
 & =-\left(k_{1}-\frac{1}{2}\right)\left\Vert e\right\Vert ^{2}-\left(k_{2}-\frac{1}{2}\right)\left\Vert r_{1}\right\Vert ^{2}-k_{3}\left\Vert r_{2}\right\Vert ^{2}-\frac{k_{2}\sigma_{1}}{2}\left\Vert \widetilde{\theta}\right\Vert ^{2}-\frac{\sigma_{2}}{2}\left\Vert \tilde{\gamma}\right\Vert ^{2}+k_{2}\sigma_{1}\frac{\left\Vert \theta^{\ast}\right\Vert ^{2}}{2}+\sigma_{2}\frac{\left\Vert \gamma^{\ast}\right\Vert ^{2}}{2}
\end{align*}

\end_inset

Gain conditions:
\begin_inset Formula 
\begin{align*}
k_{1}-\frac{1}{2} & >0,\\
k_{1} & >\frac{1}{2}.\\
k_{2}-\frac{1}{2} & >0,\\
k_{2} & >\frac{1}{2}
\end{align*}

