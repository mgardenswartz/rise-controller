\left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{2}}\varsigma_{2}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{2}\right)\right)\mathbf{e}_{2}^{\top}\\
\vdots\\
\left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}}\varsigma_{L_{i,j}}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\right)\right)\mathbf{e}_{L_{i,j}}^{\top}\\
\mathbf{0}_{L_{i,j}}^{\top}
\end{array}\right]\\
 & =\left[\begin{array}{ccccc}
\left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{1}}\varsigma_{1}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{1}\right)\right)\mathbf{e}_{1}^{\top} & \left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{2}}\varsigma_{2}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{2}\right)\right)\mathbf{e}_{2}^{\top} & \cdots & \left(\frac{{\rm d}}{{\rm d}\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}}\varsigma_{L_{i,j}}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\right)\right)\mathbf{e}_{L_{i,j}}^{\top} & \mathbf{0}_{L_{i,j}}^{\top}\end{array}\right]^{\top}
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Section
Problem Formulation
\end_layout

\begin_layout Standard
Consider the first-order nonlinear dynamical system described by the differentia
l equation
\begin_inset Formula 
\begin{equation}
\dot{q}=u,\label{eq:Agent Dynamics}
\end{equation}

\end_inset

where 
\begin_inset Formula $q:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 represents the generalized position, 
\begin_inset Formula $\dot{q}:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 represents the generalized velocity and 
\begin_inset Formula $u:\mathbb{R}_{\geq t_{0}}\to\mathbb{R}^{n}$
\end_inset

 denotes the control input, where 
\begin_inset Formula $t_{0}\in\mathbb{R}_{\ge0}$
\end_inset

 is the initial time.
 The target trajectory is governed by the autonomous first-order system
\begin_inset Formula 
\begin{equation}
\dot{q}_{d}=f_{d}\left(q_{d}\right),\label{eq:Target Dynamics}
\end{equation}

\end_inset

where 
\begin_inset Formula $q_{d}:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 denotes the generalized target position, 
\begin_inset Formula $\dot{q}_{d}:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 denotes the generalized target velocity, and 
\begin_inset Formula $f_{d}:\mathbb{R}^{n}\to\mathbb{R}^{n}$
\end_inset

 represents the unknown target dynamics.
\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "asm:target-bounds"

\end_inset

There exist known constants 
\begin_inset Formula $\overline{q}_{d},\overline{\dot{q}}_{d}\in\mathbb{R}_{>0}$
\end_inset

 such that for all 
\begin_inset Formula $t\in\mathbb{R}_{\ge t_{0}}$
\end_inset

, 
\begin_inset Formula $\left\Vert q_{d}\left(t\right)\right\Vert \le\overline{q}_{d},\left\Vert \dot{q}_{d}\left(t\right)\right\Vert \le\overline{\dot{q}}_{d}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "asm:target-dynamics"

\end_inset

The function 
\begin_inset Formula $f_{d}$
\end_inset

 is of class 
\color red

\begin_inset Formula $\mathcal{C}^{1}$
\end_inset


\color inherit
 on 
\begin_inset Formula $\mathbb{R}^{n}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
The control objectiv
\color black
e is to design a ResNet-based adaptive controller such that the trajectory
 of 
\begin_inset Formula $q$
\end_inset

 tracks 
\begin_inset Formula $q_{d}$
\end_inset

 despite the presence of unknown dynamics and bounded disturbances.

\color inherit
 To facilitate the control objective, define the tracking error 
\begin_inset Formula $e:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 as
\begin_inset Formula 
\begin{equation}
e\triangleq q_{d}-q.\label{eq:Tracking Error}
\end{equation}

\end_inset


\end_layout

\begin_layout Section
Control Design
\end_layout

\begin_layout Standard
To facilitate the control design, the auxiliary tracking error function
 
\begin_inset Formula $r:\mathbb{R}_{\ge t_{0}}\to\mathbb{R}^{n}$
\end_inset

 is defined as
\begin_inset Formula 
\begin{equation}
r\triangleq\dot{e}+k_{1}e,\label{eq: Filtered Tracking Error}
\end{equation}

\end_inset

where 
\begin_inset Formula $k_{1}\in\mathbb{R}_{>0}$
\end_inset

 is a constant control gain.
 Differentiating 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

 with respect to time and substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

 and the time derivatives of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Agent Dynamics"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Target Dynamics"
plural "false"
caps "false"
noprefix "false"

\end_inset

 yields
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{r} & =\ddot{e}+k_{1}\dot{e}\\
 & =\frac{{\rm d}}{{\rm d}t}\dot{q}_{d}\left(t\right)-\frac{{\rm d}}{{\rm d}t}\dot{q}+k_{1}\left(r-k_{1}e\right)\\
 & =\frac{{\rm d}}{{\rm d}t}f_{d}\left(q_{d}\right)-\frac{{\rm d}}{{\rm d}t}\dot{q}+k_{1}\left(r-k_{1}e\right)\\
 & =\frac{{\rm \partial}f_{d}}{\partial q_{d}}\frac{\partial q_{d}}{\partial t}-\frac{{\rm d}}{{\rm d}t}u+k_{1}r-k_{1}^{2}e\\
 & =\frac{{\rm \partial}f_{d}}{\partial q_{d}}\frac{{\rm d}}{{\rm d}t}q_{d}-\dot{u}+k_{1}r-k_{1}^{2}e\\
 & =\frac{{\rm \partial}f_{d}}{\partial q_{d}}\dot{q}_{d}-\dot{u}+k_{1}r-k_{1}^{2}e\\
 & =\frac{\partial f_{d}}{\partial q_{d}}f\left(q_{d}\right)-\dot{u}+k_{1}r-k_{1}^{2}e\\
 & =h\left(q_{d}\right)-\dot{u}+k_{1}r-k_{1}^{2}e
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{r} & =h\left(q_{d}\right)-\dot{u}+k_{1}r-k_{1}^{2}e,\end{aligned}
\label{eq:rDot}
\end{equation}

\end_inset

where 
\begin_inset Formula $h:\mathbb{R}^{n}\to\mathbb{R}^{n}$
\end_inset

 is defined as 
\begin_inset Formula $h\left(q_{d}\right)\triangleq\frac{\partial f}{\partial q_{d}}f_{d}\left(q_{d}\right)$
\end_inset

.
\end_layout

\begin_layout Subsection
Residual Neural Network Function Approximations
\end_layout

\begin_layout Standard
Following Assumption
\color red
 
\color inherit

\begin_inset CommandInset ref
LatexCommand ref
reference "asm:target-dynamics"
plural "false"
caps "false"
noprefix "false"

\end_inset

, the function 
\begin_inset Formula $h:\mathbb{R}^{n}\to\mathbb{R}^{n}$
\end_inset

 is continuous over a compact domain 
\begin_inset Formula $\Omega\subsetneq\mathbb{R}^{n}$
\end_inset

.
 Approximation of 
\begin_inset Formula $h$
\end_inset

 is achieved using a deep residual neural network, denoted by 
\begin_inset Formula $\Psi:\mathbb{R}^{n}\times\mathbb{R}^{{\tt p}}\to\mathbb{R}^{n}$
\end_inset

, constructed as described in Section 
\begin_inset CommandInset ref
LatexCommand ref
reference "subsec:Deep-Residual-Neural"

\end_inset

.
 The following result guarantees the existence of a parameter vector yielding
 arbitrarily small approximation error.
\end_layout

\begin_layout Lemma
\begin_inset CommandInset label
LatexCommand label
name "lem:Universal-Approximation-Theorem"

\end_inset


\begin_inset CommandInset citation
LatexCommand cite
after "Theorem 3.1"
key "Lin.Jegelka2018"
literal "false"

\end_inset

 (Universal Approximation Theorem for Residual Neural Networks) Let 
\begin_inset Formula $\Omega\in\mathbb{R}^{L_{\text{in}}}$
\end_inset

 be a compact domain and let 
\begin_inset Formula $h:\Omega\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

 be an arbitrary continuous function.
 Then, for any 
\color blue

\begin_inset Formula $\overline{\varepsilon}\in\mathbb{R}_{>0}$
\end_inset


\color inherit
, there exists an integer 
\color blue

\begin_inset Formula $b\in\mathbb{Z}_{\geq1}$
\end_inset


\color inherit
, a corresponding ResNet architecture 
\begin_inset Formula $\Psi:\mathbb{R}^{L_{\text{in}}}\times\mathbb{R}^{{\tt p}}\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

 
\color blue
(thus a 
\begin_inset Formula ${\tt p}\in\mathbb{Z}_{\ge1}$
\end_inset

)
\color inherit
, and a parameter vector 
\begin_inset Formula $\Theta^{\ast}\in\mathbb{R}^{{\tt p}}$
\end_inset

 such that
\begin_inset Formula 
\[
\sup_{x\in\Omega}\left\Vert h\left(x\right)-\Psi\left(x,\Theta^{\ast}\right)\right\Vert <{\color{blue}\overline{\varepsilon}}.
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard
Following Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:Universal-Approximation-Theorem"

\end_inset

, the unknown dynamics 
\begin_inset Formula $h\left(q_{d}\right)$
\end_inset

 in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rDot"

\end_inset

 are modeled as
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
h\left(q_{d}\right)=\Psi\left(q_{d},\Theta^{\ast}\right)+\varepsilon\left(q_{d}\right),\label{eq:UFAT}
\end{equation}

\end_inset

where 
\begin_inset Formula $\varepsilon:\mathbb{R}^{n}\to\mathbb{R}^{n}$
\end_inset

 denotes the residual reconstruction error associated with the optimal parameter
 
\begin_inset Formula $\Theta^{\ast}{\color{blue}\in\mathbb{R}^{{\tt p}}}$
\end_inset

, 
\color blue
where 
\begin_inset Formula $\varepsilon\left(q_{d}\right)\triangleq h\left(q_{d}\right)-\Psi\left(q_{d},\Theta^{\ast}\right)$
\end_inset

 for all 
\begin_inset Formula $q_{d}\in{\color{red}\mathbb{R}^{n}}$
\end_inset


\color inherit
.
 Based on 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rDot"

\end_inset

 and the subsequent stability analysis, the control input 
\begin_inset Formula ${\color{blue}u:\mathbb{R}_{\geq t_{0}}\to\mathbb{R}^{n}}$
\end_inset

 is designed as
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
u & =\left(k_{1}+k_{2}\right)e+\int_{t_{0}}^{t}\left(\left(1+k_{1}k_{2}\right)e+\alpha\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right)+\frac{\partial}{\partial\widehat{\Theta}}\Psi\left(q_{d},\widehat{\Theta}\right)\widehat{\Theta}\right){\rm d}\tau\\
\implies\dot{u} & =\left(k_{1}+k_{2}\right)\dot{e}+\left(1+k_{1}k_{2}\right)e+\alpha\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right)+\frac{\partial}{\partial\widehat{\Theta}}\Psi\left(q_{d},\widehat{\Theta}\right)\widehat{\Theta}\\
 & =\left(k_{1}+k_{2}\right)\dot{e}+\left(1+k_{1}k_{2}+k_{1}^{2}-k_{1}^{2}\right)e+\alpha\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right)+\frac{\partial}{\partial\widehat{\Theta}}\Psi\left(q_{d},\widehat{\Theta}\right)\widehat{\Theta}\\
 & =\left(k_{1}+k_{2}\right)\dot{e}+\left(1-k_{1}^{2}\right)e+\left(k_{1}k_{2}+k_{1}^{2}\right)e+\alpha\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right)+\frac{\partial}{\partial\widehat{\Theta}}\Psi\left(q_{d},\widehat{\Theta}\right)\widehat{\Theta}\\
 & =\left(k_{1}+k_{2}\right)\dot{e}+\left(1-k_{1}^{2}\right)e+k_{1}\left(k_{1}+k_{2}\right)e+\alpha\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right)+\frac{\partial}{\partial\widehat{\Theta}}\Psi\left(q_{d},\widehat{\Theta}\right)\widehat{\Theta}\\
 & =\left(1-k_{1}^{2}\right)e+\left(k_{1}+k_{2}\right)\dot{e}+k_{1}\left(k_{1}+k_{2}\right)e+\alpha\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right)+\frac{\partial}{\partial\widehat{\Theta}}\Psi\left(q_{d},\widehat{\Theta}\right)\widehat{\Theta}\\
 & =\left(1-k_{1}^{2}\right)e+\left(k_{1}+k_{2}\right)\left(\dot{e}+k_{1}e\right)+\alpha\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right)+\frac{\partial}{\partial\widehat{\Theta}}\Psi\left(q_{d},\widehat{\Theta}\right)\widehat{\Theta}\\
 & =\left(1-k_{1}^{2}\right)e+\left(k_{1}+k_{2}\right)r+\alpha\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right)+\frac{\partial}{\partial\widehat{\Theta}}\Psi\left(q_{d},\widehat{\Theta}\right)\widehat{\Theta}
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
u\left(t\right)=\left(k_{1}+k_{2}\right)e\left(t\right)+\varrho,\label{eq: controller}
\end{equation}

\end_inset

where 
\begin_inset Formula ${\color{blue}\varrho:\mathbb{R}_{\geq t_{0}}\to\mathbb{R}^{n}}$
\end_inset

 is the generalized solution to
\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{\varrho} & =\left(1+k_{1}k_{2}\right)e+\alpha_{1}\text{sgn}\left(e\right)\\
 & +\Psi\left(q_{d},\widehat{\Theta}\right),\hspace{1em}{\color{red}\varrho\left(t_{0}\right)=0}.
\end{aligned}
\label{eq:u integrand}
\end{equation}

\end_inset

Here, the ResNet-based approximation of 
\begin_inset Formula $h\left(q_{d}\right)$
\end_inset

 is denoted 
\begin_inset Formula $\Psi\left({\color{red}x},\widehat{\Theta}\right)$
\end_inset

, 
\color blue

\begin_inset Formula $\widehat{\Theta}:\mathbb{R}_{\geq t_{0}}\to\mathbb{R}^{{\tt p}}$
\end_inset


\color inherit
 is the subsequently designed adaptive parameter estimate, and 
\begin_inset Formula ${\color{red}x}\in\Omega$
\end_inset

.
 Taking the time-derivative of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: controller"

\end_inset

 and using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:u integrand"

\end_inset

 yields
\begin_inset Note Note
status open

\begin_layout Plain Layout
Controller:
\begin_inset Formula 
\begin{align*}
\dot{u} & =\left(1-k_{1}^{2}\right)e+\left(k_{1}+k_{2}\right)r+\alpha_{1}\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right)\\
\implies\int_{t_{0}}^{t}\frac{{\rm d}}{{\rm d}\tau}u\left(\tau\right){\rm d}\tau & =\int_{t_{0}}^{t}\left(\left(1-k_{1}^{2}\right)e\left(\tau\right)+\left(k_{1}+k_{2}\right)r\left(\tau\right)+\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\Psi\left(q_{d}\left(\tau\right),\widehat{\Theta}\left(\tau\right)\right)\right){\rm d}\tau\\
\implies\left.u\left(\tau\right)\right|_{t_{0}}^{t} & =\left(k_{1}+k_{2}\right)\int_{t_{0}}^{t}r\left(\tau\right){\rm d}\tau+\int_{t_{0}}^{t}\left(\left(1-k_{1}^{2}\right)e\left(\tau\right)+\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\Psi\left(q_{d}\left(\tau\right),\widehat{\Theta}\left(\tau\right)\right)\right){\rm d}\tau\\
\implies u\left(t\right)-u\left(t_{0}\right) & =\left(k_{1}+k_{2}\right)\int_{t_{0}}^{t}\left(\dot{e}\left(\tau\right)+k_{1}e\left(\tau\right)\right){\rm d}\tau+\int_{t_{0}}^{t}\left(\left(1-k_{1}^{2}\right)e\left(\tau\right)+\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\Psi\left(q_{d}\left(\tau\right),\widehat{\Theta}\left(\tau\right)\right)\right){\rm d}\tau\\
\implies u\left(t\right) & =u\left(t_{0}\right)+\left(k_{1}+k_{2}\right)\int_{t_{0}}^{t}\frac{{\rm d}}{{\rm d}\tau}e\left(\tau\right){\rm d}\tau+\left(k_{1}^{2}+k_{1}k_{2}\right)\int_{t_{0}}^{t}e\left(\tau\right){\rm d}\tau+\int_{t_{0}}^{t}\left(\left(1-k_{1}^{2}\right)e\left(\tau\right)+\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\Psi\left(q_{d}\left(\tau\right),\widehat{\Theta}\left(\tau\right)\right)\right){\rm d}\tau\\
 & =u\left(t_{0}\right)+\left(k_{1}+k_{2}\right)\left(\left.e\left(\tau\right)\right|_{t_{0}}^{t}\right)+\int_{t_{0}}^{t}\left(\left(1-\cancel{k_{1}^{2}}+\cancel{k_{1}^{2}}+k_{1}k_{2}\right)e\left(\tau\right)+\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\Psi\left(q_{d}\left(\tau\right),\widehat{\Theta}\left(\tau\right)\right)\right){\rm d}\tau\\
 & =u\left(t_{0}\right)+\left(k_{1}+k_{2}\right)\left(e\left(t\right)-e\left(t_{0}\right)\right)+\int_{t_{0}}^{t}\left(\left(1+k_{1}k_{2}\right)e\left(\tau\right)+\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\Psi\left(q_{d}\left(\tau\right),\widehat{\Theta}\left(\tau\right)\right)\right){\rm d}\tau
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{u} & =\left(1-k_{1}^{2}\right)e+\left(k_{1}+k_{2}\right)r+\alpha_{1}\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right),\end{aligned}
\label{eq:control input-1}
\end{equation}

\end_inset

Substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:UFAT"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:control input-1"

\end_inset

 into 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rDot"

\end_inset

, and adding and subtracting by 
\begin_inset Formula $\Psi\left(q_{d},\widehat{\Theta}\right)$
\end_inset

 yields
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{r} & =h\left(q_{d}\right)-\dot{u}+k_{1}r-k_{1}^{2}e\\
 & =\Psi\left(q_{d},\Theta^{\ast}\right)+\varepsilon\left(q_{d}\right)-\dot{u}+k_{1}r-k_{1}^{2}e\\
 & =\Psi\left(q_{d},\Theta^{\ast}\right)+\varepsilon\left(q_{d}\right)-\left(\left(1-k_{1}^{2}\right)e+\left(k_{1}+k_{2}\right)r+\alpha_{1}\text{sgn}\left(e\right)+\Psi\left(q_{d},\widehat{\Theta}\right)\right)+k_{1}r-k_{1}^{2}e\\
 & =\Psi\left(q_{d},\Theta^{\ast}\right)+\varepsilon\left(q_{d}\right)-\left(1-\cancel{k_{1}^{2}}\right)e-\left(\cancel{k_{1}}+k_{2}\right)r-\alpha_{1}\text{sgn}\left(e\right)-\Psi\left(q_{d},\widehat{\Theta}\right)+\cancel{k_{1}r}-\cancel{k_{1}^{2}e}\\
 & =\Psi\left(q_{d},\Theta^{\ast}\right)+\varepsilon\left(q_{d}\right)-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)-\Psi\left(q_{d},\widehat{\Theta}\right)+\Psi\left(q_{d},\widehat{\Theta}\right)-\Psi\left(q_{d},\widehat{\Theta}\right)\\
 & =\underbrace{\Psi\left(q_{d},\Theta^{\ast}\right)-\Psi\left(q_{d},\widehat{\Theta}\right)}_{\triangleq\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)}+\varepsilon\left(q_{d}\right)-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+\cancel{\Psi\left(q_{d},\widehat{\Theta}\right)}-\cancel{\Psi\left(q_{d},\widehat{\Theta}\right)}\\
 & =\varepsilon\left(q_{d}\right)-\alpha_{1}\text{sgn}\left(e\right)-k_{2}r-e+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{r} & =\varepsilon\left(q_{d}\right)-\alpha_{1}\text{sgn}\left(e\right)-k_{2}r-e+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right),\end{aligned}
\label{eq:rDot-1}
\end{equation}

\end_inset

where 
\begin_inset Formula $\widetilde{N}:\mathbb{R}^{n}\times\mathbb{R}^{{\tt p}}\times\mathbb{R}^{{\tt p}}\to\mathbb{R}^{n}$
\end_inset

 is defined as 
\begin_inset Formula $\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)\triangleq\Psi\left(q_{d},\Theta^{\ast}\right)-\Psi\left(q_{d},\widehat{\Theta}\right)$
\end_inset

.
\end_layout

\begin_layout Remark

\color red
REMARK ABOUT BOUNDEDNESS OF THETAHAT ASSUMPTION IN VALID CONTROLLER
\end_layout

\begin_layout Subsection
Observer Design
\end_layout

\begin_layout Standard
\begin_inset Note Note
status collapsed

\begin_layout Section
Observer Design
\end_layout

\begin_layout Plain Layout
An observer is constructed to produce an online estimate of the unknown
 state derivative 
\begin_inset Formula $f\left(x\left(t\right)\right)$
\end_inset

.
 This estimate facilitates the creation of a measurable prediction error
 signal, which is essential for the synthesis of an adaptation law for the
 parameters of the function approximator 
\begin_inset Formula $\Phi$
\end_inset

.
\end_layout

\begin_layout Plain Layout
The derivation of this observer and the subsequent Lyapunov-based stability
 analysis require certain smoothness and boundedness properties of the unknown
 dynamics function 
\begin_inset Formula $f$
\end_inset

.
 Specifically, the analysis relies on the existence and boundedness of the
 first and second time derivatives of 
\begin_inset Formula $f\left(x\left(t\right)\right)$
\end_inset

 along system trajectories.
 These requirements are consolidated into the following comprehensive assumption.
\end_layout

\begin_layout Assumption
\begin_inset CommandInset label
LatexCommand label
name "dynamic bounds"

\end_inset

The unknown dynamics function 
\begin_inset Formula $f$
\end_inset

 is twice continuously differentiable, i.e., 
\begin_inset Formula $f\in C^{2}\left(\mathbb{R}^{n},\mathbb{R}^{n}\right)$
\end_inset

.
 As a consequence of this smoothness property and the compactness of the
 domain 
\begin_inset Formula $\Omega$
\end_inset

 from Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "compact input space"

\end_inset

, the derivatives of the dynamics along any system trajectory are uniformly
 bounded.
 Specifically, there exist known positive constants 
\begin_inset Formula $\chi_{1},\chi_{2}\in\mathbb{R}_{>0}$
\end_inset

 such that for all 
\begin_inset Formula $t\geq t_{0}$
\end_inset

,
\begin_inset Formula 
\[
\left\Vert \dot{f}\left(t\right)\right\Vert _{2}\leq\chi_{1},\ \text{and}\ \left\Vert \ddot{f}\left(t\right)\right\Vert _{2}\leq\chi_{2}.
\]

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Subsection
Observer Formulation
\end_layout

\begin_layout Plain Layout
To begin the observer design, the state estimation error 
\begin_inset Formula $\tilde{x}\in\mathbb{R}^{n}$
\end_inset

 and state-derivative estimation error 
\begin_inset Formula $\tilde{f}\in\mathbb{R}^{n}$
\end_inset

 are defined as
\begin_inset Formula 
\begin{align}
\tilde{x} & \triangleq x-\hat{x},\label{eq: state estimation error}\\
\tilde{f} & \triangleq f-\hat{f},\label{fTilde}
\end{align}

\end_inset

where 
\begin_inset Formula $\hat{x}\in\mathbb{R}^{n}$
\end_inset

 is the state of a dynamic observer and 
\begin_inset Formula $\hat{f}\in\mathbb{R}^{n}$
\end_inset

 is the state-derivative estimate.
 The observer dynamics for 
\begin_inset Formula $\hat{x}$
\end_inset

 are given by
\begin_inset Formula 
\begin{equation}
\dot{\hat{x}}=\hat{f}+k_{1}\tilde{x}\label{xHatDot}
\end{equation}

\end_inset

with a constant design gain 
\begin_inset Formula $k_{1}\in\mathbb{R}_{>0}$
\end_inset

.
 The dynamics of the state estimation error are found by differentiating
 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: state estimation error"

\end_inset

, substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Agent Dynamics"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "xHatDot"

\end_inset

 into the resulting expression, and using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "fTilde"

\end_inset

, yielding
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{\tilde{x}} & =\dot{x}-\dot{\hat{x}}\\
 & =f-\left(\hat{f}+k_{1}\tilde{x}\right)\\
 & =f-\hat{f}-k_{1}\tilde{x}\\
 & =\tilde{f}-k_{1}\tilde{x}
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{align}
\dot{\tilde{x}} & =\tilde{f}-k_{1}\tilde{x}.\label{xTildeDot}
\end{align}

\end_inset


\end_layout

\begin_layout Plain Layout
The state-derivative estimate 
\begin_inset Formula $\hat{f}$
\end_inset

 is generated by the output of the following integral formulation
\begin_inset Formula 
\begin{equation}
\hat{f}\left(t\right)\triangleq k_{2}\left(\tilde{x}\left(t\right)-\tilde{x}\left(t_{0}\right)\right)+\int_{t_{0}}^{t}\left(\left(1+k_{1}k_{2}\right)\tilde{x}\left(\tau\right)+\alpha\text{sgn}\left(\tilde{x}\left(\tau\right)\right)\right){\rm d}\tau,\label{fHat}
\end{equation}

\end_inset

where 
\begin_inset Formula $k_{2},\alpha\in\mathbb{R}_{>0}$
\end_inset

 are constant gains and the function 
\begin_inset Formula $\text{sgn}:\mathbb{R}^{n}\to\left\{ -1,0,1\right\} ^{n}$
\end_inset

 denotes the element-wise signum operator.
 The time-derivative of the state-derivative estimate 
\begin_inset Formula $\hat{f}\left(t\right)$
\end_inset

 is found by applying the Leibniz integral rule to 
\begin_inset CommandInset ref
LatexCommand eqref
reference "fHat"

\end_inset

 and using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "xTildeDot"

\end_inset

, yielding
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\frac{{\rm d}}{{\rm d}t}f & =\frac{{\rm d}}{{\rm d}t}\left(k_{2}\left(\tilde{x}\left(t\right)-\tilde{x}\left(t_{0}\right)\right)+\int_{t_{0}}^{t}\left(\left(1+k_{1}k_{2}\right)\tilde{x}\left(\tau\right)+\alpha\text{sgn}\left(\tilde{x}\left(\tau\right)\right)\right){\rm d}\tau\right)\\
 & =\frac{{\rm d}}{{\rm d}t}k_{2}\left(\tilde{x}\left(t\right)-\tilde{x}\left(t_{0}\right)\right)+\frac{{\rm d}}{{\rm d}t}\int_{t_{0}}^{t}\left(\left(1+k_{1}k_{2}\right)\tilde{x}\left(\tau\right)+\alpha\text{sgn}\left(\tilde{x}\left(\tau\right)\right)\right){\rm d}\tau\\
 & =k_{2}\dot{\tilde{x}}\left(t\right)+\left(1+k_{1}k_{2}\right)\tilde{x}\left(t\right)+\alpha\text{sgn}\left(\tilde{x}\left(t\right)\right)\\
 & =k_{2}\dot{\tilde{x}}+\tilde{x}+k_{1}k_{2}\tilde{x}+\alpha\text{sgn}\left(\tilde{x}\right)\\
 & =\tilde{x}+k_{2}\left(\dot{\tilde{x}}+k_{1}\tilde{x}\right)+\alpha\text{sgn}\left(\tilde{x}\right)\\
 & =\tilde{x}+k_{2}\left(\tilde{f}-\cancel{k_{1}\tilde{x}}+\cancel{k_{1}\tilde{x}}\right)+\alpha\text{sgn}\left(\tilde{x}\right)\\
 & =\tilde{x}+k_{2}\tilde{f}+\alpha\text{sgn}\left(\tilde{x}\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\dot{\hat{f}}\stackrel{{\rm a.a.t.}}{\in}\tilde{x}+k_{2}\tilde{f}+\alpha K\left[\text{sgn}\right]\left(\tilde{x}\right).\label{eq:fHatDot}
\end{equation}

\end_inset

Substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:fHatDot"

\end_inset

 into the time-derivative of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "fTilde"

\end_inset

 yields
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{\tilde{f}} & =\dot{f}-\dot{\hat{f}}\\
 & =\dot{f}-\left(\tilde{x}+k_{2}\tilde{f}+\alpha\text{sgn}\left(\tilde{x}\right)\right)\\
 & =\dot{f}-\tilde{x}-k_{2}\tilde{f}-\alpha\text{sgn}\left(\tilde{x}\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\dot{\tilde{f}}\stackrel{{\rm a.a.t.}}{\in}\dot{f}-\tilde{x}-k_{2}\tilde{f}-\alpha K\left[\text{sgn}\right]\left(\tilde{x}\right).\label{fTildeDot}
\end{equation}

\end_inset


\end_layout

\begin_layout Subsection
Stability Analysis
\end_layout

\begin_layout Plain Layout
The stability of the observer presented in the preceding section is analyzed.
 Let 
\begin_inset Formula $z\in\mathbb{R}^{2n}$
\end_inset

 denote the augmented error state vector defined as 
\begin_inset Formula $z\triangleq\left[\begin{array}{cc}
\tilde{x}^{\top} & \tilde{f}^{\top}\end{array}\right]^{\top}$
\end_inset

.
 The evolution of 
\begin_inset Formula $z$
\end_inset

 is governed by the non-autonomous initial value problem
\begin_inset Formula 
\begin{equation}
\dot{z}\left(t\right)\stackrel{{\rm a.a.t.}}{\in}F\left(z,t\right),\ z\left(t_{0}\right)=z_{0},\label{eq:IVP-1}
\end{equation}

\end_inset

where 
\begin_inset Formula $t_{0}\geq0$
\end_inset

 is the initial time and 
\begin_inset Formula $z_{0}\in\mathbb{R}^{2n}$
\end_inset

 is the initial state.
 Using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "xTildeDot"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "fTildeDot"

\end_inset

, the non-autonomous vector field 
\begin_inset Formula $F:\mathbb{R}^{2n}\times\mathbb{R}_{\geq0}\to\mathbb{R}^{2n}$
\end_inset

 is given by
\begin_inset Formula 
\begin{equation}
F\left(z,t\right)\triangleq\left[\begin{array}{c}
\tilde{f}-k_{1}\tilde{x}\\
\dot{f}\left(t\right)-\tilde{x}-k_{2}\tilde{f}-\alpha K\left[\text{sgn}\right]\left(\tilde{x}\right)
\end{array}\right].\label{eq:CLES-1}
\end{equation}

\end_inset


\end_layout

\begin_layout Plain Layout
To facilitate the construction of a strict Lyapunov function, an auxiliary
 function 
\begin_inset Formula $P:\left[t_{0},\infty\right)\to\mathbb{R}$
\end_inset

 is introduced.
 The auxiliary function is defined as
\begin_inset Formula 
\begin{equation}
P\left(t\right)\triangleq\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)+\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right),\label{P-Function}
\end{equation}

\end_inset

where 
\begin_inset Formula $\lambda_{P}\in\mathbb{R}_{>0}$
\end_inset

 is a user-defined constant gain, and the notation 
\begin_inset Formula $\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)$
\end_inset

 denotes the convolutional integral 
\begin_inset Formula $\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)\triangleq\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\rho\left(\tau\right){\rm d}\tau$
\end_inset

.
 The function 
\begin_inset Formula $\rho\left(t\right)$
\end_inset

 within the convolution is defined as
\begin_inset Formula 
\begin{equation}
\rho\left(t\right)\triangleq\tilde{x}^{\top}\left(t\right)\ddot{f}\left(t\right)+\left(k_{1}-\lambda_{P}\right)\left(\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)\right).\label{rho-Function}
\end{equation}

\end_inset

By the definition of the convolutional integral, the integral term in 
\begin_inset Formula $P\left(t\right)$
\end_inset

 is zero at the initial time 
\begin_inset Formula $t=t_{0}$
\end_inset

.
 The initial value of the auxiliary function is therefore
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
For initial conditions, 
\begin_inset Formula 
\begin{align*}
P\left(t_{0}\right) & =\alpha\left\Vert \tilde{x}\left(t_{0}\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t_{0}\right)\dot{f}\left(t_{0}\right)+\mathrm{e}^{-\lambda_{P}t_{0}}*\left(\tilde{x}^{\top}\ddot{f}+\left(\left(k_{1}-\lambda_{P}\right)\left(\alpha\left\Vert \tilde{x}\right\Vert _{1}-\tilde{x}^{\top}\dot{f}\right)\right)\right)\\
 & =\alpha\left\Vert \tilde{x}\left(t_{0}\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t_{0}\right)\dot{f}\left(t_{0}\right)+\mathrm{e}^{-\lambda_{P}t_{0}}*\underbrace{\left(\tilde{x}^{\top}\ddot{f}+\left(\left(k_{1}-\lambda_{P}\right)\left(\alpha\left\Vert \tilde{x}\right\Vert _{1}-\tilde{x}^{\top}\dot{f}\right)\right)\right)}_{\rho\left(t\right)}\\
 & =\alpha\left\Vert \tilde{x}\left(t_{0}\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t_{0}\right)\dot{f}\left(t_{0}\right)+\mathrm{e}^{-\lambda_{P}t_{0}}*\rho\left(t\right)\\
 & =\alpha\left\Vert \tilde{x}\left(t_{0}\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t_{0}\right)\dot{f}\left(t_{0}\right)+\int_{t_{0}}^{t_{0}}\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\rho\left(\tau\right){\rm d}\tau\\
 & =\alpha\left\Vert \tilde{x}\left(t_{0}\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t_{0}\right)\dot{f}\left(t_{0}\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
P\left(t_{0}\right)=\alpha\left\Vert \tilde{x}\left(t_{0}\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t_{0}\right)\dot{f}\left(t_{0}\right).\label{eq:Pt_0-1}
\end{equation}

\end_inset


\end_layout

\begin_layout Plain Layout
The evolution of the auxiliary function 
\begin_inset Formula $P\left(t\right)$
\end_inset

 is now analyzed.
 Since 
\begin_inset Formula $t\mapsto\tilde{x}\left(t\right)$
\end_inset

 is absolutely continuous and 
\begin_inset Formula $\left\Vert \cdot\right\Vert _{1}$
\end_inset

 is globally Lipschitz, the mapping 
\begin_inset Formula $t\mapsto\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}$
\end_inset

 is differentiable almost everywhere.
 By the definition of the 
\begin_inset Formula $L_{1}$
\end_inset

-norm, 
\begin_inset Formula $\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}=\tilde{x}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)$
\end_inset

.
 By the chain rule from 
\begin_inset CommandInset citation
LatexCommand cite
after "Theorem 2.2"
key "Shevitz.Paden1994"
literal "false"

\end_inset

, the derivative of 
\begin_inset Formula $\left\Vert \tilde{x}\right\Vert _{1}$
\end_inset

 is defined for almost all time as 
\begin_inset Formula $\frac{{\rm d}}{{\rm d}t}\left\Vert \tilde{x}\right\Vert _{1}\stackrel{{\rm a.a.t.}}{\in}\dot{\tilde{x}}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)$
\end_inset

.
 Using the Leibniz integral rule, the derivative of the convolution term
 is given by 
\begin_inset Formula $\frac{{\rm d}}{{\rm d}t}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)=\rho\left(t\right)-\lambda_{P}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)$
\end_inset

.
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Before proceeding, recall the Leibniz rule:
\begin_inset Formula 
\begin{eqnarray*}
\frac{{\rm d}}{{\rm d}x}\left(\int_{a\left(x\right)}^{b\left(x\right)}f\left(x,t\right){\rm d}t\right) & = & f\left(x,b\left(x\right)\right)\frac{{\rm d}}{{\rm d}x}b\left(x\right)-f\left(x,a\left(x\right)\right)\frac{{\rm d}}{{\rm d}x}a\left(x\right)+\int_{a\left(x\right)}^{b\left(x\right)}\frac{\partial}{\partial x}f\left(x,t\right){\rm d}t
\end{eqnarray*}

\end_inset

Thus, for any given 
\begin_inset Formula $\rho:\left[t_{0},\infty\right)\to\mathbb{R}$
\end_inset

, the function 
\begin_inset Formula $\mathrm{e}^{-\lambda_{P}t}$
\end_inset

 satisfies
\begin_inset Formula 
\begin{align*}
\frac{{\rm d}}{{\rm d}t}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right) & =\frac{{\rm d}}{{\rm d}t}\left(\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\rho\left(\tau\right){\rm d}\tau\right),\\
 & =\mathrm{e}^{-\lambda_{P}\left(t-t\right)}\rho\left(t\right)\frac{{\rm d}t}{{\rm d}t}-\mathrm{e}^{-\lambda_{P}\left(t-t_{0}\right)}\rho\left(t_{0}\right)\frac{{\rm d}t_{0}}{{\rm d}t}+\int_{t_{0}}^{t}\frac{\partial}{\partial t}\left(\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\rho\left(\tau\right)\right){\rm d}\tau,\\
 & =e^{0}\rho\left(t\right)-0-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\rho\left(\tau\right){\rm d}\tau,\\
 & =\rho\left(t\right)-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\rho\left(\tau\right){\rm d}\tau,\\
 & =\rho\left(t\right)-\lambda_{P}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)
\end{align*}

\end_inset


\end_layout

\end_inset

 Thus, taking the time-derivative of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "P-Function"

\end_inset

 and substituting the error relation 
\begin_inset Formula $\tilde{f}=\dot{\tilde{x}}+k_{1}\tilde{x}$
\end_inset

 from 
\begin_inset CommandInset ref
LatexCommand eqref
reference "xTildeDot"

\end_inset

 into the resulting expression yields that 
\begin_inset Formula $t\mapsto P\left(t\right)$
\end_inset

 satisfies the differential inclusion
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
We have
\begin_inset Formula 
\begin{align*}
P\left(t\right) & \triangleq\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)+\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)
\end{align*}

\end_inset

Recall that Then
\begin_inset Formula 
\begin{align*}
\frac{{\rm d}}{{\rm d}t}P\left(t\right) & =\frac{{\rm d}}{{\rm d}t}\left(\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)+\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)\right)\\
 & =\alpha\frac{{\rm d}}{{\rm d}t}\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\frac{{\rm d}}{{\rm d}t}\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)+\frac{{\rm d}}{{\rm d}t}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)\\
 & \stackrel{{\rm a.e.}}{\in}\alpha\dot{\tilde{x}}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\tilde{x}^{\top}\left(t\right)\ddot{f}\left(t\right)-\dot{\tilde{x}}^{\top}\left(t\right)\dot{f}\left(t\right)+\rho\left(t\right)-\lambda_{P}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)\\
 & =\alpha\dot{\tilde{x}}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\cancel{\tilde{x}^{\top}\left(t\right)\ddot{f}\left(t\right)}-\dot{\tilde{x}}^{\top}\left(t\right)\dot{f}\left(t\right)-\lambda_{P}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)+\cancel{\tilde{x}^{\top}\left(t\right)\ddot{f}\left(t\right)}+\left(k_{1}-\lambda_{P}\right)\left(\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)\right)\\
 & =\alpha\dot{\tilde{x}}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\dot{\tilde{x}}^{\top}\left(t\right)\dot{f}\left(t\right)-\lambda_{P}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)+\left(k_{1}-\lambda_{P}\right)\left(\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)\right)\\
 & =\alpha\dot{\tilde{x}}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\dot{\tilde{x}}^{\top}\left(t\right)\dot{f}\left(t\right)-\lambda_{P}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)+k_{1}\left(\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)\right)-\lambda_{P}\left(\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)\right)\\
 & =\alpha\dot{\tilde{x}}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\dot{\tilde{x}}^{\top}\left(t\right)\dot{f}\left(t\right)+k_{1}\left(\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)\right)-\lambda_{P}\left(\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)+\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)\right)\\
 & =\alpha\dot{\tilde{x}}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\dot{\tilde{x}}^{\top}\left(t\right)\dot{f}\left(t\right)+k_{1}\left(\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)\right)-\lambda_{P}P\left(t\right)\\
 & =\alpha\dot{\tilde{x}}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\dot{\tilde{x}}^{\top}\left(t\right)\dot{f}\left(t\right)+k_{1}\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-k_{1}\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)-\lambda_{P}P\left(t\right)\\
 & =\alpha\dot{\tilde{x}}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\dot{\tilde{x}}^{\top}\left(t\right)\dot{f}\left(t\right)+k_{1}\alpha\tilde{x}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-k_{1}\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)-\lambda_{P}P\left(t\right)\\
 & =-\lambda_{P}P\left(t\right)+\alpha\dot{\tilde{x}}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)+k_{1}\alpha\tilde{x}^{\top}\left(t\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\dot{\tilde{x}}^{\top}\left(t\right)\dot{f}\left(t\right)-k_{1}\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)\\
 & =-\lambda_{P}P\left(t\right)+\alpha\left(\dot{\tilde{x}}^{\top}\left(t\right)+k_{1}\tilde{x}^{\top}\left(t\right)\right)K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\left(\dot{\tilde{x}}^{\top}\left(t\right)+k_{1}\tilde{x}^{\top}\left(t\right)\right)\dot{f}\left(t\right)\\
 & =-\lambda_{P}P\left(t\right)+\alpha\left(\dot{\tilde{x}}\left(t\right)+k_{1}\tilde{x}\left(t\right)\right)^{\top}K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\left(\dot{\tilde{x}}\left(t\right)+k_{1}\tilde{x}\left(t\right)\right)^{\top}\dot{f}\left(t\right)\\
 & =-\lambda_{P}P\left(t\right)+\alpha\tilde{f}^{\top}K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)-\tilde{f}^{\top}\dot{f}\left(t\right)\\
 & =-\lambda_{P}P\left(t\right)-\tilde{f}^{\top}\left(\dot{f}\left(t\right)-\alpha K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\begin{alignat}{1}
\dot{P} & \stackrel{{\rm a.a.t.}}{\in}-\lambda_{P}P\left(t\right)-\tilde{f}^{\top}\left(\dot{f}\left(t\right)-\alpha K\left[\text{sgn}\right]\left(\tilde{x}\left(t\right)\right)\right).\label{eq:PDot-1}
