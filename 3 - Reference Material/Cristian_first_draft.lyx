\begin_layout Plain Layout
Proof of this property:
\end_layout

\begin_layout Plain Layout
Given any 
\begin_inset Formula $A\in\mathbb{R}^{p\times a}$
\end_inset

, 
\begin_inset Formula $B\in\mathbb{R}^{a\times r}$
\end_inset

, and 
\begin_inset Formula $C\in\mathbb{R}^{r\times s}$
\end_inset

, Let 
\begin_inset Formula $C=[c_{1},c_{2},\ldots,c_{s}]$
\end_inset

 and 
\begin_inset Formula $B=[b_{1},b_{2},\ldots,b_{r}]$
\end_inset

.
 Then, the 
\begin_inset Formula $k^{\text{th}}$
\end_inset

 column of 
\begin_inset Formula $ABC$
\end_inset

 is 
\begin_inset Formula 
\begin{align*}
(ABC)_{:,k} & =ABc_{k}\\
 & =A\sum_{i=1}^{r}b_{i}c_{i,k}\\
 & =\sum_{i=1}^{r}c_{i,k}Ab_{i}\\
 & =[c_{1,k}A,c_{2,k}A,\ldots,c_{r,k}A]\left[\begin{array}{c}
b_{1}\\
b_{2}\\
\vdots\\
b_{r}
\end{array}\right]\\
 & =\left([c_{1,k},c_{2,k},\ldots,c_{r,k}]\otimes A\right)\text{vec}B\\
 & =\left(c_{k}^{\top}\otimes A\right)\text{vec}B
\end{align*}

\end_inset

Stacking the columns together,
\begin_inset Formula 
\begin{align*}
{\rm vec}(ABC) & =\left[\begin{array}{c}
(ABC)_{:,k}\\
(ABC)_{:,k}\\
\vdots\\
(ABC)_{:,s}
\end{array}\right]\\
 & =\left[\begin{array}{c}
\left(c_{1}^{\top}\otimes A\right)\text{vec}B\\
\left(c_{2}^{\top}\otimes A\right)\text{vec}B\\
\vdots\\
\left(c_{s}^{\top}\otimes A\right)\text{vec}B
\end{array}\right]\\
 & =(C^{\top}\otimes A){\rm vec}(B).
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{eqnarray}
\frac{\partial}{\partial\mathrm{vec}\left(B\right)}\mathrm{vec}\left(ABC\right) & = & \left(C^{\top}\otimes A\right).\label{eq:vec_diff_prop}
\end{eqnarray}

\end_inset


