\begin_layout Standard

\color red
Since the universal approximation property of the ResNet holds only on the
 compact domain 
\begin_inset Formula $\Omega$
\end_inset

, the subsequent stability analysis requires ensuring 
\begin_inset Formula $q_{d}\in\Omega$
\end_inset

.
 This is achieved by establishing a stability result which constrains the
 solution 
\begin_inset Formula $z$
\end_inset

 to a compact domain.
 Consider the Lyapunov function candidate 
\begin_inset Formula $V:\mathbb{R}^{\varphi}\to\mathbb{R}_{\geq0}$
\end_inset

 defined as
\begin_inset Formula 
\begin{equation}
V\left(z\right)\triangleq\frac{1}{2}z^{\top}Pz,\label{eq:Lyapunov}
\end{equation}

\end_inset

where 
\begin_inset Formula $P\triangleq\text{blkdiag}\left\{ I_{2n},\Gamma^{-1}\right\} \in\mathbb{R}^{\varphi\times\varphi}$
\end_inset

.
 By the Rayleigh quotient, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Lyapunov"

\end_inset

 satisfies
\begin_inset Formula 
\begin{equation}
\frac{1}{2}\lambda_{1}\left\Vert z\right\Vert ^{2}\leq V\left(z\right)\leq\frac{1}{2}\lambda_{\varphi}\left\Vert z\right\Vert ^{2},\label{eq: RQ}
\end{equation}

\end_inset

where 
\begin_inset Formula $\lambda_{1}\triangleq\lambda_{\min}\left\{ P\right\} =\min\left\{ 1,\lambda_{\min}\left\{ \Gamma^{-1}\right\} \right\} $
\end_inset

 and 
\begin_inset Formula $\lambda_{\varphi}\triangleq\lambda_{\max}\left\{ P\right\} =\max\left\{ 1,\lambda_{\max}\left\{ \Gamma^{-1}\right\} \right\} $
\end_inset

.
 Based on the subsequent analysis, define 
\begin_inset Formula $\delta\triangleq\frac{3\left(\overline{\omega}+\overline{\varepsilon}\right)^{2}}{4k_{2}}+\frac{k_{3}\overline{\Theta}^{2}}{2}$
\end_inset

 and 
\begin_inset Formula $k_{\min}\triangleq\min\left\{ k_{1},\frac{1}{3}k_{2},\frac{1}{2}k_{3}\right\} $
\end_inset

.
 Furthermore, let 
\begin_inset Formula $\rho:\mathbb{R}_{\geq0}\to\mathbb{R}_{\geq0}$
\end_inset

 denote a strictly increasing function that is subsequently defined, and
 define 
\begin_inset Formula $\overline{\rho}\left(\cdot\right)\triangleq\rho\left(\cdot\right)-\rho\left(0\right)$
\end_inset

, where 
\begin_inset Formula $\overline{\rho}$
\end_inset

 is strictly increasing and invertible.
 The region to which the state trajectory is constrained is defined as
\begin_inset Formula 
\begin{equation}
\mathcal{D}\triangleq\left\{ \iota\in\mathbb{R}^{\varphi}:\left\Vert \iota\right\Vert \leq\overline{\rho}^{-1}\left(k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right)\right)\right\} ,\label{eq:state space}
\end{equation}

\end_inset

where 
\begin_inset Formula $\lambda_{V}\in\mathbb{R}_{>0}$
\end_inset

 is a user-defined rate of convergence parameter.
 The compact domain 
\begin_inset Formula $\Omega\subset\mathbb{R}^{4n}$
\end_inset

 over which the universal approximation property must hold is selected as
\begin_inset Formula 
\begin{equation}
\begin{aligned}\Omega & \triangleq\left\{ \iota\in\mathbb{R}^{4n}\right.:\left\Vert \iota\right\Vert \leq2\left(\overline{q}_{d}+\overline{\dot{q}}_{d}\right)\\
 & +\left(k_{1}+2\right)\overline{\rho}^{-1}\left.\left(k_{2}\left(k_{\min}-\lambda_{V}\right)-\rho\left(0\right)\right)\right\} .
\end{aligned}
\label{eq:OmegaSet}
\end{equation}

\end_inset

For the dynamical system described by 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:IVP"

