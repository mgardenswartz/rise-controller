\begin_layout Plain Layout
Let 
\begin_inset Formula $\varphi_{i,j-1}\left(v\right)\triangleq\left[\begin{array}{cccc}
\left(\varphi_{i,j-1}\left(v\right)\right)_{1} & \left(\varphi_{i,j-1}\left(v\right)\right)_{2} & \cdots & \left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\end{array}\right]^{\top}\in\mathbb{R}^{L_{i,j}}$
\end_inset

 and 
\begin_inset Formula $\phi_{i,j}:\mathbb{R}^{L_{i,j}}\to\mathbb{R}^{L_{i,j}^{a}}$
\end_inset

, with
\begin_inset Formula 
\[
\phi_{i,j}\left(\varphi_{i,j-1}\left(v\right)\right)=\left[\begin{array}{c}
\varsigma_{1}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{1}\right)\\
\varsigma_{2}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{2}\right)\\
\vdots\\
\varsigma_{L_{i,j}}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\right)\\
1.0
\end{array}\right]
\]

\end_inset

Then 
\begin_inset Formula 
\begin{align*}
\frac{\partial\phi_{i,j}\left(\varphi_{i,j-1}\left(v\right)\right)}{\partial\varphi_{i,j-1}\left(v\right)} & =\frac{\partial}{\partial\varphi_{i,j-1}\left(v\right)}\left[\begin{array}{c}
\varsigma_{1}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{1}\right)\\
\varsigma_{2}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{2}\right)\\
\vdots\\
\varsigma_{L_{i,j}}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\right)\\
1.0
\end{array}\right]\\
 & =\left[\begin{array}{c}
\frac{\partial}{\partial\left[\begin{array}{cccc}
\left(\varphi_{i,j-1}\left(v\right)\right)_{1} & \left(\varphi_{i,j-1}\left(v\right)\right)_{2} & \cdots & \left(\varphi_{i,j-1}\left(v\right)\right)_{L_{i,j}}\end{array}\right]^{\top}}\varsigma_{1}\left(\left(\varphi_{i,j-1}\left(v\right)\right)_{1}\right)\\
\frac{\partial}{\partial\left[\begin{array}{cccc}
