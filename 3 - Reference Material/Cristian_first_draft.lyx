\begin_layout Subsection
Stability Analysis
\end_layout

\begin_layout Standard
Let 
\begin_inset Formula $z\in\mathbb{R}^{\varphi}$
\end_inset

 denote the concatenated state vector 
\begin_inset Formula $z\triangleq\left[\begin{array}{cccc}
e^{\top} & r^{\top} & \tilde{r}^{\top} & s_{1}^{\top}\end{array}\right]^{\top}$
\end_inset

, where 
\begin_inset Formula $\varphi\triangleq4n$
\end_inset

.
 The evolution of 
\begin_inset Formula $z$
\end_inset

 is governed by the initial value problem
\begin_inset Formula 
\begin{equation}
\dot{z}={\tt f}\left(z\right),\ z\left(t_{0}\right)=z_{0},\label{eq:IVP}
\end{equation}

\end_inset

where 
\begin_inset Formula $t_{0}\geq0$
\end_inset

 is the initial time and 
\begin_inset Formula $z_{0}\in\mathbb{R}^{\varphi}$
\end_inset

 is the initial state.
 Using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Tracking Error"

\end_inset

, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rDot-1"

\end_inset

, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rTildeDot"

\end_inset

, and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:sDot"

\end_inset

, the vector field 
\begin_inset Formula ${\tt f}:\mathbb{R}^{\varphi}\times\mathbb{R}_{\geq0}\to\mathbb{R}^{\varphi}$
\end_inset

 is defined as
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{V} & =e^{\top}\dot{e}+r^{\top}\dot{r}+\tilde{r}^{\top}\dot{\tilde{r}}+s_{1}^{\top}\dot{s}_{1}\\
 & =e^{\top}\left(-k_{1}e+r\right)+r^{\top}\left(\varepsilon\left(q_{d}\right)-\alpha_{1}\text{sgn}\left(e\right)-k_{2}r-e+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)\right)+\tilde{r}^{\top}\left(\varepsilon\left(q_{d}\right)-\alpha_{2}\text{sgn}\left(s_{1}\right)-k_{3}\tilde{r}-s_{1}+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)\right)+s_{1}^{\top}\left(-k_{1}s_{1}+\tilde{r}\right)\\
 & =-k_{1}e^{\top}e+e^{\top}r-k_{1}s_{1}^{\top}s_{1}+s_{1}^{\top}\tilde{r}+r^{\top}-k_{2}r-e\\
 & +r^{\top}\left(\varepsilon\left(q_{d}\right)+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)-\alpha_{1}\text{sgn}\left(e\right)\right)\\
 & +\tilde{r}^{\top}\left(-k_{3}\tilde{r}-s_{1}\right)+\tilde{r}^{\top}\left(\varepsilon\left(q_{d}\right)+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)-\alpha_{2}\text{sgn}\left(s_{1}\right)\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
{\tt f}\left(z\right)=\left[\begin{array}{c}
-k_{1}e+r\\
\varepsilon\left(q_{d}\right)-\alpha_{1}\text{sgn}\left(e\right)-k_{2}r-e+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)\\
\varepsilon\left(q_{d}\right)-\alpha_{2}\text{sgn}\left(s_{1}\right)-k_{3}\tilde{r}-s_{1}+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)\\
-k_{1}s_{1}+\tilde{r}
\end{array}\right].\label{eq:CLES}
\end{equation}

\end_inset

The following section provides a Lyapunov-based stability analysis to provide
 exponential tracking error convergence guarantees with the developed controller.
 Some supporting lemmas are first presented to facilitate the subsequent
 analysis.
\end_layout

\begin_layout Lemma
\begin_inset CommandInset label
LatexCommand label
name "Hb bounds"

\end_inset

There exist known constants 
\begin_inset Formula $\overline{\varepsilon},\overline{\dot{\varepsilon}}\in\mathbb{R}_{>0}$
\end_inset

 such that 
\begin_inset Formula $\sup_{q_{d}\in\Omega}\left\Vert \varepsilon\left(q_{d}\right)\right\Vert \leq\overline{\varepsilon}$
\end_inset

 and 
\begin_inset Formula $\sup_{q_{d}\in\Omega}\left\Vert \frac{{\rm d}}{{\rm d}t}\varepsilon\left(q_{d}\right)\right\Vert \leq\overline{\dot{\varepsilon}}$
\end_inset

.
\begin_inset Foot
status collapsed

\begin_layout Plain Layout
If the uncertainty bound 
\begin_inset Formula $\overline{\dot{\varepsilon}}$
\end_inset

 is unknown, adaptive RISE methods (e.g., 
\begin_inset CommandInset citation
LatexCommand cite
key "Bidikli.Tatlicioglu.ea2014"
literal "false"

\end_inset

) can estimate 
\begin_inset Formula $\overline{\dot{\varepsilon}}$
\end_inset

 in-the-loop.
\end_layout

\end_inset


\end_layout

\begin_layout Proof
By Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "targetbounds"

\end_inset

, because 
\begin_inset Formula $\Omega$
\end_inset

 is compact and 
\begin_inset Formula $\varepsilon$
\end_inset

 is continuous, the Extreme-Value Theorem guarantees that 
\begin_inset Formula $\left\Vert \varepsilon\left(q_{d}\right)\right\Vert $
\end_inset

 attains a maximum on 
\begin_inset Formula $\Omega$
\end_inset

.
 Defining 
\begin_inset Formula $\overline{\varepsilon}\triangleq\max_{q_{d}\in\Omega}\left\Vert \varepsilon\left(q_{d}\right)\right\Vert <\infty$
\end_inset

 gives 
\begin_inset Formula $\sup_{q_{d}\in\Omega}\left\Vert \varepsilon\left(q_{d}\right)\right\Vert \leq\overline{\varepsilon}$
\end_inset

.
 Furthermore, since 
\begin_inset Formula $\varepsilon$
\end_inset

 is continuously differentiable, its Jacobian 
\begin_inset Formula $J_{\varepsilon}\left(q_{d}\right)\triangleq\frac{\partial}{\partial q_{d}}\varepsilon$
\end_inset

 is continuous on 
\begin_inset Formula $\Omega$
\end_inset

 and is therefore bounded.
 Define 
\begin_inset Formula $\overline{J}_{\varepsilon}\triangleq\max_{q_{d}\in\Omega}\left\Vert \overline{J}_{\varepsilon}\left(q_{d}\right)\right\Vert <\infty$
\end_inset

.
 For all 
\begin_inset Formula $t\geq0$
\end_inset

, the chain rule yields 
\begin_inset Formula $\frac{{\rm d}}{{\rm d}t}\varepsilon\left(q_{d}\left(t\right)\right)=J_{\varepsilon}\left(q_{d}\left(t\right)\right)\dot{q}_{d}\left(t\right)$
\end_inset

, which implies that 
\begin_inset Formula $\left\Vert \frac{{\rm d}}{{\rm d}t}\varepsilon\left(q_{d}\left(t\right)\right)\right\Vert \leq\left\Vert J_{\varepsilon}\left(q_{d}\left(t\right)\right)\right\Vert \left\Vert \dot{q}_{d}\left(t\right)\right\Vert \leq\overline{J}_{\varepsilon}\overline{\dot{q}}_{d}$
\end_inset

.
 Defining 
\begin_inset Formula $\overline{\dot{\varepsilon}}\triangleq\overline{J}_{\varepsilon}\overline{\dot{q}}_{d}<\infty$
\end_inset

 gives 
\begin_inset Formula $\sup_{q_{d}\in\Omega}\left\Vert \frac{{\rm d}}{{\rm d}t}\varepsilon\left(q_{d}\right)\right\Vert \leq\overline{\dot{\varepsilon}}$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Lemma
\begin_inset CommandInset label
LatexCommand label
name "rho function"

\end_inset


\begin_inset CommandInset citation
LatexCommand cite
after "Lemma 5"
key "Kamalapurkar.Rosenfeld.ea2014"
literal "false"

\end_inset

 There exists a strictly increasing function 
\begin_inset Formula $\rho:\left[0,\infty\right)\to\left[0,\infty\right)$
\end_inset

 such that 
\begin_inset Formula $\left\Vert \widetilde{N}\right\Vert \leq\rho\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert $
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Separator plain
\end_inset


\end_layout

\begin_layout Standard

\color red
To establish exponential stability for the initial value problem in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:IVP"

\end_inset

 a 
\begin_inset Formula $P$
\end_inset

-function is introduced.
 This function is used to develop a strict Lyapunov function and is designed
 to be non-negative under specific gain conditions.
 The 
\begin_inset Formula $P$
\end_inset

-function 
\begin_inset Formula $P:{\color{red}\mathcal{I}}\to\mathbb{R}_{\geq0}$
\end_inset

 is designed as
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Before proceeding, recall the Leibniz rule:
\begin_inset Formula 
\begin{eqnarray*}
\frac{{\rm d}}{{\rm d}x}\left(\int_{a(x)}^{b(x)}f(x,t){\rm d}t\right) & = & f\left(x,b(x)\right)\frac{{\rm d}b(x)}{{\rm d}x}-f\left(x,a(x)\right)\frac{{\rm d}a(x)}{{\rm d}x}+\int_{a(x)}^{b(x)}\frac{\partial}{\partial x}f(x,t){\rm d}t
\end{eqnarray*}

\end_inset

Thus, for any given 
\begin_inset Formula $\rho:[t_{0},\infty)\to\mathbb{R}$
\end_inset

, the function 
\begin_inset Formula $\mathrm{e}^{-\lambda_{P}t}$
\end_inset

 satisfies
\begin_inset Formula 
\begin{align*}
\frac{{\rm d}}{{\rm d}t}\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right) & =\frac{{\rm d}}{{\rm d}t}\left(\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}\rho(\tau){\rm d}\tau\right),\\
 & =\mathrm{e}^{-\lambda_{P}(t-t)}\rho(t)\frac{{\rm d}t}{{\rm d}t}-\mathrm{e}^{-\lambda_{P}(t-t_{0})}\rho(t_{0})\frac{{\rm d}t_{0}}{{\rm d}t}+\int_{t_{0}}^{t}\frac{\partial}{\partial t}\left(\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau)\right){\rm d}\tau\\
 & =e^{0}\rho(t)-0-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau){\rm d}\tau\\
 & =\rho(t)-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}\rho(\tau){\rm d}t,\\
 & =-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\rho+\rho.
\end{align*}

\end_inset

Assume 
\begin_inset Formula 
\[
P=k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}+\mathrm{e}^{-\lambda_{P}t}*\left(r_{1}^{\top}\mathcal{H}^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}\right)\right)
\]

\end_inset

Then 
\begin_inset Formula 
\begin{align*}
\frac{{\rm d}}{{\rm d}t}P & =\frac{{\rm d}}{{\rm d}t}\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}+\mathrm{e}^{-\lambda_{P}t}*\left(r_{1}^{\top}\mathcal{H}^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}\right)\right)\right)\\
 & =\frac{{\rm d}}{{\rm d}t}\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-\left(\mathcal{H}r_{1}\right)^{\top}h_{B}+\mathrm{e}^{-\lambda_{P}t}*\left(\left(\mathcal{H}r_{1}\right)^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-\left(\mathcal{H}r_{1}\right)^{\top}h_{B}\right)\right)\right)\\
 & =\frac{{\rm d}}{{\rm d}t}\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}+\mathrm{e}^{-\lambda_{P}t}*\left(\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\right)\right)\\
 & =k_{4}\frac{{\rm d}}{{\rm d}t}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\frac{{\rm d}}{{\rm d}t}\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}+\frac{{\rm d}}{{\rm d}t}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\right)\\
 & =k_{4}(\ddot{\eta}+k_{1}\dot{\eta})^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}h_{B}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}+\frac{{\rm d}}{{\rm d}t}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\right)\\
 & =k_{4}(\ddot{\eta}+k_{1}\dot{\eta})^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}h_{B}-\cancel{\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}}-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\right)\\
 & +\cancel{\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\\
 & =k_{4}(\ddot{\eta}+k_{1}\dot{\eta})^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}h_{B}-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\right)\\
 & +(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\\
 & =k_{4}(\ddot{\eta}+k_{1}\dot{\eta})^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}h_{B}-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\right)\\
 & +k_{2}\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)-\lambda_{P}\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\\
 & =k_{4}(\ddot{\eta}+k_{1}\dot{\eta})^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}h_{B}+k_{2}\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\\
 & -\lambda_{P}\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\right)\\
 & =k_{4}(\ddot{\eta}+k_{1}\dot{\eta})^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}h_{B}+k_{2}\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\\
 & -\lambda_{P}\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}+\mathrm{e}^{-\lambda_{P}t}*\left(\left(\dot{\eta}+k_{1}\eta\right)^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)\right)\right)\\
 & =k_{4}(\ddot{\eta}+k_{1}\dot{\eta})^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}h_{B}+k_{2}\left(k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\right)-\lambda_{P}P\\
 & =k_{4}(\ddot{\eta}+k_{1}\dot{\eta})^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}h_{B}+k_{2}k_{4}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}-k_{2}\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}-\lambda_{P}P\\
 & =k_{4}(\ddot{\eta}+k_{1}\dot{\eta})^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}h_{B}+k_{2}k_{4}(\dot{\eta}+k_{1}\eta)^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-k_{2}\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}-\lambda_{P}P\\
 & =-\lambda_{P}P+k_{4}(\ddot{\eta}+k_{1}\dot{\eta})^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)+k_{2}k_{4}(\dot{\eta}+k_{1}\eta)^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}h_{B}-k_{2}\left(\dot{\eta}+k_{1}\eta\right)^{\top}h_{B}\\
 & =-\lambda_{P}P+k_{4}\left((\ddot{\eta}+k_{1}\dot{\eta})^{\top}+k_{2}(\dot{\eta}+k_{1}\eta)^{\top}\right)\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}+k_{2}\left(\dot{\eta}+k_{1}\eta\right)^{\top}\right)h_{B}\\
 & =-\lambda_{P}P+k_{4}\left(\ddot{\eta}+k_{1}\dot{\eta}+k_{2}(\dot{\eta}+k_{1}\eta)\right)^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}+k_{2}(\dot{\eta}+k_{1}\eta)\right)^{\top}h_{B}\\
 & =-\lambda_{P}P+k_{4}\left(\ddot{\eta}+k_{1}\dot{\eta}+k_{2}\dot{\eta}+k_{1}k_{2}\eta\right)^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+k_{1}\dot{\eta}+k_{2}\dot{\eta}+k_{1}k_{2}\eta\right)^{\top}h_{B}\\
 & =-\lambda_{P}P+k_{4}\left(\ddot{\eta}+(k_{1}+k_{2})\dot{\eta}+k_{1}k_{2}\eta\right)^{\top}\text{sgn}(\dot{\eta}+k_{1}\eta)-\left(\ddot{\eta}+(k_{1}+k_{2})\dot{\eta}+k_{1}k_{2}\eta\right)^{\top}h_{B}\\
 & =-\lambda_{P}P+k_{4}\left(\mathcal{H}r_{2}\right)^{\top}\text{sgn}(\mathcal{H}r_{1})-\left(\mathcal{H}r_{2}\right)^{\top}h_{B}\\
 & =-\lambda_{P}P-\left(\mathcal{H}r_{2}\right)^{\top}h_{B}+k_{4}\left(\mathcal{H}r_{2}\right)^{\top}\text{sgn}(\mathcal{H}r_{1})\\
 & =-\lambda_{P}P-\left(\mathcal{H}r_{2}\right)^{\top}\left(h_{B}-k_{4}\text{sgn}(\mathcal{H}r_{1})\right)\\
 & =-\lambda_{P}P-r_{2}^{\top}\mathcal{H}^{\top}\left(h_{B}-k_{4}\text{sgn}(\mathcal{H}r_{1})\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{align}
P & \triangleq k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}+\mathrm{e}^{-\lambda_{P}t}*r_{1}^{\top}\mathcal{H}^{\top}\dot{h}_{B}\nonumber \\
 & +\mathrm{e}^{-\lambda_{P}t}*\left(k_{4}\left(k_{2}-\lambda_{P}\right)\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-\left(k_{2}-\lambda_{P}\right)r_{1}^{\top}\mathcal{H}^{\top}h_{B}\right),\label{eq: P function}
\end{align}

\end_inset

where 
\begin_inset Formula $\lambda_{P}\in\mathbb{R}_{>0}$
\end_inset

 is a user-defined constant, and the symbol `
\begin_inset Formula $*$
\end_inset

' denotes the convolutional integral, defined for any given function 
\begin_inset Formula $\alpha\left(t\right):\mathcal{I}\to\mathbb{R}$
\end_inset

 as 
\begin_inset Formula $\mathrm{e}^{-\lambda_{P}t}*\alpha\left(t\right)=\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\alpha\left(t\right){\rm d}\tau$
\end_inset

.
 Using Leibniz's rule, the time derivative of a convolution integral satisfies
 
\begin_inset Formula $\frac{{\rm d}}{{\rm d}t}\left(\mathrm{e}^{-\lambda_{P}t}*\alpha\right)=\alpha\left(t\right)-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\alpha\left(\tau\right){\rm d}t$
\end_inset

 which simplifies to 
\begin_inset Formula $\frac{{\rm d}}{{\rm d}t}\left(\mathrm{e}^{-\lambda_{P}t}*\alpha\right)=\alpha\left(t\right)-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\alpha\left(t\right)$
\end_inset

.
 Using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: P function"

\end_inset

 and the definition of the convolutional integral yields
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
For initial conditions, 
\begin_inset Formula 
\begin{align*}
P(t_{0}) & =k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)+\mathrm{e}^{-\lambda_{P}t_{0}}*\left(r_{1}^{\top}(t_{0})\mathcal{H}^{\top}\dot{h}_{B}\left(q(t_{0}),t_{0}\right)+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)\right)\right)\\
 & =k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)+\mathrm{e}^{-\lambda_{P}t_{0}}*\underbrace{\left(r_{1}^{\top}(t_{0})\mathcal{H}^{\top}\dot{h}_{B}\left(q(t_{0}),t_{0}\right)+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)\right)\right)}_{\rho(t)}\\
 & =k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)+\mathrm{e}^{-\lambda_{P}t_{0}}*\rho(t)\\
 & =k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)+\int_{t_{0}}^{t_{0}}\mathrm{e}^{-\lambda_{P}(t-\tau)}\rho(t){\rm d}\tau\\
 & =k_{4}\left\Vert \mathcal{H}r_{1}(t_{0})\right\Vert _{1}-r_{1}^{\top}(t_{0})\mathcal{H}^{\top}h_{B}\left(q(t_{0}),t_{0}\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
P\left(t_{0}\right)=k_{4}\left\Vert \mathcal{H}r_{1}\left(t_{0}\right)\right\Vert _{1}-r_{1}^{\top}\left(t_{0}\right)\mathcal{H}^{\top}h_{B}\left(t_{0}\right).\label{eq:Pt_0}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard

\color red
Since 
\begin_inset Formula $t\mapsto\mathcal{H}r_{1}\left(t\right)$
\end_inset

 is absolutely continuous and 
\begin_inset Formula $\left\Vert \cdot\right\Vert _{1}$
\end_inset

 is globally Lipschitz, the mapping 
\begin_inset Formula $t\mapsto\left\Vert r_{1}\left(t\right)\right\Vert _{1}$
\end_inset

 is differentiable almost everywhere.
 By the chain rule from 
\begin_inset CommandInset citation
LatexCommand cite
after "Theorem 2.2"
key "Shevitz.Paden1994"
literal "false"

\end_inset

, the derivative of 
\begin_inset Formula $\left\Vert \mathcal{H}r_{1}\right\Vert _{1}$
\end_inset

 is given almost everywhere by 
\begin_inset Formula $\frac{{\rm d}}{{\rm d}t}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}=\frac{{\rm d}}{{\rm d}t}\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}\stackrel{{\rm a.e.}}{\in}\left(\ddot{\eta}+k_{1}\dot{\eta}\right)^{\top}K\left[\text{sgn}\right]\left(\dot{\eta}+k_{1}\eta\right)$
\end_inset

.
 By the definition of the 
\begin_inset Formula $L_{1}$
\end_inset

-norm, 
\begin_inset Formula $\left\Vert \dot{\eta}+k_{1}\eta\right\Vert _{1}=\left(\dot{\eta}+k_{1}\eta\right)^{\top}K\left[\text{sgn}\right]\left(\dot{\eta}+k_{1}\eta\right)$
\end_inset

.
 Using the definitions of the chain rule and the 
\begin_inset Formula $L_{1}$
\end_inset

-norm, taking the time-derivative of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: P function"

\end_inset

, using Leibniz's rule, and substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error Ensemble."

\end_inset

, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Auxiliary Tracking Error ensemble"

\end_inset

, and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: P function"

\end_inset

 into the resulting expression yields that 
\begin_inset Formula $t\mapsto P\left(t\right)$
\end_inset

 satisfies the differential inclusion
\end_layout

\begin_layout Standard

\color red
\begin_inset Formula 
\begin{alignat}{1}
\dot{P} & \stackrel{{\rm a.e.}}{\in}-\lambda_{P}P-r_{2}^{\top}\mathcal{H}^{\top}\left(h_{B}-k_{4}K\left[\text{sgn}\right]\left(\mathcal{H}r_{1}\right)\right).\label{eq:PDot}
