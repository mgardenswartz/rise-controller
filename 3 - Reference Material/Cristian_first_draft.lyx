\begin_layout Standard
The control design requires knowledge of the auxiliary tracking error 
\begin_inset Formula $r$
\end_inset

 defined previously.
 However, since 
\begin_inset Formula $r$
\end_inset

 depends on the unknown target dynamics through 
\begin_inset Formula $h\left(q_{d}\right)$
\end_inset

, it cannot be directly computed.
 To address this challenge, an estimate 
\begin_inset Formula $\hat{r}\in\mathbb{R}^{n}$
\end_inset

 of 
\begin_inset Formula $r$
\end_inset

 must be constructed.
 To enable the design of the state estimate, the filtered tracking error
 
\begin_inset Formula $s_{1}\in\mathbb{R}^{n}$
\end_inset

 is defined as
\begin_inset Formula 
\begin{equation}
s_{1}\triangleq e-\mu,\label{filtered tracking error}
\end{equation}

\end_inset

where the internal dynamic filter state 
\begin_inset Formula $\mu\in\mathbb{R}^{n}$
\end_inset

 evolves according to the first-order dynamics
\begin_inset Formula 
\begin{equation}
\dot{\mu}=-k_{1}\mu+\hat{r},\hspace{1em}\mu\left(t_{0}\right)=\mu_{0},\label{eq:mu}
\end{equation}

\end_inset

where 
\begin_inset Formula $\mu_{0}\in\mathbb{R}_{\geq0}$
\end_inset

.
 The estimation error 
\begin_inset Formula $\tilde{r}\in\mathbb{R}^{n}$
\end_inset

 between the true auxiliary tracking error and its estimate is defined as
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align}
\tilde{r} & \triangleq r-\hat{r}.\label{eq:Dynamic Filter}
\end{align}

\end_inset

Here, the state estimate 
\begin_inset Formula $\hat{r}\in\mathbb{R}^{n}$
\end_inset

 is defined as
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{\hat{r}} & =-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+k_{3}\tilde{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+k_{3}\left(r-\hat{r}\right)+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+k_{3}r-k_{3}\hat{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-e-\left(k_{2}-k_{3}\right)r-\alpha_{1}\text{sgn}\left(e\right)-k_{3}\hat{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-e-\left(k_{2}-k_{3}\right)\left(\dot{e}+k_{1}e\right)-\alpha_{1}\text{sgn}\left(e\right)-k_{3}\hat{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-e-\left(k_{2}-k_{3}\right)\dot{e}-k_{1}\left(k_{2}-k_{3}\right)e-\alpha_{1}\text{sgn}\left(e\right)-k_{3}\hat{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
 & =-\left(k_{2}-k_{3}\right)\dot{e}-\left(1+k_{1}\left(k_{2}-k_{3}\right)\right)e-\alpha_{1}\text{sgn}\left(e\right)-k_{3}\hat{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\\
\implies\int_{t_{0}}^{t}\frac{{\rm d}}{{\rm d}\tau}\hat{r}\left(\tau\right){\rm d}\tau & =\int_{t_{0}}^{t}\left(-\left(k_{2}-k_{3}\right)\dot{e}\left(\tau\right)-\left(1+k_{1}\left(k_{2}-k_{3}\right)\right)e\left(\tau\right)-\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)-k_{3}\hat{r}\left(\tau\right)+\alpha_{2}\text{sgn}\left(s_{1}\left(\tau\right)\right)+s_{1}\left(\tau\right)\right){\rm d}\tau\\
\implies\left.\hat{r}\left(\tau\right)\right|_{t_{0}}^{t} & =-\left(k_{2}-k_{3}\right)\int_{t_{0}}^{t}\frac{{\rm d}}{{\rm d}\tau}e\left(\tau\right){\rm d}\tau+\int_{t_{0}}^{t}\left(-\left(1+k_{1}\left(k_{2}-k_{3}\right)\right)e\left(\tau\right)-\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\alpha_{2}\text{sgn}\left(s_{1}\left(\tau\right)\right)-k_{3}\hat{r}\left(\tau\right)+s_{1}\left(\tau\right)\right){\rm d}\tau\\
\implies\hat{r}\left(t\right)-\hat{r}\left(t_{0}\right) & =-\left(k_{2}-k_{3}\right)\left(\left.e\left(\tau\right)\right|_{t_{0}}^{t}\right)+\int_{t_{0}}^{t}\left(-\left(1+k_{1}\left(k_{2}-k_{3}\right)\right)e\left(\tau\right)-\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\alpha_{2}\text{sgn}\left(s_{1}\left(\tau\right)\right)-k_{3}\hat{r}\left(\tau\right)+s_{1}\left(\tau\right)\right){\rm d}\tau\\
\implies\hat{r}\left(t\right) & =\hat{r}\left(t_{0}\right)-\left(k_{2}-k_{3}\right)\left(e\left(t\right)-e\left(t_{0}\right)\right)+\int_{t_{0}}^{t}\left(-\left(1+k_{1}\left(k_{2}-k_{3}\right)\right)e\left(\tau\right)-\alpha_{1}\text{sgn}\left(e\left(\tau\right)\right)+\alpha_{2}\text{sgn}\left(s_{1}\left(\tau\right)\right)-k_{3}\hat{r}\left(\tau\right)+s_{1}\left(\tau\right)\right){\rm d}\tau
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{align}
\hat{r} & =-\left(k_{2}+k_{3}\right)e\left(t\right)+\varsigma,\label{eq:rHat-1}
\end{align}

\end_inset

where 
\begin_inset Formula $\varsigma\in\mathbb{R}^{n}$
\end_inset

 is the generalized solution to
\begin_inset Formula 
\begin{equation}
\begin{aligned}\dot{\varsigma} & =s_{1}-\left(1+k_{1}\left(k_{2}+k_{3}\right)\right)e-k_{3}\hat{r}\\
 & +\alpha_{2}\text{sgn}\left(s_{1}\right)-\alpha_{1}\text{sgn}\left(e\right),\hspace{1em}\varsigma\left(t_{0}\right)=\varsigma_{0}.
\end{aligned}
\label{eq:u integrand-1}
\end{equation}

\end_inset

Here, 
\begin_inset Formula $k_{3},\alpha_{2}\in\mathbb{R}_{>0}$
\end_inset

 are constant control gains.
 Taking the time-derivative of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rHat-1"

\end_inset

 and using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:u integrand-1"

\end_inset

 yields
\begin_inset Formula 
\begin{equation}
\dot{\hat{r}}=-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+k_{3}\tilde{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1},\label{eq:rHat}
\end{equation}

\end_inset

Substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rDot-1"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:rHat"

\end_inset

 into the time-derivative of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Dynamic Filter"

\end_inset

 yields
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{\tilde{r}} & =-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+\varepsilon\left(q_{d}\right)-\left(-e-k_{2}r-\alpha_{1}\text{sgn}\left(e\right)+k_{3}\tilde{r}+\alpha_{2}\text{sgn}\left(s_{1}\right)+s_{1}\right)\\
 & =-\cancel{e}-\cancel{k_{2}r}-\cancel{\alpha_{1}\text{sgn}\left(e\right)}+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)+\varepsilon\left(q_{d}\right)+\cancel{e}-\cancel{k_{2}r}-k_{3}\tilde{r}+\cancel{\alpha_{1}\text{sgn}\left(e\right)}-\alpha_{2}\text{sgn}\left(s_{1}\right)-s_{1}\\
 & =\varepsilon\left(q_{d}\right)-\alpha_{2}\text{sgn}\left(s\right)-k_{3}\tilde{r}-s_{1}+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\dot{\tilde{r}}=\varepsilon\left(q_{d}\right)-\alpha_{2}\text{sgn}\left(s_{1}\right)-k_{3}\tilde{r}-s_{1}+\widetilde{N}\left(q_{d},\Theta^{\ast},\widehat{\Theta}\right).\label{eq:rTildeDot}
\end{equation}

\end_inset

Substituting 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:mu"

\end_inset

 into the time-derivative of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "filtered tracking error"

\end_inset

 and using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Dynamic Filter"

\end_inset

 yields
\begin_inset Note Note
status open

\begin_layout Plain Layout
\begin_inset Formula 
\begin{align*}
\dot{s} & =\dot{e}-\dot{\mu}\\
 & =r-k_{1}e-\left(-k_{1}\mu+\hat{r}\right)\\
 & =r-k_{1}e+k_{1}\mu-\hat{r}\\
 & =\tilde{r}-k_{1}\left(e-\mu\right)\\
 & =\tilde{r}-k_{1}s
\end{align*}

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{equation}
\dot{s}_{1}=\tilde{r}-k_{1}s_{1}.\label{eq:sDot}
\end{equation}

\end_inset


\end_layout

