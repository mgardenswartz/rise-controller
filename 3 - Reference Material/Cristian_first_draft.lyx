\begin_layout Proposition
\begin_inset CommandInset label
LatexCommand label
name "prop:Ppositive-1"

\end_inset

 Let the gain 
\begin_inset Formula $\alpha$
\end_inset

 satisfy the condition 
\begin_inset Formula $\alpha>\chi_{1}+\frac{\chi_{2}}{k_{1}-\lambda_{P}}$
\end_inset

 where the constant 
\begin_inset Formula $\lambda_{P}$
\end_inset

 is selected such that 
\begin_inset Formula $\lambda_{P}\in\left(0,k_{1}\right)$
\end_inset

, Then the auxiliary function 
\begin_inset Formula $P\left(t\right)$
\end_inset

 is non-negative for all 
\begin_inset Formula $t\geq t_{0}$
\end_inset

.
\end_layout

\begin_layout Proof
The proof proceeds by analyzing the two main components of the function
 
\begin_inset Formula $P\left(t\right)\triangleq\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)+\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)$
\end_inset

.
\end_layout

\begin_layout Proof
First, consider the term 
\begin_inset Formula $\alpha\left\Vert \tilde{x}\left(t\right)\right\Vert _{1}-\tilde{x}^{\top}\left(t\right)\dot{f}\left(t\right)$
\end_inset

.
 Applying the Hölder inequality followed by the bound on 
\begin_inset Formula $\dot{f}$
\end_inset

 from Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "dynamic bounds"

\end_inset

 yields 
\begin_inset Formula $\left|\tilde{x}^{\top}\dot{f}\right|\leq\left\Vert \tilde{x}\right\Vert _{1}\left\Vert \dot{f}\right\Vert _{\infty}\leq\left\Vert \tilde{x}\right\Vert _{1}\left\Vert \dot{f}\right\Vert _{2}\leq\chi_{1}\left\Vert \tilde{x}\right\Vert _{1}$
\end_inset

.
 This inequality implies a lower bound 
\begin_inset Formula $\alpha\left\Vert \tilde{x}\right\Vert _{1}-\tilde{x}^{\top}\dot{f}\geq\alpha\left\Vert \tilde{x}\right\Vert _{1}-\left|\tilde{x}^{\top}\dot{f}\right|\geq\left(\alpha-\chi_{1}\right)\left\Vert \tilde{x}\right\Vert _{1}\geq0.$
\end_inset

 The condition 
\begin_inset Formula $\alpha>\chi_{1}$
\end_inset

, ensures this first component is non-negative.
\end_layout

\begin_layout Proof
Next, consider the integrand 
\begin_inset Formula $\rho\left(t\right)=\tilde{x}^{\top}\ddot{f}+\left(k_{1}-\lambda_{P}\right)\left(\alpha\left\Vert \tilde{x}\right\Vert _{1}-\tilde{x}^{\top}\dot{f}\right)$
\end_inset

.
 Similar to the first term, applying the Hölder inequality followed by the
 bound on 
\begin_inset Formula $\ddot{f}$
\end_inset

 from Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "dynamic bounds"

\end_inset

 yields 
\begin_inset Formula $\rho\left(t\right)\geq-\chi_{2}\left\Vert \tilde{x}\right\Vert _{1}+\left(k_{1}-\lambda_{P}\right)\left(\alpha-\chi_{1}\right)\left\Vert \tilde{x}\right\Vert _{1}=\left(\left(k_{1}-\lambda_{P}\right)\left(\alpha-\chi_{1}\right)-\chi_{2}\right)\left\Vert \tilde{x}\right\Vert _{1}$
\end_inset

.
 The proposition's main condition, 
\begin_inset Formula $\alpha>\chi_{1}+\frac{\chi_{2}}{k_{1}-\lambda_{P}}$
\end_inset

, is equivalent to 
\begin_inset Formula $\left(k_{1}-\lambda_{P}\right)\left(\alpha-\chi_{1}\right)>\chi_{2}$
\end_inset

.
 This ensures that the integrand 
\begin_inset Formula $\rho\left(t\right)$
\end_inset

 is non-negative.
\end_layout

\begin_layout Proof
Since 
\begin_inset Formula $\rho\left(t\right)\geq0$
\end_inset

, the convolution term 
\begin_inset Formula $\left(\mathrm{e}^{-\lambda_{P}t}*\rho\right)\left(t\right)=\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}\left(t-\tau\right)}\rho\left(\tau\right){\rm d}\tau$
\end_inset

 is also non-negative.
 As 
\begin_inset Formula $P\left(t\right)$
\end_inset

 is the sum of two non-negative terms, it follows that 
\begin_inset Formula $P\left(t\right)\geq0$
\end_inset

 for all 
\begin_inset Formula $t\geq t_{0}$
\end_inset

.
\end_layout

