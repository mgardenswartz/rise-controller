A pre-activation design is used so that, before each block (except block
 
\begin_inset Formula $0$
\end_inset

), the output of the previous block is processed by an external activation
 function.
 Specifically, for each block 
\begin_inset Formula $i\in\left\{ 1,\ldots,b\right\} $
\end_inset

, define the pre-activation mapping 
\begin_inset Formula $\psi_{i}:\mathbb{R}^{L_{i,k_{i}+1}}\to\mathbb{R}^{L_{i,k_{i}+1}^{a}}$
\end_inset

 by 
\begin_inset Formula $\psi_{i}\left(\kappa_{i}\right)$
\end_inset

 
\begin_inset Formula $=$
\end_inset

 
\begin_inset Formula $\left[\varrho_{i,1}\left(\left(\kappa_{i}\right)_{1}\right)\right.$
\end_inset

 
\begin_inset Formula $\varrho_{i,2}\left(\left(\kappa_{i}\right)_{2}\right)$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\cdots\end{array}$
\end_inset

 
\begin_inset Formula $\varrho_{i,L_{i,k_{i}+1}}\left(\left(\kappa_{i}\right)_{L_{i,k_{i}+1}}\right)$
\end_inset

 
\begin_inset Formula $\left.1\right]^{\top}$
\end_inset

 
\begin_inset Formula $\in\mathbb{R}^{L_{i,k_{i}+1}^{a}}$
\end_inset

 where 
\begin_inset Formula $\left(\kappa_{i}\right)_{\ell}$
\end_inset

 denotes the 
\begin_inset Formula $\ell^{\text{th}}$
\end_inset

 component of 
\begin_inset Formula $\kappa_{i}$
\end_inset

, each 
\begin_inset Formula $\varrho_{i,j+1}:\mathbb{R}\to\mathbb{R}$
\end_inset

 denotes a 
\color red
smooth
\color inherit
 activation function, and 1 accounts for the bias term.
 The output of 
\begin_inset Formula $\psi_{i}$
\end_inset

 serves as the input to block 
\begin_inset Formula $i$
\end_inset

 and the residual connection is implemented by adding the current block
 output to the pre-activated output from the previous block.
 Hence, the ResNet recursion is defined by
\begin_inset Formula 
\begin{equation}
\kappa_{i+1}\triangleq\begin{cases}
\Phi_{0}\left(\kappa_{0}^{a},\theta_{0}\right), & i=0,\\
\kappa_{i}+\Phi_{i}\left(\psi_{i}\left(\kappa_{i}\right),\theta_{i}\right), & i\in\left\{ 1,\ldots,b\right\} ,
\end{cases}\label{eq:ResNet}
\end{equation}

\end_inset

with output 
\begin_inset Formula $y\in\mathbb{R}^{L_{\text{out}}}$
\end_inset

 and overall parameter vector 
\begin_inset Formula $\Theta\triangleq\left[\begin{array}{ccc}
\theta_{0}^{\top} & \cdots & \theta_{b}^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{{\tt p}}$
\end_inset

, with 
\begin_inset Formula ${\tt p}\triangleq\sum_{i=0}^{b}p_{i}$
\end_inset

, where 
\begin_inset Formula $\kappa_{0}^{a}\triangleq\left[\begin{array}{cc}
\kappa_{0}^{\top} & 1\end{array}\right]^{\top}\in\mathbb{R}^{L_{0,0}^{a}}$
\end_inset

 denotes the augmented input to block 
\begin_inset Formula $i=0$
\end_inset

.
 T herefore, the complete ResNet is represented as 
\begin_inset Formula $\Psi:\mathbb{R}^{L_{\text{in}}}\times\mathbb{R}^{{\tt p}}\to\mathbb{R}^{L_{\text{out}}}$
\end_inset

 expressed as 
\begin_inset Formula $\Psi\left(\kappa,\Theta\right)=\kappa_{b+1}$
\end_inset

.
\end_layout

\begin_layout Standard
The partial derivative of the ResNet with respect to the parameters is represent
ed as 
\begin_inset Formula $\frac{\partial}{\partial\Theta}\Psi\left(\kappa,\Theta\right)=\left[\begin{array}{ccc}
\frac{\partial}{\partial\theta_{0}}\Psi\left(\kappa,\Theta\right) & \cdots & \frac{\partial}{\partial\theta_{b}}\Psi\left(\kappa,\Theta\right)\end{array}\right]\in\mathbb{R}^{L_{\text{out}}\times{\tt p}}$
\end_inset

 and 
\begin_inset Formula $\frac{\partial}{\partial\theta_{i}}\Psi\left(\kappa,\Theta\right)=\left[\begin{array}{ccc}
\frac{\partial}{\partial{\rm vec}\left(V_{i,0}\right)}\Psi\left(\kappa,\Theta\right) & \cdots & \frac{\partial}{\partial{\rm vec}\left(V_{i,k_{i}}\right)}\Psi\left(\kappa,\Theta\right)\end{array}\right]\in\mathbb{R}^{L_{\text{out}}\times p_{i}}$
\end_inset

, where 
\begin_inset Formula $\frac{\partial}{\partial{\rm vec}\left(V_{i,j}\right)}\Psi\left(\kappa,\Theta\right)\in\mathbb{R}^{L_{\text{out}}\times L_{i,j}^{a}L_{i,j+1}}$
\end_inset

 for all 
\begin_inset Formula $j\in\left\{ 0,\ldots,k_{i}\right\} $
\end_inset

.
 Using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:DNN"

\end_inset

, 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:ResNet"

\end_inset

, and the property of the vectorization operator yields
\begin_inset Formula 
\begin{align*}
\frac{\partial\Psi}{\partial\mathrm{vec}\left(V_{i,j}\right)} & =\left(\stackrel{\curvearrowleft}{\stackrel[m=i+1]{b}{\prod}}\left(I_{L_{\text{out}}}+\left(\stackrel{\curvearrowleft}{\stackrel[\ell=1]{k_{m}}{\prod}}V_{m,\ell}^{\top}\frac{\partial\phi_{m,\ell}}{\partial\varphi_{m,\ell-1}}\right)V_{m,0}^{\top}\frac{\partial\psi_{m}}{\partial\kappa_{m}}\right)\right)\\
 & \hspace{1em}\cdot\left(\stackrel{\curvearrowleft}{\stackrel[\ell=j+1]{k_{i}}{\prod}}V_{i,\ell}^{\top}\frac{\partial\phi_{i,\ell}}{\partial\varphi_{i,\ell-1}}\right)\left(I_{L_{i,j+1}}\otimes\varkappa_{i,j}^{\top}\right),
\end{align*}

\end_inset

where 
\begin_inset Formula $\varkappa_{i,j}\triangleq\kappa_{0}^{a}$
\end_inset

 if 
\begin_inset Formula $i=0$
\end_inset

 and 
\begin_inset Formula $j=0$
\end_inset

, 
\begin_inset Formula $\phi_{0,j}\left(\varphi_{0,j-1}\left(\kappa_{0}^{a}\right)\right)$
\end_inset

 if 
\begin_inset Formula $i=0$
\end_inset

 and 
\begin_inset Formula $j>0$
\end_inset

, 
\begin_inset Formula $\psi_{i}\left(\kappa_{i}\right)$
\end_inset

 if 
\begin_inset Formula $i>0$
\end_inset

 and 
\begin_inset Formula $j=0$
\end_inset

, 
\begin_inset Formula $\phi_{i,j}\left(\varphi_{i,j-1}\left(\psi_{i}\left(\kappa_{i}\right)\right)\right)$
\end_inset

 if 
\begin_inset Formula $i>0$
\end_inset

 and 
\begin_inset Formula $j>0$
\end_inset

.
\end_layout

\begin_layout Standard
The Jacobian 
\begin_inset Formula $\frac{\partial\phi_{i,j}\left(\varphi_{i,j-1}\left(v\right)\right)}{\partial\varphi_{i,j-1}\left(v\right)}:\mathbb{R}^{L_{i,j}}\to\mathbb{R}^{L_{i,j}^{a}\times L_{i,j}}$
\end_inset

 of the activation function vector at the 
\begin_inset Formula $j^{\mathrm{th}}$
\end_inset

 layer is given by 
\begin_inset Formula $\frac{\partial\phi_{i,j}\left(\varphi_{i,j-1}\left(v\right)\right)}{\partial\varphi_{i,j-1}\left(v\right)}$
\end_inset

 
\begin_inset Formula $=$
\end_inset

 
\begin_inset Formula $\left[\text{diag}\left\{ \frac{{\rm d}\varsigma_{i,1}\left(\left(\varphi_{i,j-1}\right)_{1}\right)}{{\rm d}\left(\varphi_{i,j-1}\right)_{1}},\ldots,\frac{{\rm d}\varsigma_{i,L_{i,j}}\left(\left(\varphi_{i,j-1}\right)_{L_{i,j}}\right)}{{\rm d}\left(\varphi_{i,j-1}\right)_{L_{i,j}}}\right\} \right.$
\end_inset


\begin_inset Formula $\left.\mathbf{0}_{L_{i,j}}^{\top}\right]^{\top}$
\end_inset

.
 Similarly, the Jacobian 
\begin_inset Formula $\frac{\partial\psi_{m}\left(\kappa_{m}\right)}{\partial\kappa_{m}}:\mathbb{R}^{L_{\text{out}}}\to\mathbb{R}^{L_{\text{out}}^{a}\times L_{\text{out}}}$
\end_inset

 of the pre-activation function vector at block 
\begin_inset Formula $m$
\end_inset

 is given by 
\begin_inset Formula $\frac{\partial\psi_{m}\left(\kappa_{m}\right)}{\partial\kappa_{m}}$
\end_inset

 
\begin_inset Formula $=$
\end_inset

 
\begin_inset Formula $\left[\text{diag}\left\{ \frac{{\rm d}\varrho_{m,1}\left(\left(\kappa_{m}\right)_{1}\right)}{{\rm d}\left(\kappa_{m}\right)_{1}},\ldots,\frac{{\rm d}\varrho_{m,L_{\text{out}}}\left(\left(\kappa_{m}\right)_{L_{\text{out}}}\right)}{{\rm d}\left(\kappa_{m}\right)_{L_{\text{out}}}}\right\} \right.$
\end_inset


\begin_inset Formula $\left.\mathbf{0}_{L_{\text{out}}}^{\top}\right]^{\top}$
\end_inset

.
