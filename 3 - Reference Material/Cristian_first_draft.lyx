, and the solution exists for all 
\begin_inset Formula $t\in\mathbb{R}_{\geq t_{0}}$
\end_inset

 with 
\begin_inset Formula $z\left(t\right)\in\mathcal{D}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\geq t_{0}}$
\end_inset

.
\end_layout

\begin_layout Proof

\color red
Consequently, all trajectories with 
\begin_inset Formula $z\left(t_{0}\right)\in\mathcal{S}$
\end_inset

 satisfy 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:solution"

\end_inset

, for all 
\begin_inset Formula $t\in\mathbb{R}_{\geq t_{0}}$
\end_inset

.
 As 
\begin_inset Formula $t\to\infty$
\end_inset

, this bound converges to 
\begin_inset Formula $\left\Vert z\left(t\right)\right\Vert \leq\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}$
\end_inset

 which, by 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:equilibrium set"

\end_inset

, implies that the trajectory 
\begin_inset Formula $z\left(t\right)$
\end_inset

 converges to 
\begin_inset Formula $\mathcal{U}$
\end_inset

.
 Furthermore, since 
\begin_inset Formula $z\left(t\right)\in\mathcal{D}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\geq t_{0}}$
\end_inset

, it follows from 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:OmegaSet"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:kappaBounds"

\end_inset

 that 
\begin_inset Formula $q_{d}\left(t\right)\in\Omega$
\end_inset

 for all 
\begin_inset Formula $t\in\mathbb{R}_{\geq t_{0}}$
\end_inset

, ensuring that the universal approximation property of the ResNet expressed
 in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:UFAT"

\end_inset

 holds for all time.
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Consider 
\begin_inset Formula $z\in\mathcal{B}\subset\mathbb{R}^{\varphi}.$
\end_inset

 Then
\begin_inset Formula 
\[
\left\Vert z\right\Vert \leq R_{\mathcal{B}}
\]

\end_inset

To ensure 
\begin_inset Formula $z\left(t\right)\in\mathcal{S}$
\end_inset

 for some 
\begin_inset Formula $t$
\end_inset

.
 It is required that
\begin_inset Formula 
\[
\left\Vert z\right\Vert \leq\sqrt{\frac{\lambda_{1}}{\lambda_{\varphi}}}\rho^{-1}\left(k_{\min}-\lambda_{V}\right)-\sqrt{\frac{\delta}{\lambda_{V}}}.
\]

\end_inset

For 
\begin_inset Formula $\mathcal{B}\subset\mathcal{S}$
\end_inset

,
\begin_inset Formula 
\begin{align*}
R_{\mathcal{B}} & \leq\sqrt{\frac{\lambda_{1}}{\lambda_{\varphi}}}\rho^{-1}\left(k_{\min}-\lambda_{V}\right)-\sqrt{\frac{\delta}{\lambda_{V}}}\\
\implies R_{\mathcal{B}}+\sqrt{\frac{\delta}{\lambda_{V}}} & \leq\sqrt{\frac{\lambda_{1}}{\lambda_{\varphi}}}\rho^{-1}\left(k_{\min}-\lambda_{V}\right)\\
\implies\sqrt{\frac{\lambda_{\varphi}}{\lambda_{1}}}R_{\mathcal{B}}+\sqrt{\frac{\lambda_{\varphi}}{\lambda_{1}}}\sqrt{\frac{\delta}{\lambda_{V}}} & \leq\rho^{-1}\left(k_{\min}-\lambda_{V}\right)\\
\implies\rho\left(\sqrt{\frac{\lambda_{\varphi}}{\lambda_{1}}}R_{\mathcal{B}}+\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right) & \leq k_{\min}-\lambda_{V}\\
\implies k_{\min} & \geq\lambda_{V}+\rho\left(\sqrt{\frac{\lambda_{\varphi}}{\lambda_{1}}}R_{\mathcal{B}}+\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right)
\end{align*}

\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Proof

\color red
Because 
\begin_inset Formula $\lambda_{V}$
\end_inset

 is independent of the initial time 
\begin_inset Formula $t_{0}$
\end_inset

 or initial condition 
\begin_inset Formula $z\left(t_{0}\right)$
\end_inset

, the exponential convergence is uniform 
\begin_inset CommandInset citation
LatexCommand cite
key "Loria.Panteley2002"
literal "false"

\end_inset

.
 Additionally, the boundedness of 
\begin_inset Formula $\left\Vert z\left(t\right)\right\Vert $
\end_inset

 implies that 
\begin_inset Formula $\left\Vert e\left(t\right)\right\Vert $
\end_inset

, 
\begin_inset Formula $\left\Vert r\left(t\right)\right\Vert $
\end_inset

, and 
\begin_inset Formula $\left\Vert \widetilde{\Theta}\left(t\right)\right\Vert $
\end_inset

 are bounded for all 
\begin_inset Formula $t\in\mathbb{R}_{\geq t_{0}}$
\end_inset

.
 Therefore, since 
\begin_inset Formula $q_{d},\dot{q}_{d}\in\mathcal{L}_{\infty}\left(\mathbb{R}_{\geq0};\mathbb{R}^{n}\right)$
\end_inset

 by Assumption 
\begin_inset CommandInset ref
LatexCommand ref
reference "targetbounds"

\end_inset

, using 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:Tracking Error"

\end_inset

 and 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: Filtered Tracking Error"

\end_inset

 yields that 
\begin_inset Formula $q,\dot{q}\in\mathcal{L}_{\infty}\left(\mathbb{R}_{\geq0};\mathbb{R}^{n}\right)$
\end_inset

, implying that 
\begin_inset Formula $g^{+}\left(q,\dot{q},t\right)$
\end_inset

 is bounded.
 Following 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:kappaBounds"

\end_inset

 and the fact that 
\begin_inset Formula $z\in\mathcal{L}_{\infty}\left(\mathbb{R}_{\geq t_{0}};\mathbb{R}^{\varphi}\right)$
\end_inset

 yields that 
\begin_inset Formula $q_{d}\in\mathcal{L}_{\infty}\left(\mathbb{R}_{\geq t_{0}};\mathbb{R}^{4n}\right)$
\end_inset

.
 Due to the projection operator, 
\begin_inset Formula $\widehat{\Theta}\in\mathcal{L}_{\infty}\left(\mathbb{R}_{\geq t_{0}};\mathbb{R}^{{\tt p}}\right)$
\end_inset

.
 Since 
\begin_inset Formula $\left(q_{d},\widehat{\Theta}\right)\in\mathcal{L}_{\infty}\left(\mathbb{R}_{\geq0};\mathbb{R}^{4n}\times\mathbb{R}^{{\tt p}}\right)$
\end_inset

, 
\begin_inset Formula $\Psi\left(q_{d}\left(t\right),\widehat{\Theta}\left(t\right)\right)$
\end_inset

 is bounded.
 Thus, by 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:control input"

\end_inset

, 
\begin_inset Formula $u$
\end_inset

 is bounded.
\end_layout

