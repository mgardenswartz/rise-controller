To facilitate the inclusion of the 
\begin_inset Formula $P$
\end_inset

-function into the subsequent Lyapunov function candidate, 
\begin_inset Formula $P$
\end_inset

 must be designed to be non-negative under certain sufficient gain conditions.
\end_layout

\begin_layout Proposition

\color red
\begin_inset CommandInset label
LatexCommand label
name "prop:Ppositive"

\end_inset

 For the 
\begin_inset Formula $P$
\end_inset

-function defined as in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: P function"

\end_inset

, if 
\begin_inset Formula $k_{4}>\chi_{1}+\frac{\chi_{2}}{k_{2}-\lambda_{P}}$
\end_inset

 with 
\begin_inset Formula $\lambda_{P}\in\left(0,k_{2}\right)$
\end_inset

, then 
\begin_inset Formula $P\left(t\right)\geq0$
\end_inset

, for all 
\begin_inset Formula $t\in\mathcal{I}$
\end_inset

.
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
For gain conditions, we need 
\begin_inset Formula 
\[
k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}+\mathrm{e}^{-\lambda_{P}t}*\left(r_{1}^{\top}\mathcal{H}^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}\right)\right)\geq0
\]

\end_inset

which is true if and only if both
\begin_inset Formula 
\[
k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}\geq0
\]

\end_inset

and 
\begin_inset Formula 
\[
\mathrm{e}^{-\lambda_{P}t}*\left(r_{1}^{\top}\mathcal{H}^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}\right)\right)>0
\]

\end_inset

which is true if and only if 
\begin_inset Formula 
\begin{align*}
r_{1}^{\top}\mathcal{H}^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}\right) & \geq0\\
\implies0 & \leq r_{1}^{\top}\mathcal{H}^{\top}\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}\right)
\end{align*}

\end_inset

Lets use some dummy variables in the meantime.
 Find gain conditions on 
\begin_inset Formula $k_{2}$
\end_inset

 and 
\begin_inset Formula $k_{4}$
\end_inset

 so that
\begin_inset Formula 
\[
0\leq\alpha_{1}(t)\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\alpha_{2}(t)-\alpha_{1}(t)h_{B}\right)
\]

\end_inset

where 
\begin_inset Formula $\left\Vert h_{B}\right\Vert \leq\chi_{1}$
\end_inset

 and 
\begin_inset Formula $\left\Vert \dot{h}_{B}\right\Vert \leq\chi_{2}$
\end_inset

 and 
\begin_inset Formula $\alpha_{1},\alpha_{2}\in\mathbb{R}^{n}$
\end_inset

.
 We have 
\begin_inset Formula 
\begin{align*}
0 & \leq\alpha_{1}(t)\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\alpha_{2}(t)-\alpha_{1}(t)h_{B}\right)\\
 & \leq\left\Vert \alpha_{1}(t)\dot{h}_{B}+(k_{2}-\lambda_{P})\left(k_{4}\alpha_{2}(t)-\alpha_{1}(t)h_{B}\right)\right\Vert \\
 & \leq\left\Vert \alpha_{1}(t)\dot{h}_{B}\right\Vert +\left\Vert (k_{2}-\lambda_{P})\left(k_{4}\alpha_{2}(t)-\alpha_{1}(t)h_{B}\right)\right\Vert \\
 & \leq\left\Vert \alpha_{1}(t)\right\Vert \left\Vert \dot{h}_{B}\right\Vert +\left\Vert k_{2}-\lambda_{P}\right\Vert \left\Vert k_{4}\alpha_{2}(t)-\alpha_{1}(t)h_{B}\right\Vert \\
 & \leq\left\Vert \alpha_{1}(t)\right\Vert \chi_{2}+\left\Vert k_{2}-\lambda_{P}\right\Vert \left(k_{4}\left\Vert \alpha_{2}(t)\right\Vert +\left\Vert \alpha_{1}(t)h_{B}\right\Vert \right)\\
 & \leq\left\Vert \alpha_{1}(t)\right\Vert \chi_{2}+\left\Vert k_{2}-\lambda_{P}\right\Vert \left(k_{4}\left\Vert \alpha_{2}(t)\right\Vert +\left\Vert \alpha_{1}(t)\right\Vert \left\Vert h_{B}\right\Vert \right)\\
 & \leq\left\Vert \alpha_{1}(t)\right\Vert \chi_{2}+\left\Vert k_{2}-\lambda_{P}\right\Vert \left(k_{4}\left\Vert \alpha_{2}(t)\right\Vert +\left\Vert \alpha_{1}(t)\right\Vert \chi_{1}\right)\\
 & \leq\frac{\left\Vert \alpha_{1}(t)\right\Vert \chi_{2}}{\left\Vert k_{2}-\lambda_{P}\right\Vert }+k_{4}\left\Vert \alpha_{2}(t)\right\Vert +\left\Vert \alpha_{1}(t)\right\Vert \chi_{1}\\
 & \leq\frac{\left\Vert \alpha_{1}(t)\right\Vert \chi_{2}}{\left\Vert \alpha_{2}(t)\right\Vert \left\Vert k_{2}-\lambda_{P}\right\Vert }+k_{4}+\chi_{1}
\end{align*}

\end_inset

We need 
\begin_inset Formula $k_{2}>\lambda_{P}$
\end_inset

 and 
\begin_inset Formula 
\[
k_{4}>\chi_{1}+\frac{\left\Vert \alpha_{1}(t)\right\Vert }{\left\Vert \alpha_{2}(t)\right\Vert }\frac{\chi_{2}}{\left\Vert k_{2}-\lambda_{P}\right\Vert }
\]

\end_inset

We have 
\begin_inset Formula 
\begin{align*}
\frac{\left\Vert \alpha_{1}(t)\right\Vert }{\left\Vert \alpha_{2}(t)\right\Vert } & =\frac{\left\Vert \left(\mathcal{H}r_{1}\right)^{\top}\right\Vert }{\left\Vert \mathcal{H}r_{1}\right\Vert _{1}}\\
 & \leq1
\end{align*}

\end_inset

So 
\begin_inset Formula $k_{2}>\lambda_{P}$
\end_inset

 and 
\begin_inset Formula $k_{4}>\chi_{1}+\frac{\chi_{2}}{k_{2}-\lambda_{P}}$
\end_inset


\end_layout

\end_inset


\end_layout

\begin_layout Proof

\color red
By Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "Hb bounds"

\end_inset

, the 
\begin_inset Formula $k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}$
\end_inset

 term in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: P function"

\end_inset

 satisfies 
\begin_inset Formula $k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}\geq\left(k_{4}-\chi_{1}\right)\left\Vert \mathcal{H}r_{1}\right\Vert _{1}\geq0$
\end_inset

 by the Cauchy-Schwarz inequality and the condition 
\begin_inset Formula $k_{4}>\chi_{1}$
\end_inset

.
 The convolution integrand in 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq: P function"

\end_inset

 is bounded as 
\begin_inset Formula $r_{1}^{\top}\mathcal{H}^{\top}\dot{h}_{B}+\left(k_{2}-\lambda_{P}\right)\left(k_{4}\left\Vert \mathcal{H}r_{1}\right\Vert _{1}-r_{1}^{\top}\mathcal{H}^{\top}h_{B}\right)\geq\left\Vert \mathcal{H}r_{1}\right\Vert _{1}\left(\left(k_{2}-\lambda_{P}\right)\left(k_{4}-\chi_{1}\right)-\chi_{2}\right)$
\end_inset

.
 This expression is non-negative when 
\begin_inset Formula $\left(k_{2}-\lambda_{P}\right)\left(k_{4}-\chi_{1}\right)\geq\chi_{2}$
\end_inset

 which is equivalent to 
\begin_inset Formula $k_{4}\geq\chi_{1}+\frac{\chi_{2}}{k_{2}-\lambda_{P}}$
\end_inset

.
 Since 
\begin_inset Formula $k_{4}>\chi_{1}+\frac{\chi_{2}}{k_{2}-\lambda_{P}}$
\end_inset

 by assumption, the convolution integrand is positive, making the entire
 convolution positive.
 Therefore, 
\begin_inset Formula $P\left(t\right)\geq0$
\end_inset

, for all 
\begin_inset Formula $t\in\mathcal{I}$
\end_inset

.
\end_layout

