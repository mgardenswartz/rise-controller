\end_inset

,
\begin_inset Formula 
\begin{align*}
R_{\mathcal{B}} & \leq\sqrt{\frac{\lambda_{1}}{\lambda_{\varphi}}}\rho^{-1}\left(k_{\min}-\lambda_{V}\right)-\sqrt{\frac{\delta}{\lambda_{V}}}\\
\implies R_{\mathcal{B}}+\sqrt{\frac{\delta}{\lambda_{V}}} & \leq\sqrt{\frac{\lambda_{1}}{\lambda_{\varphi}}}\rho^{-1}\left(k_{\min}-\lambda_{V}\right)\\
\implies\sqrt{\frac{\lambda_{\varphi}}{\lambda_{1}}}R_{\mathcal{B}}+\sqrt{\frac{\lambda_{\varphi}}{\lambda_{1}}}\sqrt{\frac{\delta}{\lambda_{V}}} & \leq\rho^{-1}\left(k_{\min}-\lambda_{V}\right)\\
\implies\rho\left(\sqrt{\frac{\lambda_{\varphi}}{\lambda_{1}}}R_{\mathcal{B}}+\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right) & \leq k_{\min}-\lambda_{V}\\
\implies k_{\min} & \geq\lambda_{V}+\rho\left(\sqrt{\frac{\lambda_{\varphi}}{\lambda_{1}}}R_{\mathcal{B}}+\sqrt{\frac{\lambda_{\varphi}\delta}{\lambda_{1}\lambda_{V}}}\right)
\end{align*}

