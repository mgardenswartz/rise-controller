\begin_layout Standard
For each 
\begin_inset Formula $j\in\left\{ 0,1,\ldots,k_{i}\right\} $
\end_inset

 the matrix 
\begin_inset Formula $V_{i,j}\in\mathbb{R}^{L_{i,j}^{a}\times L_{i,j+1}}$
\end_inset

 contains the weights and biases; in particular, if a layer has 
\begin_inset Formula $n$
\end_inset

 (augmented) inputs and the subsequent layer has 
\begin_inset Formula $m$
\end_inset

 nodes, then 
\begin_inset Formula $V\in\mathbb{R}^{n\times m}$
\end_inset

 is constructed so that its 
\begin_inset Formula $\left(i,j\right)^{\text{th}}$
\end_inset

 entry represents the weight from the 
\begin_inset Formula $i^{\text{th}}$
\end_inset

 node of the input to the 
\begin_inset Formula $j^{\text{th}}$
\end_inset

 node of the output, with the last row corresponding to the bias terms.
 For the DNN architecture described by 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:DNN"

\end_inset

, the vector of DNN weights of the 
\begin_inset Formula $i^{\text{th}}$
\end_inset

 block is 
\begin_inset Formula $\theta_{i}\triangleq\left[\begin{array}{ccc}
\text{vec}\left(V_{i,0}\right)^{\top} & \cdots & \text{vec}\left(V_{i,k_{i}}\right)^{\top}\end{array}\right]^{\top}\in\mathbb{R}^{p_{i}}$
\end_inset

, where 
\begin_inset Formula $p_{i}\triangleq\sum_{j=0}^{k_{i}}L_{i,j}^{a}L_{i,j+1}$
\end_inset

, and 
\begin_inset Formula $\text{vec}\left(V_{i,j}\right)$
\end_inset

 denotes the vectorization of 
\begin_inset Formula $V_{i,j}$
\end_inset

 performed in column-major order (i.e., the columns are stacked sequentially
 to form a vector).
 The activation function 
\begin_inset Formula $\phi_{i,j}:\mathbb{R}^{L_{i,j}}\to\mathbb{R}^{L_{i,j}^{a}}$
\end_inset

 is given by 
\begin_inset Formula $\phi_{i,j}\left(\varphi_{i,j-1}\right)$
\end_inset

 
\begin_inset Formula $=$
\end_inset

 
\begin_inset Formula $\left[\varsigma_{i,1}\left(\left(\varphi_{i,j-1}\right)_{1}\right)\right.$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\varsigma_{i,2}\left(\left(\varphi_{i,j-1}\right)_{2}\right)\end{array}$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\cdots\end{array}$
\end_inset

 
\begin_inset Formula $\begin{array}{c}
\varsigma_{i,L_{i,j}}\left(\left(\varphi_{i,j-1}\right)_{L_{i,j}}\right)\end{array}$
\end_inset

 
\begin_inset Formula $\left.1\right]^{\top}$
\end_inset

 
\begin_inset Formula $\in\mathbb{R}^{L_{i,j}^{a}}$
\end_inset

 where 
\begin_inset Formula $\left(\varphi_{i,j-1}\right)_{\ell}$
\end_inset

 denotes the 
\begin_inset Formula $\ell^{\text{th}}$
\end_inset

 component of 
\begin_inset Formula $\varphi_{i,j-1}$
\end_inset

, each 
\begin_inset Formula $\varsigma_{i,j}:\mathbb{R}\to\mathbb{R}$
\end_inset

 denotes a smooth activation function, and 1 accounts for the bias term.
\end_layout

