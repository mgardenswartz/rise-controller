The right hand side (RHS) of (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:P_expand"
plural "false"
caps "false"
noprefix "false"

\end_inset

) is almost everywhere (a.e.) differentiable with respect to time, because
 every term on the RHS is absolutely continuous, including 
\begin_inset Formula $\left\Vert e\right\Vert _{1}$
\end_inset

, since 
\begin_inset Formula $\left\Vert \cdot\right\Vert _{1}$
\end_inset

 is globally Lipschitz and 
\begin_inset Formula $e$
\end_inset

 is absolutely continuous.
 The time-derivative of 
\begin_inset Formula $\left\Vert e\right\Vert _{1}$
\end_inset

, whenever it exists, is 
\begin_inset Formula $\dot{e}^{T}\textrm{sgn}(e)$
\end_inset

, using the chain rule.
 Therefore, taking the time-derivative of both the sides of (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:P_expand"
plural "false"
caps "false"
noprefix "false"

\end_inset

) at points where 
\begin_inset Formula $P$
\end_inset

 is differentiable yields
\begin_inset Formula 
\begin{align}
\dot{P} & \stackrel{a.e.}{=}\beta\dot{e}^{T}\textrm{sgn}(e)-\dot{e}^{T}N_{B}-e^{T}\dot{N}_{B}\nonumber \\
 & +\frac{d}{dt}(\mathrm{e}^{-\lambda_{P}t}*((\alpha-\lambda_{P})(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})+e^{T}\dot{N}_{B}))\nonumber \\
 & +\frac{d}{dt}\left(\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)\right).\label{eq:Pdoteval1}
\end{align}

\end_inset

Based on the Leibniz rule, for any given 
\begin_inset Formula $q:[t_{0},\infty)\to\mathbb{R}$
\end_inset

, the function 
\begin_inset Formula $\mathrm{e}^{-\lambda_{P}t}$
\end_inset

 satisfies 
\begin_inset Formula $\frac{d}{dt}\left(\mathrm{e}^{-\lambda_{P}t}*q\right)=\frac{d}{dt}\left(\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau)d\tau\right)=q(t)-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau)d\tau=-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*q+q$
\end_inset

.
 Additionally, 
\begin_inset Formula $L=\dot{e}^{T}N_{B}+\alpha e^{T}N_{B}-\beta\dot{e}^{T}\mathrm{sgn}\left(e\right)-\alpha\beta\left\Vert e\right\Vert _{1}-(\gamma_{4}+\rho_{2}(\left\Vert z\right\Vert ))\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}$
\end_inset

 is obtained after substituting (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:edot"
plural "false"
caps "false"
noprefix "false"

\end_inset

) into (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:L"
plural "false"
caps "false"
noprefix "false"

\end_inset

).
 Therefore, the expression for 
\begin_inset Formula $\dot{P}$
\end_inset

 in (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:Pdoteval1"
plural "false"
caps "false"
noprefix "false"

\end_inset

) can be rewritten as
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Given
\begin_inset Formula 
\begin{eqnarray*}
P & = & \beta\left\Vert e\right\Vert _{1}-e^{T}N_{B}(t)\\
 &  & +\mathrm{e}^{-\lambda_{P}t}*\left((\alpha-\lambda_{P})\left(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B}(t)\right)+e^{T}\dot{N}_{B}(t)\right)\\
 & {\color{blue}} & {\color{blue}+\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)},
\end{eqnarray*}

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
\dot{P} & = & \beta\dot{e}^{T}\textrm{sgn}(e)-\dot{e}^{T}N_{B}(t)-e^{T}\dot{N}_{B}(t)\\
 &  & +\frac{d}{dt}(\mathrm{e}^{-\lambda_{P}t}*((\alpha-\lambda_{P})(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})+e^{T}\dot{N}_{B}))\\
 &  & {\color{blue}+\frac{d}{dt}\left(\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)\right)}
\end{eqnarray*}

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
\frac{d}{dt}\left(\mathrm{e}^{-\lambda_{P}t}*q\right) & = & \frac{d}{dt}\left(\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau)d\tau\right)
\end{eqnarray*}

\end_inset


\end_layout

\begin_layout Plain Layout
Leibniz Rule says
\begin_inset Formula 
\begin{eqnarray*}
\frac{d}{dx}\left(\int_{a(x)}^{b(x)}f(x,t)dt\right) & = & f(x,b(x))\frac{db(x)}{dx}-f(x,a(x))\frac{da(x)}{dx}+\int_{a(x)}^{b(x)}\frac{\partial}{\partial x}f(x,t)dt
\end{eqnarray*}

\end_inset

Applying Leibniz Rule yields,
\begin_inset Formula 
\begin{eqnarray*}
\frac{d}{dt}\left(\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau)d\tau\right) & = & \mathrm{e}^{-\lambda_{P}(t-t)}q(t)\frac{dt}{dt}-\mathrm{e}^{-\lambda_{P}(t-t_{0})}q(t_{0})\frac{dt_{0}}{dt}+\int_{t_{0}}^{t}\frac{\partial}{\partial t}\left(\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau)\right)d\tau\\
 & = & \mathrm{e}^{0}q(t)1-0-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau)d\tau\\
 & = & q(t)-\lambda_{P}\int_{t_{0}}^{t}\mathrm{e}^{-\lambda_{P}(t-\tau)}q(\tau)d\tau\\
 & = & q(t)-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*q
\end{eqnarray*}

\end_inset

therefore the property 
\begin_inset Formula 
\[
\frac{d}{dt}\left(\mathrm{e}^{-\lambda_{P}t}*q\right)=q-\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*q
\]

\end_inset

Applying this property to 
\begin_inset Formula $\frac{d}{dt}(\mathrm{e}^{-\lambda_{P}t}*((\alpha-\lambda_{P})(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})+e^{T}\dot{N}_{B}))$
\end_inset

 and 
\begin_inset Formula $\frac{d}{dt}\left(\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)\right)$
\end_inset

 terms in 
\begin_inset Formula $\dot{P}$
\end_inset

 yields
\begin_inset Formula 
\begin{eqnarray*}
\dot{P} & = & \beta\dot{e}^{T}\textrm{sgn}(e)-\dot{e}^{T}N_{B}(t)-e^{T}\dot{N}_{B}(t)\\
 &  & +(\alpha-\lambda_{P})(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})+e^{T}\dot{N}_{B}\\
 &  & +\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(((\alpha-\lambda_{P})(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})+e^{T}\dot{N}_{B}\right)\\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)\\
 & = & \beta\dot{e}^{T}\textrm{sgn}(e)-\dot{e}^{T}N_{B}(t)-e^{T}\dot{N}_{B}(t)\\
 &  & +\alpha(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})-\lambda_{P}(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})\\
 &  & +e^{T}\dot{N}_{B}+\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(((\alpha-\lambda_{P})(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})+e^{T}\dot{N}_{B}\right)\\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)\\
 & = & \beta\dot{e}^{T}\textrm{sgn}(e)-\dot{e}^{T}N_{B}(t)-\cancel{e^{T}\dot{N}_{B}(t)}\\
 &  & +\alpha\beta\left\Vert e\right\Vert _{1}-\alpha e^{T}N_{B}-\lambda_{P}\beta\left\Vert e\right\Vert _{1}+\lambda_{P}e^{T}N_{B}\\
 &  & +\cancel{e^{T}\dot{N}_{B}}+\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(((\alpha-\lambda_{P})(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})+e^{T}\dot{N}_{B}\right)\\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)\\
 & = & \beta\dot{e}^{T}\textrm{sgn}(e)+\alpha\beta\left\Vert e\right\Vert _{1}\\
 &  & -\dot{e}^{T}N_{B}-\alpha e^{T}N_{B}\\
 &  & +\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\\
 &  & -\lambda_{P}\beta\left\Vert e\right\Vert _{1}+\lambda_{P}e^{T}N_{B}\\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(((\alpha-\lambda_{P})(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})+e^{T}\dot{N}_{B}\right)\\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)\\
 & = & \beta\left(\dot{e}+\alpha e\right)^{T}\textrm{sgn}(e)\\
 &  & -\left(\dot{e}+\alpha e\right)^{T}N_{B}\\
 &  & +\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\\
 &  & -\lambda_{P}\left(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B}\right)\\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(((\alpha-\lambda_{P})(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})+e^{T}\dot{N}_{B}\right)\\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)\\
 & = & \beta r^{T}\textrm{sgn}(e)-r^{T}N_{B}+\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}-\lambda_{P}P
\end{eqnarray*}

\end_inset

Recall 
\begin_inset Formula $L=r^{T}N_{B}(t)-r^{T}\beta\mathrm{sgn}\left(e\right){\color{blue}-\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}}$
\end_inset

.
 Therefore
\begin_inset Formula 
\[
P=-\lambda_{P}P-L.
\]

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{eqnarray}
\dot{P} & \stackrel{a.e.}{=} & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)\nonumber \\
 &  & -\lambda_{P}\mathrm{e}^{-\lambda_{P}t}*((\alpha-\lambda_{P})(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B})+e^{T}\dot{N}_{B})\nonumber \\
 &  & -\lambda_{P}\beta\left\Vert e\right\Vert _{1}+\lambda_{P}e^{T}N_{B}+\beta\dot{e}^{T}\textrm{sgn}(e)\nonumber \\
 &  & -\dot{e}^{T}N_{B}+\alpha\beta\left\Vert e\right\Vert _{1}-\alpha e^{T}N_{B}\nonumber \\
 &  & +\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\nonumber \\
 & = & -\lambda_{P}P-L.\label{eq:Pdoteval2}
\end{eqnarray}

\end_inset

Filippov's differential inclusion for (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:Pdot"
plural "false"
caps "false"
noprefix "false"

\end_inset

) is given by
\begin_inset Formula 
\begin{eqnarray}
\dot{P} & \in & -\lambda_{P}P-K\left[L\right].\label{eq:PFillipov}
\end{eqnarray}

\end_inset

To prove the uniqueness of the solution to (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:PFillipov"
plural "false"
caps "false"
noprefix "false"

\end_inset

), consider any two solutions with the same initial conditions, i.e., 
\begin_inset Formula $P_{1}$
\end_inset

 and 
\begin_inset Formula $P_{2}$
\end_inset

, with 
\begin_inset Formula $P_{1}(t_{0})=P_{2}(t_{0})$
\end_inset

, implying
\begin_inset Formula 
\begin{eqnarray}
\dot{P}_{1} & \stackrel{a.e.}{\in} & -\lambda_{P}P_{1}-K\left[L\right],\label{eq:P1dot}\\
\dot{P}_{2} & \stackrel{a.e.}{\in} & -\lambda_{P}P_{2}-K\left[L\right].\label{eq:P2dot}
\end{eqnarray}

\end_inset

Based on (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:L"
plural "false"
caps "false"
noprefix "false"

\end_inset

), 
\begin_inset Formula $t\mapsto K\left[L\right](\psi(t))$
\end_inset

 is set-valued only when there exists some 
\begin_inset Formula $i\in\{1,2,\ldots,n\}$
\end_inset

 such that 
\begin_inset Formula $t\to K[\textrm{sgn}](e_{i}(t))$
\end_inset

 is set-valued and 
\begin_inset Formula $r_{i}(t)\neq0$
\end_inset

.
 Using Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:meas_zero"
plural "false"
caps "false"
noprefix "false"

\end_inset

, 
\begin_inset Formula $t\mapsto K\left[L\right](\psi(t))$
\end_inset

 is set-valued only for a set of time-instants of measure zero.
 Therefore, defining 
\begin_inset Formula $\Delta(t)=P_{2}(t)-P_{1}(t)$
\end_inset

, and using (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:P1dot"
plural "false"
caps "false"
noprefix "false"

\end_inset

) and (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:P2dot"
plural "false"
caps "false"
noprefix "false"

\end_inset

) yields
\begin_inset Formula 
\begin{equation}
\dot{\Delta}\stackrel{a.e.}{=}-\lambda_{P}\Delta,\label{eq:delta}
\end{equation}

\end_inset

with 
\begin_inset Formula $\Delta(t_{0})=0$
\end_inset

.
 Since 
\begin_inset Formula $\Delta\equiv0$
\end_inset

 is an equilibrium point of (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:delta"
plural "false"
caps "false"
noprefix "false"

\end_inset

), 
\begin_inset Formula $\Delta(t_{0})=0$
\end_inset

 implies 
\begin_inset Formula $\left\Vert \Delta(t)\right\Vert =0,\,\forall t\in\mathcal{I}$
\end_inset

, therefore 
\begin_inset Formula $P_{1}(t)=P_{2}(t),\,\forall t\in[t_{0},\infty)$
\end_inset

, i.e., any two solutions are equal, implying the solution is unique.
\end_layout

