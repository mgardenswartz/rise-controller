 &  & {\color{blue}+\frac{n\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)}{2}\left\Vert e\right\Vert ^{2}}\\
 & \leq & r^{T}({\color{blue}\widetilde{N}+N_{B}}-kr-e-\beta K\left[\mathrm{sgn}\right](e))\\
 &  & +e^{T}(r-\alpha e)-\lambda_{P}P\\
 &  & -r^{T}N_{B}+r^{T}\beta K\left[\mathrm{sgn}\right](e)\\
 &  & {\color{blue}+\frac{\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)}{2}\left\Vert z\right\Vert ^{2}}\\
 &  & {\color{blue}+\frac{n\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)}{2}\left\Vert z\right\Vert ^{2}}\\
 & \leq & r^{T}({\color{blue}\widetilde{N}+N_{B}}-kr-e-\beta K\left[\mathrm{sgn}\right](e))\\
 &  & +e^{T}(r-\alpha e)-\lambda_{P}P\\
 &  & -r^{T}N_{B}+r^{T}\beta K\left[\mathrm{sgn}\right](e)\\
 &  & {\color{blue}+\frac{(n+1)\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)}{2}\left\Vert z\right\Vert ^{2}}\\
 &  & \textrm{Note that \ensuremath{n+1\leq2n} since \ensuremath{n\in\mathbb{N}}}\\
 & \leq & r^{T}({\color{blue}\widetilde{N}+\cancel{N_{B}}}-kr-\cancel{e}-\cancel{\beta K\left[\mathrm{sgn}\right](e)})\\
 &  & +e^{T}(\cancel{r}-\alpha e)-\lambda_{P}P\\
 &  & \cancel{-r^{T}N_{B}}+\cancel{r^{T}\beta K\left[\mathrm{sgn}\right](e)}\\
 &  & {\color{blue}+n\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}}\\
 & {\color{blue}\overset{a.e.}{\leq}} & -k\left\Vert r\right\Vert ^{2}+r^{T}\widetilde{N}-\alpha\left\Vert e\right\Vert ^{2}-\lambda_{P}P\\
 &  & {\color{blue}+n\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}}\\
 & \leq & -k\left\Vert r\right\Vert ^{2}+\left\Vert r\right\Vert \left\Vert \widetilde{N}\right\Vert -\alpha\left\Vert e\right\Vert ^{2}-\lambda_{P}P\\
 &  & {\color{blue}+n\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}}\\
 & \leq & -k\left\Vert r\right\Vert ^{2}+\left\Vert r\right\Vert \left(\gamma_{2}\left\Vert z\right\Vert +\rho_{1}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \right)-\alpha\left\Vert e\right\Vert ^{2}-\lambda_{P}P\\
 &  & {\color{blue}+n\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}}\\
 & \leq & -k\left\Vert r\right\Vert ^{2}-\alpha\left\Vert e\right\Vert ^{2}-\lambda_{P}P\\
 &  & +\left\Vert z\right\Vert \left(\gamma_{2}\left\Vert z\right\Vert +\rho_{1}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \right)\\
 &  & +n\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}\\
 & \leq & -k\left\Vert r\right\Vert ^{2}-\alpha\left\Vert e\right\Vert ^{2}-\lambda_{P}P\\
 &  & +\left(\gamma_{2}+\rho_{1}\left(\left\Vert z\right\Vert \right)+n\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\right)\left\Vert z\right\Vert ^{2}\\
 & = & -\left(\min\left\{ k,\alpha\right\} \right)\left\Vert z\right\Vert ^{2}-\lambda_{P}P\\
 &  & +\left(\gamma_{2}+\rho_{1}\left(\left\Vert z\right\Vert \right)+n\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\right)\left\Vert z\right\Vert ^{2}\\
 & = & -\left(\min\left\{ k,\alpha\right\} -\gamma_{2}-n\gamma_{4}\right)\left\Vert z\right\Vert ^{2}-\lambda_{P}P\\
 &  & +\left(\rho_{1}\left(\left\Vert z\right\Vert \right)+n\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}\\
 & = & -\left(\min\left\{ k-\gamma_{2}-n\gamma_{4},\alpha-\gamma_{2}-n\gamma_{4}\right\} \right)\left\Vert z\right\Vert ^{2}-\lambda_{P}P\\
 &  & +\left(\rho_{1}\left(\left\Vert z\right\Vert \right)+n\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}\\
 & = & -\left(\min\left\{ k-\gamma_{2}-n\gamma_{4},\alpha-\gamma_{2}-n\gamma_{4}\right\} \right)\left\Vert z\right\Vert ^{2}-\left(\frac{\lambda_{P}}{2}\right)2P\\
 &  & +\left(\rho_{1}\left(\left\Vert z\right\Vert \right)+n\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}\\
 & \leq & -2\left(\min\left\{ k-\gamma_{2}-n\gamma_{4},\alpha-\gamma_{2}-n\gamma_{4},\frac{\lambda_{P}}{2}\right\} \right)V_{L}\\
 &  & +\left(\rho_{1}\left(\left\Vert z\right\Vert \right)+n\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert ^{2}\\
 & \leq & -\left(\min\left\{ k-\gamma_{2}-n\gamma_{4},\alpha-\gamma_{2}-n\gamma_{4},\frac{\lambda_{P}}{2}\right\} \right)V_{L}\\
 &  & +\left(\rho_{1}\left(\sqrt{2V_{L}}\right)+n\rho_{2}\left(\sqrt{2V_{L}}\right)\right)V_{L}\\
 &  & \textrm{Defining \ensuremath{c=\min\left\{ k-\gamma_{2}-n\gamma_{4},\alpha-\gamma_{2}-n\gamma_{4},\frac{\lambda_{P}}{2}\right\} }and \ensuremath{\rho\left(V_{L}\right)=\rho_{1}\left(V_{L}\right)+n\rho_{2}\left(V_{L}\right)}}\\
 & \leq & -2cV_{L}+2\rho\left(\sqrt{2V_{L}}\right)V_{L}\\
 & = & -2\left(c-\rho\left(\sqrt{2V_{L}}\right)\right)V_{L}
\end{eqnarray*}

\end_inset

Consider the set 
\begin_inset Formula $\mathcal{D}\triangleq\{\sigma\in\mathbb{R}^{2n+1}|V_{L}(\sigma)<\frac{(\rho^{-1}(c-\lambda_{V}))^{2}}{2}\}$
\end_inset

 .
 Then 
\begin_inset Formula 
\begin{eqnarray*}
\dot{V}_{L} & \overset{a.e.}{\leq} & -2\left(c-\rho\left(\sqrt{2V_{L}}\right)\right)V_{L}\\
 & \overset{a.e.}{\leq} & -2\left(c-\rho\left(\sqrt{\cancel{2}\frac{(\rho^{-1}(c-\lambda_{V}))^{2}}{\cancel{2}}}\right)\right)V_{L},\,\forall\psi(t)\in\mathcal{D}.\\
 & \overset{a.e.}{\leq} & -2\left(c-\rho\left(\sqrt{(\rho^{-1}(c-\lambda_{V}))^{2}}\right)\right)V_{L},\,\forall\psi(t)\in\mathcal{D}.\\
 & \overset{a.e.}{\leq} & -2\left(c-\cancel{\rho}\left(\cancel{\rho^{-1}}(c-\lambda_{V})\right)\right)V_{L},\,\forall\psi(t)\in\mathcal{D}.\\
 & \overset{a.e.}{\leq} & -2\left(c-\left(c-\lambda_{V}\right)\right)V_{L},\,\forall\psi(t)\in\mathcal{D}.\\
 & \overset{a.e.}{\leq} & -2\left(\cancel{c}-\cancel{c}+\lambda_{V}\right)V_{L},\,\forall\psi(t)\in\mathcal{D}.\\
 & \overset{a.e.}{\leq} & -2\lambda_{V}V_{L},\,\forall\psi(t)\in\mathcal{D}.
\end{eqnarray*}

