 Using Holder's inequality and Assumption 1 yields lower bounds on 
\begin_inset Formula $-e^{T}N_{B}$
\end_inset

 and 
\begin_inset Formula $e^{T}\dot{N}_{B}$
\end_inset

,
\begin_inset Formula 
\begin{eqnarray}
-e^{T}N_{B} & \geq & -\left\Vert e\right\Vert _{1}\left\Vert N_{B}\right\Vert _{1}\geq-\gamma_{1}\left\Vert e\right\Vert _{1},\label{eq:e_ddot}
\end{eqnarray}

\end_inset

and
\begin_inset Formula 
\begin{eqnarray}
e^{T}\dot{N}_{B} & \geq & -\left\Vert e\right\Vert _{1}\left\Vert \dot{N}_{B}\right\Vert _{1}\nonumber \\
 & \geq & -\left(\gamma_{3}+\gamma_{4}\left\Vert z\right\Vert +\rho_{2}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \right)\left\Vert e\right\Vert _{1},\label{eq:e_dddot}
\end{eqnarray}

\end_inset


\begin_inset Formula $\forall t\in\mathcal{I}$
\end_inset

.
 Substituting the bounds in (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:e_ddot"
plural "false"
caps "false"
noprefix "false"

\end_inset

) and (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:e_dddot"
plural "false"
caps "false"
noprefix "false"

\end_inset

) into the expression for 
\begin_inset Formula $P$
\end_inset

 in (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:P_expand"
plural "false"
caps "false"
noprefix "false"

\end_inset

) yields
\begin_inset Formula 
\begin{eqnarray}
P & \geq & \beta\left\Vert e\right\Vert _{1}-\gamma_{1}\left\Vert e\right\Vert _{1}\nonumber \\
 &  & +\mathrm{e}^{-\lambda_{P}t}*\left(\left((\alpha-\lambda_{P})\left(\beta-\gamma_{1}\right)-\gamma_{3}\right)\left\Vert e\right\Vert _{1}\right).\label{eq:P_lowerbound}
\end{eqnarray}

\end_inset


\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Given
\begin_inset Formula 
\begin{eqnarray*}
P & = & \beta\left\Vert e\right\Vert _{1}-e^{T}N_{B}(t)\\
 &  & +\mathrm{e}^{-\lambda_{P}t}*\left((\alpha-\lambda_{P})\left(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B}(t)\right)+e^{T}\dot{N}_{B}(t)\right)\\
 & {\color{blue}} & {\color{blue}+\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)}
\end{eqnarray*}

\end_inset

Using (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:e_ddot"
plural "false"
caps "false"
noprefix "false"

\end_inset

) and (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:e_dddot"
plural "false"
caps "false"
noprefix "false"

\end_inset

) ,
\begin_inset Formula 
\[
\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B}(t)\geq\beta\left\Vert e\right\Vert _{1}-\gamma_{1}\left\Vert e\right\Vert _{1},
\]

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
\mathrm{e}^{-\lambda_{P}t}*\left((\alpha-\lambda_{P})\left(\beta\left\Vert e\right\Vert _{1}-e^{T}N_{B}(t)\right)+e^{T}\dot{N}_{B}(t)\right) & \geq & \mathrm{e}^{-\lambda_{P}t}*\left((\alpha-\lambda_{P})\left(\beta\left\Vert e\right\Vert _{1}-\gamma_{1}\left\Vert e\right\Vert _{1}\right)-\left(\gamma_{3}+\gamma_{4}\left\Vert z\right\Vert +\rho_{2}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \right)\left\Vert e\right\Vert _{1}\right)\\
 & = & \mathrm{e}^{-\lambda_{P}t}*\left(\left((\alpha-\lambda_{P})\left(\beta-\gamma_{1}\right)-\left(\gamma_{3}+\gamma_{4}\left\Vert z\right\Vert +\rho_{2}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \right)\right)\left\Vert e\right\Vert _{1}\right)\\
 & = & \mathrm{e}^{-\lambda_{P}t}*\left(\left((\alpha-\lambda_{P})\left(\beta-\gamma_{1}\right)-\gamma_{3}\right)\left\Vert e\right\Vert _{1}\right)-\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}\left\Vert z\right\Vert +\rho_{2}\left(\left\Vert z\right\Vert \right)\left\Vert z\right\Vert \right)\left\Vert e\right\Vert _{1}\right)\\
 & = & \mathrm{e}^{-\lambda_{P}t}*\left(\left((\alpha-\lambda_{P})\left(\beta-\gamma_{1}\right)-\gamma_{3}\right)\left\Vert e\right\Vert _{1}\right)-\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)
\end{eqnarray*}

\end_inset

Therefore,
\begin_inset Formula 
\begin{eqnarray*}
P & \geq & \beta\left\Vert e\right\Vert _{1}-\gamma_{1}\left\Vert e\right\Vert _{1}\\
 &  & +\mathrm{e}^{-\lambda_{P}t}*\left(\left((\alpha-\lambda_{P})\left(\beta-\gamma_{1}\right)-\gamma_{3}\right)\left\Vert e\right\Vert _{1}\right)-\cancel{\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)}\\
 &  & {\color{blue}\cancel{+\mathrm{e}^{-\lambda_{P}t}*\left(\left(\gamma_{4}+\rho_{2}\left(\left\Vert z\right\Vert \right)\right)\left\Vert z\right\Vert \left\Vert e\right\Vert _{1}\right)}}\\
 & = & \beta\left\Vert e\right\Vert _{1}-\gamma_{1}\left\Vert e\right\Vert _{1}+\mathrm{e}^{-\lambda_{P}t}*\left(\left((\alpha-\lambda_{P})\left(\beta-\gamma_{1}\right)-\gamma_{3}\right)\left\Vert e\right\Vert _{1}\right)
\end{eqnarray*}

\end_inset

Selecting 
\begin_inset Formula $\beta>{\color{blue}\gamma_{1}}+\frac{{\color{blue}\gamma_{3}}}{\alpha-\lambda_{P}}$
\end_inset

 and 
\begin_inset Formula $\alpha>\lambda_{P}$
\end_inset

, yields 
\begin_inset Formula $\beta\left\Vert e\right\Vert _{1}-\gamma_{1}\left\Vert e\right\Vert _{1}\geq0$
\end_inset

 and 
\begin_inset Formula $\mathrm{e}^{-\lambda_{P}t}*\left(\left((\alpha-\lambda_{P})\left(\beta-\gamma_{1}\right)-\gamma_{3}\right)\left\Vert e\right\Vert _{1}\right)\geq0$
\end_inset

, therefore, 
\begin_inset Formula $P\geq0$
\end_inset

.
\end_layout

\end_inset

