\begin_layout Subsection
Control Objective
\end_layout

\begin_layout Standard
Consider a control affine system with the nonlinear dynamics
\begin_inset Formula 
\begin{equation}
\dot{x}=d(x,\nu,t)+u,\label{eq:dynamicsystem}
\end{equation}

\end_inset

where 
\begin_inset Formula $t\in\mathbb{R}_{\geq0}$
\end_inset

 denotes time, 
\begin_inset Formula $x:\mathcal{I}\to\mathbb{R}^{n}$
\end_inset

 denotes a Filippov solution
\begin_inset Foot
status open

\begin_layout Plain Layout
We consider Filippov solutions instead of classical solutions to facilitate
 a nonsmooth control design.
 Alternatively, Krasovskii solutions can also be considered.
 Generalized solutions such as Filippov or Krasovskii solutions are guaranteed
 to exist for nonsmooth systems with Lebesgue measurable and locally essentially
 bounded right-hand-sides 
\begin_inset CommandInset citation
LatexCommand cite
after "Proposition 3"
key "Cortes2008"
literal "false"

\end_inset

, whereas classical solutions might not exist.
 
\end_layout

\end_inset

 to (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:dynamicsystem"
plural "false"
caps "false"
noprefix "false"

\end_inset

), with the interval of existence 
\begin_inset Formula $\mathcal{I}=[t_{0},t_{1})$
\end_inset

 for some 
\begin_inset Formula $t_{0},t_{1}\in\mathbb{R}_{\geq0}$
\end_inset

 s.t.
 
\begin_inset Formula $t_{1}>t_{0}$
\end_inset

, 
\begin_inset Formula $\nu:\mathbb{R}_{\geq0}\to\mathbb{R}^{m}$
\end_inset

 denotes an auxiliary function representing some external dynamic compensator-ba
sed terms (e.g., adaptive feedforward terms, observer-based terms), 
\begin_inset Formula $d:\mathbb{R}^{n}\times\mathbb{R}^{m}\times\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 represents 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

 modeling uncertainty in the system, and 
\begin_inset Formula $u:\mathcal{I}\to\mathbb{R}^{n}$
\end_inset

 represents the control input.
 
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout

\color blue
Let 
\begin_inset Formula $\dot{d}:\mathbb{R}^{n}\times\mathbb{R}^{n}\times\mathbb{R}^{m}\times\mathbb{R}^{m}\times\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 and 
\begin_inset Formula $\ddot{d}:\mathbb{R}^{n}\times\mathbb{R}^{n}\times\mathbb{R}^{n}\times\mathbb{R}^{m}\times\mathbb{R}^{m}\times\mathbb{R}^{m}\times\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 denote
\end_layout

\end_inset

Let 
\begin_inset Formula $\dot{d}(x,\dot{x},\nu,\dot{\nu},t)\triangleq\nabla d^{T}\left(x,\nu,t\right)[\dot{x};\dot{\nu};1]$
\end_inset

 and 
\begin_inset Formula $\ddot{d}(x,\dot{x},\ddot{x},\nu,\dot{\nu},\ddot{\nu},t)=[\dot{x};\dot{\nu};1]^{T}\nabla^{2}d\left(x,\nu,t\right)[\dot{x};\dot{\nu};1]+\nabla d^{T}\left(x,\nu,t\right)[\ddot{x};\ddot{\nu};0]$
\end_inset


\begin_inset Note Note
status collapsed

\begin_layout Plain Layout

\color blue
\begin_inset Formula $\dot{d}(x,\dot{x},\nu,\dot{\nu},t)\triangleq\frac{d}{dt}\left(d(x,\nu,t)\right)$
\end_inset

 
\begin_inset Formula $ $
\end_inset

and 
\begin_inset Formula $\ddot{d}(x,\dot{x},\ddot{x},\nu,\dot{\nu},\ddot{\nu},t)\triangleq\frac{d^{2}}{dt^{2}}\left(d(x,\nu,t)\right)$
\end_inset


\end_layout

\end_inset

, respectively, where 
\begin_inset Formula $\nabla$
\end_inset

 and 
\begin_inset Formula $\nabla^{2}$
\end_inset

 denote the gradient and Hessian operators, respectively.
 It is assumed that for each 
\begin_inset Formula $(a,b,p,v,w,s)\in\mathbb{R}^{n}\times\mathbb{R}^{n}\times\mathbb{R}^{n}\times\mathbb{R}^{m}\times\mathbb{R}^{m}\times\mathbb{R}^{m}$
\end_inset

, the mappings 
\begin_inset Formula $t\mapsto d(a,v,t)$
\end_inset

, 
\begin_inset Formula $t\mapsto\dot{d}(a,b,v,w,t)$
\end_inset

, and 
\begin_inset Formula $t\mapsto\ddot{d}(a,b,p,v,w,s,t)$
\end_inset

 are bounded
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout

\color blue
there exists some constants 
\begin_inset Formula $M_{1},\,M_{2},\,M_{3}\in\mathbb{R}_{>0}$
\end_inset

 such that 
\begin_inset Formula $\left\Vert d(a,v,t)\right\Vert \leq M_{1}$
\end_inset

, 
\begin_inset Formula $\left\Vert \dot{d}(a,b,v,w,t)\right\Vert \leq M_{2}$
\end_inset

, and 
\begin_inset Formula $\left\Vert \ddot{d}(a,b,p,v,w,s,t)\right\Vert \leq M_{3}$
\end_inset

 for all 
\begin_inset Formula $t\in\mathcal{I}$
\end_inset


\end_layout

\end_inset

.
 The objective is to design a controller such that the state tracks a smooth
 bounded reference trajectory.
 The objective is quantified by defining the tracking error
\begin_inset Formula 
\begin{equation}
e\triangleq x-x_{d},\label{eq:e}
\end{equation}

\end_inset

where 
\begin_inset Formula $x_{d}:\mathbb{R}_{\geq0}\to\mathbb{R}^{n}$
\end_inset

 is a 
\begin_inset Formula $\mathcal{C}^{2}$
\end_inset

