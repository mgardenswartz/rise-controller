\begin_inset Formula $x_{d},\dot{x}_{d}\in\mathcal{L}_{\infty}$
\end_inset

.
\end_layout

\begin_layout Subsection
Control Law Development
\end_layout

\begin_layout Standard
\noindent
To facilitate the subsequent analysis, a filtered tracking error 
\begin_inset Formula $r:\mathcal{I}\to\mathbb{R}^{n}$
\end_inset

 is defined as 
\begin_inset Formula $r\triangleq d(x,\nu,t)+u-\dot{x}_{d}+\alpha e$
\end_inset

,
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
\noindent
\begin_inset Formula 
\begin{eqnarray*}
r & = & \dot{e}+\alpha e\\
 & = & \dot{x}-\dot{x}_{d}+\alpha e\\
 & = & d(x,\nu,t)+u-\dot{x}_{d}+\alpha e
\end{eqnarray*}

\end_inset


\end_layout

\end_inset

 where 
\begin_inset Formula $\alpha\in\mathbb{R}_{>0}$
\end_inset

 is a constant control gain.
 To facilitate the subsequent analysis, the dynamics in terms of 
\begin_inset Formula $\dot{e}$
\end_inset

 can be rewritten using (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:dynamicsystem"
plural "false"
caps "false"
noprefix "false"

\end_inset

) and (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:e"
plural "false"
caps "false"
noprefix "false"

\end_inset

) as
\begin_inset Formula 
\begin{equation}
\dot{e}=r-\alpha e.\label{eq:edot}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\noindent
Let 
\begin_inset Formula $z:\mathcal{I}\to\mathbb{R}^{2n}$
\end_inset

 denote the augmented tracking error, 
\begin_inset Formula $z\triangleq\left[\begin{array}{cc}
e^{T} & r^{T}\end{array}\right]^{T}$
\end_inset

.
 From the subsequent stability analysis, a continuous RISE control input
 is designed as 
\begin_inset CommandInset citation
LatexCommand cite
key "Xian2004"
literal "false"

\end_inset


\begin_inset Formula 
\begin{equation}
u\triangleq\dot{x}_{d}-\alpha e-\hat{d},\label{eq:controlinput}
\end{equation}

\end_inset

where 
\begin_inset Formula $\hat{d}:\mathcal{I}\to\mathbb{R}^{n}$
\end_inset

 is an auxiliary term designed as a Filippov solution
\begin_inset Foot
status open

\begin_layout Plain Layout
Since 
\begin_inset Formula $r$
\end_inset

 may not be commonly available, 
\begin_inset Formula $\hat{d}(t)$
\end_inset

 is evaluated using 
\begin_inset Formula $\hat{d}(t)=\hat{d}(t_{0})+ke(t)-ke(t_{0})+\int_{t_{0}}^{t}\left((k\alpha+1)e(\tau)+\beta\mathrm{sgn}(e(\tau))\right)d\tau$
\end_inset

 for closed-loop implementation.
 Note that 
\begin_inset Formula $\beta\mathrm{sgn}(e(\cdot))$
\end_inset

 is Riemann integrable on 
\begin_inset Formula $[t_{0},t],\,\forall t\in\mathcal{I}$
\end_inset

 according to Lemma 
\begin_inset CommandInset ref
LatexCommand ref
reference "lem:integrable"
plural "false"
caps "false"
noprefix "false"

\end_inset

.
\end_layout

\end_inset

 to
\begin_inset Formula 
\begin{equation}
\dot{\hat{d}}=kr+e+\beta\mathrm{sgn}\left(e\right),\label{eq:mudot}
\end{equation}

\end_inset

given any user-selected 
\begin_inset Formula $\hat{d}(t_{0})\in\mathbb{R}^{n}.$
\end_inset

 In (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:mudot"
plural "false"
caps "false"
noprefix "false"

\end_inset

), 
\begin_inset Formula $k,\beta\in\mathbb{R}_{>0}$
\end_inset

 are constant control gains.
 Using (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:dynamicsystem"
plural "false"
caps "false"
noprefix "false"

\end_inset

)-(
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:controlinput"
