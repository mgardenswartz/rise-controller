after "Theorem 11.33"
key "Rudin1976"
literal "false"

\end_inset

 on 
\begin_inset Formula $[t_{0},t_{1}]$
\end_inset

, 
\begin_inset Formula $\forall t_{1}\in\mathcal{I}$
\end_inset

.
 
