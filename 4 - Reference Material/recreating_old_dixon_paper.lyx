\end_inset

.
\begin_inset Formula 
\begin{align*}
L\left(t\right) & =\intop_{t_{0}}^{t}\left(\dot{e}_{2}^{\top}N_{B3}\left(Q_{d},\widetilde{\Theta},s\right)+\alpha_{2}e_{2}^{\top}N_{B1}\left(Q_{d},\widetilde{\Theta},s\right)-\beta_{1}\frac{d}{ds}\left\Vert e_{2}\right\Vert _{1}-\alpha_{2}\beta_{1}\left\Vert e_{2}\right\Vert _{1}-\beta_{2}\left\Vert e_{2}\right\Vert ^{2}\right)ds\\
 & =\intop_{t_{0}}^{t}\dot{e}_{2}^{\top}N_{B3}\left(Q_{d},\widetilde{\Theta},s\right)ds+\alpha_{2}\intop_{t_{0}}^{t}e_{2}^{\top}N_{B1}\left(Q_{d},\widetilde{\Theta},s\right)ds-\beta_{1}\intop_{t_{0}}^{t}\frac{d}{ds}\left\Vert e_{2}\right\Vert _{1}ds-\alpha_{2}\beta_{1}\intop_{t_{0}}^{t}\left\Vert e_{2}\right\Vert _{1}ds-\beta_{2}\intop_{t_{0}}^{t}\left\Vert e_{2}\right\Vert ^{2}ds
\end{align*}

\end_inset

 Integration by parts tutorial.
 
\begin_inset Note Note
status collapsed

\begin_layout Plain Layout
Integration by parts is
\begin_inset Formula 
\[
\intop udv=uv-\intop vdu
\]

\end_inset


\end_layout

\begin_layout Plain Layout
Good candidates for choosing 
\begin_inset Formula $u$
\end_inset

 are LIATE: logarithmic, inverse functions like arctangent, algebraic functions
 (
\begin_inset Formula $x^{2}$
\end_inset

 and 
\begin_inset Formula $3x$
\end_inset

), trigonometric functions, and exponential functions.
 Choose earlier items in the list first.
 Easy example: 
\begin_inset Formula $\intop x{\rm e}^{x}dx$
\end_inset

.
 Let 
\begin_inset Formula $u=x$
\end_inset

 and 
\begin_inset Formula $dv={\rm e}^{x}dx$
\end_inset

.
 Thus, 
\begin_inset Formula $v={\rm e}^{x}$
\end_inset

 (no constant term) and 
\begin_inset Formula $du=1\cdot dx.$
\end_inset


\begin_inset Formula 
\begin{align*}
\intop x{\rm e}^{x}dx & =x{\rm e}^{x}-\intop{\rm e}^{x}dx\\
 & =x{\rm e}^{x}-{\rm e}^{x}+C\\
 & =\left(x-1\right){\rm e}^{x}+C
\end{align*}

\end_inset


\end_layout

\begin_layout Plain Layout
Hard example: 
\begin_inset Formula $I\triangleq\intop{\rm e}^{x}\cos\left(x\right)dx$
\end_inset

.
 Let 
\begin_inset Formula $u=\cos\left(x\right)$
\end_inset

 and 
\begin_inset Formula $dv={\rm e}^{x}dx$
\end_inset

.
 Thus, 
\begin_inset Formula $du=-\sin\left(x\right)dx$
\end_inset

 and 
\begin_inset Formula $v={\rm e}^{x}$
\end_inset

.
\begin_inset Formula 
\[
I={\rm e}^{x}\cos\left(x\right)+\intop{\rm e}^{x}\sin\left(x\right)dx
\]

\end_inset

Again.
 Let 
\begin_inset Formula $u=\sin\left(x\right)$
\end_inset

 and 
\begin_inset Formula $dv={\rm e}^{x}dx$
\end_inset

.
 Thus, 
\begin_inset Formula $du=\cos\left(x\right)dx$
\end_inset

 and 
\begin_inset Formula $v={\rm e}^{x}$
\end_inset

.
\begin_inset Formula 
\begin{align*}
\intop{\rm e}^{x}\sin\left(x\right)dx & ={\rm e}^{x}\sin\left(x\right)-\intop{\rm e}^{x}\cos\left(x\right)dx\\
 & ={\rm e}^{x}\sin\left(x\right)-I+C
\end{align*}

\end_inset

Substitute and solve
\begin_inset Formula 
\begin{align*}
I & ={\rm e}^{x}\cos\left(x\right)+{\rm e}^{x}\sin\left(x\right)-I\\
2I & ={\rm e}^{x}\cos\left(x\right)+{\rm e}^{x}\sin\left(x\right)\\
I & =\frac{1}{2}{\rm e}^{x}\left(\cos\left(x\right)+\sin\left(x\right)\right)
\end{align*}

\end_inset


\end_layout

