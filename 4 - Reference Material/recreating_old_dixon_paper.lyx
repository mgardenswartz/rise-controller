And
\begin_inset Formula 
\begin{align*}
M\left(q\right)e_{3} & =M\left(q\right)\left(\dot{e}_{2}+\alpha_{2}e_{2}\right)\\
 & =M\left(q\right)\dot{e}_{2}+M\left(q\right)\alpha_{2}e_{2}\\
 & =M\left(q\right)\left(\ddot{e}_{1}+\alpha_{1}\dot{e}_{1}\right)+M\left(q\right)\alpha_{2}e_{2}\\
 & =M\left(q\right)\left(\ddot{e}_{1}+\alpha_{1}\dot{e}_{1}\right)+M\left(q\right)\alpha_{2}e_{2}\\
 & =M\left(q\right)\ddot{e}_{1}+M\left(q\right)\alpha_{1}\dot{e}_{1}+M\left(q\right)\alpha_{2}e_{2}\\
 & =M\left(q\right)\ddot{e}_{1}+M\left(q\right)\left(\alpha_{1}\dot{e}_{1}+\alpha_{2}e_{2}\right)\\
 & =M\left(q\right)\left(\ddot{q}_{d}-\ddot{q}\right)+M\left(q\right)\left(\alpha_{1}\dot{e}_{1}+\alpha_{2}e_{2}\right)\\
 & =-M\left(q\right)\ddot{q}+M\left(q\right)\left(\ddot{q}_{d}+\alpha_{1}\dot{e}_{1}+\alpha_{2}e_{2}\right)\\
 & =V_{m}\left(q,\dot{q}\right)\dot{q}+G\left(q\right)+F\left(\dot{q}\right)+\tau_{d}\left(t\right)-\tau\left(t\right)+M\left(q\right)\left(\ddot{q}_{d}+\alpha_{1}\dot{e}_{1}+\alpha_{2}e_{2}\right)\\
\\
 & =V_{m}\left(q,\dot{q}\right)\dot{q}+G\left(q\right)+F\left(\dot{q}\right)+\tau_{d}\left(t\right)-\tau\left(t\right)+M\left(q\right)\left(\ddot{q}_{d}+\alpha_{1}\dot{e}_{1}+\alpha_{2}e_{2}\right)\\
 & +M\left(q_{d}\right)\ddot{q}_{d}+V_{m}\left(q_{d},\dot{q}_{d}\right)\dot{q}_{d}+G\left(q_{d}\right)+F\left(\dot{q}_{d}\right)-M\left(q_{d}\right)\ddot{q}_{d}-V_{m}\left(q_{d},\dot{q}_{d}\right)\dot{q}_{d}-G\left(q_{d}\right)-F\left(\dot{q}_{d}\right)\\
\\
 & =\underbrace{V_{m}\left(q,\dot{q}\right)\dot{q}-V_{m}\left(q_{d},\dot{q}_{d}\right)\dot{q}_{d}+G\left(q\right)-G\left(q_{d}\right)+F\left(\dot{q}\right)-F\left(\dot{q}_{d}\right)+M\left(q\right)\left(\ddot{q}_{d}+\alpha_{1}\dot{e}_{1}+\alpha_{2}e_{2}\right)-M\left(q_{d}\right)\ddot{q}_{d}}_{S\left(q,\dot{q},q_{d},\dot{q}_{d}\ddot{q}_{d}\right)}\\
 & +\tau_{d}\left(t\right)-\tau\left(t\right)+\underbrace{M\left(q_{d}\right)\ddot{q}_{d}+V_{m}\left(q_{d},\dot{q}_{d}\right)\dot{q}_{d}+G\left(q_{d}\right)+F\left(\dot{q}_{d}\right)}_{f_{d}\left(q_{d},\dot{q}_{d}\ddot{q}_{d}\right)}\\
\\
 & =S\left(q,\dot{q},q_{d},\dot{q}_{d}\ddot{q}_{d}\right)+\tau_{d}\left(t\right)-\tau\left(t\right)+f_{d}\left(q_{d},\dot{q}_{d}\ddot{q}_{d}\right)
\end{align*}

