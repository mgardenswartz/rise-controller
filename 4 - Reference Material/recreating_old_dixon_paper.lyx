\begin_layout Standard
Returnign to the error system, we had
\begin_inset Formula 
\[
M\left(q\right)e_{3}=S\left(q,\dot{q},q_{d},\dot{q}_{d}\ddot{q}_{d}\right)+\tau_{d}\left(t\right)-\tau\left(t\right)+f_{d}\left(q_{d},\dot{q}_{d}\ddot{q}_{d}\right)
\]

\end_inset

Take the time derivative gives
\begin_inset Formula 
\[
\frac{d}{dt}\left(M\left(q\right)e_{3}\right)=\dot{M}\left(q\right)e_{3}+M\left(q\right)\dot{e}_{3}
\]

\end_inset

So,
\begin_inset Formula 
\begin{align*}
\dot{M}\left(q\right)e_{3}+M\left(q\right)\dot{e}_{3} & =\frac{d}{dt}\left(S+\tau_{d}-\tau+f_{d}\right)\\
\dot{M}\left(q\right)e_{3}+M\left(q\right)\dot{e}_{3} & =\dot{S}+\dot{\tau}_{d}-\dot{\tau}+\dot{f}_{d}\\
M\left(q\right)\dot{e}_{3} & =-\dot{M}\left(q\right)e_{3}+\dot{S}+\dot{\tau}_{d}-\dot{\tau}+\dot{f}_{d}\\
M\left(q\right)\dot{e}_{3} & =-\dot{M}\left(q\right)e_{3}+\dot{S}+\dot{\tau}_{d}-\left(\left(k_{s}+1\right)\dot{e}_{2}+\left(k_{s}+1\right)\alpha_{2}e_{2}+\beta_{1}\text{sgn}\left(e_{2}\right)+\Phi\left(Q_{d},\widehat{\Theta}\right)\right)+\Phi\left(Q_{d},\Theta^{\ast}\right)+\varepsilon\left(Q_{d}\right)\\
M\left(q\right)\dot{e}_{3} & =-\dot{M}\left(q\right)e_{3}+\dot{S}+\dot{\tau}_{d}-\left(k_{s}+1\right)\dot{e}_{2}-\left(k_{s}+1\right)\alpha_{2}e_{2}-\beta_{1}\text{sgn}\left(e_{2}\right)-\Phi\left(Q_{d},\widehat{\Theta}\right)+\Phi\left(Q_{d},\Theta^{\ast}\right)+\varepsilon\left(Q_{d}\right)
\end{align*}

\end_inset

Taylor series
\begin_inset Formula 
\[
\Phi\left(Q_{d},\Theta^{\ast}\right)=\Phi\left(Q_{d},\widehat{\Theta}\right)+\frac{\partial\Phi}{\partial\widehat{\Theta}}\widetilde{\Theta}+R\left(Q_{d},\widetilde{\Theta}\right)
\]

\end_inset

So,
\begin_inset Formula 
\begin{align*}
M\left(q\right)\dot{e}_{3} & =-\dot{M}\left(q\right)e_{3}+\dot{S}+\dot{\tau}_{d}-\left(k_{s}+1\right)\dot{e}_{2}-\left(k_{s}+1\right)\alpha_{2}e_{2}-\beta_{1}\text{sgn}\left(e_{2}\right)+\frac{\partial\Phi}{\partial\widehat{\Theta}}\widetilde{\Theta}+R\left(Q_{d},\widetilde{\Theta}\right)+\varepsilon\left(Q_{d}\right)\\
 & =-\frac{1}{2}\dot{M}\left(q\right)e_{3}-\frac{1}{2}\dot{M}\left(q\right)e_{3}+e_{2}-e_{2}+\dot{S}+\dot{\tau}_{d}-\left(k_{s}+1\right)\dot{e}_{2}-\left(k_{s}+1\right)\alpha_{2}e_{2}-\beta_{1}\text{sgn}\left(e_{2}\right)+\frac{\partial\Phi}{\partial\widehat{\Theta}}\widetilde{\Theta}+R\left(Q_{d},\widetilde{\Theta}\right)+\varepsilon\left(Q_{d}\right)\\
 & =-\frac{1}{2}\dot{M}\left(q\right)e_{3}\underbrace{-\frac{1}{2}\dot{M}\left(q\right)e_{3}+\dot{S}+e_{2}}_{\widetilde{N}}-e_{2}-\left(k_{s}+1\right)\dot{e}_{2}-\left(k_{s}+1\right)\alpha_{2}e_{2}-\beta_{1}\text{sgn}\left(e_{2}\right)+\underbrace{\frac{\partial\Phi}{\partial\widehat{\Theta}}\left(Q_{d}\right)\widetilde{\Theta}}_{N_{B2}}+\underbrace{R\left(Q_{d},\widetilde{\Theta}\right)+\varepsilon\left(Q_{d}\right)+\dot{\tau}_{d}}_{N_{B1}}
\end{align*}

\end_inset

Let
\begin_inset Formula 
\[
N_{B3}\triangleq N_{B1}+N_{B2}
\]

\end_inset


\end_layout

