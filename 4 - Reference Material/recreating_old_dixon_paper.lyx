Let 
\begin_inset Formula $\beta_{2}\in\mathbb{R}_{>0}$
\end_inset

 and let
\begin_inset Formula 
\[
P=\beta_{1}\left\Vert e_{2}\left(t_{0}\right)\right\Vert -e_{2}\left(t_{0}\right)^{\top}N_{B3}\left(\widetilde{\Theta}\left(t_{0}\right),Q_{d}\left(t_{0}\right),t_{0}\right)-\intop_{t_{0}}^{t}L\left(s\right)ds
\]

\end_inset

where
\begin_inset Formula 
\begin{align*}
L\left(t\right) & =e_{3}^{\top}\left(N_{B1}\left(Q_{d},\widetilde{\Theta},t\right)-\beta_{1}\text{sgn}\left(e_{2}\right)\right)+\dot{e}_{2}^{\top}N_{B2}\left(\widetilde{\Theta},Q_{d}\right)-\beta_{2}\left\Vert e_{2}\right\Vert ^{2}\\
 & =e_{3}^{\top}N_{B1}\left(Q_{d},\widetilde{\Theta},t\right)-\beta_{1}e_{3}^{\top}\text{sgn}\left(e_{2}\right)+\dot{e}_{2}^{\top}N_{B2}\left(\widetilde{\Theta},Q_{d}\right)-\beta_{2}\left\Vert e_{2}\right\Vert ^{2}\\
 & =\left(\dot{e}_{2}+\alpha_{2}e_{2}\right)^{\top}N_{B1}\left(Q_{d},\widetilde{\Theta},t\right)-\beta_{1}\left(\dot{e}_{2}+\alpha_{2}e_{2}\right)^{\top}\text{sgn}\left(e_{2}\right)+\dot{e}_{2}^{\top}N_{B2}\left(\widetilde{\Theta},Q_{d}\right)-\beta_{2}\left\Vert e_{2}\right\Vert ^{2}\\
 & =\dot{e}_{2}^{\top}N_{B1}\left(Q_{d},\widetilde{\Theta},t\right)+\alpha_{2}e_{2}^{\top}N_{B1}\left(Q_{d},\widetilde{\Theta},t\right)-\beta_{1}\dot{e}_{2}^{\top}\text{sgn}\left(e_{2}\right)-\alpha_{2}\beta_{1}e_{2}^{\top}\text{sgn}\left(e_{2}\right)+\dot{e}_{2}^{\top}N_{B2}\left(\widetilde{\Theta},Q_{d}\right)-\beta_{2}\left\Vert e_{2}\right\Vert ^{2}\\
 & =\dot{e}_{2}^{\top}N_{B3}\left(Q_{d},\widetilde{\Theta},t\right)+\alpha_{2}e_{2}^{\top}N_{B1}\left(Q_{d},\widetilde{\Theta},t\right)-\beta_{1}\dot{e}_{2}^{\top}\text{sgn}\left(e_{2}\right)-\alpha_{2}\beta_{1}e_{2}^{\top}\text{sgn}\left(e_{2}\right)-\beta_{2}\left\Vert e_{2}\right\Vert ^{2}
\end{align*}

\end_inset

Take the integral.
 Note that 
