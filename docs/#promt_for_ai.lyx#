\end_inset

 NN-in-the-integral controller (New)
\begin_inset Formula 
\begin{align*}
u & =u_{1}+\left(k_{1}+k_{2}\right)\left(e\left(t\right)-e\left(t_{0}\right)\right)+\dot{x}_{d}\left(t\right)-\dot{x}_{d}\left(t_{0}\right)+I\left(t\right)\\
\dot{I} & \left(t\right)=\beta\text{sgn}\left(e\left(t\right)\right)+\left(k_{1}k_{2}+1\right)e\left(t\right)-\Psi\left(\kappa\left(t\right),\widehat{\theta}\left(t\right)\right)\quad I\left(t_{0}\right)=\mathbf{0}_{n}
\end{align*}

\end_inset

The baseline is:
\begin_inset Formula 
\begin{align*}
u & =u_{1}+\Psi\left(x,\widehat{\theta}\right)+\left(k_{1}+k_{2}\right)\left(e\left(t\right)-e\left(t_{0}\right)\right)+\dot{x}_{d}\left(t\right)-\dot{x}_{d}\left(t_{0}\right)+\intop_{t_{0}}^{t}\left(\left(k_{1}k_{2}+1\right)e\left(s\right)+\beta\text{sgn}\left(e\left(s\right)\right)\right)ds\\
 & \dot{I}\left(t\right)=\beta\text{sgn}\left(e\left(t\right)\right)+\left(k_{1}k_{2}+1\right)e\left(t\right)\quad I\left(t_{0}\right)=\mathbf{0}_{n}
\end{align*}

\end_inset


