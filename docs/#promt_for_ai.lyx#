For implementation:
\begin_inset Formula 
\begin{align*}
u & =[k_{1}e+\dot{x}_{d}]_{t_{0}}^{t}+\intop_{t_{0}}^{t}\left(\beta\text{sgn}\left(e\left(s\right)\right)+k_{2}r+e-\Psi\left(\kappa\left(s\right),\widehat{\theta}\left(s\right)\right)\right)ds\\
 & =[k_{1}e+\dot{x}_{d}]_{t_{0}}^{t}+\intop_{t_{0}}^{t}\left(\beta\text{sgn}\left(e\left(s\right)\right)+k_{2}\left(\dot{e}+k_{1}e\right)+e-\Psi\left(\kappa\left(s\right),\widehat{\theta}\left(s\right)\right)\right)ds\\
 & =[\left(k_{1}+k_{2}\right)e+\dot{x}_{d}]_{t_{0}}^{t}+\intop_{t_{0}}^{t}\left(\beta\text{sgn}\left(e\left(s\right)\right)+\left(k_{1}k_{2}+1\right)e\left(s\right)-\Psi\left(\kappa\left(s\right),\widehat{\theta}\left(s\right)\right)\right)ds\\
 & =\left(k_{1}+k_{2}\right)\left(e\left(t\right)-e\left(t_{0}\right)\right)+\dot{x}_{d}\left(t\right)-\dot{x}_{d}\left(t_{0}\right)+\intop_{t_{0}}^{t}\left(\beta\text{sgn}\left(e\left(s\right)\right)+\left(k_{1}k_{2}+1\right)e\left(s\right)-\Psi\left(\kappa\left(s\right),\widehat{\theta}\left(s\right)\right)\right)ds
\end{align*}

\end_inset


